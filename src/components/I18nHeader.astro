---
// src/components/I18nHeader.astro
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';
import { languages } from '../i18n/languages';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ✅ Tüm href'ler TR slug olarak tanımlanır.
// getLocalizedRoute mevcut dile göre doğru URL'e çevirir.
const navItems = [
  {
    href: getLocalizedRoute('/', lang),
    label: t('nav.home')
  },
  {
    href: getLocalizedRoute('/hakkimizda', lang),
    label: t('nav.about')
  },
  {
    href: getLocalizedRoute('/urunlerimiz', lang),
    label: t('nav.products'),
    dropdown: [
      { href: getLocalizedRoute('/pvc-kapilar', lang),              label: t('products.pvc') },
      { href: getLocalizedRoute('/laminoks-kapilar', lang),         label: t('products.laminoks') },
      { href: getLocalizedRoute('/elitpan-kapilar', lang),          label: t('products.elitpan') },
      { href: getLocalizedRoute('/hastane-kapilari', lang),         label: t('products.hospital') },
      { href: getLocalizedRoute('/otel-kapilari', lang),            label: t('products.hotel') },
      { href: getLocalizedRoute('/yangina-dayanikli-kapilar', lang),label: t('products.fire') },
    ]
  },
  {
    href: getLocalizedRoute('/iletisim', lang),
    label: t('nav.contact')
  },
  {
    href: getLocalizedRoute('/kapi-malzemeleri', lang),
    label: t('nav.materials')
  }
];
---

<header class="header">
  <div class="container">
    <nav class="nav">
      <!-- Logo -->
      <div class="logo">
        <a href={getLocalizedRoute('/', lang)} class="logo-link">
          <img
            src="/assets/img/logo/header-logo1.webp"
            alt="CihanPan Door"
            width="120"
            height="40"
            loading="eager"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="nav-desktop">
        {navItems.map((item) => (
          item.dropdown ? (
            <div class="nav-item dropdown-item">
              <a href={item.href} class="nav-link">
                {item.label}
                <span class="dropdown-arrow">▼</span>
              </a>
              <div class="dropdown-menu">
                {item.dropdown.map((dropdownItem) => (
                  <a href={dropdownItem.href} class="dropdown-link">
                    {dropdownItem.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
          )
        ))}

        <LanguageSwitcher />
      </div>

      <!-- CTA Button -->
      <div class="nav-cta">
        <a href={getLocalizedRoute('/iletisim', lang)} class="cta-btn">
          {t('nav.contact')}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
        <span class="hamburger"></span>
        <span class="hamburger"></span>
        <span class="hamburger"></span>
      </button>
    </nav>

    <!-- Mobile Navigation -->
    <div class="nav-mobile" id="mobile-menu">
      {navItems.map((item) => (
        <div class="mobile-nav-item">
          <a
            href={item.href}
            class="nav-mobile-link"
            data-has-dropdown={item.dropdown ? 'true' : 'false'}
          >
            {item.label}
            {item.dropdown && <span class="mobile-dropdown-arrow">▼</span>}
          </a>
          {item.dropdown && (
            <div class="mobile-dropdown">
              {item.dropdown.map((dropdownItem) => (
                <a href={dropdownItem.href} class="mobile-dropdown-item">
                  {dropdownItem.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}

      <div class="mobile-language-switcher">
        <LanguageSwitcher />
      </div>

      <a href={getLocalizedRoute('/iletisim', lang)} class="mobile-cta">
        {t('nav.contact')}
      </a>
    </div>
  </div>
</header>

<style>


  /* ── TOKENS (sayfayla aynı palette) ── */
  .header {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --bdr:      #e4eaf4;
    --body:     #3d4f63;
    --white:    #ffffff;

    font-family: 'Inter', system-ui, sans-serif;
    position: fixed;
    top: 0; left: 0; right: 0;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--bdr);
    z-index: 1000;
    transition: box-shadow 0.25s ease, background 0.25s ease;
  }

  .header.scrolled {
    box-shadow: 0 2px 20px rgba(15,35,71,0.08);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2rem);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    min-height: 70px;
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  /* ── NAV LINKS ── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    text-decoration: none;
    color: var(--body);
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.925rem;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    position: relative;
  }

  .nav-link:hover { color: var(--navy); background: rgba(15,35,71,0.04); }

  /* ── DROPDOWN ── */
  .dropdown-item { position: relative; }

  .dropdown-arrow {
    font-size: 0.6rem;
    opacity: 0.5;
    transition: transform 0.2s;
  }
  .dropdown-item:hover .dropdown-arrow { transform: rotate(180deg); opacity: 1; }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px); left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: var(--white);
    border: 1px solid var(--bdr);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(15,35,71,0.12);
    min-width: 210px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 1001;
    padding: 0.5rem;
  }

  .dropdown-item:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    padding: 0.6rem 0.875rem;
    text-decoration: none;
    color: var(--body);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.15s;
    gap: 0.5rem;
  }
  .dropdown-link:hover { background: var(--cream); color: var(--navy); }

  /* ── CTA BUTTON ── */
  .nav-cta { display: none; }

  .cta-btn {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--navy);
    color: var(--white);
    text-decoration: none;
    padding: 0.55rem 1.35rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
    border: 1.5px solid transparent;
  }
  .cta-btn:hover {
    background: var(--navy-mid);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(15,35,71,0.22);
  }

  /* ── MOBILE BUTTON ── */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px; height: 40px;
    background: none;
    border: 1px solid var(--bdr);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    gap: 5px;
    transition: border-color 0.2s;
  }
  .mobile-menu-btn:hover { border-color: var(--navy); }

  .hamburger {
    width: 18px; height: 1.5px;
    background: var(--navy);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .mobile-menu-btn.active .hamburger:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
  .mobile-menu-btn.active .hamburger:nth-child(2) { opacity: 0; }
  .mobile-menu-btn.active .hamburger:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

  /* ── MOBILE MENU ── */
  .nav-mobile {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: var(--white);
    border-bottom: 1px solid var(--bdr);
    box-shadow: 0 8px 24px rgba(15,35,71,0.1);
    padding: 0.75rem 0 1rem;
    transform: translateY(-8px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s ease;
    max-height: calc(100vh - 70px);
    overflow-y: auto;
  }

  .nav-mobile.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-item { position: relative; }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    color: var(--body);
    font-family: 'Inter', system-ui, sans-serif;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s;
  }
  .nav-mobile-link:hover { background: var(--cream); color: var(--navy); }

  .mobile-dropdown-arrow {
    font-size: 0.6rem;
    opacity: 0.4;
    transition: transform 0.2s;
  }
  .mobile-nav-item.active .mobile-dropdown-arrow { transform: rotate(180deg); opacity: 1; }

  .mobile-dropdown {
    background: var(--cream);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .mobile-nav-item.active .mobile-dropdown { max-height: 300px; }

  .mobile-dropdown-item {
    display: block;
    padding: 0.6rem 1.5rem 0.6rem 2.25rem;
    color: var(--body);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s;
    border-left: 2px solid transparent;
    margin-left: 1.5rem;
  }
  .mobile-dropdown-item:hover { color: var(--navy); border-left-color: var(--gold); }

  .mobile-language-switcher {
    padding: 0.875rem 1.5rem;
    border-top: 1px solid var(--bdr);
    margin-top: 0.25rem;
  }

  .mobile-cta {
    display: block;
    margin: 0.75rem 1.5rem 0;
    background: var(--navy);
    color: var(--white);
    font-family: 'Inter', system-ui, sans-serif;
    text-decoration: none;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-align: center;
    transition: background 0.2s;
  }
  .mobile-cta:hover { background: var(--navy-mid); }

  /* ── RESPONSIVE ── */
  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
    .nav-cta { display: block; }
    .mobile-menu-btn,
    .nav-mobile { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const header = document.querySelector('.header');

    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenuBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    const mobileNavItems = document.querySelectorAll('.mobile-nav-item');
    mobileNavItems.forEach(item => {
      const link = item.querySelector('.nav-mobile-link');
      const dropdown = item.querySelector('.mobile-dropdown');
      if (dropdown) {
        link?.addEventListener('click', (e) => {
          e.preventDefault();
          item.classList.toggle('active');
        });
      }
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    });
  });
</script>
