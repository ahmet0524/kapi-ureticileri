---
import { Image } from 'astro:assets';
import I18nLayout from './I18nLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl } from '../i18n/utils';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  keywords?: string;
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage, keywords, ogImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<I18nLayout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage || heroImage}
  ogTitle={title}
  ogDescription={description}
>
  <I18nHeader />
  <main>
    <article>
      <div class="hero-image">
        {heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
      </div>
      <div class="prose">
        <div class="title">
          <div class="date">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <div class="last-updated-on">
                  <FormattedDate date={updatedDate} />
                </div>
              )
            }
          </div>
          <h1>{title}</h1>
          <hr />
        </div>
        <slot />
      </div>
    </article>
  </main>
  <I18nFooter />
</I18nLayout>

<style>
  main {
    width: calc(100% - 2em);
    max-width: 100%;
    margin: 0;
  }
  .hero-image {
    width: 100%;
  }
  .hero-image img {
    display: block;
    margin: 0 auto;
    border-radius: 12px;
    box-shadow: var(--box-shadow);
  }
  .prose {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 1em;
    color: rgb(var(--gray-dark));
  }
  .title {
    margin-bottom: 1em;
    padding: 1em 0;
    text-align: center;
    line-height: 1;
  }
  .title h1 {
    margin: 0 0 0.5em 0;
  }
  .date {
    margin-bottom: 0.5em;
    color: rgb(var(--gray));
  }
  .last-updated-on {
    font-style: italic;
  }
</style>
