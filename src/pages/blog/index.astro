---
// src/pages/blog/index.astro — EN default
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const currentUrl = `${baseUrl}/blog`;

const allPosts = [
  {
    slug: '/blog/pvc-door-manufacturers',
    title: 'PVC Door Manufacturers: Quality Solutions from Turkey to the World',
    excerpt: 'Comprehensive guide to Turkey\'s leading PVC door manufacturers. Production, pricing, models and export information.',
    image: '/assets/img/blog/pvc-kapi-ureticileri-og.webp',
    date: '2025-01-15',
    readTime: '8 min read',
    category: 'Manufacturing',
    featured: true
  },
  {
    slug: '/en/blog/turkish-hospital-doors',
    title: 'Hospital Doors: Medical Series Features',
    excerpt: 'Detailed guide about antibacterial hospital doors specially designed for healthcare facilities.',
    image: '/assets/img/blog/hastane-thumb.webp',
    date: '2025-01-08',
    readTime: '8 min read',
    category: 'Products',
    featured: false
  },
  {
    slug: '/en/blog/hotel-doors',
    title: 'Hotel Doors: Comfort and Aesthetics',
    excerpt: 'Ideal door models and features for hotels and accommodation facilities.',
    image: '/assets/img/blog/otel-thumb.webp',
    date: '2025-01-05',
    readTime: '7 min read',
    category: 'Products',
    featured: false
  }
];

allPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredPost = allPosts.find(p => p.featured);
const regularPosts = allPosts.filter(p => !p.featured);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": currentUrl }
  ]
};
---

<I18nLayout
  title="Blog | Door Industry Guides & Export Articles | CihanPan Door"
  description="Expert guides on PVC door manufacturing, wholesale pricing, hotel and hospital door projects from Turkey's leading interior door manufacturer."
  keywords="pvc door blog, door manufacturing turkey, wholesale doors, hotel doors, hospital doors"
  canonical={currentUrl}
  ogTitle="CihanPan Door Blog | Expert Articles from the Door Industry"
  ogDescription="Guides, news and export tips from Turkey's leading interior door manufacturer."
  ogImage="/assets/img/og/blog-og.webp"
  schema={[breadcrumbSchema]}
>

<I18nHeader />

<main class="bl">

  <!-- ══ HERO ══ -->
  <section class="bl-hero">
    <div class="bl-hero__bg" aria-hidden="true">
      <div class="bl-hero__overlay"></div>
      <div class="bl-hero__glow"></div>
    </div>
    <div class="bl-wrap bl-hero__inner">
      <nav class="bl-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Blog</span>
      </nav>
      <span class="bl-eyebrow">
        <span class="bl-eyebrow__line"></span>
        Knowledge Base · CihanPan Door
      </span>
      <h1 class="bl-hero__h1">
        Door Industry<br /><em>Guides & Insights</em>
      </h1>
      <p class="bl-hero__lead">
        Expert articles on PVC door manufacturing, wholesale export, hotel and hospital door projects from Kayseri, Turkey.
      </p>
    </div>
  </section>

  <!-- ══ FEATURED POST ══ -->
  {featuredPost && (
    <section class="bl-sec bl-sec--cream" aria-labelledby="featured-h2">
      <div class="bl-wrap">
        <div class="bl-head">
          <span class="bl-tag">Featured Article</span>
          <h2 id="featured-h2">Editor's Pick</h2>
        </div>
        <article class="bl-featured">
          <a href={featuredPost.slug} class="bl-featured__link">
            <div class="bl-featured__img">
              <img
                src={featuredPost.image}
                alt={featuredPost.title}
                width="680" height="420"
                loading="eager"
              />
              <span class="bl-featured__badge">{featuredPost.category}</span>
            </div>
            <div class="bl-featured__body">
              <div class="bl-meta">
                <time datetime={featuredPost.date}>
                  {new Date(featuredPost.date).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
                <span class="bl-meta__dot"></span>
                <span>⏱ {featuredPost.readTime}</span>
              </div>
              <h3>{featuredPost.title}</h3>
              <p>{featuredPost.excerpt}</p>
              <span class="bl-read-more">
                Read Article
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        </article>
      </div>
    </section>
  )}

  <!-- ══ ALL POSTS ══ -->
  <section class="bl-sec bl-sec--white" aria-labelledby="posts-h2">
    <div class="bl-wrap">
      <div class="bl-head">
        <span class="bl-tag">All Articles</span>
        <h2 id="posts-h2">Browse the Library</h2>
        <p>Technical guides, product deep-dives and export insights</p>
      </div>
      <div class="bl-grid">
        {regularPosts.map(post => (
          <article class="bl-card">
            <a href={post.slug} class="bl-card__link">
              <div class="bl-card__img">
                <img src={post.image} alt={post.title} loading="lazy" width="400" height="240" />
                <span class="bl-card__cat">{post.category}</span>
              </div>
              <div class="bl-card__body">
                <div class="bl-meta">
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <span class="bl-meta__dot"></span>
                  <span>⏱ {post.readTime}</span>
                </div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <span class="bl-read-more">
                  Read More
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ CTA BAND ══ -->
  <section class="bl-cta" aria-labelledby="cta-h2">
    <div class="bl-cta__glow" aria-hidden="true"></div>
    <div class="bl-wrap bl-cta__inner">
      <div class="bl-cta__text">
        <span class="bl-tag bl-tag--gold">Get Started</span>
        <h2 id="cta-h2">Ready to Source Wholesale Doors?</h2>
        <p>Share your requirements — door type, quantity and destination. Receive a quote within 24 hours.</p>
      </div>
      <div class="bl-cta__btns">
        <a href="/contact" class="bl-btn bl-btn--gold">
          Get Free Quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/pvc-doors" class="bl-btn bl-btn--ghost">
          View Products
        </a>
      </div>
    </div>
  </section>

</main>

<I18nFooter />

</I18nLayout>

<style>
  .bl {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  .bl-wrap {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }

  .bl-sec        { padding-block: clamp(4rem, 8vw, 6rem); }
  .bl-sec--white { background: var(--white); }
  .bl-sec--cream { background: var(--cream); }

  .bl-head { text-align: center; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .bl-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700; color: var(--text);
    margin: .3rem 0 .7rem; line-height: 1.2;
  }
  .bl-head p { color: var(--slate); font-size: 1rem; max-width: 520px; margin-inline: auto; line-height: 1.7; }

  .bl-tag {
    display: inline-block;
    font-size: .78rem; font-weight: 600;
    letter-spacing: .15em; text-transform: uppercase;
    color: var(--gold); margin-bottom: .4rem;
  }
  .bl-tag--gold { color: rgba(201,168,76,.9); }

  .bl-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .9rem; font-weight: 600;
    padding: .9rem 1.75rem; border-radius: 8px;
    text-decoration: none; white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform .2s, box-shadow .2s, background .2s, border-color .2s, color .2s;
  }
  .bl-btn--gold  { background: var(--gold); color: var(--navy); font-weight: 700; }
  .bl-btn--gold:hover { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,.4); }
  .bl-btn--ghost { background: transparent; color: rgba(255,255,255,.85); border: 1.5px solid rgba(255,255,255,.25); }
  .bl-btn--ghost:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.07); transform: translateY(-2px); }

  /* Hero */
  .bl-hero {
    position: relative;
    padding-top: 80px;
    padding-bottom: clamp(4rem, 8vw, 6rem);
    overflow: hidden;
    background: var(--navy);
  }
  .bl-hero__bg   { position: absolute; inset: 0; z-index: 0; }
  .bl-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,.97) 0%, rgba(15,35,71,.88) 60%, rgba(30,74,138,.6) 100%);
  }
  .bl-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 55% at 90% 30%, rgba(201,168,76,.09) 0%, transparent 65%),
      radial-gradient(ellipse 45% 70% at 10% 75%, rgba(30,74,138,.3) 0%, transparent 60%);
  }
  .bl-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    max-width: 760px;
  }
  .bl-breadcrumb {
    display: flex; gap: .5rem; align-items: center;
    font-size: .85rem; color: rgba(255,255,255,.45);
    margin-bottom: 1.5rem;
  }
  .bl-breadcrumb a { color: rgba(255,255,255,.45); text-decoration: none; transition: color .2s; }
  .bl-breadcrumb a:hover { color: var(--gold); }
  .bl-eyebrow {
    display: inline-flex; align-items: center; gap: .75rem;
    font-size: .78rem; font-weight: 600;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.25rem;
  }
  .bl-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: .5; flex-shrink: 0; }
  .bl-hero__h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 900; color: var(--white);
    line-height: 1.1; margin: 0 0 1.25rem;
  }
  .bl-hero__h1 em { font-style: normal; color: var(--gold); }
  .bl-hero__lead {
    font-size: 1.05rem; color: rgba(255,255,255,.6);
    line-height: 1.8; max-width: 560px; margin: 0;
  }

  /* Meta */
  .bl-meta {
    display: flex; align-items: center; gap: .6rem;
    font-size: .85rem; color: var(--slate);
    margin-bottom: .75rem; flex-wrap: wrap;
  }
  .bl-meta__dot { width: 4px; height: 4px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  /* Featured */
  .bl-featured {
    background: var(--white);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(15,35,71,.07);
    transition: transform .3s, box-shadow .3s;
  }
  .bl-featured:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(15,35,71,.12); }
  .bl-featured__link {
    display: grid; grid-template-columns: 1fr 1fr;
    text-decoration: none; color: inherit;
  }
  .bl-featured__img { position: relative; overflow: hidden; min-height: 360px; }
  .bl-featured__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s cubic-bezier(.22,1,.36,1); }
  .bl-featured:hover .bl-featured__img img { transform: scale(1.04); }
  .bl-featured__badge {
    position: absolute; top: 1.25rem; left: 1.25rem;
    background: var(--gold); color: var(--navy);
    font-size: .72rem; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase;
    padding: .3rem .85rem; border-radius: 20px;
  }
  .bl-featured__body {
    padding: clamp(2rem, 4vw, 3rem);
    display: flex; flex-direction: column; justify-content: center;
  }
  .bl-featured__body h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700; color: var(--text);
    margin: 0 0 1rem; line-height: 1.25;
  }
  .bl-featured__body p { font-size: .975rem; color: var(--body); line-height: 1.8; margin: 0 0 1.5rem; }

  /* Read more */
  .bl-read-more {
    display: inline-flex; align-items: center; gap: .45rem;
    font-size: .875rem; font-weight: 700;
    color: var(--navy-l);
    border-bottom: 1.5px solid var(--bdr); padding-bottom: 1px;
    transition: color .2s, border-color .2s, gap .2s;
  }
  .bl-featured__link:hover .bl-read-more,
  .bl-card__link:hover .bl-read-more { color: var(--gold); border-color: var(--gold); gap: .65rem; }

  /* Grid */
  .bl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .bl-card {
    background: var(--white);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform .3s, box-shadow .3s, border-color .3s;
  }
  .bl-card:hover { transform: translateY(-5px); box-shadow: 0 16px 36px rgba(15,35,71,.1); border-color: rgba(201,168,76,.3); }
  .bl-card__link { display: flex; flex-direction: column; text-decoration: none; color: inherit; height: 100%; }
  .bl-card__img  { position: relative; overflow: hidden; aspect-ratio: 16/9; }
  .bl-card__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s cubic-bezier(.22,1,.36,1); }
  .bl-card:hover .bl-card__img img { transform: scale(1.05); }
  .bl-card__cat {
    position: absolute; top: 1rem; left: 1rem;
    background: var(--navy); color: var(--white);
    font-size: .72rem; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase;
    padding: .3rem .8rem; border-radius: 20px;
  }
  .bl-card__body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .bl-card__body h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem; font-weight: 700;
    color: var(--text); margin: 0 0 .6rem; line-height: 1.3;
  }
  .bl-card__body p { font-size: .9rem; color: var(--body); line-height: 1.7; margin: 0 0 1.25rem; flex: 1; }

  /* CTA */
  .bl-cta {
    position: relative;
    background: var(--navy);
    overflow: hidden;
    padding: clamp(4rem, 8vw, 6rem) 0;
  }
  .bl-cta__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 80% at 105% 50%, rgba(201,168,76,.14) 0%, transparent 65%),
      linear-gradient(140deg, #08192e 0%, var(--navy) 100%);
    pointer-events: none;
  }
  .bl-cta__inner {
    position: relative; z-index: 1;
    display: flex; align-items: center;
    justify-content: space-between;
    gap: 3rem; flex-wrap: wrap;
  }
  .bl-cta__text h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    font-weight: 700; color: var(--white);
    margin: .35rem 0 .7rem; line-height: 1.2;
  }
  .bl-cta__text p { color: rgba(255,255,255,.55); font-size: .95rem; line-height: 1.7; max-width: 400px; margin: 0; }
  .bl-cta__btns  { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

  @media (max-width: 900px) {
    .bl-featured__link { grid-template-columns: 1fr; }
    .bl-featured__img  { min-height: 260px; }
  }
  @media (max-width: 768px) {
    .bl-grid       { grid-template-columns: 1fr; }
    .bl-cta__inner { flex-direction: column; text-align: center; }
    .bl-cta__text p { margin-inline: auto; }
    .bl-cta__btns  { justify-content: center; }
  }
</style>
