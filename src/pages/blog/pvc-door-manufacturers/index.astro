---
// src/pages/en/blog/pvc-door-manufacturers/index.astro
import I18nLayout from '../../../../layouts/I18nLayout.astro';
import I18nHeader from '../../../../components/I18nHeader.astro';
import I18nFooter from '../../../../components/I18nFooter.astro';
import I18nBreadcrumbs from '../../../../components/I18nBreadcrumbs.astro';
import { getLangFromUrl } from '../../../../i18n/utils';

import { content as enContent } from '../../../../content/blog/pvc-kapi-ihracati/en';

const lang = getLangFromUrl(Astro.url); // 'en'
const c = enContent;

const baseUrl    = 'https://cihanpandoor.netlify.app';
const currentUrl = `${baseUrl}/blog/pvc-door-manufacturers`;

const breadcrumbItems = [
  { name: c.breadcrumb.home, href: '/' },
  { name: c.breadcrumb.blog, href: '/blog' },
  { name: c.breadcrumb.current }
];

// ── SCHEMA ────────────────────────────────────────────────────────────
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "inLanguage": "en-US",
  "headline": c.hero.h1,
  "description": c.meta.description,
  "image": `${baseUrl}/assets/img/blog/pvc-kapi-ureticileri-og.webp`,
  "author": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
  "publisher": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "logo": { "@type": "ImageObject", "url": `${baseUrl}/assets/img/logo.webp` }
  },
  "datePublished": c.meta.dateISO,
  "dateModified":  c.meta.dateISO,
  "mainEntityOfPage": { "@type": "WebPage", "@id": currentUrl }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": c.schema.faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.href ? `${baseUrl}${item.href}` : currentUrl
  }))
};
---

<I18nLayout
  title={c.meta.title}
  description={c.meta.description}
  keywords={c.meta.keywords}
  canonical={currentUrl}
  ogImage="/assets/img/blog/pvc-kapi-ureticileri-og.webp"
  ogTitle={c.meta.ogTitle}
  ogDescription={c.meta.ogDescription}
  schema={[articleSchema, faqSchema, breadcrumbSchema]}
>

<I18nHeader />
<I18nBreadcrumbs items={breadcrumbItems} />

<main>
<article class="blog-article">
<div class="container">

<!-- ── ARTICLE HEADER ── -->
<header class="article-header">
  <div class="article-meta">
    <time datetime={c.meta.dateISO} class="publish-date">{c.meta.publishDate}</time>
    <span class="reading-time">⏱️ {c.meta.readingTime}</span>
    <span class="category">{c.meta.category}</span>
  </div>
  <h1>{c.hero.h1}</h1>
  <p class="article-lead" set:html={c.hero.lead} />
  <div class="article-image">
    <img
      src="/assets/img/blog/pvc-kapi-ureticileri-hero.webp"
      alt={c.hero.imgAlt}
      width="1200" height="600"
      loading="eager"
    />
  </div>
</header>

<!-- ── MAIN CONTENT + SIDEBAR ── -->
<div class="article-content">

  <section class="content-section" id="pvc-door-production-turkey">
    <h2>{c.sections.production.h2}</h2>
    <p set:html={c.sections.production.p1} />
    <p set:html={c.sections.production.p2} />
    <h3>{c.sections.production.advantagesTitle}</h3>
    <div class="highlight-box">
      <ul class="checkmark-list">
        {c.sections.production.advantages.map(item => (
          <li set:html={item} />
        ))}
      </ul>
    </div>
    <p set:html={c.sections.production.p3} />
  </section>

  <section class="content-section" id="why-pvc-doors">
    <h2>{c.sections.whyPvc.h2}</h2>
    <div class="features-grid">
      {c.sections.whyPvc.features.map(f => (
        <div class="feature-card">
          <div class="feature-icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section cta-section-inline" id="cihanpan-door">
    <div class="inline-cta">
      <h3>{c.sections.cihanpan.ctaTitle}</h3>
      <p set:html={c.sections.cihanpan.ctaDesc} />
      <a href={c.sections.cihanpan.ctaBtnHref} class="btn-cta-inline">
        {c.sections.cihanpan.ctaBtn}
      </a>
    </div>
  </section>

  <section class="content-section">
    <h3>{c.sections.cihanpan.productListTitle}</h3>
    <ul class="product-list">
      {c.sections.cihanpan.products.map(p => (
        <li set:html={p} />
      ))}
    </ul>
    <h3>{c.sections.cihanpan.capacityTitle}</h3>
    <p>{c.sections.cihanpan.capacityDesc}</p>
    <div class="info-box">
      <h4>{c.sections.cihanpan.qualityTitle}</h4>
      <ul class="compact-list">
        {c.sections.cihanpan.qualityItems.map(q => (
          <li>{q}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="content-section" id="models">
    <h2>{c.sections.models.h2}</h2>
    <h3>{c.sections.models.seriesTitle}</h3>
    <div class="model-series">
      {c.sections.models.series.map(s => (
        <div class="series-card">
          <h4>{s.name}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <h3>{c.sections.models.colorsTitle}</h3>
    <div class="color-categories">
      {c.sections.models.colorGroups.map(g => (
        <div class="color-category">
          <h4>{g.title}</h4>
          <ul>
            {g.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section" id="production-process">
    <h2>{c.sections.process.h2}</h2>
    <div class="process-steps">
      {c.sections.process.steps.map(step => (
        <div class="process-step">
          <div class="step-number">{step.num}</div>
          <h3>{step.title}</h3>
          {step.desc && <p>{step.desc}</p>}
          {step.items && (
            <ul>
              {step.items.map(item => <li>{item}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="content-section pricing-section" id="pricing">
    <h2>{c.sections.pricing.h2}</h2>
    <p>{c.sections.pricing.intro}</p>
    <div class="price-cards">
      {c.sections.pricing.cards.map(card => (
        <div class={`price-card${card.featured ? ' featured' : ''}`}>
          {card.featured && 'badge' in card && <div class="badge">{card.badge}</div>}
          <h3>{card.title}</h3>
          <div class="price">{card.price}</div>
          <p>{card.desc}</p>
        </div>
      ))}
    </div>
    <div class="info-box">
      <h4>{c.sections.pricing.includedTitle}</h4>
      <ul class="included-services">
        {c.sections.pricing.included.map(item => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="content-section">
    <h2>{c.sections.selection.h2}</h2>
    <h3>{c.sections.selection.qualityTitle}</h3>
    <ul class="checkmark-list">
      {c.sections.selection.qualityItems.map(item => (
        <li set:html={item} />
      ))}
    </ul>
    <h3>{c.sections.selection.sizeTitle}</h3>
    <p>{c.sections.selection.sizeDesc}</p>
  </section>

  <section class="content-section" id="application-areas">
    <h2>{c.sections.usage.h2}</h2>
    <div class="usage-areas">
      {c.sections.usage.areas.map(area => (
        <div class="usage-card">
          <h3>{area.title}</h3>
          <ul>
            {area.items.map(item => <li set:html={item} />)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section export-section" id="export">
    <h2>{c.sections.export.h2}</h2>
    <p set:html={c.sections.export.intro} />
    <div class="export-regions">
      {c.sections.export.regions.map(r => (
        <div class="region">
          <h4>{r.flag} {r.title}</h4>
          <p>{r.countries}</p>
        </div>
      ))}
    </div>
    <h3>{c.sections.export.advantagesTitle}</h3>
    <ul class="checkmark-list">
      {c.sections.export.advantages.map(a => <li>{a}</li>)}
    </ul>
  </section>

  <section class="content-section" id="maintenance">
    <h2>{c.sections.maintenance.h2}</h2>
    <div class="maintenance-tips">
      {c.sections.maintenance.tips.map(tip => (
        <div class="tip-card">
          <h3>{tip.title}</h3>
          <ul>
            {tip.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="content-section faq-section">
    <h2>{c.sections.faq.h2}</h2>
    <div class="faq-list">
      {c.sections.faq.items.map(item => (
        <details class="faq-item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="content-section conclusion">
    <h2>{c.sections.conclusion.h2}</h2>
    <p set:html={c.sections.conclusion.p1} />
    <p>{c.sections.conclusion.p2}</p>
  </section>

  <section class="content-section contact-info-section">
    <h3>{c.sections.contact.h3}</h3>
    <div class="contact-grid">
      <div class="contact-item">
        <strong>🌐 {c.sections.contact.web}</strong>
        <a href="https://cihanpandoor.com" target="_blank" rel="noopener">cihanpandoor.com</a>
      </div>
      <div class="contact-item">
        <strong>📱 {c.sections.contact.phone}</strong>
        <a href="tel:+905441690038">+90 544 169 00 38</a>
      </div>
      <div class="contact-item">
        <strong>💬 {c.sections.contact.whatsapp}</strong>
        <a href="https://wa.me/905441690038" target="_blank" rel="noopener">+90 544 169 00 38</a>
      </div>
      <div class="contact-item">
        <strong>📧 {c.sections.contact.email}</strong>
        <a href="mailto:export@cihanpandoor.com">export@cihanpandoor.com</a>
      </div>
      <div class="contact-item">
        <strong>📍 {c.sections.contact.address}</strong>
        {c.sections.contact.addressValue}
      </div>
    </div>
  </section>

</div>

<aside class="article-sidebar">
  <div class="sidebar-widget">
    <h3>{c.sidebar.tocTitle}</h3>
    <nav class="table-of-contents">
      <ul>
        {c.sidebar.toc.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="sidebar-widget cta-widget">
    <h3>{c.sidebar.ctaTitle}</h3>
    <p>{c.sidebar.ctaDesc}</p>
    <a href={c.sidebar.ctaBtnHref} class="btn-sidebar-cta">{c.sidebar.ctaBtn}</a>
    <a href="https://wa.me/905441690038" class="btn-sidebar-whatsapp" target="_blank" rel="noopener">
      {c.sidebar.ctaWhatsapp}
    </a>
  </div>
  <div class="sidebar-widget stats-widget">
    <h3>{c.sidebar.statsTitle}</h3>
    {c.sidebar.stats.map(s => (
      <div class="stat-item">
        <div class="stat-value">{s.value}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
  <div class="sidebar-widget related-links">
    <h3>{c.sidebar.relatedTitle}</h3>
    <ul>
      {c.sidebar.related.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </div>
</aside>

</div>
</article>

<section class="final-cta-section">
  <div class="container">
    <h2>{c.finalCta.h2}</h2>
    <p>{c.finalCta.desc}</p>
    <div class="cta-buttons">
      <a href={c.finalCta.btnContactHref} class="btn btn-primary">{c.finalCta.btnContact}</a>
      <a href="https://wa.me/905441690038" class="btn btn-whatsapp" target="_blank" rel="noopener">
        {c.finalCta.btnWhatsapp}
      </a>
      <a href="tel:+905441690038" class="btn btn-phone">{c.finalCta.btnPhone}</a>
    </div>
  </div>
</section>

<section class="related-articles-section">
  <div class="container">
    <h2>{c.relatedArticles.h2}</h2>
    <div class="articles-grid">
      {c.relatedArticles.articles.map(article => (
        <article class="article-card">
          <img src={article.img} alt={article.imgAlt} loading="lazy" />
          <div class="article-card-content">
            <h3><a href={article.href}>{article.title}</a></h3>
            <p>{article.desc}</p>
            <span class="read-more">{c.relatedArticles.readMore}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="tags-section">
  <div class="container">
    <h3>{c.tags.h3}</h3>
    <div class="tags-cloud">
      {c.tags.items.map(tag => (
        <a href={tag.href} class="tag">{tag.label}</a>
      ))}
    </div>
  </div>
</section>

</main>
<I18nFooter />
</I18nLayout>

<style>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
.blog-article{padding:4rem 0;background:#fff}
.blog-article .container{display:grid;grid-template-columns:1fr 300px;gap:4rem;align-items:start}
.article-header{grid-column:1/-1;margin-bottom:3rem}
.article-meta{display:flex;gap:1.5rem;margin-bottom:1.5rem;font-size:.95rem;color:#6b7280;flex-wrap:wrap}
.publish-date,.reading-time,.category{display:flex;align-items:center;gap:.5rem}
.article-header h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;color:#111827;line-height:1.2;margin-bottom:1.5rem}
.article-lead{font-size:1.25rem;line-height:1.7;color:#4b5563;margin-bottom:2rem}
.article-image{width:100%;border-radius:16px;overflow:hidden;box-shadow:0 10px 40px rgba(0,0,0,.1)}
.article-image img{width:100%;height:auto;display:block}
.article-content{grid-column:1}
.content-section{margin-bottom:3rem}
.content-section h2{font-size:2rem;font-weight:700;color:#111827;margin-bottom:1.5rem;line-height:1.3}
.content-section h3{font-size:1.5rem;font-weight:600;color:#1f2937;margin:2rem 0 1rem}
.content-section h4{font-size:1.25rem;font-weight:600;color:#374151;margin:1.5rem 0 .75rem}
.content-section p{font-size:1.05rem;line-height:1.8;color:#374151;margin-bottom:1.25rem}
.checkmark-list{list-style:none;padding-left:0;margin:1.5rem 0}
.checkmark-list li{padding-left:2rem;margin-bottom:.75rem;position:relative;line-height:1.6}
.checkmark-list li::before{content:"✓";position:absolute;left:0;color:#10b981;font-weight:bold;font-size:1.2rem}
.product-list,.compact-list{margin:1rem 0;padding-left:1.5rem}
.product-list li,.compact-list li{margin-bottom:.75rem;line-height:1.6}
.highlight-box{background:linear-gradient(135deg,#667eea15,#764ba215);border-left:4px solid #667eea;padding:2rem;border-radius:8px;margin:2rem 0}
.info-box{background:#f0fdf4;border:2px solid #10b981;border-radius:12px;padding:1.5rem;margin:2rem 0}
.info-box h4{color:#065f46;margin-top:0}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2rem;margin:2rem 0}
.feature-card{background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:2rem;text-align:center;transition:all .3s ease}
.feature-card:hover{border-color:#667eea;transform:translateY(-5px);box-shadow:0 10px 30px rgba(102,126,234,.15)}
.feature-icon{font-size:3rem;margin-bottom:1rem}
.inline-cta{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;padding:2.5rem;border-radius:16px;text-align:center;margin:3rem 0}
.inline-cta h3{color:#fff;margin-top:0}
.inline-cta p{color:rgba(255,255,255,.95);font-size:1.1rem}
.inline-cta a:not(.btn-cta-inline){color:#fff;text-decoration:underline}
.btn-cta-inline{display:inline-block;background:#fff;color:#667eea;padding:1rem 2.5rem;border-radius:50px;font-weight:600;text-decoration:none;margin-top:1.5rem;transition:all .3s ease}
.model-series{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;margin:2rem 0}
.series-card{background:#f9fafb;padding:1.5rem;border-radius:8px;border:1px solid #e5e7eb}
.series-card h4{color:#667eea;margin-top:0}
.color-categories{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;margin:2rem 0}
.color-category{background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:1.5rem}
.process-steps{margin:2rem 0}
.process-step{background:#fff;border-left:4px solid #667eea;padding:2rem 2rem 2rem 5rem;margin-bottom:2rem;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.05);position:relative}
.step-number{position:absolute;left:1.5rem;top:2rem;width:50px;height:50px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:bold}
.price-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2rem;margin:2rem 0}
.price-card{background:#fff;border:2px solid #e5e7eb;border-radius:16px;padding:2rem;text-align:center;position:relative;transition:all .3s ease}
.price-card.featured{border-color:#667eea;background:linear-gradient(135deg,#667eea15,#764ba215)}
.price-card .badge{position:absolute;top:-12px;right:20px;background:#10b981;color:#fff;padding:.5rem 1rem;border-radius:20px;font-size:.85rem;font-weight:600}
.price{font-size:2rem;font-weight:800;color:#667eea;margin:1rem 0}
.included-services{list-style:none;padding-left:0}
.included-services li{padding:.5rem 0;border-bottom:1px solid #d1fae5}
.included-services li:last-child{border-bottom:none}
.usage-areas{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin:2rem 0}
.usage-card{background:#f9fafb;padding:2rem;border-radius:12px;border:1px solid #e5e7eb}
.export-regions{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;margin:2rem 0}
.region{background:#fff;padding:1.5rem;border-radius:8px;border:2px solid #e5e7eb;text-align:center}
.region h4{margin:0 0 .5rem;font-size:1.5rem}
.maintenance-tips{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin:2rem 0}
.tip-card{background:#fffbeb;border:2px solid #fbbf24;border-radius:12px;padding:2rem}
.tip-card h3{margin-top:0;color:#92400e}
.faq-list{margin:2rem 0}
.faq-item{background:#fff;border:2px solid #e5e7eb;border-radius:12px;margin-bottom:1rem;overflow:hidden}
.faq-item summary{padding:1.5rem;cursor:pointer;font-weight:600;font-size:1.1rem;list-style:none;display:flex;justify-content:space-between;align-items:center}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:"+";font-size:1.5rem;color:#667eea;transition:transform .3s ease}
.faq-item[open] summary::after{transform:rotate(45deg)}
.faq-item p{padding:0 1.5rem 1.5rem;margin:0;color:#4b5563;line-height:1.7}
.contact-info-section{background:linear-gradient(135deg,#667eea15,#764ba215);border-radius:16px;padding:2.5rem}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;margin-top:1.5rem}
.contact-item{background:#fff;padding:1.25rem;border-radius:8px;border:1px solid #e5e7eb}
.contact-item strong{display:block;margin-bottom:.5rem;color:#667eea}
.contact-item a{color:#374151;text-decoration:none}
.article-sidebar{grid-column:2;position:sticky;top:100px}
.sidebar-widget{background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:1.5rem;margin-bottom:2rem}
.sidebar-widget h3{font-size:1.25rem;margin-top:0;margin-bottom:1rem;color:#111827}
.table-of-contents ul{list-style:none;padding:0;margin:0}
.table-of-contents li{margin-bottom:.75rem}
.table-of-contents a{color:#4b5563;text-decoration:none;font-size:.95rem}
.table-of-contents a:hover{color:#667eea}
.cta-widget{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;text-align:center}
.cta-widget h3{color:#fff}
.cta-widget p{color:rgba(255,255,255,.95);font-size:.95rem}
.btn-sidebar-cta,.btn-sidebar-whatsapp{display:block;width:100%;padding:.875rem;border-radius:8px;text-decoration:none;font-weight:600;text-align:center;margin-top:1rem;transition:all .3s ease}
.btn-sidebar-cta{background:#fff;color:#667eea}
.btn-sidebar-whatsapp{background:#10b981;color:#fff}
.stats-widget{text-align:center}
.stat-item{padding:1rem 0;border-bottom:1px solid #e5e7eb}
.stat-item:last-child{border-bottom:none}
.stat-value{font-size:2rem;font-weight:800;color:#667eea}
.stat-label{font-size:.85rem;color:#6b7280;text-transform:uppercase;letter-spacing:.5px}
.related-links ul{list-style:none;padding:0;margin:0}
.related-links li{margin-bottom:.75rem}
.related-links a{color:#4b5563;text-decoration:none;display:block;padding:.5rem;border-radius:6px;transition:all .2s ease}
.related-links a:hover{background:#f9fafb;color:#667eea}
.final-cta-section{padding:5rem 0;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;text-align:center}
