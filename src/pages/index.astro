---
// src/pages/index.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const baseUrl  = 'https://cihanpandoor.netlify.app';
const pageUrl  = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const isEN     = lang === 'en';

// ── SCHEMA ───────────────────────────────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CihanPan Door",
  "url": baseUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${baseUrl}/search?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CihanPan Door",
  "url": baseUrl,
  "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
  "foundingDate": "1995",
  "description": isEN
    ? "CE & ISO 9001 certified interior door manufacturer in Turkey. Wholesale PVC, MDF & Laminox doors for USA, Europe & Middle East. 600K units/year. MOQ 50 units."
    : "Kayseri'de 1995'ten bu yana faaliyet gösteren CE ve ISO 9001 sertifikalı kapı üreticisi.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
    "addressLocality": "Kayseri",
    "addressRegion": "Kayseri",
    "postalCode": "38070",
    "addressCountry": "TR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+90-544-169-0038",
    "contactType": "Sales",
    "availableLanguage": ["Turkish", "English", "Arabic", "German"],
    "areaServed": ["TR", "US", "EU", "ME"]
  },
  "sameAs": ["https://www.cihanpandoor.com"]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": isEN ? "Wholesale Interior Door Collection" : "Kapı Koleksiyonu",
  "url": pageUrl,
  "numberOfItems": 6,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "PVC Interior Doors" : "PVC Kapılar",      "url": `${pageUrl}/pvc-doors` },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Laminox Interior Doors" : "Laminoks Kapılar", "url": `${pageUrl}/laminox-doors` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "Hotel Room Doors" : "Otel Kapıları",     "url": `${pageUrl}/hotel-doors` },
    { "@type": "ListItem", "position": 4, "name": isEN ? "Hospital Doors" : "Hastane Kapıları",    "url": `${pageUrl}/hospital-doors` },
    { "@type": "ListItem", "position": 5, "name": isEN ? "Elitpan MDF Doors" : "Elitpan Kapılar", "url": `${pageUrl}/elitpan-doors` },
    { "@type": "ListItem", "position": 6, "name": isEN ? "Fire-Resistant Doors" : "Yangına Dayanıklı Kapılar", "url": `${pageUrl}/fire-doors` }
  ]
};

const schemas = [websiteSchema, organizationSchema, productSchema];

// ── CATEGORIES DATA ──────────────────────────────────────────────────
const categories = [
  {
    slug: '/pvc-kapilar',
    img: '/assets/img/categories/pvc-kapilar.webp',
    badge: isEN ? 'Best Seller' : 'Çok Satan',
    title: isEN ? 'PVC Interior Doors' : 'PVC Kapılar',
    desc: isEN
      ? 'Moisture-resistant, antibacterial PVC doors. Ideal for bathrooms, hospitals and high-humidity environments.'
      : 'Su geçirmez, antibakteriyel PVC kapılar. Banyo ve nemli alanlar için idealdir.',
    tags: isEN ? ['Waterproof', 'Antibacterial', 'Easy Clean'] : ['Su Geçirmez', 'Antibakteriyel', 'Kolay Bakım'],
  },
  {
    slug: '/laminoks-kapilar',
    img: '/assets/img/categories/laminoks-kapilar.webp',
    badge: isEN ? 'Featured' : 'Öne Çıkan',
    title: isEN ? 'Laminox Interior Doors' : 'Laminoks Kapılar',
    desc: isEN
      ? 'Premium MDF core with durable Laminox surface. Scratch-resistant finish in 50+ color options for wholesale projects.'
      : 'Dayanıklı laminoks yüzeyli, MDF özlü premium kapılar. 50+ renk seçeneği.',
    tags: isEN ? ['Scratch-Resistant', '50+ Colors', 'MDF Core'] : ['Çizilmez', '50+ Renk', 'MDF Özlü'],
    featured: true,
  },
  {
    slug: '/elitpan-kapilar',
    img: '/assets/img/categories/elitpan-kapilar.webp',
    badge: isEN ? 'Premium' : 'Premium',
    title: isEN ? 'Elitpan MDF Doors' : 'Elitpan Kapılar',
    desc: isEN
      ? 'UV-coated MDF surface with high gloss finish. Export-grade quality for residential and commercial wholesale.'
      : 'UV boyalı, parlak MDF yüzeyli premium kapılar. İhracat kalitesi.',
    tags: isEN ? ['UV Coated', 'High Gloss', 'Export Grade'] : ['UV Boyalı', 'Parlak Yüzey', 'İhracat Kalitesi'],
  },
  {
    slug: '/hastane-kapilari',
    img: '/assets/img/categories/hastane-kapilari.webp',
    badge: isEN ? 'Specialist' : 'Uzman',
    title: isEN ? 'Hospital Grade Doors' : 'Hastane Kapıları',
    desc: isEN
      ? 'CE certified hygiene doors for healthcare facilities. Lead-lined, radio-opaque and antimicrobial options available.'
      : 'Sağlık tesisleri için CE sertifikalı hijyen kapılar.',
    tags: isEN ? ['CE Certified', 'Lead-Lined Option', 'Antimicrobial'] : ['CE Sertifikalı', 'Kurşun Seçenek', 'Antimikrobiyal'],
  },
  {
    slug: '/otel-kapilari',
    img: '/assets/img/categories/otel-kapilari.webp',
    badge: isEN ? 'Hospitality' : 'Otel',
    title: isEN ? 'Hotel Room Doors' : 'Otel Kapıları',
    desc: isEN
      ? 'Sound-insulated, fire-rated hotel doors for 3★ to 5★ properties. Bulk pricing available for 500+ unit orders.'
      : 'Yangına dayanıklı, ses yalıtımlı otel kapıları. Toplu fiyatlandırma mevcut.',
    tags: isEN ? ['Sound-Insulated', 'Fire-Rated', 'Bulk Pricing'] : ['Ses Yalıtımı', 'Yangın Dayanımı', 'Toplu Fiyat'],
  },
  {
    slug: '/yangina-dayanikli-kapilar',
    img: '/assets/img/categories/yangina-dayanikli-kapilar.webp',
    badge: isEN ? 'Certified' : 'Sertifikalı',
    title: isEN ? 'Fire-Resistant Doors' : 'Yangına Dayanıklı Kapılar',
    desc: isEN
      ? 'EI30–EI90 rated fire doors with CE certification. Compliant with European and international building codes.'
      : 'CE sertifikalı EI30–EI90 yangın kapıları. Uluslararası standartlara uygun.',
    tags: isEN ? ['EI30–EI90', 'CE Certified', 'Building Code'] : ['EI30–EI90', 'CE Sertifikalı', 'Yönetmelik Uyumlu'],
  },
];

const trustItems = isEN ? [
  { icon: '🏭', label: 'Direct Factory',    desc: 'No middlemen — buy directly from the manufacturer' },
  { icon: '📋', label: 'CE + ISO 9001',     desc: 'Certified quality on every wholesale shipment' },
  { icon: '📦', label: 'MOQ: 50 Units',     desc: 'Low minimums to test before scaling' },
  { icon: '🌍', label: '25+ Countries',     desc: 'Proven export track record since 2010' },
  { icon: '🚢', label: 'FOB / CIF Terms',   desc: 'Flexible Incoterms for US importers' },
  { icon: '⚡', label: '24h Response',      desc: 'Quote turnaround within one business day' },
] : [
  { icon: '🏭', label: 'Direkt Fabrika',    desc: 'Aracısız, üreticiden doğrudan satış' },
  { icon: '📋', label: 'CE + ISO 9001',     desc: 'Her siparişte sertifikalı kalite güvencesi' },
  { icon: '📦', label: 'Min. 50 Adet',      desc: 'Düşük MOQ ile test imkânı' },
  { icon: '🌍', label: '25+ Ülke',          desc: '2010\'dan bu yana kanıtlanmış ihracat deneyimi' },
  { icon: '🚢', label: 'FOB / CIF',         desc: 'Esnek Incoterm seçenekleri' },
  { icon: '⚡', label: '24s Yanıt',          desc: 'Bir iş günü içinde fiyat teklifi' },
];
---

<I18nLayout
  title={isEN
    ? "Wholesale Interior Door Manufacturer Turkey | CE & ISO Certified | CihanPan Door"
    : "İç Kapı Üreticisi Kayseri | Toptan Satış & İhracat | CihanPan Door"}
  description={isEN
    ? "CE & ISO 9001 certified wholesale interior door manufacturer in Turkey. PVC, Laminox, MDF & fire-rated doors. Export to USA, Europe & Middle East. MOQ 50 units. Factory-direct pricing."
    : "Kayseri'de 1995'ten bu yana faaliyet gösteren CE & ISO 9001 sertifikalı kapı üreticisi. PVC, Laminoks, MDF kapılar. Toptan satış ve ihracat."}
  keywords={isEN
    ? "interior door manufacturer Turkey, wholesale interior doors Turkey, Turkish door exporter USA, PVC door wholesale Turkey, MDF interior door exporter, CE ISO certified door manufacturer, bulk interior doors Turkey"
    : "kapı üreticisi kayseri, iç kapı toptan satış, PVC kapı üreticisi, laminoks kapı fabrika, kapı ihracat türkiye"}
  canonical={pageUrl}
  schema={schemas}
  ogTitle={isEN ? "Turkey's Leading Wholesale Interior Door Manufacturer | CihanPan Door" : "CihanPan Door — Türkiye'nin Kapı Üreticisi"}
  ogDescription={isEN
    ? "Factory-direct wholesale interior doors from Kayseri, Turkey. CE, TSE & ISO 9001 certified. Exporting to 25+ countries since 1995."
    : "Kayseri'den dünyaya, 1995'ten bu yana kaliteli kapı üretimi ve ihracatı."}
  ogImage="/assets/img/og/home-og.webp"
>
  <I18nHeader />

  <main class="hp" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="hp-hero" aria-labelledby="hero-h1">
      <div class="hp-hero__bg" aria-hidden="true">
        <div class="hp-hero__img"></div>
        <div class="hp-hero__overlay"></div>
        <div class="hp-hero__glow"></div>
      </div>

      <div class="hp-wrap hp-hero__inner">
        <div class="hp-hero__copy">
          <span class="hp-eyebrow">
            <span class="hp-eyebrow__line"></span>
            {isEN ? 'Kayseri, Turkey · Est. 1995' : 'Kayseri · 1995\'ten Bu Yana'}
          </span>

          <!-- PRIMARY KEYWORD H1 -->
          <h1 class="hp-hero__h1" id="hero-h1">
            {isEN ? (
              <>Turkey's Leading<br /><em>Wholesale Interior Door</em><br />Manufacturer &amp; Exporter</>
            ) : (
              <>Türkiye'nin Önde Gelen<br /><em>İç Kapı Üreticisi</em><br />ve İhracatçısı</>
            )}
          </h1>

          <p class="hp-hero__lead">
            {isEN
              ? 'CE, TSE & ISO 9001 certified. Factory-direct PVC, MDF & Laminox interior doors for wholesale importers in the USA, Europe and Middle East. 600,000 units/year capacity.'
              : 'CE, TSE ve ISO 9001 sertifikalı. PVC, MDF ve Laminoks iç kapılar. Toptan satış ve ihracat — yılda 600.000 adet üretim kapasitesi.'}
          </p>

          <div class="hp-hero__tags">
            <span class="hp-htag">✓ CE Certified</span>
            <span class="hp-htag">✓ ISO 9001</span>
            <span class="hp-htag">✓ MOQ 50 Units</span>
            <span class="hp-htag">✓ USA Export Ready</span>
          </div>

          <div class="hp-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--gold">
              {isEN ? 'Get a Free Quote' : 'Teklif Al'}
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#products" class="hp-btn hp-btn--ghost">
              {isEN ? 'View All Products' : 'Ürünleri Gör'}
            </a>
          </div>
        </div>


      </div>

      <!-- Stats bar -->
      <div class="hp-wrap">
        <div class="hp-statsbar">
          <div class="hp-sitem">
            <strong>30<sup>+</sup></strong>
            <span>{isEN ? 'Years Manufacturing' : 'Yıl Üretim'}</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>600K</strong>
            <span>{isEN ? 'Units / Year' : 'Adet / Yıl'}</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>25<sup>+</sup></strong>
            <span>{isEN ? 'Export Countries' : 'İhracat Ülkesi'}</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>15K m²</strong>
            <span>{isEN ? 'Factory Floor' : 'Fabrika Alanı'}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TRUST BAR
    ══════════════════════════════════════════ -->
    <section class="hp-trust" aria-label={isEN ? 'Why choose us' : 'Neden biz'}>
      <div class="hp-wrap">
        <div class="hp-trust__grid">
          {trustItems.map(item => (
            <div class="hp-trust__item">
              <span class="hp-trust__icon" aria-hidden="true">{item.icon}</span>
              <div>
                <strong>{item.label}</strong>
                <p>{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         PRODUCTS — SEO keyword-rich section
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" id="products" aria-labelledby="products-h2">
      <div class="hp-wrap">
        <div class="hp-head">
          <span class="hp-tag">{isEN ? 'Our Product Range' : 'Ürün Gamımız'}</span>
          <!-- SECONDARY KEYWORD H2 -->
          <h2 id="products-h2">
            {isEN
              ? 'Wholesale Interior Door Collection — Factory Direct from Turkey'
              : 'Kapı Koleksiyonu — Fabrikadan Doğrudan'}
          </h2>
          <p>
            {isEN
              ? 'All product lines are CE & ISO 9001 certified and available for bulk wholesale export to the USA, Europe and Middle East.'
              : 'Tüm ürün serileri CE ve ISO 9001 sertifikalı. Toptan satış ve ihracat için hazır.'}
          </p>
        </div>

        <div class="hp-products">
          {categories.map((cat, i) => (
            <article class={`hp-product ${cat.featured ? 'hp-product--featured' : ''}`}>
              <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__img-wrap" tabindex="-1" aria-hidden="true">
                <img
                  src={cat.img}
                  alt={cat.title}
                  width="480"
                  height="360"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class={`hp-product__badge ${cat.featured ? 'hp-product__badge--gold' : ''}`}>{cat.badge}</span>
              </a>
              <div class="hp-product__body">
                <h3>
                  <a href={getLocalizedRoute(cat.slug, lang)}>{cat.title}</a>
                </h3>
                <p>{cat.desc}</p>
                <ul class="hp-product__tags">
                  {cat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__cta">
                  {isEN ? 'View & Request Quote' : 'İncele & Teklif Al'}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SOLUTIONS — US buyer journey
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--navy" aria-labelledby="solutions-h2">
      <div class="hp-wrap">
        <div class="hp-head hp-head--light">
          <span class="hp-tag">{isEN ? 'How We Work' : 'Nasıl Çalışırız'}</span>
          <h2 id="solutions-h2">
            {isEN
              ? 'Interior Door Wholesale & Export Services'
              : 'Toptan Satış & İhracat Hizmetleri'}
          </h2>
          <p>
            {isEN
              ? 'Three flexible sourcing models for US importers, distributors and project developers'
              : 'Bayiler, inşaatçılar ve ihracatçılar için üç esnek tedarik modeli'}
          </p>
        </div>

        <div class="hp-solutions">
          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">01</div>
            <div class="hp-sol__icon" aria-hidden="true">🏭</div>
            <h3>{isEN ? 'Wholesale Orders' : 'Toptan Siparişler'}</h3>
            <p>{isEN
              ? 'MOQ 50 units. Fixed catalog prices for standard sizes. Volume discounts from 200+ units. Pre-shipment samples included.'
              : 'Minimum 50 adet. Standart boyutlar için sabit fiyatlar. 200+ adet için hacim indirimleri.'}</p>
            <ul>
              <li>{isEN ? 'MOQ 50 units' : 'Min. 50 adet'}</li>
              <li>{isEN ? 'Volume discounts available' : 'Hacim indirimleri mevcut'}</li>
              <li>{isEN ? 'CE/ISO docs included' : 'CE/ISO belgeler dahil'}</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">02</div>
            <div class="hp-sol__icon" aria-hidden="true">🌍</div>
            <h3>{isEN ? 'Export & Import Services' : 'İhracat Hizmetleri'}</h3>
            <p>{isEN
              ? 'Full export documentation: commercial invoice, packing list, certificate of origin, CE & ISO certificates. FOB / CIF / EXW terms.'
              : 'Tam ihracat belgelendirmesi. FOB / CIF / EXW Incoterm seçenekleri.'}</p>
            <ul>
              <li>{isEN ? 'FOB / CIF / EXW Incoterms' : 'FOB / CIF / EXW seçenekleri'}</li>
              <li>{isEN ? 'Full export documentation' : 'Tam belgelendirme'}</li>
              <li>{isEN ? 'Freight forwarder coordination' : 'Nakliye koordinasyonu'}</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">03</div>
            <div class="hp-sol__icon" aria-hidden="true">🏗️</div>
            <h3>{isEN ? 'Custom Project Solutions' : 'Proje Çözümleri'}</h3>
            <p>{isEN
              ? 'Non-standard dimensions, private label, custom finishes — available for hotels, hospitals, residential complexes and commercial projects.'
              : 'Standart dışı boyutlar, özel etiket, özel yüzeyler. Otel, hastane ve konut projeleri için.'}</p>
            <ul>
              <li>{isEN ? 'Custom sizing & finish' : 'Özel boyut ve yüzey'}</li>
              <li>{isEN ? 'Private label available' : 'Özel etiket mevcut'}</li>
              <li>{isEN ? 'On-site measurement support' : 'Ölçü desteği'}</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ABOUT / CONTENT — SEO long-form text
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" aria-labelledby="about-h2">
      <div class="hp-wrap hp-about">

        <div class="hp-about__text">
          <span class="hp-tag">{isEN ? 'About CihanPan Door' : 'Hakkımızda'}</span>
          <!-- LONG-TAIL KEYWORD H2 -->
          <h2 id="about-h2">
            {isEN
              ? 'CE & ISO 9001 Certified Interior Door Factory in Kayseri, Turkey'
              : 'Kayseri\'de CE ve ISO 9001 Sertifikalı İç Kapı Fabrikası'}
          </h2>

          {isEN ? (
            <>
              <p>Founded in 1995, <strong>CihanPan Door</strong> is one of Turkey's most experienced <strong>wholesale interior door manufacturers</strong>. Operating from a 15,000 m² production facility in Kayseri Organized Industrial Zone, we produce over <strong>600,000 interior door sets per year</strong> for wholesale buyers in the USA, Europe, and the Middle East.</p>
              <h3>Why Source Interior Doors from Turkey?</h3>
              <p>Turkey has emerged as the leading alternative to Chinese door manufacturing for US importers — offering <strong>CE & ISO certified quality</strong>, competitive factory pricing, and significantly shorter sea freight times to East Coast ports. CihanPan Door ships to New York, Los Angeles, Miami, Houston, and all major US ports.</p>
              <h3>Our Interior Door Manufacturing Capabilities</h3>
              <p>We manufacture <strong>PVC coated doors, Laminox surface doors, UV-painted Elitpan MDF doors, hospital-grade hygiene doors, hotel room doors, and EI30–EI90 fire-rated doors</strong>. All product lines support custom sizing, non-standard dimensions, and private label for wholesale partners.</p>
            </>
          ) : (
            <>
              <p>1995 yılında kurulan <strong>CihanPan Door</strong>, Kayseri Organize Sanayi Bölgesi'ndeki 15.000 m² üretim tesisinde yılda <strong>600.000 iç kapı seti</strong> üretmektedir. PVC, Laminoks, Elitpan (MDF), hastane, otel ve yangına dayanıklı kapı serileriyle Türkiye'nin önde gelen kapı üreticilerindendir.</p>
              <h3>Neden CihanPan Door?</h3>
              <p>CE, TSE ve ISO 9001 sertifikalarıyla desteklenen üretim sürecimiz, her siparişte tutarlı kalite güvencesi sağlar. Minimum 50 adetlik toptan siparişler, özel boyut ve yüzey seçenekleri, tam ihracat belgelendirmesi sunuyoruz.</p>
            </>
          )}

          <div class="hp-about__cta">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--navy">
              {isEN ? 'Request Wholesale Pricing' : 'Toptan Fiyat Al'}
            </a>
            <a href="https://www.cihanpandoor.com/E-Katalog.pdf" target="_blank" rel="noopener noreferrer" class="hp-btn hp-btn--outline-dark">
              {isEN ? 'Download Catalogue (PDF)' : 'Kataloğu İndir (PDF)'}
            </a>
          </div>
        </div>

        <aside class="hp-about__stats" aria-label="Company statistics">
          <div class="hp-kpi">
            <strong>1995</strong>
            <span>{isEN ? 'Founded' : 'Kuruluş Yılı'}</span>
          </div>
          <div class="hp-kpi">
            <strong>600K</strong>
            <span>{isEN ? 'Units / Year' : 'Adet / Yıl'}</span>
          </div>
          <div class="hp-kpi">
            <strong>25<sup>+</sup></strong>
            <span>{isEN ? 'Export Countries' : 'İhracat Ülkesi'}</span>
          </div>
          <div class="hp-kpi">
            <strong>150<sup>+</sup></strong>
            <span>{isEN ? 'Employees' : 'Çalışan'}</span>
          </div>
          <div class="hp-kpi">
            <strong>15K m²</strong>
            <span>{isEN ? 'Factory Floor' : 'Fabrika Alanı'}</span>
          </div>

        </aside>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="hp-cta" aria-labelledby="cta-h2">
      <div class="hp-cta__glow" aria-hidden="true"></div>
