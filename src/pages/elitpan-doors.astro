---
// src/pages/elitpan-doors.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang  = getLangFromUrl(Astro.url);
const t     = useTranslations(lang);
const isEN  = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/elitpan-doors`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Elitpan-Serisi-301.webp",
  "CihanpanDoor-Elitpan-Serisi-302.webp",
  "CihanpanDoor-Elitpan-Serisi-303.webp",
  "CihanpanDoor-Elitpan-Serisi-304.webp",
  "CihanpanDoor-Elitpan-Serisi-305.webp",
  "CihanpanDoor-Elitpan-Serisi-306.webp",
  "CihanpanDoor-Elitpan-Serisi-307.webp",
  "CihanpanDoor-Elitpan-Serisi-308.webp",
  "CihanpanDoor-Elitpan-Serisi-309.webp",
  "CihanpanDoor-Elitpan-Serisi-310.webp",
  "CihanpanDoor-Elitpan-Serisi-311.webp",
  "CihanpanDoor-Elitpan-Serisi-312.webp",
  "CihanpanDoor-Elitpan-Serisi-313.webp",
  "CihanpanDoor-Elitpan-Serisi-314.webp",
  "CihanpanDoor-Elitpan-Serisi-315.webp",
  "CihanpanDoor-Elitpan-Serisi-316.webp",
  "CihanpanDoor-Elitpan-Serisi-317.webp",
  "CihanpanDoor-Elitpan-Serisi-318.webp",
  "CihanpanDoor-Elitpan-Serisi-319.webp",
  "CihanpanDoor-Elitpan-Serisi-320.webp",
  "CihanpanDoor-Elitpan-Serisi-321.webp",
  "CihanpanDoor-Elitpan-Serisi-322.webp",
  "CihanpanDoor-Elitpan-Serisi-323.webp",
  "CihanpanDoor-Elitpan-Serisi-324.webp",
  "CihanpanDoor-Elitpan-Serisi-325.webp",
  "CihanpanDoor-Elitpan-Serisi-326.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const elitpanSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN
    ? `Elitpan UV Interior Doors — ${modelCount}+ Models | CihanPan Door`
    : `Elitpan UV İç Oda Kapıları — ${modelCount}+ Model | CihanPan Door`,
  "description": isEN
    ? `Wholesale UV-coated Elitpan interior doors from Kayseri, Turkey. Antibacterial, scratch-resistant, ${modelCount}+ models, CE certified, factory-direct pricing for hotels, hospitals and commercial projects.`
    : `Kayseri'den toptan UV kaplı Elitpan iç oda kapıları. Antibakteriyel, çizilmez, ${modelCount}+ model, CE belgeli.`,
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "Elitpan Door Models" : "Elitpan Kapı Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": isEN ? "Elitpan UV Interior Door" : "Elitpan UV İç Oda Kapısı",
        "description": isEN
          ? "UV-coated MDF core interior door. Antibacterial, scratch-resistant, moisture-proof. CE certified, 5-year warranty. Wholesale manufacturer from Kayseri, Turkey."
          : "UV kaplı MDF özlü iç kapı. Antibakteriyel, çizilmez, su dayanımlı. CE belgeli, 5 yıl garanti.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": isEN ? "UV Coating over MDF" : "UV Kaplama / MDF",
        "category": isEN ? "Interior Door" : "İç Oda Kapısı",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "What is an Elitpan door?", "acceptedAnswer": { "@type": "Answer", "text": "Elitpan doors are premium interior doors with a UV-coated MDF core. The UV finish provides an antibacterial, highly scratch-resistant and moisture-proof surface — ideal for hospitals, hotels, commercial buildings and upscale residential projects." }},
    { "@type": "Question", "name": "What is the difference between Elitpan and Laminox doors?", "acceptedAnswer": { "@type": "Answer", "text": "Both series use an MDF core. Elitpan doors feature a UV-cured coating that delivers exceptional gloss, colour fastness and antibacterial properties. Laminox (HPL) doors use a high-pressure melamine laminate with superior scratch and impact resistance. Elitpan is preferred when premium gloss finish and hygiene are priorities." }},
    { "@type": "Question", "name": "Are Elitpan doors suitable for humid environments?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The UV coating and moisture-resistant MDF core make Elitpan doors well-suited for bathrooms, kitchens and other moderately humid interior spaces. For extremely wet environments, additional sealing is recommended." }},
    { "@type": "Question", "name": "What is the MOQ for wholesale Elitpan door orders?", "acceptedAnswer": { "@type": "Answer", "text": "Minimum order quantity is 50 units. Volume discounts apply from 200 units. Custom dimensions, glass apertures and private-label options are available for larger bulk orders." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home"     : "Ana Sayfa",        "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler",          "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "Elitpan Interior Doors" : "Elitpan Kapılar", "item": currentUrl },
  ]
};

const allSchemas = [elitpanSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: isEN ? 'All Products'   : 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: isEN ? 'PVC Doors'      : 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: isEN ? 'Laminox Doors'  : 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',           label: isEN ? 'Elitpan Doors'  : 'Elitpan Kapılar',   active: true  },
  { slug: '/hastane-kapilari',          label: isEN ? 'Hospital Doors' : 'Hastane Kapıları',  active: false },
  { slug: '/otel-kapilari',             label: isEN ? 'Hotel Doors'    : 'Otel Kapıları',      active: false },
  { slug: '/yangina-dayanikli-kapilar', label: isEN ? 'Fire-Rated'     : 'Yangın Kapıları',   active: false },
];

// ── SSR PRODUCT LIST (for SEO) ────────────────────────────────────────
interface ElitpanProduct {
  id: string;
  model: string;
  label: string;
  image: string;
  alt: string;
}

const elitpanProducts: ElitpanProduct[] = fileNames.map((fn) => {
  const model = fn.replace('.webp', '').split('-').pop()!;
  return {
    id:    `elitpan-${model}`,
    model,
    label: `Elitpan ${model}`,
    image: `/assets/img/elitpan-doors/${fn}`,
    alt:   isEN
      ? `CihanPan Door Elitpan Series ${model} — UV Interior Door`
      : `CihanPan Door Elitpan Serisi ${model} — UV İç Kapı`,
  };
});
---

<I18nLayout
  title={isEN
    ? `Elitpan UV Interior Doors — ${modelCount}+ Models | Wholesale Turkey | CihanPan Door`
    : `Elitpan UV İç Oda Kapıları — ${modelCount}+ Model | Toptan | CihanPan Door`}
  description={isEN
    ? `Wholesale UV-coated Elitpan interior doors from Kayseri, Turkey. Antibacterial MDF core, ${modelCount}+ models, CE & ISO 9001 certified. Factory-direct pricing for hotels, hospitals and commercial projects. MOQ 50 units.`
    : `Kayseri'den toptan UV kaplı Elitpan kapılar. Antibakteriyel MDF özlü, ${modelCount}+ model, CE sertifikalı.`}
  keywords={isEN
    ? "Elitpan interior doors wholesale Turkey, UV coated door manufacturer, antibacterial door Kayseri, scratch resistant interior door CE certified, premium door bulk order"
    : "elitpan kapı, UV kaplı iç kapı, antibakteriyel kapı, toptan elitpan kayseri, CE belgeli kapı"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? `Elitpan UV Interior Doors — ${modelCount}+ Models | CihanPan Door` : `Elitpan Kapılar — ${modelCount}+ Model | CihanPan Door`}
  ogDescription={isEN
    ? `Antibacterial UV-coated Elitpan interior doors. Factory direct from Kayseri. MOQ 50 units.`
    : `Antibakteriyel UV kaplı Elitpan kapılar. Fabrikadan doğrudan.`}
  ogImage="/assets/img/og/elitpan-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>{isEN ? 'Home' : 'Ana Sayfa'}</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>{isEN ? 'Products' : 'Ürünler'}</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{isEN ? 'Elitpan Doors' : 'Elitpan Kapılar'}</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            {isEN ? `Premium UV Collection · ${modelCount}+ Models` : `Premium UV Koleksiyonu · ${modelCount}+ Model`}
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            {isEN
              ? <><em>Elitpan Interior Doors</em><br/>UV-Coated · Antibacterial · Premium Finish</>
              : <><em>Elitpan İç Oda Kapıları</em><br/>UV Kaplı · Antibakteriyel · Premium Görünüm</>}
          </h1>
          <p class="lam-hero__lead">
            {isEN
              ? `Factory-direct wholesale Elitpan interior doors from Kayseri, Turkey. UV-cured coating over solid MDF core delivers antibacterial, moisture-proof and scratch-resistant performance. CE & ISO 9001 certified. ${modelCount}+ models. MOQ 50 units.`
              : `Kayseri fabrikasından toptan Elitpan kapılar. Masif MDF özlü UV kaplama — antibakteriyel, su dayanımlı ve çizilmez performans. CE ve ISO 9001 sertifikalı.`}
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ {isEN ? 'UV-Coated MDF Core' : 'UV Kaplı MDF Öz'}</span>
            <span class="lam-htag">✓ {modelCount}+ {isEN ? 'Models' : 'Model'}</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ {isEN ? 'Antibacterial' : 'Antibakteriyel'}</span>
            <span class="lam-htag">✓ MOQ 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              {isEN ? 'Get a Free Quote' : 'Ücretsiz Teklif Al'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              {isEN ? 'Browse Models' : 'Modelleri Gör'}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}<sup>+</sup></strong><span>{isEN ? 'Models' : 'Model'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>UV</strong><span>{isEN ? 'Coating' : 'Kaplama'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>MOQ 50</strong><span>{isEN ? 'Units' : 'Adet'}</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label={isEN ? 'Door categories' : 'Kapı kategorileri'}>
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">{isEN ? 'Elitpan Door Collection' : 'Elitpan Kapı Koleksiyonu'}</span>
          <h2 id="catalogue-h2">
            {isEN ? 'Elitpan Interior Door Models' : 'Elitpan Kapı Modelleri'}
          </h2>
          <p>
            {isEN
              ? `Browse the full Elitpan UV door collection — ${modelCount} models, series 301–326. Each model is available in multiple finish variants. Click any model to request a wholesale quote.`
              : `Tüm Elitpan UV kapı koleksiyonunu inceleyin — ${modelCount} model, 301–326 serisi. Her model birden fazla yüzey varyantında mevcuttur.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            {isEN ? 'Request Wholesale Quote' : 'Toptan Teklif Al'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">{isEN ? 'Response within 24 hours · MOQ 50 units' : '24 saat içinde yanıt · Min. 50 adet'}</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid" id="productsGrid" aria-label={isEN ? 'Elitpan door models' : 'Elitpan kapı modelleri'}>
          {elitpanProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 8 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <p class="lam-card__name">{product.label}</p>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            {isEN
              ? 'What Is an Elitpan Door? Why Choose UV-Coated MDF?'
              : 'Elitpan Kapı Nedir? Neden UV Kaplı MDF Tercih Edilir?'}
          </h2>

          <p>
            {isEN
              ? (<><strong>Elitpan interior doors</strong> are manufactured with a solid MDF core finished with a <em>UV-cured coating</em> that bonds directly to the surface under ultraviolet light. At <strong>CihanPan Door</strong>, our Kayseri factory produces the complete {modelCount}-model Elitpan collection for wholesale buyers in the USA, Europe and the Middle East.</>)
              : (<><strong>Elitpan kapılar</strong>, masif MDF özlü, yüzeye ultraviyole ışık altında direkt bağlanan <em>UV kür kaplama</em> ile üretilen iç kapılardır. <strong>CihanPan Door</strong> olarak Kayseri fabrikamızda {modelCount} modellik tam Elitpan koleksiyonunu toptan satış için üretiyoruz.</>)}
          </p>

          <h3>{isEN ? 'Advantages of Elitpan Doors' : 'Elitpan Kapının Avantajları'}</h3>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Antibacterial Surface:' : 'Antibakteriyel Yüzey:'}</strong> {isEN ? 'UV curing creates a non-porous, antibacterial finish — essential for hospitals, clinics and food-processing environments.' : 'UV kür, gözeneksiz, antibakteriyel bir yüzey oluşturur — hastane, klinik ve gıda tesisleri için zorunludur.'}</li>
            <li><strong>{isEN ? 'Exceptional Colour Fastness:' : 'Üstün Renk Dayanımı:'}</strong> {isEN ? 'UV-bonded pigments resist fading from sunlight and cleaning agents far better than standard laminates.' : 'UV bağlı pigmentler, standart laminatlara kıyasla güneş ışığına ve temizlik maddelerine karşı solmaz.'}</li>
            <li><strong>{isEN ? 'Scratch & Impact Resistant:' : 'Çizilmez ve Darbeye Dayanıklı:'}</strong> {isEN ? 'The hardened UV surface withstands daily wear, trolleys and sharp objects common in commercial settings.' : 'Sertleştirilmiş UV yüzey, ticari ortamlarda günlük kullanıma, troleylere ve keskin nesnelere dayanır.'}</li>
            <li><strong>{isEN ? 'Moisture-Proof:' : 'Su Dayanımlı:'}</strong> {isEN ? 'Moisture-resistant MDF core and sealed UV coating prevent warping in bathrooms and kitchens.' : 'Nem dayanımlı MDF öz ve kapalı UV kaplama, banyo ve mutfaklarda çarpma yapmaz.'}</li>
            <li><strong>{isEN ? 'Easy Maintenance:' : 'Kolay Bakım:'}</strong> {isEN ? 'Non-porous surface wipes clean — no painting or sealing required throughout the product life.' : 'Gözeneksiz yüzey temizlenir — ürün ömrü boyunca boya veya vernikleme gerekmez.'}</li>
            <li><strong>{isEN ? 'High-Gloss Aesthetic:' : 'Yüksek Parlaklık Estetiği:'}</strong> {isEN ? 'UV coating delivers a deep, consistent gloss that elevates interiors in luxury hotels and premium residences.' : 'UV kaplama, lüks otel ve premium konutlarda iç mekanları yükselten derin, tutarlı parlaklık sağlar.'}</li>
          </ul>

          <h3>{isEN ? 'Ideal Applications' : 'İdeal Kullanım Alanları'}</h3>
          <p>{isEN ? 'Elitpan doors excel wherever hygiene, aesthetics and durability converge:' : 'Elitpan kapılar hijyen, estetik ve dayanıklılığın buluştuğu her yerde üstündür:'}</p>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Hospitals & Healthcare:' : 'Hastane ve Sağlık:'}</strong> {isEN ? 'Antibacterial surface meets the strictest hygiene standards in clinical environments.' : 'Antibakteriyel yüzey, klinik ortamların en katı hijyen standartlarını karşılar.'}</li>
            <li><strong>{isEN ? 'Hotels & Hospitality:' : 'Otel ve Konaklama:'}</strong> {isEN ? 'Premium gloss finish and durable surface handle heavy guest traffic with minimal upkeep.' : 'Premium parlak yüzey ve dayanıklı yüzey, minimum bakımla yoğun misafir trafiğini kaldırır.'}</li>
            <li><strong>{isEN ? 'Commercial Buildings:' : 'Ticari Binalar:'}</strong> {isEN ? 'Modern gloss aesthetics for offices, retail spaces and public buildings.' : 'Ofis, perakende alanları ve kamu binaları için modern parlak estetik.'}</li>
            <li><strong>{isEN ? 'Residential Wet Rooms:' : 'Konut Islak Alanları:'}</strong> {isEN ? 'Moisture-proof and antibacterial properties make Elitpan the ideal bathroom and kitchen door.' : 'Su dayanımlı ve antibakteriyel özellikler Elitpan\'ı ideal banyo ve mutfak kapısı yapar.'}</li>
          </ul>

          <h3>{isEN ? 'Technical Specifications' : 'Teknik Özellikler'}</h3>
          <ul class="lam-checklist">
            <li>{isEN ? 'Surface: UV-cured coating — high-gloss, antibacterial' : 'Yüzey: UV kür kaplama — yüksek parlaklık, antibakteriyel'}</li>
            <li>{isEN ? 'Core: Solid moisture-resistant MDF' : 'Öz: Masif nem dayanımlı MDF'}</li>
            <li>{isEN ? 'Standard size: 70×200 cm · 80×200 cm — custom sizes available' : 'Standart boyut: 70×200 cm · 80×200 cm — özel boyut mevcut'}</li>
            <li>{isEN ? 'Finish options: High-gloss, Satin, Textured' : 'Finish seçenekleri: Yüksek parlak, Saten, Dokulu'}</li>
            <li>{isEN ? 'Glass aperture options available' : 'Cam açıklık seçeneği mevcut'}</li>
            <li>CE & ISO 9001 {isEN ? 'certified' : 'sertifikalı'}</li>
            <li>{isEN ? '5-year manufacturer warranty' : '5 yıl üretici garantisi'}</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}<sup>+</sup></strong><span>{isEN ? 'Models' : 'Model'}</span></div>
            <div class="lam-kpi"><strong>UV</strong><span>{isEN ? 'Coating' : 'Kaplama'}</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>{isEN ? 'Warranty' : 'Garanti'}</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">{isEN ? 'Get in Touch' : 'İletişim'}</span>
            <h3>{isEN ? 'Request a Quote' : 'Teklif Al'}</h3>
            <p>{isEN ? 'Share your quantity and requirements — we respond within 24 hours.' : 'Miktar ve gereksinimlerinizi paylaşın — 24 saat içinde yanıt veririz.'}</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                {isEN ? 'Contact Form' : 'İletişim Formu'}
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
