---
// src/pages/en/support.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLocalizedRoute } from '../i18n/utils';

const lang = 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/en`;
const currentUrl = `${pageUrl}/support`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const supportSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Customer Support | CihanPan Door",
  "description": "CihanPan Door customer support services. Phone, WhatsApp, and email support. Technical assistance, after-sales service, and order tracking.",
  "url": currentUrl,
  "inLanguage": "en-US",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",    "item": pageUrl },
      { "@type": "ListItem", "position": 2, "name": "Support", "item": currentUrl },
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are your support hours?",           "acceptedAnswer": { "@type": "Answer", "text": "Our phone and WhatsApp support is available Monday–Friday, 09:00–18:00 (GMT+3). Email inquiries are answered within 24 hours." }},
    { "@type": "Question", "name": "How can I track my order?",              "acceptedAnswer": { "@type": "Answer", "text": "You can contact us via phone, WhatsApp, or email with your order number and we will provide a production and delivery status update." }},
    { "@type": "Question", "name": "Do you offer after-sales service?",      "acceptedAnswer": { "@type": "Answer", "text": "Yes, we provide warranty-covered maintenance and repair services for all our products." }},
    { "@type": "Question", "name": "Can I visit the factory?",               "acceptedAnswer": { "@type": "Answer", "text": "Factory visits are welcome. Please contact us in advance to schedule an appointment." }},
    { "@type": "Question", "name": "Do you provide technical documentation?","acceptedAnswer": { "@type": "Answer", "text": "Yes, installation guides, product datasheets, and certificates are available upon request." }},
  ]
};

const allSchemas = [supportSchema, faqSchema];
---

<I18nLayout
  title="Customer Support | CihanPan Door"
  description="CihanPan Door customer support services. Phone, WhatsApp, and email support. Technical assistance, after-sales service, and order tracking."
  keywords="CihanPan Door support, door manufacturer customer service, door factory Turkey contact, technical support Kayseri"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="Customer Support | CihanPan Door"
  ogDescription="Phone, WhatsApp, and email support. Technical assistance, after-sales service, and order tracking."
  ogImage="/assets/img/og/support-og.webp"
  lang="en"
>
  <I18nHeader />

  <main class="sup" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="sup-hero" aria-labelledby="sup-h1">
      <div class="sup-hero__bg" aria-hidden="true">
        <div class="sup-hero__overlay"></div>
        <div class="sup-hero__glow"></div>
      </div>
      <div class="sup-wrap sup-hero__inner">
        <nav class="sup-breadcrumb" aria-label="Breadcrumb">
          <a href={pageUrl}>Home</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">Support</span>
        </nav>

        <span class="sup-eyebrow">
          <span class="sup-eyebrow__line"></span>
          We're Here to Help
        </span>

        <h1 class="sup-hero__h1" id="sup-h1">
          🤝 <em>Customer Support</em><br/>Reliable Help at Every Step
        </h1>
        <p class="sup-hero__lead">
          Reach our team by phone, WhatsApp, or email. From technical assistance
          to after-sales service — we're with you every step of the way.
        </p>
        <div class="sup-hero__tags">
          <span class="sup-htag">✓ Mon–Fri 09:00–18:00</span>
          <span class="sup-htag">✓ 24h Email Response</span>
          <span class="sup-htag">✓ WhatsApp Live Chat</span>
          <span class="sup-htag">✓ Technical Support</span>
          <span class="sup-htag">✓ After-Sales Service</span>
        </div>
        <div class="sup-hero__actions">
          <a href="https://wa.me/905441690038" class="sup-btn sup-btn--gold" target="_blank" rel="noopener noreferrer">
            WhatsApp Support
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="mailto:info@cihanpandoor.com" class="sup-btn sup-btn--ghost">
            info@cihanpandoor.com
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="sup-wrap">
        <div class="sup-statsbar">
          <div class="sup-sitem"><strong>24h</strong><span>Email Response</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>5★</strong><span>Customer Rating</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>15+</strong><span>Years Experience</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>100%</strong><span>Satisfaction</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CONTACT CARDS
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--white" aria-labelledby="contact-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">Contact Channels</span>
          <h2 id="contact-h2">How Can We Help You?</h2>
        </div>

        <div class="sup-cards">

          <div class="sup-card">
            <div class="sup-card__icon">📞</div>
            <h3>Phone Support</h3>
            <p>Monday–Friday, 09:00–18:00 (GMT+3)</p>
            <a href="tel:+905441690038" class="sup-card__btn">+90 544 169 00 38</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">💬</div>
            <h3>WhatsApp</h3>
            <p>Quick replies for urgent inquiries</p>
            <a href="https://wa.me/905441690038" class="sup-card__btn sup-card__btn--wa" target="_blank" rel="noopener noreferrer">Chat on WhatsApp</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">✉️</div>
            <h3>Email Support</h3>
            <p>Response within 24 hours</p>
            <a href="mailto:info@cihanpandoor.com" class="sup-card__btn">Send an Email</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">📍</div>
            <h3>Factory Visit</h3>
            <p>Schedule an in-person appointment</p>
            <a href={getLocalizedRoute('/iletisim', lang)} class="sup-card__btn">Address &amp; Map</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         QUICK LINKS
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--cream" aria-labelledby="quick-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">Quick Access</span>
          <h2 id="quick-h2">Popular Resources</h2>
        </div>
        <div class="sup-quick">
          <a href={getLocalizedRoute('/sss', lang)}        class="sup-qlink">❓ Frequently Asked Questions</a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)} class="sup-qlink">📦 Product Catalogue</a>
          <a href={getLocalizedRoute('/iletisim', lang)}   class="sup-qlink">📝 Request a Quote</a>
          <a href={getLocalizedRoute('/hakkimizda', lang)} class="sup-qlink">ℹ️ About Us</a>
          <a href={getLocalizedRoute('/export', lang)}     class="sup-qlink">🌍 Export Services</a>
          <a href={getLocalizedRoute('/sertifikalar', lang)} class="sup-qlink">🏅 Certificates</a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SUPPORT SERVICES
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--white" aria-labelledby="services-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">Our Services</span>
          <h2 id="services-h2">Support Services We Provide</h2>
        </div>
        <div class="sup-info-grid">
          <div class="sup-info-item">
            <div class="sup-info-icon">🔧</div>
            <h3>Technical Support</h3>
            <p>Professional guidance on product installation, usage, and maintenance from our engineering team.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">🛡️</div>
            <h3>After-Sales Service</h3>
            <p>Warranty-covered maintenance and repair services ensuring long-term product performance.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">📦</div>
            <h3>Order Tracking</h3>
            <p>Stay informed on your order's production progress and estimated delivery timeline.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">💼</div>
            <h3>Project Consulting</h3>
            <p>Custom solutions and tailored pricing for large-scale and special projects.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">📄</div>
            <h3>Documentation</h3>
            <p>Installation guides, product datasheets, CE certificates, and compliance documents on request.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">🌐</div>
            <h3>Export Assistance</h3>
            <p>Customs documentation, logistics coordination, and multilingual support for international buyers.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--cream" aria-labelledby="faq-h2">
      <div class="sup-wrap sup-faq-wrap">
        <div class="sup-head">
          <span class="sup-tag">FAQ</span>
          <h2 id="faq-h2">Frequently Asked Questions</h2>
        </div>

        <div class="sup-faqs" role="list">

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              What are your support hours?
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">Our phone and WhatsApp support is available Monday–Friday, 09:00–18:00 (GMT+3). Email inquiries are answered within 24 hours.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              How can I track my order?
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">Contact us via phone, WhatsApp, or email with your order number and we will provide a full production and delivery status update.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              Do you offer after-sales service?
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">Yes, we provide warranty-covered maintenance and repair services for all our products.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              Can I visit the factory?
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">Factory visits are welcome. Please contact us in advance to schedule an appointment at our facility in Kayseri, Turkey.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              Do you provide technical documentation?
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">Yes, installation guides, product datasheets, and certificates are available upon request. Contact us and we will send the relevant documents.</p>
          </details>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="sup-cta" aria-label="Contact us">
      <div class="sup-cta__glow" aria-hidden="true"></div>
      <div class="sup-wrap sup-cta__inner">
        <div class="sup-cta__text">
          <span class="sup-tag sup-tag--light">Get in Touch</span>
          <h2>Still Have Questions?</h2>
          <p>Our team is ready to help. Reach out via phone, WhatsApp, or email and we'll get back to you promptly.</p>
        </div>
        <div class="sup-cta__btns">
          <a href="tel:+905441690038" class="sup-btn sup-btn--gold">
            Call Now
          </a>
          <a href="https://wa.me/905441690038" class="sup-btn sup-btn--wa" target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS ── */
  :root {
    --navy:   #0f2347;
    --gold:   #c9a84c;
    --gold-l: #dfc078;
    --white:  #ffffff;
    --cream:  #f9f6f0;
    --text:   #1a202c;
    --body:   #4a5568;
    --slate:  #6b7280;
    --bdr:    #e5e7eb;
    --green:  #16a34a;
    --radius: 14px;
  }

  /* ── LAYOUT ── */
  .sup-wrap { max-width: 1200px; margin: 0 auto; padding-inline: clamp(1rem, 4vw, 2.5rem); }
  .sup-sec  { padding: clamp(3.5rem, 7vw, 6rem) 0; }
  .sup-sec--white { background: var(--white); }
  .sup-sec--cream { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .sup-head { text-align: center; margin-bottom: 3rem; }
  .sup-tag  {
    display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.3); border-radius: 4px; padding: 0.3rem 0.85rem;
    margin-bottom: 0.9rem;
  }
  .sup-tag--light { color: var(--gold-l); background: rgba(201,168,76,0.08); border-color: rgba(201,168,76,0.2); }
  .sup-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; color: var(--text); margin: 0;
  }

  /* ── BUTTONS ── */
  .sup-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.75rem; border-radius: 8px; font-weight: 700;
    font-size: 0.92rem; text-decoration: none; transition: all 0.25s; white-space: nowrap;
  }
  .sup-btn--gold  { background: var(--gold); color: var(--navy); }
  .sup-btn--gold:hover { background: var(--gold-l); transform: translateY(-2px); }
  .sup-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .sup-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }
  .sup-btn--wa    { background: var(--green); color: var(--white); }
  .sup-btn--wa:hover { background: #15803d; transform: translateY(-2px); }

  /* ── HERO ── */
  .sup-hero {
    position: relative; min-height: 70vh; display: flex;
    flex-direction: column; justify-content: center;
    padding-top: 70px; overflow: hidden;
  }
  .sup-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .sup-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.96) 0%, rgba(15,35,71,0.88) 60%, rgba(26,58,110,0.82) 100%);
  }
  .sup-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 80% 30%, rgba(201,168,76,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 10% 70%, rgba(30,74,138,0.3) 0%, transparent 60%);
  }
  .sup-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .sup-breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; flex-wrap: wrap;
  }
  .sup-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .sup-breadcrumb a:hover { color: var(--gold-l); }
  .sup-breadcrumb span[aria-current] { color: var(--gold); }
  .sup-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem;
  }
  .sup-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: 0.5; flex-shrink: 0; }
  .sup-hero__h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 3.4rem); font-weight: 900;
    color: var(--white); line-height: 1.15; margin: 0 0 1.2rem;
  }
  .sup-hero__h1 em { font-style: normal; color: var(--gold); }
  .sup-hero__lead { font-size: 1.05rem; color: rgba(255,255,255,0.65); line-height: 1.8; max-width: 580px; margin: 0 0 1.5rem; }
  .sup-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .sup-htag {
    display: inline-block; padding: 0.3rem 0.85rem;
    border: 1px solid rgba(201,168,76,0.35); background: rgba(201,168,76,0.08);
    color: var(--gold-l); font-size: 0.82rem; font-weight: 600; border-radius: 4px;
  }
  .sup-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Stats bar */
  .sup-statsbar {
    position: relative; z-index: 1;
    display: flex; align-items: center; flex-wrap: wrap; gap: 0;
    background: rgba(255,255,255,0.06); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;
    padding: 1.5rem 2rem; margin-top: 2rem;
  }
  .sup-sitem { display: flex; flex-direction: column; flex: 1; min-width: 80px; padding-inline: 1rem; text-align: center; }
  .sup-sitem:first-child { padding-left: 0; }
  .sup-sitem:last-child  { padding-right: 0; }
  .sup-sitem strong {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem; font-weight: 900; color: var(--gold); line-height: 1; display: block;
  }
  .sup-sitem span { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-top: 0.3rem; display: block; }
  .sup-sdiv { width: 1px; height: 32px; background: rgba(255,255,255,0.12); flex-shrink: 0; }

  /* ── CONTACT CARDS ── */
  .sup-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .sup-card {
    background: var(--white); border: 1px solid var(--bdr);
    border-radius: var(--radius); padding: 2rem; text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .sup-card:hover {
    transform: translateY(-4px); box-shadow: 0 16px 36px rgba(15,35,71,0.1);
    border-color: rgba(201,168,76,0.35);
  }
  .sup-card__icon { font-size: 2.5rem; margin-bottom: 1rem; line-height: 1; }
  .sup-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem; font-weight: 700; color: var(--text); margin: 0 0 0.5rem;
  }
  .sup-card p { font-size: 0.9rem; color: var(--slate); margin: 0 0 1.5rem; }
  .sup-card__btn {
    display: inline-block; background: var(--navy); color: var(--white);
    padding: 0.7rem 1.4rem; border-radius: 8px; text-decoration: none;
    font-weight: 600; font-size: 0.88rem; transition: all 0.25s;
  }
  .sup-card__btn:hover { background: #1a3a7a; transform: translateY(-2px); }
  .sup-card__btn--wa { background: var(--green); }
  .sup-card__btn--wa:hover { background: #15803d; }

  /* ── QUICK LINKS ── */
  .sup-quick {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .sup-qlink {
    background: var(--white); color: var(--body);
    padding: 1rem 1.25rem; border-radius: 10px; text-decoration: none;
    font-weight: 600; font-size: 0.9rem; text-align: center;
    border: 1px solid var(--bdr); transition: all 0.25s;
  }
  .sup-qlink:hover { background: var(--navy); color: var(--white); transform: translateY(-2px); border-color: var(--navy); }

  /* ── SUPPORT INFO ── */
  .sup-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.75rem;
  }
  .sup-info-item {
    background: var(--cream); border: 1px solid var(--bdr);
    border-radius: var(--radius); padding: 1.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .sup-info-item:hover { border-color: rgba(201,168,76,0.35); box-shadow: 0 8px 24px rgba(15,35,71,0.07); }
  .sup-info-icon { font-size: 2rem; margin-bottom: 0.75rem; line-height: 1; }
  .sup-info-item h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem; font-weight: 700; color: var(--text); margin: 0 0 0.5rem;
  }
  .sup-info-item p { font-size: 0.9rem; color: var(--body); line-height: 1.7; margin: 0; }

  /* ── FAQ ── */
  .sup-faq-wrap { max-width: 800px; }
