            <li><span class="art-facts__label">Acoustic</span><span class="art-facts__val">Rw 32–42 dB</span></li>
            <li><span class="art-facts__label">Standard</span><span class="art-facts__val">EN 1634-1, CE</span></li>
            <li><span class="art-facts__label">Lead time</span><span class="art-facts__val">3–8 weeks</span></li>
            <li><span class="art-facts__label">Min. width</span><span class="art-facts__val">900 mm clear</span></li>
          </ul>
        </div>

        <div class="art-sidebar__card">
