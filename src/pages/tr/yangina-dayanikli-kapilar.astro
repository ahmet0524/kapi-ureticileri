---
// src/pages/tr/yangina-dayanikli-kapilar.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { useTranslations, getLocalizedRoute } from '../../i18n/utils';

const lang = 'tr';
const t    = useTranslations(lang);

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = baseUrl;
const currentUrl = `${pageUrl}/yangina-dayanikli-kapilar`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Yangin-Serisi-601-EI30-White.webp",
  "CihanpanDoor-Yangin-Serisi-602-EI60-Anthracite.webp",
  "CihanpanDoor-Yangin-Serisi-603-EI90-Grey.webp",
  "CihanpanDoor-Yangin-Serisi-604-EI30-Walnut.webp",
  "CihanpanDoor-Yangin-Serisi-605-EI60-Oak.webp",
  "CihanpanDoor-Yangin-Serisi-606-EI90-Wenge.webp",
  "CihanpanDoor-Yangin-Serisi-607-EI30-Cappuccino.webp",
  "CihanpanDoor-Yangin-Serisi-608-EI60-Black.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Yangina Dayanikli Kapilar — EI Sertifikali Seri | CihanPan Door",
  "description": "Kayseri uretimi yangina dayanikli kapi modelleri. EI-30, EI-60, EI-90 sertifikali, TSE onayli.",
  "url": currentUrl,
  "inLanguage": "tr-TR",
  "mainEntity": {
    "@type": "ItemList",
    "name": "Yangina Dayanikli Kapi Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "Yangina Dayanikli Kapi — EI Sertifikali",
        "description": "EI-30, EI-60, EI-90 sertifikali yangina dayanikli kapi. TSE onayli, duman sizdirmaz conta, otomatik kapanma.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "Yangin Dayanikli Celik",
        "category": "Yangina Dayanikli Kapi",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "TRY",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Yangina dayanikli kapi nedir?",                        "acceptedAnswer": { "@type": "Answer", "text": "Yangina dayanikli kapi, yangin ve dumani belirli bir sure boyunca engelleyen sertifikali bir kapi sistemidir. EI-30, EI-60 ve EI-90 degerleri 30, 60 veya 90 dakikalik yangin ve duman direncini gosterir." }},
    { "@type": "Question", "name": "EI-30, EI-60 ve EI-90 arasindaki fark nedir?",         "acceptedAnswer": { "@type": "Answer", "text": "Bu degerler kapinin yangin ve dumana kac dakika dayandigini gosterir. EI-30: 30 dakika, EI-60: 60 dakika, EI-90: 90 dakika. Bina sinifina gore dogru sertifika secimi yonetmelik geregi zorunludur." }},
    { "@type": "Question", "name": "Hangi binalarda yangin kapisi zorunludur?",             "acceptedAnswer": { "@type": "Answer", "text": "Is merkezleri, hastaneler, oteller, okullar, AVM ve apartmanlarda yangin yonetmeligi geregi zorunludur. Yangin kacis yollari ve merdiven kovelari sertifikali yangin kapisi gerektirmektedir." }},
    { "@type": "Question", "name": "Yangin kapisi siparislerinde MOQ nedir?",               "acceptedAnswer": { "@type": "Answer", "text": "Minimum siparis miktari 10 adettir. 50+ adet icin hacim indirimleri gecerlidir. Tam bina donanim projeleri icin ozel olcu, panik donanimlari, elektrikli kilit hazirligi ve proje belgelendirme mevcut." }},
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa",                   "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "Ürünler",                     "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "Yangina Dayanikli Kapilar",   "item": currentUrl },
  ]
};

const allSchemas = [hotelSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',             label: 'Elitpan Kapılar',   active: false },
  { slug: '/hospital-doors',            label: 'Hastane Kapıları',  active: false },
  { slug: '/hotel-doors',               label: 'Otel Kapilari',     active: false },
  { slug: '/yangina-dayanikli-kapilar', label: 'Yangin Kapilari',   active: true  },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface FireProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  badge: string;
  image: string;
  alt: string;
}

const fireProducts: FireProduct[] = fileNames.map((fn, i) => {
  const parts      = fn.replace('.webp', '').split('-');
  const model      = parts[3];
  const fireRaw    = parts[4];
  const color      = parts.slice(5).join(' ');
  const fireRating = fireRaw.replace('EI', 'EI-');
  return {
    id:    `fire-${model}`,
    model,
    color,
    label: `Yangin ${model} - ${color}`,
    badge: `${fireRating} - TSE Onayli`,
    image: `/assets/img/yangina-dayanikli-kapilar/${fn}`,
    alt:   `CihanPan Door Yangin Serisi ${model} ${color} ${fireRating} Sertifikali Yangin Kapisi`,
  };
});
---

<I18nLayout
  title="Yangina Dayanikli Kapilar — EI Sertifikali Seri | CihanPan Door"
  description="Kayseri uretimi yangina dayanikli kapi modelleri. EI-30, EI-60, EI-90 sertifikali, TSE onayli."
  keywords="yangina dayanikli kapi, yangin kapisi, EI-30 kapi, EI-60 kapi, kayseri yangin kapisi, TSE onayli yangin kapisi"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="Yangina Dayanikli Kapilar — EI Sertifikali | CihanPan Door"
  ogDescription="EI-30, EI-60, EI-90 sertifikali yangina dayanikli kapilar. TSE onayli. Fabrikadan dogrudan."
  ogImage="/assets/img/og/fire-resistant-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>Ana Sayfa</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>Ürünler</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">Yangına Dayanıklı Kapılar</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            Yangin Guvenlik Koleksiyonu · EI Sertifikali
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>Yangina Dayanikli Kapilar</em><br/>EI Sertifikali · TSE Onayli · Duman Sizdirmaz
          </h1>
          <p class="lam-hero__lead">
            Kayseri fabrikasindan toptan yangin kapilari. EI-30, EI-60, EI-90 yangin dayanim sertifikali, TSE onayli modeller.
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ EI-30 / EI-60 / EI-90</span>
            <span class="lam-htag">✓ TSE Onayli</span>
            <span class="lam-htag">✓ Duman Sizdirmaz Conta</span>
            <span class="lam-htag">✓ Otomatik Kapanma</span>
            <span class="lam-htag">✓ TS EN 1634-1</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--fire">
              Yangin Kapisi Teklifi Al
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              Modelleri Gor
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>Model</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>TSE</strong><span>Onay</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>EI-90</strong><span>Sertifika</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>Guvenlik</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label="Kapi kategorileri">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">Yangin Kapi Koleksiyonu</span>
          <h2 id="catalogue-h2">
            Yangina Dayanikli Kapi Modelleri
          </h2>
          <p>
            {modelCount} yangin guvenlik kapisi modeli — 601–608 serisi. EI-30, EI-60 ve EI-90 sertifikali, TSE onayli.
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            Yangin Kapisi Proje Teklifi Al
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">24 saat icinde yanit · Proje bazli fiyatlandirma</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label="Yangin kapi modelleri">
          {fireProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.badge}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            Sertifikali Bir Yangina Dayanikli Kapi Nedir? CihanPan Yaklasimi
          </h2>

          <p>
            <strong>CihanPan Door yangin serisi</strong>, siki yangin guvenligi muhendisligi ile Kayseri fabrikamizin uretim hassasiyetini birlestirmektedir. Her model TS EN 1634-1 standartlarina uygun EI-30, EI-60 ve EI-90 sertifikalari icin tasarlanmistir.
          </p>

          <h3>Temel Yangin Guvenligi Ozellikleri</h3>
          <ul class="lam-checklist">
            <li><strong>EI-30 / EI-60 / EI-90 Sertifikasi:</strong> Turk ve AB yangin yonetmeliklerinde farkli bina sinifi gereksinimlerini karsilamak icin uc yangin direnci seviyesi.</li>
            <li><strong>TSE Onayli:</strong> Turk Standartlari Enstitusu sertifikasi, TS EN 1634-1 yangin direnci ve duman kontrol testlerine uygunlugu onaylar.</li>
            <li><strong>Duman Sizdirmaz Conta Sistemi:</strong> Intumesans ve duman conta sistemleri tum sicakliklarinda zehirli gaz ve duman gecisini engelleyerek kacis yollarini korur.</li>
            <li><strong>Otomatik Kapanma Mekanizmasi:</strong> Yay yuklu veya hidrolik kapi kapatici, kapinin her zaman kapali olmasini saglar ve acik kapi uzerinden yangin yayilmasini onler.</li>
            <li><strong>Celik Cerceve Konstruksiyonu:</strong> Galvanizli celik cerceve ve kapi kanadi, asiri isi altinda yapisal bozulmaya karsi direnir.</li>
            <li><strong>Panik Donanimina Hazir:</strong> Acil cikis uyumu icin panik bar ve elektromanyetik acik tutma sistemleriyle uyumludur.</li>
          </ul>

          <h3>Kullanim Alanlari</h3>
          <p>CihanPan Door yangin serisi su alanlarda tercih edilir:</p>
          <ul class="lam-checklist">
            <li><strong>AVM ve Is Merkezleri:</strong> EI-60 veya EI-90 sertifikasi gerektiren yangin bolmesi kapilari, kacis yollari ve merdiven alanlari.</li>
            <li><strong>Hastaneler:</strong> Yangin kontrolunun kritik oldugu hasta koridorlari, ameliyathane girisleri ve yogun bakim bolgeleri.</li>
            <li><strong>Oteller:</strong> Kat koridor yangin kapilari, merdiven girisleri ve servis alani bolmelendirmesi.</li>
            <li><strong>Endustriyel Tesisler:</strong> Uretim tesisleri, depolar ve proses tesisleri icin agir hizmet yangin bolmesi kapilari.</li>
            <li><strong>Apartmanlar:</strong> Konut bina kodlari tarafindan zorunlu olan ortak alan yangin kapilari, bodrum girisleri ve tesisat sahtalari.</li>
            <li><strong>Kamu Binalari:</strong> Kacis yollarinda ve merdiven kovalarinda sertifikali yangin kapilari gerektiren okullar, universiteler ve resmi binalar.</li>
          </ul>

          <h3>Teknik Ozellikler</h3>
          <ul class="lam-checklist">
            <li>Cerceve: Galvanizli yangin dayanikli celik, 1.5 mm et kalinligi</li>
            <li>Dolgu: Yangin dayanikli mineral yun (yogunluk: 100 kg/m3)</li>
            <li>Standart boyutlar: 80x200 cm, 90x200 cm — ozel olcu mevcut</li>
            <li>Yangin dayanimi: EI-30, EI-60, EI-90 (TS EN 1634-1)</li>
            <li>Aksesuarlar: Yangin mentesesi, otomatik kapama, duman sizdirmaz esik, panik bar</li>
            <li>TSE onayli · TS EN 1634-1 sertifikali · 2 yil uretici garantisi</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>Model</span></div>
            <div class="lam-kpi"><strong>TSE</strong><span>Onay</span></div>
            <div class="lam-kpi"><strong>EI-90</strong><span>Sertifika</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>Guvenlik</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">Yangin Guvenligi Uzmani</span>
            <h3>Yangin Kapisi Teklifi Al</h3>
            <p>Bina turunuzu, sertifika duzeyini ve kapi sayisini paylasin — 24 saat icinde yanit veririz.</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--fire lam-btn--sm">
                Iletisim Formu
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                WhatsApp
              </a>
              <a href="tel:+905441690038" class="lam-btn lam-btn--outline lam-btn--sm" style="color: white;">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <div class="lam-features-card">
            <h3>One Cikan Ozellikler</h3>
            <ul class="lam-feat-list">
              <li>🔥 EI-30 / EI-60 / EI-90 sertifikali</li>
              <li>✅ TSE onayli, TS EN 1634-1 uyumlu</li>
              <li>💨 Duman sizdirmaz conta sistemi</li>
              <li>⚙️ Otomatik kapanma mekanizmasi</li>
              <li>📐 Ozel olcu ve cift kanat secenegi</li>
              <li>🏗️ Proje bazli toplu tedarik</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="faq-h2">
      <div class="lam-wrap lam-faq-wrap">
        <div class="lam-head">
          <span class="lam-tag">SSS</span>
          <h2 id="faq-h2">Sik Sorulan Sorular</h2>
        </div>
        <div class="lam-faqs">
          {[
            { q: 'Yangina dayanikli kapi nedir?',                         a: 'Yangina dayanikli kapi, yangin ve dumani belirli bir sure boyunca engelleyen sertifikali bir kapi sistemidir. EI-30, EI-60 ve EI-90 degerleri 30, 60 veya 90 dakikalik yangin ve duman direncini gosterir.' },
            { q: 'EI-30, EI-60 ve EI-90 arasindaki fark nedir?',         a: 'Bu degerler kapinin yangin ve dumana kac dakika dayandigini gosterir. EI-30: 30 dakika, EI-60: 60 dakika, EI-90: 90 dakika. Bina sinifina gore dogru sertifika secimi yonetmelik geregi zorunludur.' },
            { q: 'Hangi binalarda yangin kapisi zorunludur?',             a: 'Is merkezleri, hastaneler, oteller, okullar, AVM ve apartmanlarda yangin yonetmeligi geregi zorunludur. Yangin kacis yollari ve merdiven kovelari sertifikali yangin kapisi gerektirmektedir.' },
            { q: 'Yangin kapisi siparislerinde MOQ nedir?',               a: 'Minimum siparis miktari 10 adettir. 50+ adet icin hacim indirimleri gecerlidir. Tam bina donanim projeleri icin ozel olcu, panik donanimlari, elektrikli kilit hazirligi ve proje belgelendirme mevcut.' },
          ].map(item => (
            <details class="lam-faq">
              <summary class="lam-faq__q">
                {item.q}
                <span class="lam-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="lam-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="lam-cta" aria-labelledby="cta-h2">
      <div class="lam-cta__glow" aria-hidden="true"></div>
      <div class="lam-wrap lam-cta__inner">
        <div class="lam-cta__text">
          <span class="lam-tag lam-tag--fire">Yangin Guvenligi Tedariki</span>
          <h2 id="cta-h2">
            Yangina Dayanikli Kapi<br/>Proje Teklifi Alin
          </h2>
          <p>
            Bina turunuzu, sertifika duzeyini ve kapi sayisini paylasin. 24 saat icinde TSE ve EN 1634-1 belgeli fiyat teklifi.
          </p>
        </div>
        <div class="lam-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--fire">
            Ucretsiz Teklif Al
