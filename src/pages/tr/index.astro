---
// src/pages/tr/index.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'tr';
const baseUrl = 'https://cihanpandoor.netlify.app';
const pageUrl = baseUrl;

// ── SCHEMA ───────────────────────────────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CihanPan Door",
  "url": baseUrl,
  "inLanguage": "tr-TR",
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${baseUrl}/search?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CihanPan Door",
  "url": baseUrl,
  "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
  "foundingDate": "1995",
  "description": "Kayseri'de 1995'ten bu yana faaliyet gösteren CE ve ISO 9001 sertifikalı kapı üreticisi.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
    "addressLocality": "Kayseri",
    "addressRegion": "Kayseri",
    "postalCode": "38070",
    "addressCountry": "TR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+90-544-169-0038",
    "contactType": "Sales",
    "availableLanguage": ["Turkish", "English", "Arabic", "German"],
    "areaServed": ["TR", "US", "EU", "ME"]
  },
  "sameAs": ["https://www.cihanpandoor.com"]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Kapı Koleksiyonu",
  "url": pageUrl,
  "numberOfItems": 6,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "PVC Kapılar",               "url": `${pageUrl}/pvc-kapilar` },
    { "@type": "ListItem", "position": 2, "name": "Laminoks Kapılar",          "url": `${pageUrl}/laminoks-kapilar` },
    { "@type": "ListItem", "position": 3, "name": "Otel Kapıları",             "url": `${pageUrl}/otel-kapilari` },
    { "@type": "ListItem", "position": 4, "name": "Hastane Kapıları",          "url": `${pageUrl}/hastane-kapilari` },
    { "@type": "ListItem", "position": 5, "name": "Elitpan Kapılar",           "url": `${pageUrl}/elitpan-kapilar` },
    { "@type": "ListItem", "position": 6, "name": "Yangına Dayanıklı Kapılar", "url": `${pageUrl}/yangina-dayanikli-kapilar` }
  ]
};

const schemas = [websiteSchema, organizationSchema, productSchema];

// ── CATEGORIES DATA ──────────────────────────────────────────────────
const categories = [
  {
    slug: '/pvc-kapilar',
    img: '/assets/img/categories/pvc-kapilar.webp',
    badge: 'Çok Satan',
    badgeGold: true,
    title: 'PVC Kapılar',
    desc: 'Su geçirmez, antibakteriyel PVC kapılar. Banyo ve nemli alanlar için idealdir.',
    tags: ['Su Geçirmez', 'Antibakteriyel', 'Kolay Bakım'],
  },
  {
    slug: '/laminoks-kapilar',
    img: '/assets/img/categories/laminoks-kapilar.webp',
    badge: 'Öne Çıkan',
    badgeGold: false,
    title: 'Laminoks Kapılar',
    desc: 'Dayanıklı laminoks yüzeyli, MDF özlü premium kapılar. 50+ renk seçeneği.',
    tags: ['Çizilmez', '50+ Renk', 'MDF Özlü'],
    featured: true,
  },
  {
    slug: '/elitpan-kapilar',
    img: '/assets/img/categories/CihanpanDoor-Elitpan-Serisi-317.jpg',
    badge: 'Premium',
    badgeGold: false,
    title: 'Elitpan Kapılar',
    desc: 'UV boyalı, parlak MDF yüzeyli premium kapılar. İhracat kalitesi.',
    tags: ['UV Boyalı', 'Parlak Yüzey', 'İhracat Kalitesi'],
  },
  {
    slug: '/hastane-kapilari',
    img: '/assets/img/categories/hastane-kapilari.webp',
    badge: 'Uzman',
    badgeGold: false,
    title: 'Hastane Kapıları',
    desc: 'Sağlık tesisleri için CE sertifikalı hijyen kapılar.',
    tags: ['CE Sertifikalı', 'Kurşun Seçenek', 'Antimikrobiyal'],
  },
  {
    slug: '/otel-kapilari',
    img: '/assets/img/categories/otel-kapilari.webp',
    badge: 'Otel',
    badgeGold: false,
    title: 'Otel Kapıları',
    desc: 'Yangına dayanıklı, ses yalıtımlı otel kapıları. Toplu fiyatlandırma mevcut.',
    tags: ['Ses Yalıtımı', 'Yangın Dayanımı', 'Toplu Fiyat'],
  },
  {
    slug: '/yangina-dayanikli-kapilar',
    img: '/assets/img/categories/yangina-dayanikli-kapilar.webp',
    badge: 'Sertifikalı',
    badgeGold: false,
    title: 'Yangına Dayanıklı Kapılar',
    desc: 'CE sertifikalı EI30–EI90 yangın kapıları. Uluslararası standartlara uygun.',
    tags: ['EI30–EI90', 'CE Sertifikalı', 'Yönetmelik Uyumlu'],
  },
];

const trustItems = [
  { icon: '🏭', label: 'Direkt Fabrika',  desc: 'Aracısız, üreticiden doğrudan satış' },
  { icon: '📋', label: 'CE + ISO 9001',   desc: 'Her siparişte sertifikalı kalite güvencesi' },
  { icon: '📦', label: 'Min. 50 Adet',    desc: 'Düşük MOQ ile test imkânı' },
  { icon: '🌍', label: '25+ Ülke',        desc: '2010\'dan bu yana kanıtlanmış ihracat deneyimi' },
  { icon: '🚢', label: 'FOB / CIF',       desc: 'Esnek Incoterm seçenekleri' },
  { icon: '⚡', label: '24s Yanıt',        desc: 'Bir iş günü içinde fiyat teklifi' },
];
---

<I18nLayout
  title="İç Kapı Üreticisi Kayseri | Toptan Satış & İhracat | CihanPan Door"
  description="Kayseri'de 1995'ten bu yana faaliyet gösteren CE & ISO 9001 sertifikalı kapı üreticisi. PVC, Laminoks, MDF kapılar. Toptan satış ve ihracat."
  keywords="kapı üreticisi kayseri, iç kapı toptan satış, PVC kapı üreticisi, laminoks kapı fabrika, kapı ihracat türkiye"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="CihanPan Door — Türkiye'nin Kapı Üreticisi"
  ogDescription="Kayseri'den dünyaya, 1995'ten bu yana kaliteli kapı üretimi ve ihracatı."
  ogImage="/assets/img/og/home-og.webp"
>
  <I18nHeader />

  <main class="hp" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="hp-hero" aria-labelledby="hero-h1">
      <div class="hp-hero__bg" aria-hidden="true">
        <div class="hp-hero__img"></div>
        <div class="hp-hero__overlay"></div>
        <div class="hp-hero__glow"></div>
      </div>

      <div class="hp-wrap hp-hero__inner">
        <div class="hp-hero__copy">
          <span class="hp-eyebrow">
            <span class="hp-eyebrow__line"></span>
            Kayseri · 1995'ten Bu Yana
          </span>

          <h1 class="hp-hero__h1" id="hero-h1">
            Türkiye'nin Önde Gelen<br /><em>İç Kapı Üreticisi</em><br />ve İhracatçısı
          </h1>

          <p class="hp-hero__lead">
            CE, TSE ve ISO 9001 sertifikalı. PVC, MDF ve Laminoks iç kapılar. Toptan satış ve ihracat — yılda 600.000 adet üretim kapasitesi.
          </p>

          <div class="hp-hero__tags">
            <span class="hp-htag">✓ CE Sertifikalı</span>
            <span class="hp-htag">✓ ISO 9001</span>
            <span class="hp-htag">✓ Min. 50 Adet</span>
            <span class="hp-htag">✓ İhracata Hazır</span>
          </div>

          <div class="hp-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--gold">
              Teklif Al
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#products" class="hp-btn hp-btn--ghost">
              Ürünleri Gör
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="hp-wrap">
        <div class="hp-statsbar">
          <div class="hp-sitem">
            <strong>30<sup>+</sup></strong>
            <span>Yıl Üretim</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>600K</strong>
            <span>Adet / Yıl</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>25<sup>+</sup></strong>
            <span>İhracat Ülkesi</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>15K m²</strong>
            <span>Fabrika Alanı</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TRUST BAR
    ══════════════════════════════════════════ -->
    <section class="hp-trust" aria-label="Neden biz">
      <div class="hp-wrap">
        <div class="hp-trust__grid">
          {trustItems.map(item => (
            <div class="hp-trust__item">
              <span class="hp-trust__icon" aria-hidden="true">{item.icon}</span>
              <div>
                <strong>{item.label}</strong>
                <p>{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         PRODUCTS
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" id="products" aria-labelledby="products-h2">
      <div class="hp-wrap">
        <div class="hp-head">
          <span class="hp-tag">Ürün Gamımız</span>
          <h2 id="products-h2">Kapı Koleksiyonu — Fabrikadan Doğrudan</h2>
          <p>Tüm ürün serileri CE ve ISO 9001 sertifikalı. Toptan satış ve ihracat için hazır.</p>
        </div>

        <div class="hp-products">
          {categories.map((cat, i) => (
            <article class={`hp-product ${cat.featured ? 'hp-product--featured' : ''}`}>
              <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__img-wrap" tabindex="-1" aria-hidden="true">
                <img
                  src={cat.img}
                  alt={cat.title}
                  width="480"
                  height="360"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class={`hp-product__badge ${cat.badgeGold ? 'hp-product__badge--gold' : ''}`}>{cat.badge}</span>
              </a>
              <div class="hp-product__body">
                <h3><a href={getLocalizedRoute(cat.slug, lang)}>{cat.title}</a></h3>
                <p>{cat.desc}</p>
                <ul class="hp-product__tags">
                  {cat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__cta">
                  İncele & Teklif Al
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SOLUTIONS
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--navy" aria-labelledby="solutions-h2">
      <div class="hp-wrap">
        <div class="hp-head hp-head--light">
          <span class="hp-tag">Nasıl Çalışırız</span>
          <h2 id="solutions-h2">Toptan Satış & İhracat Hizmetleri</h2>
          <p>Bayiler, inşaatçılar ve ihracatçılar için üç esnek tedarik modeli</p>
        </div>

        <div class="hp-solutions">
          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">01</div>
            <div class="hp-sol__icon" aria-hidden="true">🏭</div>
            <h3>Toptan Siparişler</h3>
            <p>Minimum 50 adet. Standart boyutlar için sabit fiyatlar. 200+ adet için hacim indirimleri.</p>
            <ul>
              <li>Min. 50 adet</li>
              <li>Hacim indirimleri mevcut</li>
              <li>CE/ISO belgeler dahil</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">02</div>
            <div class="hp-sol__icon" aria-hidden="true">🌍</div>
            <h3>İhracat Hizmetleri</h3>
            <p>Tam ihracat belgelendirmesi. FOB / CIF / EXW Incoterm seçenekleri.</p>
            <ul>
              <li>FOB / CIF / EXW seçenekleri</li>
              <li>Tam belgelendirme</li>
              <li>Nakliye koordinasyonu</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">03</div>
            <div class="hp-sol__icon" aria-hidden="true">🏗️</div>
            <h3>Proje Çözümleri</h3>
            <p>Standart dışı boyutlar, özel etiket, özel yüzeyler. Otel, hastane ve konut projeleri için.</p>
            <ul>
              <li>Özel boyut ve yüzey</li>
              <li>Özel etiket mevcut</li>
              <li>Ölçü desteği</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ABOUT
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" aria-labelledby="about-h2">
      <div class="hp-wrap hp-about">

        <div class="hp-about__text">
          <span class="hp-tag">Hakkımızda</span>
          <h2 id="about-h2">Kayseri'de CE ve ISO 9001 Sertifikalı İç Kapı Fabrikası</h2>

          <p>1995 yılında kurulan <strong>CihanPan Door</strong>, Kayseri Organize Sanayi Bölgesi'ndeki 15.000 m² üretim tesisinde yılda <strong>600.000 iç kapı seti</strong> üretmektedir. PVC, Laminoks, Elitpan (MDF), hastane, otel ve yangına dayanıklı kapı serileriyle Türkiye'nin önde gelen kapı üreticilerindendir.</p>
          <h3>Neden CihanPan Door?</h3>
          <p>CE, TSE ve ISO 9001 sertifikalarıyla desteklenen üretim sürecimiz, her siparişte tutarlı kalite güvencesi sağlar. Minimum 50 adetlik toptan siparişler, özel boyut ve yüzey seçenekleri, tam ihracat belgelendirmesi sunuyoruz.</p>

          <div class="hp-about__cta">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--navy">
              Toptan Fiyat Al
            </a>
            <a href="https://www.cihanpandoor.com/E-Katalog.pdf" target="_blank" rel="noopener noreferrer" class="hp-btn hp-btn--outline-dark">
              Kataloğu İndir (PDF)
            </a>
          </div>
        </div>

        <aside class="hp-about__stats" aria-label="Firma istatistikleri">
          <div class="hp-kpi">
            <strong>1995</strong>
            <span>Kuruluş Yılı</span>
          </div>
          <div class="hp-kpi">
            <strong>600K</strong>
            <span>Adet / Yıl</span>
          </div>
          <div class="hp-kpi">
            <strong>25<sup>+</sup></strong>
            <span>İhracat Ülkesi</span>
          </div>
          <div class="hp-kpi">
            <strong>150<sup>+</sup></strong>
            <span>Çalışan</span>
          </div>
          <div class="hp-kpi">
            <strong>15K m²</strong>
            <span>Fabrika Alanı</span>
          </div>
        </aside>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="hp-cta" aria-labelledby="cta-h2">
      <div class="hp-cta__glow" aria-hidden="true"></div>
      <div class="hp-wrap hp-cta__inner">
        <div class="hp-cta__text">
          <span class="hp-tag hp-tag--gold">Hemen Başlayın</span>
          <h2 id="cta-h2">Toptan Kapı Teklifi Alın</h2>
          <p>Kapı türü, adet ve teslimat bilgilerinizi paylaşın. 24 saat içinde fiyat teklifi alın.</p>
        </div>
        <div class="hp-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--gold">
            Ücretsiz Teklif Al
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/hakkimizda', lang)} class="hp-btn hp-btn--ghost">
            Hakkımızda
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  .hp {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  .hp-wrap {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }

  .hp-sec          { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .hp-sec--white   { background: var(--white); }
  .hp-sec--navy    { background: var(--navy); }
  .hp-sec--cream   { background: var(--cream); }

  .hp-head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .hp-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.7rem;
    line-height: 1.2;
  }
  .hp-head p {
    color: var(--slate);
    font-size: 1rem;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.7;
  }
  .hp-head--light h2 { color: var(--white); }
  .hp-head--light p  { color: rgba(255,255,255,0.5); }

  .hp-tag {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .hp-tag--gold { color: rgba(201,168,76,0.9); }

  .hp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s, color 0.2s;
  }
  .hp-btn--gold { background: var(--gold); color: var(--navy); font-weight: 700; }
  .hp-btn--gold:hover { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .hp-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .hp-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }
  .hp-btn--navy { background: var(--navy); color: var(--white); font-weight: 700; }
  .hp-btn--navy:hover { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,0.3); }
  .hp-btn--outline-dark { background: transparent; color: var(--navy); border: 1.5px solid var(--bdr); }
  .hp-btn--outline-dark:hover { border-color: var(--navy); transform: translateY(-2px); }

  .hp-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 70px;
    overflow: hidden;
  }
  .hp-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hp-hero__img {
    position: absolute; inset: 0;
    background-image: url('/assets/img/hero/door-factory.webp');
    background-size: cover;
    background-position: center;
  }
  .hp-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.93) 0%, rgba(15,35,71,0.82) 60%, rgba(15,35,71,0.6) 100%);
  }
  .hp-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 40%, rgba(201,168,76,0.08) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 15% 70%, rgba(30,74,138,0.35) 0%, transparent 60%);
  }
  .hp-hero__inner {
    position: relative; z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    padding-top: clamp(3rem, 8vw, 5rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }
  .hp-hero__copy { max-width: 640px; flex: 1; }

  .hp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.4rem;
