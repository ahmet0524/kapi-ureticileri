---
// src/pages/tr/kapi-malzemeleri.astro
// TR → /tr/kapi-malzemeleri
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';

const lang  = 'tr';
const isRTL = false;

const colourCount = '50+';
const modelCount  = '350+';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const currentUrl = `${baseUrl}/tr/kapi-malzemeleri`;

// ── PAGE META ─────────────────────────────────────────────────────────
const meta = {
  title:         'Kapı Üretim Malzemeleri — İç Yapı, Yüzey & Aksesuar | CihanPan Door',
  description:   'CihanPan Door üretiminde kullanılan tüm malzemeleri keşfedin: petek & yarı masif özekler, PVC ve Laminoks yüzey kaplamaları, kulplar, menteşeler ve akustik contalar. Kayseri, Türkiye.',
  keywords:      'kapı üretim malzemeleri, petek özek kapı, yarı masif kapı, PVC kapı yüzeyi, laminoks HPL, toptan kapı menteşesi, kapı kolu Türkiye',
  ogTitle:       'Kapı Malzemeleri Rehberi | CihanPan Door',
  ogDescription: "Kapılarımızın içindeki her şey — petek özekler, HPL kaplamalar, kulplar, menteşeler ve contalar. Kayseri'den fabrika doğrudan toptan satış.",
};

// ── SCHEMA ────────────────────────────────────────────────────────────
const materialsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": meta.title,
  "description": meta.description,
  "url": currentUrl,
  "inLanguage": "tr-TR",
  "publisher": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl }
};

const faqData = [
  { q: 'İç kapılarda petek özek nedir?',
    a: 'Petek özek, altıgen hücrelerden oluşan hafif bir iç yapıdır. Yüksek mukavemet/ağırlık oranı, mükemmel ses yalıtımı ve nem direnci sağlarken kapıyı hafif ve kolay monte edilebilir tutar.' },
  { q: 'Petek Özek 1 ile Petek Özek 2 arasındaki fark nedir?',
    a: 'Petek Özek 1, konut kapıları için ideal olan standart hafif özekimizdir. Petek Özek 2, daha iyi akustik performans ve daha yüksek sertlik sunan daha yoğun hücreli yapıya sahiptir.' },
  { q: 'Yarı Masif Ahşap nedir ve ne zaman kullanılır?',
    a: 'Yarı masif ahşap, doğal ahşap çerçeveleri iç dolgu ile birleştirir. Yüksek kaliteli koleksiyonlarımızda ve üstün menteşe tutma gücü ya da premium sağlamlık hissi gereken yerlerde kullanılır.' },
  { q: 'PVC ve Laminoks yüzeyler arasındaki fark nedir?',
    a: 'PVC, MDF üzerine vakumla preslenen su geçirmez bir termoplastik filmdir; banyolar için idealdir. Laminoks (HPL melamin), daha yüksek çizilme ve darbe direnci ile premium bir estetik sunan yüksek basınçlı bir laminattır.' },
  { q: 'Aksesuar siparişini kapılardan bağımsız verebilir miyim?',
    a: 'Evet. Kulplar, kilit setleri, menteşeler ve contaları hem kapılarımızla entegre hem de toplu proje siparişleri için bağımsız aksesuar olarak tedarik ediyoruz. Fiyatlandırma ve MOQ için bizimle iletişime geçin.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${baseUrl}/tr` },
    { "@type": "ListItem", "position": 2, "name": "Ürünler",   "item": `${baseUrl}/tr/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "Kapı Malzemeleri", "item": currentUrl },
  ]
};

const allSchemas = [materialsSchema, faqSchema, breadcrumbSchema];

// ── MATERIALS DATA ────────────────────────────────────────────────────
const materials = [
  {
    category: 'core', img: '/assets/img/materials/honeycomb-1-core.webp',
    title: 'Petek Özek 1', subtitle: 'Standart Hafif Özek',
    desc: 'Yüksek mukavemetli, hafif petek iç yapısı. Altıgen hücre tasarımı, ağırlığı minimize ederken rijitliği maksimize eder — tüm standart kapı hatlarında kapı dayanıklılığını artırır ve kalıcı performans sağlar.',
    tags: ['Hafif Yapı', 'Yüksek Mukavemet', 'Ses Yalıtımı', 'Neme Dayanıklı'],
    specs: [['Hücre Boyutu', '15-20 mm'], ['Özek Yoğunluğu', 'Standart'], ['Kullanım Alanı', 'Konut kapıları']],
  },
  {
    category: 'core', img: '/assets/img/materials/honeycomb-2-core.webp',
    title: 'Petek Özek 2', subtitle: 'Yoğun Hücreli Premium Özek',
    desc: 'Gelişmiş üretim teknolojisiyle yoğun hücreli petek yapısı. Üstün akustik performans, daha yüksek sertlik ve geliştirilmiş dayanıklılık — performansın vazgeçilmez olduğu premium ve proje sınıfı kapı hatlarımızda kullanılır.',
    tags: ['Yoğun Hücre Yapısı', 'Üstün Dayanıklılık', 'Gelişmiş Akustik', 'Çevre Dostu'],
    specs: [['Hücre Boyutu', '10-13 mm'], ['Özek Yoğunluğu', 'Yüksek'], ['Kullanım Alanı', 'Premium & proje kapıları']],
  },
  {
    category: 'core', img: '/assets/img/materials/semi-solid-core.webp',
    title: 'Yarı Masif Ahşap', subtitle: 'Doğal Ahşap Sağlamlığı',
    desc: 'Doğal ahşap çerçeveler ve iç dolgu kombinasyonu — pratik bir ağırlıkta gerçek ahşabın sağlamlığı. Olağanüstü menteşe tutma gücü ve premium his, yüksek kaliteli kapı koleksiyonlarımızda kullanılır.',
    tags: ['Doğal Ahşap', 'Yüksek Sağlamlık', 'Premium Kalite', 'Uzun Ömürlü'],
    specs: [['Malzeme', 'Doğal çam / kavak'], ['Ağırlık', 'Orta-ağır'], ['Kullanım Alanı', 'Yüksek kaliteli koleksiyonlar']],
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'PVC Yüzey Malzemeleri', subtitle: 'Su Geçirmez Termoplastik Laminat',
    desc: 'MDF yüzeye vakumla preslenen su geçirmez PVC film. Neme karşı yüksek direnç, kolay temizlik ve geniş renk & ahşap desen seçenekleri — ıslak alanlar için ekonomik tercih.',
    tags: ['Su Geçirmez', 'Kolay Temizlik', 'Geniş Renk Yelpazesi', 'Ekonomik'],
    specs: [['Kalınlık', '0.18-0.25 mm'], ['Yüzey', 'Mat / Parlak / Ahşap Desen'], ['Uygulama', 'Vakum pres']],
    link: '/tr/pvc-kapilar', linkLabel: 'PVC Kapıları Görüntüle',
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'Laminoks Yüzey Malzemeleri', subtitle: 'Yüksek Basınçlı Melamin Laminat (HPL)',
    desc: "MDF üzerine yapıştırılan yüksek basınçlı melamin (HPL) laminat. Standart PVC'ye kıyasla üstün çizilme ve darbe direnci — daha zengin desenler, mat veya parlak seçenekler ve premium estetik.",
    tags: ['Çizilmez', 'Darbeye Dayanıklı', 'Zengin Desenler', 'Mat & Parlak Seçenek'],
    specs: [['Kalınlık', '0.6-1.0 mm'], ['Yüzey', 'Mat / Yüksek Parlak / Dokulu'], ['Uygulama', 'Soğuk / sıcak pres']],
    link: '/tr/laminoks-kapilar', linkLabel: 'Laminoks Kapıları Görüntüle',
  },
  {
    category: 'accessories', img: '/assets/img/materials/door-handles.webp',
    title: 'Kapı Kolları & Kilit Sistemleri', subtitle: 'Paslanmaz Çelik & Pirinç Donanım',
    desc: 'Paslanmaz çelik ve pirinçten premium kapı kolları. Ergonomik tasarımlar, çoklu yüzey seçenekleri — krom, mat siyah, altın, saten — her uygulama için entegre güvenlik kilit silindiri.',
    tags: ['304 Paslanmaz Çelik', 'Ergonomik Tasarım', 'Çoklu Yüzey', 'Güvenlik Kilidi'],
    specs: [['Malzeme', 'SS304 / Pirinç'], ['Yüzeyler', 'Krom, Mat Siyah, Altın, Saten'], ['Standart', 'EN 1906']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/hinges.webp',
    title: 'Menteşeler & Bağlantı Elemanları', subtitle: 'Sessiz, Ağır Hizmet Tipi Menteşe Sistemleri',
    desc: 'Yüksek kaliteli çelikten hassas mühendislik menteşe sistemleri. Sessiz çalışma, kolay üç boyutlu ayar ve uzun servis ömrü — tüm CihanPan kapı ağırlıkları ve profilleriyle uyumlu.',
    tags: ['Sessiz Çalışma', 'Yüksek Dayanıklılık', 'Kolay 3D Ayar', 'Korozyona Dayanıklı'],
    specs: [['Malzeme', 'Çelik / çinko alaşım'], ['Yük Kapasitesi', "120 kg'a kadar"], ['Yüzey', 'Nikel / krom / beyaz']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/seals.webp',
    title: 'Contalar & Hava Sızdırmazlık Sistemleri', subtitle: 'Hava Geçirmez Akustik Sızdırmazlık',
    desc: 'Hava sızıntısını önleyen, ses iletimini azaltan ve enerji verimliliğini artıran yüksek kaliteli TPE ve EPDM contalar. Konut konforu ve akustik kapı montajları için vazgeçilmez.',
    tags: ['Hava Geçirmez', 'Akustik Azaltma', 'Enerji Tasarrufu', 'UV & Hava Dayanımlı'],
    specs: [['Malzeme', 'TPE / EPDM'], ['Sıcaklık Aralığı', '-30 ile +80 °C'], ['Sıkıştırma Seti', '< %20']],
  },
];

// ── COMPARISON TABLE ──────────────────────────────────────────────────
const cmpHeaders = ['Özellik', 'Petek Özek 1', 'Petek Özek 2', 'Yarı Masif Ahşap'];

const comparisonRows = [
  ['Ağırlık',        'Hafif',             'Orta-hafif',        'Orta-ağır'],
  ['Mukavemet',      '3/5',               '4/5',               '5/5'],
  ['Ses Yalıtımı',   '3/5',               '4/5',               '4/5'],
  ['Nem Direnci',    '4/5',               '4/5',               '3/5'],
  ['Çevre Dostu',    'Evet',              'Evet',              'Kısmen'],
  ['Kullanım Alanı', 'Konut / Ekonomik',  'Premium / Akustik', 'Yüksek Kalite / Masif'],
];

// ── UI STRINGS ────────────────────────────────────────────────────────
const ui = {
  filterAll:         'Tümü',
  filterCore:        'Özek Malzemeler',
  filterSurface:     'Yüzey Malzemeleri',
  filterAccessories: 'Aksesuarlar',
  catCore:           'Özek',
  catSurface:        'Yüzey',
  catAccessory:      'Aksesuar',
  heroEyebrow:       'Üretim Kalitesi · Kayseri, Türkiye',
  heroH1a:           'Her CihanPan Kapısının',
  heroH1b:           'İçinde Neler Var',
  heroLead:          'Petek özekten yüzey laminatına ve aradaki her menteşeye kadar — kapı kalitemizi tanımlayan malzemelere eksiksiz rehber.',
  heroCert1:         'ISO 9001 Sertifikalı',
  heroCert2:         'CE Uyumlu',
  heroCert3:         'Fabrika Doğrudan',
  heroCert4:         'Toptan Fiyatlar',
  heroBtn1:          'Malzemeleri Keşfet',
  heroBtn2:          'Teklif Al',
  coreTypes:         'Özek Türleri',
  surfaceLines:      'Yüzey Hatları',
  colourOptions:     'Renk Seçeneği',
  doorModels:        'Kapı Modeli',
  introTag:          'Felsefemiz',
  introH2:           'Kalite İçeriden Başlar',
  introP1:           "Bir kapı, ancak parçalarının toplamı kadar iyidir. CihanPan Door'da her katmanı — iç özek, yüzey laminatı ve donanım — Kayseri fabrikamızda kontrol ediyoruz. Her malzeme, üretime girmeden önce CE ve ISO 9001 standartlarını karşılamak üzere seçilip test edilmektedir.",
  introP2:           'Kapılarımızın içinde ne olduğunu anlamak, her proje için — konut, otelcilik, sağlık veya ticari olsun — doğru ürünü belirlemenize yardımcı olur.',
  pillar1Title:      'Özek Yapı',
  pillar1Desc:       'Ağırlığı, mukavemeti ve ses yalıtımını belirler.',
  pillar2Title:      'Yüzey Kaplaması',
  pillar2Desc:       'Estetik, dayanıklılık ve nem direncini belirler.',
  pillar3Title:      'Donanım',
  pillar3Desc:       'Kulplar, menteşeler ve contalar performansı tamamlar.',
  matTag:            'Tam Malzeme Yelpazesi',
  matH2:             'Kapılarımızda Kullanılan Malzemeler',
  matSubtitle:       'Her bileşeni keşfetmek için kategoriye göre filtreleyin — iç yapıdan yüzey ve donanıma.',
  cmpTag:            'Karşılaştırmalı',
  cmpH2:             'Özek Malzeme Karşılaştırması',
  cmpSubtitle:       'Proje ihtiyaçlarınız için doğru iç yapıyı seçin.',
  faqTag:            'Sık Sorulan Sorular',
  faqH2:             'Sıkça Sorulan Sorular',
  ctaTag:            'Sipariş Vermeye Hazır mısınız?',
  ctaH2:             'Her Malzeme veya Kapı için\nFabrika Fiyatı Alın',
  ctaP:              'Proje özelliklerinizi paylaşın — kapı tipi, özek tercihi, yüzey kaplaması, miktar ve teslimat yeri. CE/ISO belgeleriyle birlikte tam fiyatlandırmayla 24 saat içinde yanıtlıyoruz.',
  ctaBtn1:           'Ücretsiz Teklif Al',
  ctaBtn2:           'Tüm Ürünleri Gör',
  contactHref:       '/tr/iletisim',
  productsHref:      '/tr/urunlerimiz',
};
---

<I18nLayout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage="/assets/img/og/door-materials-og.webp"
  lang={lang}
  dir="ltr"
>
  <I18nHeader />

  <main class="dm" id="main-content" dir="ltr">

    <!-- HERO -->
    <section class="dm-hero" aria-labelledby="dm-h1">
      <div class="dm-hero__bg" aria-hidden="true">
        <div class="dm-hero__overlay"></div>
      </div>
      <div class="dm-wrap dm-hero__inner">
        <div class="dm-hero__content">
          <span class="dm-eyebrow">
            <span class="dm-eyebrow__line"></span>
            {ui.heroEyebrow}
          </span>
          <h1 class="dm-hero__h1" id="dm-h1">
            <em>{ui.heroH1a}</em><br/>{ui.heroH1b}
          </h1>
          <p class="dm-hero__lead">{ui.heroLead}</p>
          <div class="dm-hero__tags">
            <span class="dm-htag">✓ {ui.heroCert1}</span>
            <span class="dm-htag">✓ {ui.heroCert2}</span>
            <span class="dm-htag">✓ {ui.heroCert3}</span>
            <span class="dm-htag">✓ {ui.heroCert4}</span>
          </div>
          <div class="dm-hero__cta">
            <a href="#materials" class="dm-btn dm-btn--gold">{ui.heroBtn1}</a>
            <a href={ui.contactHref} class="dm-btn dm-btn--ghost">{ui.heroBtn2}</a>
          </div>
        </div>
        <div class="dm-hero__stats">
          <div class="dm-stat"><span class="dm-stat__num">3</span><span class="dm-stat__label">{ui.coreTypes}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">2</span><span class="dm-stat__label">{ui.surfaceLines}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{colourCount}</span><span class="dm-stat__label">{ui.colourOptions}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{modelCount}</span><span class="dm-stat__label">{ui.doorModels}</span></div>
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="dm-section dm-section--light">
      <div class="dm-wrap dm-intro">
        <div class="dm-intro__text">
          <span class="dm-tag">{ui.introTag}</span>
          <h2>{ui.introH2}</h2>
          <p>{ui.introP1}</p>
          <p>{ui.introP2}</p>
        </div>
        <div class="dm-intro__pillars">
          <div class="dm-pillar"><span class="dm-pillar__icon">🏗️</span><div><strong>{ui.pillar1Title}</strong><p>{ui.pillar1Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🎨</span><div><strong>{ui.pillar2Title}</strong><p>{ui.pillar2Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🔩</span><div><strong>{ui.pillar3Title}</strong><p>{ui.pillar3Desc}</p></div></div>
        </div>
      </div>
    </section>

    <!-- MATERIALS GRID -->
    <section class="dm-section" id="materials" aria-labelledby="dm-mat-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.matTag}</span>
          <h2 id="dm-mat-h2">{ui.matH2}</h2>
          <p class="dm-section__sub">{ui.matSubtitle}</p>
        </div>
        <div class="dm-filters" role="tablist">
          <button class="dm-filter dm-filter--active" data-filter="all" role="tab" aria-selected="true">{ui.filterAll}</button>
          <button class="dm-filter" data-filter="core" role="tab" aria-selected="false">{ui.filterCore}</button>
          <button class="dm-filter" data-filter="surface" role="tab" aria-selected="false">{ui.filterSurface}</button>
          <button class="dm-filter" data-filter="accessories" role="tab" aria-selected="false">{ui.filterAccessories}</button>
        </div>
        <div class="dm-grid">
          {materials.map(m => (
            <article class="dm-card" data-category={m.category}>
              <div class="dm-card__img">
                <img src={m.img} alt={m.title} loading="lazy" width="400" height="200"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="dm-card__placeholder">🚪</div>
                <span class="dm-card__cat-badge">
                  {m.category === 'core' ? ui.catCore : m.category === 'surface' ? ui.catSurface : ui.catAccessory}
                </span>
              </div>
              <div class="dm-card__body">
                <p class="dm-card__subtitle">{m.subtitle}</p>
                <h3>{m.title}</h3>
                <p class="dm-card__desc">{m.desc}</p>
                <ul class="dm-card__tags">
                  {m.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <table class="dm-card__specs">
                  <tbody>
                    {m.specs.map(([k,v]) => (
                      <tr><th scope="row">{k}</th><td>{v}</td></tr>
                    ))}
                  </tbody>
                </table>
                {m.link && (
                  <a href={m.link} class="dm-card__link">{m.linkLabel} →</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON TABLE -->
    <section class="dm-section dm-section--light" aria-labelledby="dm-cmp-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.cmpTag}</span>
          <h2 id="dm-cmp-h2">{ui.cmpH2}</h2>
          <p class="dm-section__sub">{ui.cmpSubtitle}</p>
        </div>
        <div class="dm-table-wrap">
          <table class="dm-cmp-table">
            <thead>
              <tr>{cmpHeaders.map(h => <th scope="col">{h}</th>)}</tr>
            </thead>
            <tbody>
              {comparisonRows.map(row => (
                <tr>
                  {row.map((cell, i) => i === 0
                    ? <td class="dm-cmp-prop">{cell}</td>
                    : <td>{cell}</td>
                  )}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="dm-section" aria-labelledby="dm-faq-h2">
      <div class="dm-wrap dm-faq-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.faqTag}</span>
          <h2 id="dm-faq-h2">{ui.faqH2}</h2>
        </div>
        <div class="dm-faqs">
          {faqData.map(f => (
            <details class="dm-faq">
              <summary class="dm-faq__q">
                {f.q}
                <svg class="dm-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="dm-faq__a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="dm-cta" aria-labelledby="dm-cta-h2">
      <div class="dm-cta__glow" aria-hidden="true"></div>
      <div class="dm-wrap dm-cta__inner">
        <div class="dm-cta__text">
          <span class="dm-tag dm-tag--light">{ui.ctaTag}</span>
          <h2 id="dm-cta-h2">{ui.ctaH2}</h2>
          <p>{ui.ctaP}</p>
        </div>
        <div class="dm-cta__btns">
          <a href={ui.contactHref}  class="dm-btn dm-btn--gold">{ui.ctaBtn1}</a>
          <a href={ui.productsHref} class="dm-btn dm-btn--ghost">{ui.ctaBtn2}</a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  :root {
    --navy:   #0f2347;
    --gold:   #c9a84c;
    --white:  #ffffff;
    --cream:  #f8f6f1;
    --text:   #1a1a2e;
    --body:   #4a4a6a;
    --slate:  #6b7280;
    --bdr:    #e5e0d8;
    --radius: 12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .dm-wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .dm-section { padding: clamp(4rem, 8vw, 6rem) 0; }
  .dm-section--light { background: var(--cream); }
  .dm-section__hd { text-align: center; margin-bottom: 3rem; }
