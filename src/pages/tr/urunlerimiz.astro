---
// src/pages/urunlerimiz.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../../i18n/utils';
import Breadcrumbs from '../../components/I18nBreadcrumbs.astro';

// Dynamic URL'ler için base setup
const baseUrl = 'https://kapi-ureticileri.vercel.app';
const currentUrl = `${baseUrl}${Astro.url.pathname}`;

const breadcrumbItems = [
  { name: "Ana Sayfa", href: "/" },
  { name: "Ürünlerimiz", href: "/urunlerimiz" }
];

// CollectionPage Schema - Detaylı
const productsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Ürünlerimiz - İç Oda Kapıları ve Malzemeler",
  "description": "Kayseri'den üretilen kaliteli iç oda kapıları ve malzemeleri. PVC, Laminoks, Elitpan yüzey malzemeleri, honeycomb core, kapı aksesuarları. 350+ model, CE belgeli, 5 yıl garanti.",
  "url": currentUrl,
  "inLanguage": "tr-TR",
  "mainEntity": {
    "@type": "ItemList",
    "name": "Ürün Kategorileri",
    "numberOfItems": 7,
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Product",
          "name": "PVC Kapılar",
          "description": "Su geçirmez antibakteriyel PVC kapılar. 247 model.",
          "url": `${baseUrl}/pvc-kapilar`,
          "category": "İç Oda Kapısı"
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Product",
          "name": "Laminoks Kapılar",
          "description": "MDF yüzeyli laminoks kapılar. 80+ model.",
          "url": `${baseUrl}/laminoks-kapilar`,
          "category": "İç Oda Kapısı"
        }
      },
      {
        "@type": "ListItem",
        "position": 3,
        "item": {
          "@type": "Product",
          "name": "Elitpan Kapılar",
          "description": "UV kaplama Elitpan kapılar. 26+ model.",
          "url": `${baseUrl}/elitpan-kapilar`,
          "category": "İç Oda Kapısı"
        }
      },
      {
        "@type": "ListItem",
        "position": 4,
        "item": {
          "@type": "Product",
          "name": "Hastane Kapıları",
          "description": "Hijyenik antibakteriyel hastane kapıları.",
          "url": `${baseUrl}/hastane-kapilar`,
          "category": "Özel Kapılar"
        }
      },
      {
        "@type": "ListItem",
        "position": 5,
        "item": {
          "@type": "Product",
          "name": "Otel Kapıları",
          "description": "Ses yalıtımlı premium otel kapıları.",
          "url": `${baseUrl}/otel-kapilar`,
          "category": "Özel Kapılar"
        }
      },
      {
        "@type": "ListItem",
        "position": 6,
        "item": {
          "@type": "Product",
          "name": "Yangına Dayanıklı Kapılar",
          "description": "30-60 dakika yangın dayanımlı kapılar.",
          "url": `${baseUrl}/yangina-dayanikli-kapilar`,
          "category": "Özel Kapılar"
        }
      },
      {
        "@type": "ListItem",
        "position": 7,
        "item": {
          "@type": "Product",
          "name": "Kapı Malzemeleri ve Aksesuarlar",
          "description": "Honeycomb core, PVC yüzeyler, kilit sistemleri.",
          "url": currentUrl,
          "category": "Malzemeler"
        }
      }
    ]
  }
};

// FAQ Schema - Ürünler Hakkında
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Hangi kapı modellerini üretiyorsunuz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PVC kapılar (247 model), Laminoks/Melamin kapılar (80+ model), Elitpan kapılar (26+ model), hastane kapıları, otel kapıları, yangına dayanıklı kapılar ve özel tasarım kapılar üretmekteyiz. Toplam 350'den fazla model seçeneği sunuyoruz."
      }
    },
    {
      "@type": "Question",
      "name": "Kapılarda hangi iç materyal kullanılıyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kapılarımızda honeycomb (bal peteği) core, semi solid wood (yarı masif ahşap) ve tam dolgu iç materyal seçenekleri kullanılmaktadır. Honeycomb core hafif, dayanıklı ve ses yalıtımlı özelliklere sahiptir."
      }
    },
    {
      "@type": "Question",
      "name": "PVC ve Laminoks arasındaki fark nedir?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PVC kapılar su geçirmez plastik kaplama ile üretilir ve daha ekonomiktir. Laminoks kapılar ise MDF yüzey üzerine yüksek basınçlı melamin (HPL) kaplama uygulanarak üretilir, çizilmeye karşı daha dayanıklıdır ve premium görünüm sunar."
      }
    },
    {
      "@type": "Question",
      "name": "Kapı aksesuarları nelerdir?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kapı kolları, kilit sistemleri, menteşeler, conta ve fitil sistemleri sunuyoruz. Tüm aksesuarlar paslanmaz çelik veya yüksek kaliteli malzemelerden üretilmiştir. Çeşitli tasarım ve renk seçenekleri mevcuttur."
      }
    },
    {
      "@type": "Question",
      "name": "Özel ölçü kapı üretimi yapıyor musunuz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Evet, standart ölçülerin yanı sıra özel ölçü kapı üretimi de yapmaktayız. Proje bazlı toplu siparişlerde özel tasarım, renk ve ölçü seçenekleri sunuyoruz. Minimum sipariş miktarı için bizimle iletişime geçebilirsiniz."
      }
    },
    {
      "@type": "Question",
      "name": "Ürünleriniz garanti kapsamında mı?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tüm kapı modellerimiz 5 yıl üretici garantisi ile sunulmaktadır. Garanti kapsamında üretim hatalarından kaynaklanan sorunlar, çarpma, renk solması ve kaplama problemleri karşılanır."
      }
    }
  ]
};

// Organization Schema - Detaylı
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CihanPan Door",
  "alternateName": "CihanPan Kapı",
  "url": baseUrl,
  "logo": `${baseUrl}/assets/images/logo/header_logo1.webp`,
  "image": `${baseUrl}/assets/images/fabrika.webp`,
  "description": "Kayseri'den kaliteli iç oda kapısı üreticisi. PVC, Laminoks, Elitpan kapılar. 350+ model, CE belgeli ürünler, B2B toptan satış ve ihracat.",
  "foundingDate": "1995",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
    "addressLocality": "Kayseri",
    "addressRegion": "Kayseri",
    "postalCode": "38070",
    "addressCountry": "TR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "38.7312",
    "longitude": "35.4787"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+90-544-169-0038",
      "contactType": "Sales",
      "availableLanguage": ["Turkish", "English", "German", "Arabic"],
      "areaServed": ["TR", "EU", "ME"]
    }
  ],
  "areaServed": [
    {
      "@type": "Country",
      "name": "Turkey"
    },
    {
      "@type": "Place",
      "name": "Europe"
    },
    {
      "@type": "Place",
      "name": "Middle East"
    }
  ],
  "serviceType": [
    "İç Oda Kapısı Üretimi",
    "PVC Kapı Üretimi",
    "Laminoks Kapı Üretimi",
    "Elitpan Kapı Üretimi",
    "Hastane Kapısı Üretimi",
    "Otel Kapısı Üretimi",
    "Yangın Kapısı Üretimi",
    "Özel Tasarım Kapı Üretimi",
    "Toptan Kapı Satışı",
    "İhracat"
  ],
  "makesOffer": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Product",
        "name": "PVC Kapılar"
      },
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Product",
        "name": "Laminoks Kapılar"
      },
      "availability": "https://schema.org/InStock"
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Product",
        "name": "Elitpan Kapılar"
      },
      "availability": "https://schema.org/InStock"
    }
  ],
  "sameAs": [
    "https://www.cihanpandoor.com",
    "https://www.facebook.com/cihanpandoor",
    "https://www.instagram.com/cihanpan_door",
    "https://www.linkedin.com/company/cihanpan-door"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "247",
    "bestRating": "5",
    "worstRating": "1"
  }
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.href ? `${baseUrl}${item.href}` : currentUrl
  }))
};

// WebPage Schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ürünlerimiz - CihanPan Door",
  "description": "350+ kapı modeli ve malzeme seçeneği. PVC, Laminoks, Elitpan kapılar. Hastane, otel ve yangın kapıları.",
  "url": currentUrl,
  "inLanguage": "tr-TR",
  "isPartOf": {
    "@type": "WebSite",
    "name": "CihanPan Door",
    "url": baseUrl
  },
  "breadcrumb": breadcrumbSchema
};

// ✅ CRITICAL: allSchemas array
const allSchemas = [productsSchema, faqSchema, organizationSchema, breadcrumbSchema, webPageSchema];
---
<I18nLayout
  title="Ürünlerimiz | CihanPan Door İç Kapı Malzemeleri ve Aksesuarlar"
  description="Kayseri'nin kaliteli iç oda kapıları için kullanılan malzemeler ve aksesuarlar. PVC, Laminoks yüzey malzemeleri, honeycomb core, aksesuarlar."
  keywords="kapı malzemeleri, pvc yüzey, laminoks kaplama, honeycomb core, kapı aksesuarları, kayseri kapı üreticisi"
  canonical={currentUrl}
  ogImage="/assets/img/og/urunlerimiz-og.webp"
  ogTitle="Ürünlerimiz | CihanPan Door Malzemeler ve Aksesuarlar"
  ogDescription="Kaliteli iç oda kapıları için kullanılan malzemeler ve aksesuarlar. PVC, Laminoks yüzey malzemeleri."
  ogType="website"
  ogUrl={currentUrl}
  twitterCard="summary_large_image"
  twitterTitle="Ürünlerimiz | CihanPan Door"
  twitterDescription="İç oda kapıları malzemeleri ve aksesuarlar koleksiyonu."
  twitterImage="/assets/img/og/urunlerimiz-og.webp"
  schema={[productsSchema, organizationSchema, breadcrumbSchema]}
>

  <I18nHeader />
  <Breadcrumbs items={breadcrumbItems} />

  <main>
    <!-- Page Header -->
    <section class="page-header">
      <div class="container">
        <h1>Ürünlerimiz</h1>
        <p>Kaliteli iç oda kapısı üretiminde kullandığımız malzemeler ve aksesuarlar</p>
      </div>
    </section>

    <!-- Filter Section -->
    <section class="filter-section">
      <div class="container">
        <!-- Kapı Türleri Filtreleri -->
        <div class="product-filters">
          <h3>Kapı Kategorileri</h3>
          <div class="product-filter-tabs">
            <a href="/urunlerimiz" class="product-filter-btn active">
              <span>Tümü</span>
            </a>
            <a href="/pvc-kapilar" class="product-filter-btn">
              <span>PVC Kapılar</span>
            </a>
            <a href="/laminoks-kapilar" class="product-filter-btn">
              <span>Laminoks Kapılar</span>
            </a>
            <a href="/elitpan-kapilar" class="product-filter-btn">
              <span>Elitpan Kapılar</span>
            </a>
            <a href="/hastane-kapilar" class="product-filter-btn">
              <span>Hastane Kapıları</span>
            </a>
            <a href="/otel-kapilar" class="product-filter-btn">
              <span>Otel Kapıları</span>
            </a>
            <a href="/yangina-dayanikli-kapilar" class="product-filter-btn">
              <span>Yangına Dayanıklı Kapılar</span>
            </a>
          </div>
        </div>

        <!-- Malzeme Filtreleri -->
        <div class="material-filters">
          <h3>Kullanılan Malzemeler</h3>
          <div class="material-filter-tabs">
            <button class="material-filter-btn active" data-filter="all-materials">Hepsi</button>
            <button class="material-filter-btn" data-filter="core">İç Materyal</button>
            <button class="material-filter-btn" data-filter="surface">Yüzey Malzemeleri</button>
            <button class="material-filter-btn" data-filter="accessories">Aksesuarlar</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Products Section -->
    <section class="products-section">
      <div class="container">
        <div class="products-grid">

          <!-- Core Materials -->
          <article class="product-card" data-category="core">
            <div class="product-image">
              <img src="/assets/img/materials/honeycomb-1-core.webp"
                   alt="Honeycomb Core 1 - Hafif ve dayanıklı iç yapı malzemesi"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Honeycomb Core 1</h3>
              <p class="product-description">
                Yüksek mukavemet ve hafiflik özelliği sunan honeycomb iç yapı malzemesi.
                Kapılarımızın dayanıklılığını artırarak uzun ömürlü kullanım sağlar.
              </p>
              <ul class="product-features">
                <li>Hafif yapı</li>
                <li>Yüksek mukavemet</li>
                <li>Ses yalıtımı</li>
                <li>Nem direnci</li>
              </ul>
            </div>
          </article>

          <article class="product-card" data-category="core">
            <div class="product-image">
              <img src="/assets/img/materials/honeycomb-2-core.webp"
                   alt="Honeycomb Core 2 - Gelişmiş honeycomb teknolojisi"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Honeycomb Core 2</h3>
              <p class="product-description">
                Gelişmiş honeycomb teknolojisi ile üretilen, daha yoğun hücre yapısına sahip
                iç malzeme. Üstün performans ve dayanıklılık sunar.
              </p>
              <ul class="product-features">
                <li>Yoğun hücre yapısı</li>
                <li>Üstün dayanıklılık</li>
                <li>İyi ses yalıtımı</li>
                <li>Çevre dostu</li>
              </ul>
            </div>
          </article>

          <article class="product-card" data-category="core">
            <div class="product-image">
              <img src="/assets/img/materials/semi-solid-core.webp"
                   alt="Semi Solid Wood - Yarı masif ahşap iç yapı"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Semi Solid Wood</h3>
              <p class="product-description">
                Yarı masif ahşap iç yapı, doğal ahşabın sağlamlığını modern üretim
                teknikleriyle birleştirir. Premium kalite ürünlerde kullanılır.
              </p>
              <ul class="product-features">
                <li>Doğal ahşap</li>
                <li>Yüksek sağlamlık</li>
                <li>Premium kalite</li>
                <li>Uzun ömürlü</li>
              </ul>
            </div>
          </article>

          <!-- Surface Materials -->
          <article class="product-card" data-category="surface">
            <div class="product-image">
              <img src="/assets/img/materials/PVCFOLYOLAR.webp"
                   alt="PVC Yüzey Malzemeleri - Su geçirmez ve dayanıklı"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">PVC Yüzey Malzemeleri</h3>
              <p class="product-description">
                Su geçirmez ve dayanıklı PVC yüzey kaplamaları. Nemli ortamlarda
                kullanım için ideal, kolay temizlenebilir özelliğe sahiptir.
              </p>
              <ul class="product-features">
                <li>Su geçirmez</li>
                <li>Kolay temizlik</li>
                <li>Çok renk seçeneği</li>
                <li>Ekonomik fiyat</li>
              </ul>
              <div class="product-footer">
                <a href="/pvc-kapilar" class="product-link">Detayları Gör</a>
              </div>
            </div>
          </article>

          <article class="product-card" data-category="surface">
            <div class="product-image">
              <img src="/assets/img/materials/PVCFOLYOLAR.webp"
                   alt="Laminoks Yüzey Malzemeleri - Yüksek kaliteli laminat"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Laminoks Yüzey Malzemeleri</h3>
              <p class="product-description">
                MDF yüzey üzerine uygulanan yüksek kaliteli laminat kaplama.
                Çizilme ve darbe direnci yüksek, estetik görünüm sunar.
              </p>
              <ul class="product-features">
                <li>Çizilme direnci</li>
                <li>Darbe dayanımı</li>
                <li>Zengin desen</li>
                <li>Mat/Parlak seçenekler</li>
              </ul>
              <div class="product-footer">
                <a href="/laminoks-kapilar" class="product-link">Detayları Gör</a>
              </div>
            </div>
          </article>

          <!-- Accessories -->
          <article class="product-card" data-category="accessories">
            <div class="product-image">
              <img src="https://picsum.photos/300/250?random=1"
                   alt="Kapı Kolları ve Kilit Sistemleri"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Kapı Kolları ve Kilit Sistemleri</h3>
              <p class="product-description">
                Yüksek kaliteli paslanmaz çelik ve pirinç kapı kolları.
                Çeşitli tasarım ve renk seçenekleri ile her tarza uygun çözümler.
              </p>
              <ul class="product-features">
                <li>Paslanmaz malzeme</li>
                <li>Ergonomik tasarım</li>
                <li>Çeşitli renkler</li>
                <li>Güvenlik kilitleri</li>
              </ul>
            </div>
          </article>

          <article class="product-card" data-category="accessories">
            <div class="product-image">
              <img src="https://picsum.photos/300/250?random=2"
                   alt="Menteşeler ve Bağlantı Elemanları"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Menteşeler ve Bağlantı Elemanları</h3>
              <p class="product-description">
                Dayanıklı ve sessiz çalışan menteşe sistemleri.
                Yüksek kalite malzemeden üretilmiş, uzun ömürlü kullanım garantisi.
              </p>
              <ul class="product-features">
                <li>Sessiz çalışma</li>
                <li>Yüksek dayanıklılık</li>
                <li>Kolay montaj</li>
                <li>Ayarlanabilir</li>
              </ul>
            </div>
          </article>

          <article class="product-card" data-category="accessories">
            <div class="product-image">
              <img src="https://picsum.photos/300/250?random=3"
                   alt="Conta ve Fitil Sistemleri"
                   loading="lazy"
                   width="300"
                   height="250">
            </div>
            <div class="product-info">
              <h3 class="product-title">Conta ve Fitil Sistemleri</h3>
              <p class="product-description">
                Hava ve ses geçişini engelleyen yüksek kaliteli conta ve fitil sistemleri.
                Enerji verimliliği ve konfor için önemli detaylar.
              </p>
              <ul class="product-features">
                <li>Hava sızdırmazlığı</li>
                <li>Ses yalıtımı</li>
                <li>Enerji tasarrufu</li>
                <li>UV dayanımı</li>
              </ul>
            </div>
          </article>

        </div>

        <!-- Contact CTA -->
        <div class="contact-cta">
          <h2>Özel Projeleriniz İçin</h2>
          <p>
            Toptan satış, özel ölçü üretim ve ihracat konularında detaylı bilgi almak için
            uzman ekibimizle iletişime geçin.
          </p>
          <div class="cta-buttons">
            <a href="/iletisim" class="btn-primary">İletişime Geç</a>
            <a href="tel:+905441690038" class="btn-secondary">📞 Hemen Ara</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* Base styles */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Page Header */
  .page-header {
    padding: 4rem 0 3rem;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #111827;
    margin-bottom: 1rem;
  }

  .page-header p {
    color: #6b7280;
    font-size: clamp(1rem, 2vw, 1.1rem);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Filter Section */
  .filter-section {
    padding: 3rem 0;
    background: white;
    border-bottom: 1px solid #e5e7eb;
  }

  /* Kapı Türleri Filtreleri */
  .product-filters {
    margin-bottom: 3rem;
  }

  .product-filters h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
