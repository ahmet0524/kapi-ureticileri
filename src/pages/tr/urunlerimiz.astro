<script is:inline>
  // @ts-nocheck
  // Filter functionality
  document.addEventListener('DOMContentLoaded', function() {
    const materialFilterBtns = document.querySelectorAll('.material-filter-btn');
    const productCards = document.querySelectorAll('.product-card');

    materialFilterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const clickedBtn = this;

        // Update active button
        materialFilterBtns.forEach(b => b.classList.remove('active'));
        clickedBtn.classList.add('active');

        // Filter products
        const filterValue = clickedBtn.getAttribute('data-filter');

        productCards.forEach(card => {
          if (filterValue === 'all-materials' || card.getAttribute('data-category') === filterValue) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
