---
// src/pages/tr/otel-kapilari.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../../i18n/utils';

const lang  = 'tr';
const t     = useTranslations(lang);

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = baseUrl;
const currentUrl = `${pageUrl}/otel-kapilari`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Otel-Serisi-401-Italyan-Ceviz.webp",
  "CihanpanDoor-Otel-Serisi-402-Kestane.webp",
  "CihanpanDoor-Otel-Serisi-403-Tik.webp",
  "CihanpanDoor-Otel-Serisi-404-Yildiz-Metal-Antrasit.webp",
  "CihanpanDoor-Otel-Serisi-405-Vision-Gri.webp",
  "CihanpanDoor-Otel-Serisi-406-Dark-Santana.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Otel ve Konaklama Tesisi Kapıları — Premium Seri | CihanPan Door",
  "description": "Kayseri'den toptan premium otel kapıları. Lüks laminat yüzey, ses yalıtımlı, yangın güvenlikli, CE belgeli.",
  "url": currentUrl,
  "inLanguage": "tr-TR",
  "mainEntity": {
    "@type": "ItemList",
    "name": "Otel Kapı Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "Otel Kapısı — Premium Seri",
        "description": "Premium laminat otel kapısı. Misafir konforu için ses yalıtımlı, yangın güvenlikli, CE belgeli. Yoğun günlük kullanımda dayanıklı.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "Premium Laminat / MDF",
        "category": "Otel Kapısı",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa",    "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "Ürünler",      "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "Otel Kapıları","item": currentUrl },
  ]
};

const allSchemas = [hotelSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',             label: 'Elitpan Kapılar',   active: false },
  { slug: '/hospital-doors',            label: 'Hastane Kapıları',  active: false },
  { slug: '/otel-kapilari',             label: 'Otel Kapıları',      active: true  },
  { slug: '/yangina-dayanikli-kapilar', label: 'Yangın Kapıları',   active: false },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface HotelProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  badge: string;
  image: string;
  alt: string;
}

const hotelProducts: HotelProduct[] = fileNames.map((fn, i) => {
  const parts = fn.replace('.webp', '').split('-');
  const model = parts[3];
  const color = parts.slice(4).join(' ');
  return {
    id:    `hotel-${model}`,
    model,
    color,
    label: `Hotel ${model} · ${color}`,
    badge: i < 3 ? 'Premium · Şık Tasarım' : 'Lüks · Özel Tasarım',
    image: `/assets/img/hotel-doors/${fn}`,
    alt:   `CihanPan Door Otel Serisi ${model} ${color} — Premium Konaklama Kapısı`,
  };
});
---

<I18nLayout
  title="Otel ve Konaklama Tesisi Kapıları — Premium Seri | Toptan | CihanPan Door"
  description="Kayseri'den toptan premium otel kapıları. Lüks laminat, ses yalıtımlı, yangın güvenlikli, CE sertifikalı."
  keywords="otel kapısı toptan, konaklama tesisi kapısı, premium kapı kayseri, ses yalıtımlı otel kapısı, lüks kapı"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="Otel Kapıları — Premium Seri | CihanPan Door"
  ogDescription="Ses yalıtımlı ve yangın güvenlikli premium otel kapıları. Fabrikadan doğrudan."
  ogImage="/assets/img/og/hotel-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>Ana Sayfa</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>Ürünler</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">Otel Kapıları</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            Konaklama Koleksiyonu · Premium Seri
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>Otel ve Konaklama Kapıları</em><br/>Lüks Yüzey · Ses Yalıtımlı · CE Belgeli
          </h1>
          <p class="lam-hero__lead">
            Kayseri fabrikasından toptan otel kapıları. Dayanıklı MDF özlü premium laminat yüzeyler — yoğun konaklama ortamları için tasarlanmış. CE ve ISO 9001 sertifikalı.
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ Lüks Laminat Yüzey</span>
            <span class="lam-htag">✓ 32–42 dB Ses</span>
            <span class="lam-htag">✓ Yangın Güvenlikli</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ MOQ 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              Ücretsiz Teklif Al
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              Modelleri Gör
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>Model</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>Kalite</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>42<sup>dB</sup></strong><span>Ses</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>Sertifikalı</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label="Kapı kategorileri">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">Otel Kapı Koleksiyonu</span>
          <h2 id="catalogue-h2">
            Otel ve Konaklama Kapı Modelleri
          </h2>
          <p>
            {`${modelCount} premium otel kapısı modeli — 401–406 serisi. Yüksek kaliteli konaklama projeleri için lüks ahşap dokulu ve çağdaş yüzeyler.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            Otel Proje Teklifi Al
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">24 saat içinde yanıt · Min. 50 adet</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label="Otel kapı modelleri">
          {hotelProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.badge}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            İyi Bir Otel Kapısını Ne Yapar? CihanPan Yaklaşımı
          </h2>

          <p>
            <strong>CihanPan Door'un otel serisi</strong>, konaklama tasarım gereksinimlerini Kayseri fabrikamızın üretim hassasiyetiyle birleştirir. Her model, mülkün ömrü boyunca lüks estetiği korurken milyonlarca kapı döngüsüne dayanacak şekilde <em>premium laminat yüzeyle</em> kaplanmış dayanıklı MDF öz üzerine inşa edilmiştir.
          </p>

          <h3>Konaklama Ortamları İçin Temel Özellikler</h3>
          <ul class="lam-checklist">
            <li><strong>Premium Laminat Yüzey:</strong> Zengin ahşap dokulu ve çağdaş yüzeyler — İtalyan Ceviz, Kestane, Tik, Vision Gri ve daha fazlası — koridor ve oda estetiğini yükseltir.</li>
            <li><strong>Ses Yalıtımı 32–42 dB:</strong> Misafir mahremiyetini korur ve koridor gürültüsünü azaltır — olumlu yorumlar ve tekrar rezervasyonlar için kritik bir faktör.</li>
            <li><strong>Yoğun Trafik Dayanıklılığı:</strong> MDF öz ve laminat yüzey, yüksek doluluk oranlarına sahip otellerde tipik olan sürekli kullanıma dayanır.</li>
            <li><strong>Yangın Güvenliği Uyumu:</strong> Türkiye, AB ve Orta Doğu'daki konaklama binası yönetmeliklerini karşılamak için yangın dayanımlı seçenekler mevcuttur.</li>
            <li><strong>Kolay Bakım:</strong> Laminat yüzey kolayca temizlenir — periyodik yeniden kaplama veya boyama gerekmez, temizlik arıza süresini en aza indirir.</li>
            <li><strong>Elektronik Kilit Hazır:</strong> Tüm otel serisi modellerinde kart anahtarlı ve RFID elektronik kilit sistemleri için önceden hazırlanmış açıklık mevcuttur.</li>
          </ul>

          <h3>Konaklama Kullanım Alanları</h3>
          <p>CihanPan Door otel serisi şu alanlarda tercih edilir:</p>
          <ul class="lam-checklist">
            <li><strong>Otel Odaları:</strong> 3 yıldızdan 5 yıldıza kadar mülklerde üstün misafir deneyimi için premium yüzey ve ses yalıtımı.</li>
            <li><strong>Butik Oteller:</strong> Benzersiz iç tasarım konseptlerini tamamlayan ayırt edici ahşap dokulu yüzeyler.</li>
            <li><strong>Apart Oteller:</strong> Yüksek günlük doluluklu uzun süreli konaklama için dayanıklı çözüm.</li>
            <li><strong>Tatil Köyleri:</strong> Yüzlerce eşleşen kapı gerektiren büyük tatil köyü tesisleri için toplu tedarik çözümleri.</li>
            <li><strong>Pansiyonlar:</strong> Rekabetçi toptan fiyatlarla otel kalitesinde dayanıklılık sunan maliyet etkin premium seçenek.</li>
            <li><strong>Toplantı ve Etkinlik Tesisleri:</strong> Toplantı odaları, konferans alanları ve etkinlik salonları için ideal ses yalıtımlı kapılar.</li>
          </ul>

          <h3>Teknik Özellikler</h3>
          <ul class="lam-checklist">
            <li>Yüzey: Premium laminat — ahşap dokulu ve çağdaş yüzeyler</li>
            <li>Öz: Masif dayanıklı MDF</li>
            <li>Standart boyutlar: 80×200 cm · 90×200 cm — özel boyut mevcut</li>
            <li>Ses yalıtımı: 32–42 dB</li>
            <li>Yangın dayanımı: isteğe bağlı 30–60 dk (EN 1634)</li>
            <li>Aksesuar: ağır hizmet menteşe, çarpma önleyici sistem, elektronik kilit hazırlığı</li>
            <li>CE & ISO 9001 sertifikalı</li>
            <li>5 yıl üretici garantisi</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>Model</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>Kalite</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>Sertifikalı</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>Garanti</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">Konaklama Uzmanı</span>
            <h3>Proje Teklifi Al</h3>
            <p>Tesis türünüzü, oda sayısını ve gereksinimlerinizi paylaşın — 24 saat içinde yanıt veririz.</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                İletişim Formu
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                WhatsApp
              </a>
              <a href="tel:+905441690038" class="lam-btn lam-btn--outline lam-btn--sm" style="color: white;">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <div class="lam-features-card">
            <h3>Öne Çıkan Özellikler</h3>
            <ul class="lam-feat-list">
              <li>✨ Premium lüks laminat yüzey</li>
              <li>🔇 32–42 dB ses yalıtımı</li>
              <li>🔥 Yangın dayanımlı seçenek</li>
              <li>🔑 Elektronik kilit hazır</li>
              <li>🏨 Toplu proje tedariki</li>
              <li>📐 Özel ölçü ve konfigürasyon</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="faq-h2">
      <div class="lam-wrap lam-faq-wrap">
        <div class="lam-head">
          <span class="lam-tag">SSS</span>
          <h2 id="faq-h2">Sık Sorulan Sorular</h2>
        </div>
        <div class="lam-faqs">
          {([
            { q: 'Otel kullanımına uygun kapıyı ne yapar?',               a: 'Otel kapıları yüzlerce odada sürekli günlük kullanıma dayanmalı, misafir mahremiyeti için üstün ses yalıtımı sağlamalı, yangın güvenliği yönetmeliklerini karşılamalı ve mülkün markasını yansıtan premium estetiği korumalıdır.' },
            { q: 'Otel kapıları için hangi yüzey seçenekleri mevcuttur?',  a: '401–406 serisi İtalyan Ceviz, Kestane, Tik, Yıldız Metal Antrasit, Vision Gri ve Dark Santana gibi zengin ahşap dokulu yüzeyleri içerir. Büyük siparişler için özel yüzey, kaplama ve RAL renk seçenekleri mevcuttur.' },
            { q: 'Otel kapıları ne kadar ses yalıtımı sağlar?',            a: 'CihanPan Door otel kapıları model ve konfigürasyona göre 32–42 dB ses yalıtımı sağlar. Koridor performansını maksimize etmek için akustik contalar ve kasalar mevcuttur.' },
            { q: 'Toptan otel kapısı siparişlerinde MOQ nedir?',           a: 'Minimum sipariş miktarı 50 adettir. 100+ adet için hacim indirimleri geçerlidir. Tam otel donanım projeleri için özel ölçü, cam panel, elektronik kilit hazırlığı ve özel etiket çözümleri mevcuttur.' },
          ]).map(item => (
            <details class="lam-faq">
              <summary class="lam-faq__q">
                {item.q}
                <span class="lam-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="lam-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="lam-cta" aria-labelledby="cta-h2">
      <div class="lam-cta__glow" aria-hidden="true"></div>
      <div class="lam-wrap lam-cta__inner">
        <div class="lam-cta__text">
          <span class="lam-tag lam-tag--gold">Konaklama Tedariki</span>
          <h2 id="cta-h2">
            Otel Kapısı Toptan<br/>Fiyat Teklifi Alın
          </h2>
          <p>
            Tesis türünüzü, oda sayısını ve kapı modellerini paylaşın. 24 saat içinde CE & ISO belgeli fiyat teklifi.
          </p>
        </div>
        <div class="lam-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
            Ücretsiz Teklif Al
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)} class="lam-btn lam-btn--ghost">
            Tüm Ürünler
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS — laminoks-doors.astro ile özdeş ── */
  .lam {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    --green:    #16a34a;

    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
