---
// src/pages/tr/blog/index.astro  ← Türkçe blog listesi
import I18nLayout from '../../../layouts/I18nLayout.astro';
import I18nHeader from '../../../components/I18nHeader.astro';
import I18nFooter from '../../../components/I18nFooter.astro';

const baseUrl = 'https://cihanpandoor.netlify.app';
const currentUrl = `${baseUrl}/tr/blog`;

const allPosts = [
  {
    slug: '/tr/blog/pvc-kapi-ihracati',
    title: "PVC Kapı İhracatı: Türkiye'den Dünyaya",
    excerpt: 'Türkiye PVC kapı ihracatı hakkında detaylı bilgiler, ihracat prosedürleri ve hedef pazarlar.',
    image: '/assets/img/blog/pvc-kapi-ureticileri-og.webp',
    date: '2025-01-10',
    readTime: '6 dakika',
    category: 'İhracat',
    featured: true
  },
  {
    slug: '/tr/blog/hastane-kapilari',
    title: 'Hastane Kapıları: Medikal Seri Özellikleri',
    excerpt: 'Sağlık tesisleri için özel tasarlanmış antibakteriyel hastane kapıları hakkında detaylı rehber.',
    image: '/assets/img/blog/hastane-thumb.webp',
    date: '2025-01-08',
    readTime: '8 dakika',
    category: 'Ürünler',
    featured: false
  },
  {
    slug: '/tr/blog/otel-kapilari',
    title: 'Otel Kapıları: Konfor ve Estetik',
    excerpt: 'Otel ve konaklama tesisleri için ideal kapı modelleri ve özellikleri.',
    image: '/assets/img/blog/otel-thumb.webp',
    date: '2025-01-05',
    readTime: '7 dakika',
    category: 'Ürünler',
    featured: false
  }
];

allPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredPost = allPosts.find(post => post.featured);
const regularPosts = allPosts.filter(post => !post.featured);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": `${baseUrl}/tr` },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": currentUrl }
  ]
};
---

<I18nLayout
  title="Blog | Kapı Rehberi, PVC & İhracat Yazıları | CihanPan Door"
  description="PVC kapı üretimi, modeller, fiyatlar, otel ve hastane projeleri hakkında güncel blog yazıları."
  keywords="pvc kapı blog, kapı üretimi, pvc kapı fiyatları, otel kapıları, hastane kapıları"
  canonical={currentUrl}
  ogTitle="CihanPan Door Blog | Kapı Dünyasından Uzman Yazıları"
  ogDescription="PVC kapı sektöründen haberler, rehberler ve ihracat ipuçları."
  ogImage="/assets/img/og/blog-og.webp"
  schema={[breadcrumbSchema]}
>
<I18nHeader />
<main>
  <section class="blog-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/tr">Ana Sayfa</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Blog</span>
      </nav>
      <h1>Blog</h1>
      <p>Kapı dünyasından haberler, rehberler ve uzman tavsiyeleri</p>
    </div>
  </section>

  {featuredPost && (
    <section class="featured-post-section">
      <div class="container">
        <h2 class="section-title">⭐ Öne Çıkan Yazı</h2>
        <article class="featured-post">
          <a href={featuredPost.slug} class="featured-link">
            <div class="featured-image">
              <img src={featuredPost.image} alt={featuredPost.title} loading="eager" width="600" height="400" />
              <span class="featured-badge">Öne Çıkan</span>
            </div>
            <div class="featured-content">
              <div class="blog-meta">
                <span class="category-badge">{featuredPost.category}</span>
                <span class="separator">•</span>
                <time datetime={featuredPost.date}>
                  {new Date(featuredPost.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
                <span class="separator">•</span>
                <span>⏱️ {featuredPost.readTime}</span>
              </div>
              <h2>{featuredPost.title}</h2>
              <p>{featuredPost.excerpt}</p>
              <span class="read-more-btn">Yazıyı Oku →</span>
            </div>
          </a>
        </article>
      </div>
    </section>
  )}

  <section class="blog-grid-section">
    <div class="container">
      <h2 class="section-title">📖 Tüm Yazılar ({regularPosts.length})</h2>
      <div class="blog-grid">
        {regularPosts.map(post => (
          <article class="blog-card">
            <a href={post.slug} class="blog-card-link">
              <div class="blog-card-image">
                <img src={post.image} alt={post.title} loading="lazy" width="350" height="220" />
                <span class="blog-category">{post.category}</span>
              </div>
              <div class="blog-card-content">
                <div class="blog-meta">
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <span>•</span>
                  <span>⏱️ {post.readTime}</span>
                </div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <span class="read-more">Devamını Oku →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</main>
<I18nFooter />
</I18nLayout>

<style>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
.breadcrumb{display:flex;gap:.5rem;align-items:center;font-size:.9rem;color:rgba(255,255,255,.7);margin-bottom:1.5rem}
.breadcrumb a{color:rgba(255,255,255,.7);text-decoration:none}
.breadcrumb a:hover{color:#fff}
.blog-hero{padding:5rem 0 3rem;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;text-align:center}
.blog-hero h1{font-size:clamp(2.5rem,5vw,3.5rem);margin-bottom:1rem;font-weight:800}
.blog-hero p{font-size:1.25rem;opacity:.95;max-width:600px;margin:0 auto 1.5rem}
.section-title{font-size:2rem;font-weight:700;color:#111827;margin-bottom:2rem;text-align:center}
.featured-post-section{padding:4rem 0 2rem;background:#f9fafb}
.featured-post{background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 10px 40px rgba(0,0,0,.1);transition:all .3s ease}
.featured-post:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(0,0,0,.15)}
.featured-link{display:grid;grid-template-columns:1fr 1fr;gap:0;text-decoration:none;color:inherit}
.featured-image{position:relative;height:400px;overflow:hidden}
.featured-image img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.featured-post:hover .featured-image img{transform:scale(1.05)}
.featured-badge{position:absolute;top:1.5rem;left:1.5rem;background:#f59e0b;color:#fff;padding:.75rem 1.5rem;border-radius:25px;font-size:.9rem;font-weight:700}
.featured-content{padding:3rem;display:flex;flex-direction:column;justify-content:center}
.blog-meta{display:flex;gap:.75rem;align-items:center;font-size:.9rem;color:#6b7280;margin-bottom:1rem;flex-wrap:wrap}
.category-badge{background:#667eea;color:#fff;padding:.4rem 1rem;border-radius:15px;font-weight:600;font-size:.85rem}
.separator{color:#d1d5db}
.featured-content h2{font-size:2rem;font-weight:800;color:#111827;margin-bottom:1rem;line-height:1.3}
.featured-content p{color:#4b5563;line-height:1.7;font-size:1.1rem;margin-bottom:1.5rem}
.read-more-btn{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;padding:1rem 2rem;border-radius:50px;font-weight:600;transition:all .3s ease;width:fit-content}
.blog-grid-section{padding:4rem 0}
.blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:2rem;margin-top:2rem}
.blog-card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.08);transition:all .3s ease;height:100%}
.blog-card:hover{transform:translateY(-8px);box-shadow:0 12px 30px rgba(0,0,0,.15)}
.blog-card-link{text-decoration:none;color:inherit;display:flex;flex-direction:column;height:100%}
.blog-card-image{position:relative;height:220px;overflow:hidden}
.blog-card-image img{width:100%;height:100%;object-fit:cover;transition:transform .3s ease}
.blog-card:hover .blog-card-image img{transform:scale(1.05)}
.blog-category{position:absolute;top:1rem;left:1rem;background:#667eea;color:#fff;padding:.5rem 1rem;border-radius:20px;font-size:.85rem;font-weight:600}
.blog-card-content{padding:1.5rem;flex:1;display:flex;flex-direction:column}
.blog-card h3{font-size:1.35rem;font-weight:700;color:#111827;margin-bottom:.75rem;line-height:1.4}
.blog-card p{color:#4b5563;line-height:1.6;margin-bottom:1rem;flex:1}
.read-more{color:#667eea;font-weight:600;font-size:.95rem;margin-top:auto}
@media(max-width:1024px){.featured-link{grid-template-columns:1fr}.featured-image{height:300px}}
@media(max-width:768px){.blog-hero{padding:3rem 0 2rem}.blog-grid{grid-template-columns:1fr}}
</style>
