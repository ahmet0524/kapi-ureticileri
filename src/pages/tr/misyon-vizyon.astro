---
// src/pages/misyon-vizyon.astro  (TR — ana dil, /tr prefix yok)
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';

const lang = 'tr';

// ── SEO DATA ──────────────────────────────────────────────────────────
const baseUrl  = 'https://cihanpandoor.netlify.app';
const pageUrl  = `${baseUrl}/misyon-vizyon`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Misyon & Vizyon | CihanPan Door — Kayseri Kapı Üreticisi",
  "description": "CihanPan Door'un misyonu, vizyonu ve temel değerleri. 1995'ten bu yana Kayseri'de CE, TSE ve ISO 9001 sertifikalı kapı üretimi. Yıllık 600.000 adet üretim kapasitesi.",
  "url": pageUrl,
  "inLanguage": "tr",
  "isPartOf": {
    "@type": "WebSite",
    "name": "CihanPan Door",
    "url": baseUrl
  },
  "about": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "alternateName": "Cihanpan Kapı",
    "url": baseUrl,
    "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
    "foundingDate": "1995",
    "description": "Türkiye'nin önde gelen iç mekan kapı üreticisi ve ihracatçısı. CE, TSE, ISO 9001 sertifikalı. PVC, MDF, Laminoks kapılar — otel, hastane, konut ve ticari projeler için.",
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 150 },
    "areaServed": ["TR", "EU", "ME", "AF"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "name": "CE Sertifikası" },
      { "@type": "EducationalOccupationalCredential", "name": "TSE Sertifikası" },
      { "@type": "EducationalOccupationalCredential", "name": "ISO 9001" }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
      "addressLocality": "Kayseri",
      "addressRegion": "Kayseri",
      "postalCode": "38070",
      "addressCountry": "TR"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+90-544-169-0038",
      "contactType": "Satış",
      "availableLanguage": ["Turkish", "English", "Arabic", "German"],
      "areaServed": ["TR", "EU", "ME"]
    },
    "sameAs": [
      "https://www.cihanpandoor.com",
      "https://www.linkedin.com/company/cihanpan-door"
    ]
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Misyon & Vizyon", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "CihanPan Door'un misyonu nedir?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CihanPan Door'un misyonu; Kayseri'den dünyaya kaliteli ve yenilikçi kapı çözümleri sunarak müşteri beklentilerini aşan ürünler üretmek ve sürdürülebilir üretim anlayışıyla sektöre değer katmaktır."
      }
    },
    {
      "@type": "Question",
      "name": "CihanPan Door hangi sertifikalara sahiptir?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CE, TSE ve ISO 9001 sertifikalarına sahip olan CihanPan Door, Avrupa ve uluslararası kalite standartlarını tam olarak karşılamaktadır. Sertifikalar her sevkiyatta temin edilir."
      }
    },
    {
      "@type": "Question",
      "name": "CihanPan Door kaç ülkeye ihracat yapmaktadır?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CihanPan Door, başta Orta Doğu, Avrupa ve Afrika olmak üzere 25'ten fazla ülkeye toptan kapı ihracatı gerçekleştirmektedir. 2027 yılına kadar 40'tan fazla ülkeye ulaşmayı hedeflemektedir."
      }
    },
    {
      "@type": "Question",
      "name": "CihanPan Door hangi tür kapılar üretmektedir?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PVC kaplı, Laminoks, Elitpan (UV boyalı MDF), hastane tipi, otel tipi ve yangına dayanıklı iç mekan kapıları üretilmektedir. Tüm ürünler özel ölçü ve renk seçenekleriyle sunulmaktadır."
      }
    }
  ]
};

const schemas = [aboutPageSchema, breadcrumbSchema, faqSchema];

// ── PAGE DATA ─────────────────────────────────────────────────────────
const values = [
  { num: '01', title: 'A Sınıfı Kalite',       text: 'Üretim hattımıza yalnızca birinci sınıf hammaddeler girer. Her kapı, sevkiyat öncesinde çok aşamalı kalite kontrolünden geçer.' },
  { num: '02', title: 'Kanıtlanmış Güvenilirlik', text: '30 yılı aşkın tutarlı üretim ve zamanında ihracat teslimatı — sicilimiz kendi adına konuşur.' },
  { num: '03', title: 'Müşteri Odaklılık',      text: 'Her toptan satış ortağı için özel hesap yöneticisi, sevkiyat öncesi numune ve satış sonrası destek.' },
  { num: '04', title: 'Ar-Ge ve İnovasyon',     text: 'CNC teknolojisine ve yeni yüzey kaplamalarına sürekli yatırım, katalogumuzun pazar trendlerinin önünde kalmasını sağlar.' },
];

const timeline = [
  { year: '1995', title: "Kayseri'de Kuruluş",           text: "Türkiye'nin üretim merkezi Kayseri'de uzmanlaşmış bir iç mekan kapı atölyesi olarak başladı." },
  { year: '2003', title: 'Modern Fabrika Açıldı',        text: 'Kayseri Organize Sanayi Bölgesi\'ne taşınarak tam kapasiteli otomatik üretim hatları kuruldu.' },
  { year: '2010', title: 'Uluslararası İhracata Başlangıç', text: 'Orta Doğu ve Afrika pazarlarına ihracata başlandı — bugün 25\'ten fazla ülkeye ulaşılmaktadır.' },
  { year: '2018', title: 'ISO 9001 Sertifikası Alındı',  text: 'Mevcut CE ve TSE onaylarına ek olarak ISO 9001 sertifikası elde edildi.' },
  { year: '2024', title: 'Yıllık 600.000 Adet',          text: 'Yıllık 600.000 kapı seti üretim kapasitesine ulaşıldı — her hacimde toptan siparişe hazır.' },
];

const certs = [
  { badge: 'CE',  title: 'CE Sertifikası',  text: 'Avrupa pazarı güvenlik ve kalite standartlarına uygunluğu onaylar' },
  { badge: 'TSE', title: 'TSE Sertifikası', text: 'Türk Standartları Enstitüsü — Türk üreticiler için zorunlu kalite belgesi' },
  { badge: 'ISO', title: 'ISO 9001:2015',   text: 'Uluslararası kalite yönetim sistemi — her partide tutarlı üretim' },
];

const whyUs = [
  { icon: '🏭', title: 'Doğrudan Fabrika Fiyatı',   text: 'Acente yok, aracı yok. Üreticiden doğrudan satın alırsınız — işiniz için maksimum kâr marjı.' },
  { icon: '🌍', title: 'İhracata Hazır',              text: 'Tam dokümantasyon: ticari fatura, ambalaj listesi, menşe şahadetnamesi ve CE/ISO sertifikaları dahil.' },
  { icon: '📦', title: '50 Adet MOQ',                 text: 'Düşük minimum sipariş miktarı, büyük hacme geçmeden önce ürün kalitesini test etmenizi sağlar.' },
  { icon: '⚙️', title: 'Özel Ölçü ve Yüzey',         text: 'Standart dışı ölçüler, özel renkler, özel marka — tüm toptan siparişlerde mevcut.' },
  { icon: '🚢', title: 'Esnek Teslim Koşulları',      text: 'EXW, FOB, CIF — nakliyecini ile çalışır veya talep üzerine uçtan uca lojistiği üstleniriz.' },
  { icon: '🏅', title: 'CE + ISO Sertifikalı',        text: 'Her sevkiyat, gümrüksüz geçiş için CE, TSE ve ISO 9001 belgeleri eşliğinde gelir.' },
];
---

<I18nLayout
  title="Misyon & Vizyon | CihanPan Door — Kayseri Kapı Üreticisi"
  description="CihanPan Door'un misyonu, vizyonu ve temel değerleri. 1995'ten bu yana CE, TSE ve ISO 9001 sertifikalı kapı üretimi. Orta Doğu, Avrupa ve Afrika'ya ihracat."
  keywords="CihanPan Door misyon vizyon, Kayseri kapı üreticisi, kapı ihracatçısı Türkiye, CE sertifikalı kapı, TSE kapı, ISO 9001 kapı üretimi, toptan kapı Türkiye"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="Misyon & Vizyon | CihanPan Door"
  ogDescription="CihanPan Door olarak misyonumuz kaliteli ve yenilikçi kapı çözümleri sunmak, vizyonumuz ise Türkiye'nin lider kapı ihracatçısı olmaktır."
  ogImage="/assets/img/og/misyon-vizyon-og.webp"
>
  <I18nHeader />

  <main class="mv" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="mv-hero" aria-labelledby="hero-heading">
      <div class="mv-hero__grid" aria-hidden="true"></div>
      <div class="mv-wrap mv-hero__inner">

        <div class="mv-hero__copy">
          <span class="mv-eyebrow">
            <span class="mv-eyebrow__line"></span>
            Kayseri, Türkiye · Est. 1995
          </span>

          <h1 class="mv-hero__h1" id="hero-heading">
            Kaliteyi Rehber,<br>
            <em>İnovasyonu İlke</em><br>
            Olarak Benimsiyoruz
          </h1>

          <p class="mv-hero__sub">
            1995'ten bu yana Kayseri'de CE, TSE &amp; ISO 9001 sertifikalı üretim.
            <strong>Türkiye, Orta Doğu ve Avrupa'ya</strong> 25'ten fazla ülkeye ihracat —
            yılda <strong>600.000 adet</strong> üretim kapasitesiyle.
          </p>

          <div class="mv-hero__tags">
            <span class="mv-htag">✓ CE Sertifikalı</span>
            <span class="mv-htag">✓ ISO 9001</span>
            <span class="mv-htag">✓ Min. 50 Adet</span>
            <span class="mv-htag">✓ İhracata Hazır</span>
          </div>

          <div class="mv-stats">
            <div class="mv-stat">
              <strong>30<sup>+</sup></strong>
              <span>Yıl Üretim</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>600K</strong>
              <span>Adet / Yıl</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>25<sup>+</sup></strong>
              <span>İhracat Ülkesi</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>150<sup>+</sup></strong>
              <span>Çalışan</span>
            </div>
          </div>
        </div>

        <div class="mv-hero__badges" aria-label="Kalite sertifikaları">
          <div class="mv-hb mv-hb--gold" title="CE Sertifikalı">CE</div>
          <div class="mv-hb" title="TSE Sertifikalı">TSE</div>
          <div class="mv-hb" title="ISO 9001 Sertifikalı">ISO<br>9001</div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         MİSYON / VİZYON
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="mv-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">Yönümüz</span>
          <h2 id="mv-heading">Misyon &amp; Vizyon</h2>
          <p>Üretim ve ihracat anlayışımızı şekillendiren değerler ve uzun vadeli hedefler</p>
        </div>
        <div class="mv-cards">
          <div class="mv-card mv-card--blue">
            <div class="mv-card__bar"></div>
            <div class="mv-card__icon mv-card__icon--blue" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>Misyonumuz</h3>
            <p>Kayseri'den dünyaya <strong>kaliteli ve yenilikçi kapı çözümleri</strong> sunarak müşteri beklentilerini aşan ürünler üretmek. Sürdürülebilir üretim anlayışıyla sektöre değer katmak.</p>
            <ul class="mv-checks">
              <li>Aracısız, doğrudan fabrika fiyatı</li>
              <li>50 adetten toptan, büyük hacim fiyatlandırması</li>
              <li>Özel ölçü, yüzey ve özel marka seçeneği</li>
            </ul>
          </div>
          <div class="mv-card mv-card--gold">
            <div class="mv-card__bar"></div>
            <div class="mv-card__icon mv-card__icon--gold" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3>Vizyonumuz</h3>
            <p>Türkiye'nin önde gelen kapı üreticilerinden biri olarak <strong>uluslararası pazarda CihanPan Door markasını</strong> güvenilir ve tanınan bir isim haline getirmek. İnovasyon ve kalite standartlarında lider konumda olmak.</p>
            <ul class="mv-checks">
              <li>CE, TSE &amp; ISO 9001 — her sevkiyatta</li>
              <li>Sürdürülebilir, çevre dostu üretim</li>
              <li>2027'ye kadar 40+ ülkeye ihracat</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         DEĞERLER
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--navy" aria-labelledby="values-heading">
      <div class="mv-wrap">
        <div class="mv-head mv-head--light">
          <span class="mv-tag">Temel İlkeler</span>
          <h2 id="values-heading">Üretim Değerlerimiz</h2>
          <p>Hammadde seçiminden ihracat teslimatına kadar bizi tanımlayan ilkeler</p>
        </div>
        <div class="mv-vals">
          {values.map(v => (
            <div class="mv-val">
              <span class="mv-val__n" aria-hidden="true">{v.num}</span>
              <div class="mv-val__bar" aria-hidden="true"></div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
              <div class="mv-val__sweep" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SÜRDÜRÜLEBİLİRLİK
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--cream" aria-labelledby="sustain-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">Çevre &amp; Gelecek</span>
          <h2 id="sustain-heading">Sürdürülebilirlik Taahhüdümüz</h2>
          <p>Sorumlu üretimle hem insanlara hem gezegene değer katıyoruz</p>
        </div>
        <div class="mv-sustain">
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">♻️</div>
            <h3>Geri Dönüştürülebilir Malzeme</h3>
            <p>Üretimde kullandığımız hammaddelerin büyük bölümü geri dönüştürülebilir nitelikte olup atık miktarını minimize eden üretim hatları kullanıyoruz.</p>
          </div>
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">⚡</div>
            <h3>Enerji Verimliliği</h3>
            <p>Fabrikamızda enerji tüketimini optimize eden akıllı sistemler ve LED aydınlatma altyapısıyla karbon ayak izimizi sürekli azaltıyoruz.</p>
          </div>
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">🌱</div>
            <h3>Çevre Dostu Üretim</h3>
            <p>Çevre dostu boya ve yüzey kaplama sistemleri kullanarak hem iç ortam hava kalitesini hem de doğal kaynakları koruyoruz.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TARİHSEL SÜREÇ
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="history-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">30 Yıllık Üretim</span>
          <h2 id="history-heading">Türk Kapı Üreticisi Olarak<br>Tarihimiz</h2>
          <p>CihanPan Door'u küresel ölçekte güvenilir bir toptan tedarikçiye dönüştüren kilometre taşları</p>
        </div>
        <div class="mv-tl-wrap">
          {timeline.map((item) => (
            <div class="mv-tl">
              <div class="mv-tl__yr">{item.year}</div>
              <div class="mv-tl__spine" aria-hidden="true">
                <div class="mv-tl__line"></div>
                <div class="mv-tl__dot"></div>
                <div class="mv-tl__line"></div>
              </div>
              <div class="mv-tl__body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SERTİFİKALAR
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--cream" aria-labelledby="certs-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">Uluslararası Standartlar</span>
          <h2 id="certs-heading">CE, TSE &amp; ISO 9001 Sertifikalı<br>Kapı Üretimi</h2>
          <p>Her toptan sevkiyat, uluslararası alanda tanınan kalite belgeleriyle desteklenir</p>
        </div>
        <div class="mv-certs">
          {certs.map(c => (
            <div class="mv-cert">
              <div class="mv-cert__badge" aria-label={c.title}>{c.badge}</div>
              <div class="mv-cert__body">
                <h3>{c.title}</h3>
                <p>{c.text}</p>
              </div>
              <div class="mv-cert__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          ))}
        </div>
        <p class="mv-certs__note">
          Tüm sertifikalar talep üzerine sağlanır ve her ihracat paketine dahil edilir.
          <a href="/iletisim" class="mv-link">Belge talep edin →</a>
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         NEDEN BİZ
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="whyus-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">Neden CihanPan Door</span>
          <h2 id="whyus-heading">Alıcıların Türk Kapı Fabrikamızı<br>Tercih Etme Nedenleri</h2>
          <p>Kâr marjınızı koruyan ve tedarik zincirinizi kolaylaştıran doğrudan üretici avantajları</p>
        </div>
        <div class="mv-why">
          {whyUs.map(w => (
            <div class="mv-why__card">
              <div class="mv-why__icon" aria-hidden="true">{w.icon}</div>
              <h3>{w.title}</h3>
              <p>{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SSS
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--cream" aria-labelledby="faq-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">SSS</span>
          <h2 id="faq-heading">Sıkça Sorulan Sorular</h2>
          <p>Hakkımızda ve ürünlerimiz hakkında en çok merak edilen sorular</p>
        </div>
        <div class="mv-faq">
          <details class="mv-faq__item">
            <summary><h3>CihanPan Door'un misyonu nedir?</h3></summary>
            <p>Kayseri'den dünyaya <strong>kaliteli ve yenilikçi kapı çözümleri</strong> sunarak müşteri beklentilerini aşan ürünler üretmek ve sürdürülebilir üretim anlayışıyla sektöre değer katmaktır.</p>
          </details>
          <details class="mv-faq__item">
            <summary><h3>CihanPan Door hangi sertifikalara sahiptir?</h3></summary>
            <p><strong>CE, TSE ve ISO 9001</strong> sertifikalarına sahip olan CihanPan Door, Avrupa ve uluslararası kalite standartlarını tam olarak karşılamaktadır. Sertifikalar her sevkiyata dahil edilir.</p>
          </details>
          <details class="mv-faq__item">
            <summary><h3>Toptan sipariş için minimum miktar nedir?</h3></summary>
            <p>Minimum toptan sipariş miktarı <strong>50 adettir</strong>. Otel, hastane ve konut projeleri gibi büyük ölçekli projeler için özel toplu fiyatlandırma ve proje desteği sunulmaktadır.</p>
          </details>
          <details class="mv-faq__item">
            <summary><h3>CihanPan Door hangi tür kapılar üretmektedir?</h3></summary>
