---
// src/pages/about.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ── SEO DATA ──────────────────────────────────────────────────────────
const baseUrl = 'https://cihanpandoor.netlify.app';
const pageUrl = `${baseUrl}/en/about`;

/*
  TARGET KEYWORDS (US Market):
  PRIMARY  → "interior door manufacturer Turkey"
  PRIMARY  → "Turkish interior door wholesale exporter"
  SECONDARY→ "wholesale interior doors from Turkey"
  SECONDARY→ "interior door supplier Turkey USA"
  LONG-TAIL→ "ISO certified interior door manufacturer Turkey"
  LONG-TAIL→ "bulk interior door exporter Turkey USA"
  LONG-TAIL→ "PVC MDF interior door wholesale Turkey"
  INTENT   → Buyers replacing Chinese suppliers (tariff shift trend)
*/

// ── SCHEMA: AboutPage + Organization ─────────────────────────────────
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About CihanPan Door — Interior Door Manufacturer & Exporter Turkey",
  "description": "CihanPan Door is a CE, TSE & ISO 9001 certified interior door manufacturer in Kayseri, Turkey. Wholesale & export to USA, Europe, Middle East since 1995. 600,000 units/year capacity.",
  "url": pageUrl,
  "inLanguage": "en",
  "isPartOf": {
    "@type": "WebSite",
    "name": "CihanPan Door",
    "url": baseUrl
  },
  "about": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "alternateName": "Cihanpan Kapı",
    "url": baseUrl,
    "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
    "foundingDate": "1995",
    "description": "Turkey's leading interior door manufacturer and wholesale exporter. CE, TSE, ISO 9001 certified. PVC, MDF, Laminox doors for hotels, hospitals, residential & commercial projects.",
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 150 },
    "areaServed": ["US", "EU", "ME", "AF"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "name": "CE Certificate" },
      { "@type": "EducationalOccupationalCredential", "name": "TSE Certificate" },
      { "@type": "EducationalOccupationalCredential", "name": "ISO 9001" }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
      "addressLocality": "Kayseri",
      "addressRegion": "Kayseri",
      "postalCode": "38070",
      "addressCountry": "TR"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+90-544-169-0038",
      "contactType": "Sales",
      "availableLanguage": ["English", "Turkish", "Arabic", "German"],
      "areaServed": ["US", "EU", "ME"]
    },
    "sameAs": [
      "https://www.cihanpandoor.com",
      "https://www.linkedin.com/company/cihanpan-door"
    ]
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${baseUrl}/en` },
    { "@type": "ListItem", "position": 2, "name": "About Us", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is CihanPan Door a certified interior door manufacturer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. CihanPan Door holds CE, TSE, and ISO 9001 certifications, ensuring full compliance with European and international quality standards for all interior door products."
      }
    },
    {
      "@type": "Question",
      "name": "What is the minimum order quantity for wholesale interior doors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The minimum wholesale order is 50 units. For large-scale projects including hotels, hospitals, and residential complexes, we offer fully customized bulk pricing."
      }
    },
    {
      "@type": "Question",
      "name": "Does CihanPan Door export interior doors to the USA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. CihanPan Door exports wholesale interior doors to more than 25 countries including the United States. We provide full export documentation, competitive FOB/CIF pricing, and flexible shipping terms."
      }
    },
    {
      "@type": "Question",
      "name": "What types of interior doors does CihanPan Door manufacture?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We manufacture PVC coated, Laminox, Elitpan (UV-painted MDF), hospital-grade, hotel-grade, and fire-resistant interior doors. All products are available for wholesale export worldwide."
      }
    }
  ]
};

const schemas = [aboutPageSchema, breadcrumbSchema, faqSchema];

// ── PAGE DATA ─────────────────────────────────────────────────────────
const values = [
  { num: '01', title: 'Grade-A Quality',     text: 'Only premium raw materials enter our production line. Every door undergoes multi-stage quality inspection before shipment.' },
  { num: '02', title: 'Proven Reliability',  text: '30+ years of consistent manufacturing and on-time export delivery — our track record speaks for itself.' },
  { num: '03', title: 'Client-First',        text: 'Dedicated account managers, pre-shipment samples, and after-sale support for every wholesale partner.' },
  { num: '04', title: 'R&D Innovation',      text: 'Continuous investment in CNC technology and new surface finishes keeps our catalog ahead of market trends.' },
];

const timeline = [
  { year: '1995', title: 'Founded in Kayseri',          text: 'Started as a specialized interior door workshop in Kayseri, Turkey\'s manufacturing heartland.' },
  { year: '2003', title: 'Modern Factory Opened',       text: 'Moved to Kayseri Organized Industrial Zone with full-scale automated production lines.' },
  { year: '2010', title: 'International Export Launch', text: 'Began exporting to Middle East and African markets — now serving 25+ countries.' },
  { year: '2018', title: 'ISO 9001 Certified',          text: 'Achieved ISO 9001 certification alongside existing CE and TSE approvals.' },
  { year: '2024', title: '600,000 Units / Year',        text: 'Reached annual production capacity of 600,000 door sets — ready for any volume wholesale order.' },
];

const certs = [
  { badge: 'CE',  title: 'CE Certificate',  text: 'Confirms compliance with European market safety & quality standards' },
  { badge: 'TSE', title: 'TSE Certificate', text: 'Turkish Standards Institute — mandatory quality mark for Turkish manufacturers' },
  { badge: 'ISO', title: 'ISO 9001:2015',   text: 'International quality management system — consistent production at every batch' },
];

const whyUs = [
  { icon: '🏭', title: 'Direct Factory Price',   text: 'No agents, no middlemen. You buy directly from the manufacturer — maximum margin for your business.' },
  { icon: '🇺🇸', title: 'USA Export Ready',       text: 'Full documentation: commercial invoice, packing list, certificate of origin, and CE/ISO certificates included.' },
  { icon: '📦', title: '50-Unit MOQ',             text: 'Low minimum order lets you test product quality before committing to large volumes.' },
  { icon: '⚙️', title: 'Custom Sizing & Finish',  text: 'Non-standard dimensions, custom colors, private label — all available for wholesale orders.' },
  { icon: '🚢', title: 'Flexible Incoterms',      text: 'EXW, FOB, CIF — we work with your freight forwarder or handle end-to-end logistics on request.' },
  { icon: '🏅', title: 'CE + ISO Certified',      text: 'Every shipment backed by CE, TSE and ISO 9001 documentation for hassle-free customs clearance.' },
];
---

<I18nLayout
  title="Interior Door Manufacturer & Exporter Turkey | CihanPan Door – Since 1995"
  description="CE & ISO 9001 certified interior door manufacturer in Turkey. Wholesale PVC, MDF & Laminox doors for USA, Europe & Middle East. 600K units/year. MOQ 50 units. Request a quote."
  keywords="interior door manufacturer Turkey, Turkish interior door wholesale, interior door exporter Turkey USA, wholesale interior doors Turkey, PVC door manufacturer Turkey, MDF door wholesale exporter, ISO certified door manufacturer Turkey, bulk interior doors Turkey"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="Turkey's #1 Wholesale Interior Door Manufacturer | CihanPan Door"
  ogDescription="Factory-direct interior doors from Kayseri, Turkey. CE, TSE & ISO 9001 certified. Exporting to USA, Europe & Middle East since 1995. MOQ 50 units."
  ogImage="/assets/img/og/about-og.webp"
>
  <I18nHeader />

  <main class="ab" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO — H1 contains primary keyword
    ══════════════════════════════════════════ -->
    <section class="ab-hero" aria-labelledby="hero-heading">
      <div class="ab-hero__grid" aria-hidden="true"></div>
      <div class="ab-wrap ab-hero__inner">

        <div class="ab-hero__copy">
          <span class="ab-eyebrow">
            <span class="ab-eyebrow__line"></span>
            Kayseri, Turkey · Est. 1995
          </span>

          <!-- PRIMARY KEYWORD in H1 -->
          <h1 class="ab-hero__h1" id="hero-heading">
            Turkey's Leading<br>
            <em>Interior Door Manufacturer</em><br>
            &amp; Wholesale Exporter
          </h1>

          <p class="ab-hero__sub">
            CE, TSE &amp; ISO 9001 certified wholesale interior door manufacturer in Kayseri, Turkey.
            Exporting PVC, MDF and Laminox interior doors to the <strong>USA, Europe and Middle East</strong>
            since 1995 — with a production capacity of <strong>600,000 units per year</strong>.
          </p>

          <div class="ab-hero__tags">
            <span class="ab-htag">✓ CE Certified</span>
            <span class="ab-htag">✓ ISO 9001</span>
            <span class="ab-htag">✓ MOQ: 50 Units</span>
            <span class="ab-htag">✓ USA Export Ready</span>
          </div>

          <div class="ab-stats">
            <div class="ab-stat">
              <strong>30<sup>+</sup></strong>
              <span>Years Manufacturing</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>600K</strong>
              <span>Units / Year</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>25<sup>+</sup></strong>
              <span>Export Countries</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>150<sup>+</sup></strong>
              <span>Employees</span>
            </div>
          </div>
        </div>

        <div class="ab-hero__badges" aria-label="Quality certifications">
          <div class="ab-hb ab-hb--gold" title="CE Certified">CE</div>
          <div class="ab-hb" title="TSE Certified">TSE</div>
          <div class="ab-hb" title="ISO 9001 Certified">ISO<br>9001</div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         WHY US — US buyer decision factors
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--cream" aria-labelledby="whyus-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">Why CihanPan Door</span>
          <!-- SECONDARY KEYWORD in H2 -->
          <h2 id="whyus-heading">Why US Importers Choose Our<br>Turkish Interior Door Factory</h2>
          <p>Direct manufacturer advantages that protect your margins and simplify your supply chain</p>
        </div>
        <div class="ab-why">
          {whyUs.map(w => (
            <div class="ab-why__card">
              <div class="ab-why__icon" aria-hidden="true">{w.icon}</div>
              <h3>{w.title}</h3>
              <p>{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         MISSION / VISION
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="mv-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">Our Direction</span>
          <h2 id="mv-heading">Mission &amp; Vision</h2>
          <p>The values and long-term goals that shape how we manufacture and export</p>
        </div>
        <div class="ab-mv">
          <div class="ab-mv__card ab-mv__card--blue">
            <div class="ab-mv__bar"></div>
            <div class="ab-mv__icon ab-mv__icon--blue" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>Our Mission</h3>
            <p>To be the most trusted <strong>wholesale interior door exporter from Turkey</strong> — delivering factory-direct quality, full CE/ISO documentation, and reliable logistics for every international order.</p>
            <ul class="ab-checks">
              <li>Factory-direct pricing — no agents or middlemen</li>
              <li>Wholesale from 50 units, bulk pricing available</li>
              <li>Custom dimensions, finishes &amp; private label</li>
            </ul>
          </div>
          <div class="ab-mv__card ab-mv__card--gold">
            <div class="ab-mv__bar"></div>
            <div class="ab-mv__icon ab-mv__icon--gold" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3>Our Vision</h3>
            <p>To become the top-of-mind <strong>Turkish interior door manufacturer for wholesale buyers in the USA and Europe</strong> — recognized for certified quality, on-time delivery, and transparent business practices.</p>
            <ul class="ab-checks">
              <li>CE, TSE &amp; ISO 9001 on every shipment</li>
              <li>Sustainable, eco-conscious production</li>
              <li>Expanding to 40+ export countries by 2027</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         VALUES
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--navy" aria-labelledby="values-heading">
      <div class="ab-wrap">
        <div class="ab-head ab-head--light">
          <span class="ab-tag">Core Principles</span>
          <h2 id="values-heading">Our Manufacturing Values</h2>
          <p>What we stand for — from raw material selection to export delivery</p>
        </div>
        <div class="ab-vals">
          {values.map(v => (
            <div class="ab-val">
              <span class="ab-val__n" aria-hidden="true">{v.num}</span>
              <div class="ab-val__bar" aria-hidden="true"></div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
              <div class="ab-val__sweep" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TIMELINE — rich keyword content
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="history-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">30 Years of Manufacturing</span>
          <!-- LONG-TAIL KEYWORD in H2 -->
          <h2 id="history-heading">Our History as a Turkish<br>Interior Door Manufacturer</h2>
          <p>Key milestones that shaped CihanPan Door into a globally trusted wholesale supplier</p>
        </div>
        <div class="ab-tl-wrap">
          {timeline.map((item) => (
            <div class="ab-tl">
              <div class="ab-tl__yr">{item.year}</div>
              <div class="ab-tl__spine" aria-hidden="true">
                <div class="ab-tl__line"></div>
                <div class="ab-tl__dot"></div>
                <div class="ab-tl__line"></div>
              </div>
              <div class="ab-tl__body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CERTIFICATES
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--cream" aria-labelledby="certs-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">International Standards</span>
          <!-- LONG-TAIL KEYWORD in H2 -->
          <h2 id="certs-heading">CE, TSE &amp; ISO 9001 Certified<br>Interior Door Production</h2>
          <p>Every wholesale shipment is backed by internationally recognized quality documentation</p>
        </div>
        <div class="ab-certs">
          {certs.map(c => (
            <div class="ab-cert">
              <div class="ab-cert__badge" aria-label={c.title}>{c.badge}</div>
              <div class="ab-cert__body">
                <h3>{c.title}</h3>
                <p>{c.text}</p>
              </div>
              <div class="ab-cert__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          ))}
        </div>

        <p class="ab-certs__note">
          All certificates are available upon request and included in every shipment's export documentation package.
          <a href="/en/contact" class="ab-link">Request a copy →</a>
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ — Schema + keyword-rich content
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="faq-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">Common Questions</span>
          <h2 id="faq-heading">FAQs for US Wholesale Buyers</h2>
          <p>Everything you need to know before placing your first interior door import order from Turkey</p>
        </div>
        <div class="ab-faq">
          <details class="ab-faq__item">
            <summary><h3>Is CihanPan Door a certified interior door manufacturer?</h3></summary>
            <p>Yes. CihanPan Door holds <strong>CE, TSE, and ISO 9001 certifications</strong>, ensuring full compliance with European and international quality standards for all interior door products. Certificates are provided with every wholesale shipment.</p>
          </details>
          <details class="ab-faq__item">
            <summary><h3>What is the minimum order quantity for wholesale interior doors?</h3></summary>
            <p>The minimum wholesale order is <strong>50 units</strong>. For large-scale projects — hotels, hospitals, residential complexes — we offer fully customized bulk pricing with dedicated project support.</p>
          </details>
          <details class="ab-faq__item">
            <summary><h3>Does CihanPan Door export interior doors to the USA?</h3></summary>
            <p>Yes. We export wholesale interior doors to <strong>25+ countries including the United States</strong>. We provide full export documentation, competitive FOB/CIF pricing, and work with your freight forwarder or our own logistics partners.</p>
          </details>
          <details class="ab-faq__item">
            <summary><h3>What types of interior doors do you manufacture?</h3></summary>
            <p>We manufacture <strong>PVC coated, Laminox, Elitpan (UV-painted MDF), hospital-grade, hotel-grade, and fire-resistant interior doors</strong>. Custom dimensions, colors, and finishes are available for all wholesale orders. <a href="/en/products" class="ab-link">See all products →</a></p>
          </details>
          <details class="ab-faq__item">
            <summary><h3>Can I source interior doors from Turkey instead of China?</h3></summary>
            <p>Absolutely. With rising US tariffs on Chinese imports, many American wholesalers and importers are switching to <strong>Turkish interior door manufacturers</strong> for better pricing stability, CE/ISO compliance, and shorter lead times to Europe-facing markets. <a href="/en/contact" class="ab-link">Talk to our export team →</a></p>
          </details>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA
    ══════════════════════════════════════════ -->
    <section class="ab-cta" aria-labelledby="cta-heading">
      <div class="ab-cta__glow" aria-hidden="true"></div>
      <div class="ab-wrap ab-cta__inner">
        <div class="ab-cta__text">
          <span class="ab-tag ab-tag--gold">Start Sourcing from Turkey</span>
          <h2 id="cta-heading">Request a Wholesale<br>Interior Door Quote</h2>
          <p>Tell us your quantities, door types, and destination — we'll reply within 24 hours with factory-direct pricing and full CE/ISO documentation.</p>
        </div>
        <div class="ab-cta__btns">
          <a href="/en/contact" class="ab-btn ab-btn--gold">
            Get a Free Quote
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://www.cihanpandoor.com/E-Katalog.pdf" target="_blank" rel="noopener noreferrer" class="ab-btn ab-btn--outline">
            Download Product Catalogue
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── FONTS ── */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap');

  /* ── TOKENS ── */
  .ab {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;

    font-family: 'DM Sans', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
  .ab-wrap {
    max-width: 1140px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }

  .ab-sec          { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .ab-sec--white   { background: var(--white); }
  .ab-sec--navy    { background: var(--navy); }
  .ab-sec--cream   { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .ab-head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .ab-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.6rem;
    line-height: 1.2;
  }
  .ab-head p {
    color: var(--slate);
    font-size: 1rem;
    max-width: 500px;
    margin-inline: auto;
    line-height: 1.7;
  }
  .ab-head--light h2 { color: var(--white); }
  .ab-head--light p  { color: rgba(255,255,255,0.5); }

  .ab-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .ab-tag--gold { color: rgba(201,168,76,0.9); }

  .ab-link {
    color: var(--navy-l);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: color 0.2s;
  }
  .ab-link:hover { color: var(--gold); }

  /* ── HERO ── */
  .ab-hero {
    position: relative;
    background: var(--navy);
    padding: calc(70px + clamp(3.5rem, 7vw, 5rem)) 0 clamp(4rem, 8vw, 6rem);
    overflow: hidden;
  }
  .ab-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
  }
  .ab-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }
