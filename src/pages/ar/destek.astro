---
// src/pages/ar/destek.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/destek`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const supportSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "دعم العملاء | CihanPan Door",
  "description": "خدمات دعم عملاء CihanPan Door. دعم هاتفي وواتساب وبريد إلكتروني. مساعدة تقنية وخدمة ما بعد البيع وتتبع الطلبات.",
  "url": currentUrl,
  "inLanguage": "ar",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": pageUrl },
      { "@type": "ListItem", "position": 2, "name": "الدعم",    "item": currentUrl },
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "ما هي ساعات الدعم لديكم؟",              "acceptedAnswer": { "@type": "Answer", "text": "يتوفر دعم الهاتف والواتساب من الاثنين إلى الجمعة، من 09:00 إلى 18:00 (GMT+3). يُجاب على استفسارات البريد الإلكتروني خلال 24 ساعة." }},
    { "@type": "Question", "name": "كيف يمكنني تتبع طلبي؟",                "acceptedAnswer": { "@type": "Answer", "text": "تواصل معنا عبر الهاتف أو الواتساب أو البريد الإلكتروني برقم طلبك وسنزودك بتحديث كامل عن حالة الإنتاج والتسليم." }},
    { "@type": "Question", "name": "هل تقدمون خدمة ما بعد البيع؟",          "acceptedAnswer": { "@type": "Answer", "text": "نعم، نقدم خدمات صيانة وإصلاح مشمولة بالضمان لجميع منتجاتنا." }},
    { "@type": "Question", "name": "هل يمكنني زيارة المصنع؟",               "acceptedAnswer": { "@type": "Answer", "text": "زيارات المصنع مرحب بها. يُرجى التواصل معنا مسبقاً لتحديد موعد في منشأتنا بقيصري، تركيا." }},
    { "@type": "Question", "name": "هل تقدمون وثائق تقنية؟",               "acceptedAnswer": { "@type": "Answer", "text": "نعم، تتوفر أدلة التركيب وصفحات البيانات الفنية وشهادات CE بناءً على الطلب." }},
  ]
};

const allSchemas = [supportSchema, faqSchema];
---

<I18nLayout
  title="دعم العملاء | CihanPan Door"
  description="خدمات دعم عملاء CihanPan Door. دعم هاتفي وواتساب وبريد إلكتروني. مساعدة تقنية وخدمة ما بعد البيع وتتبع الطلبات."
  keywords="دعم CihanPan Door, خدمة عملاء مصنع أبواب, التواصل مصنع أبواب تركيا, الدعم الفني قيصري"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="دعم العملاء | CihanPan Door"
  ogDescription="دعم هاتفي وواتساب وبريد إلكتروني. مساعدة تقنية وخدمة ما بعد البيع وتتبع الطلبات."
  ogImage="/assets/img/og/support-og.webp"
  lang="ar"
  dir="rtl"
>
  <I18nHeader />

  <main class="sup" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="sup-hero" aria-labelledby="sup-h1">
      <div class="sup-hero__bg" aria-hidden="true">
        <div class="sup-hero__overlay"></div>
        <div class="sup-hero__glow"></div>
      </div>
      <div class="sup-wrap sup-hero__inner">
        <nav class="sup-breadcrumb" aria-label="مسار التنقل">
          <a href={pageUrl}>الرئيسية</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">الدعم</span>
        </nav>

        <span class="sup-eyebrow">
          <span class="sup-eyebrow__line"></span>
          نحن هنا لمساعدتك
        </span>

        <h1 class="sup-hero__h1" id="sup-h1">
          🤝 <em>دعم العملاء</em><br/>مساعدة موثوقة في كل خطوة
        </h1>
        <p class="sup-hero__lead">
          تواصل مع فريقنا عبر الهاتف أو الواتساب أو البريد الإلكتروني.
          من الدعم الفني إلى خدمة ما بعد البيع — نحن معك في كل مرحلة.
        </p>
        <div class="sup-hero__tags">
          <span class="sup-htag">✓ الاثنين–الجمعة 09:00–18:00</span>
          <span class="sup-htag">✓ رد خلال 24 ساعة</span>
          <span class="sup-htag">✓ دردشة واتساب مباشرة</span>
          <span class="sup-htag">✓ دعم فني</span>
          <span class="sup-htag">✓ خدمة ما بعد البيع</span>
        </div>
        <div class="sup-hero__actions">
          <a href="https://wa.me/905441690038" class="sup-btn sup-btn--gold" target="_blank" rel="noopener noreferrer">
            دعم واتساب
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <a href="mailto:info@cihanpandoor.com" class="sup-btn sup-btn--ghost">
            info@cihanpandoor.com
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="sup-wrap">
        <div class="sup-statsbar">
          <div class="sup-sitem"><strong>24 س</strong><span>رد بالبريد</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>5★</strong><span>تقييم العملاء</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>+15</strong><span>سنة خبرة</span></div>
          <div class="sup-sdiv"></div>
          <div class="sup-sitem"><strong>%100</strong><span>رضا العملاء</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CONTACT CARDS
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--white" aria-labelledby="contact-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">قنوات التواصل</span>
          <h2 id="contact-h2">كيف يمكننا مساعدتك؟</h2>
        </div>

        <div class="sup-cards">

          <div class="sup-card">
            <div class="sup-card__icon">📞</div>
            <h3>الدعم الهاتفي</h3>
            <p>الاثنين–الجمعة، 09:00–18:00 (GMT+3)</p>
            <a href="tel:+905441690038" class="sup-card__btn" dir="ltr">+90 544 169 00 38</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">💬</div>
            <h3>واتساب</h3>
            <p>ردود سريعة للاستفسارات العاجلة</p>
            <a href="https://wa.me/905441690038" class="sup-card__btn sup-card__btn--wa" target="_blank" rel="noopener noreferrer">تواصل عبر واتساب</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">✉️</div>
            <h3>البريد الإلكتروني</h3>
            <p>يُجاب خلال 24 ساعة</p>
            <a href="mailto:info@cihanpandoor.com" class="sup-card__btn">إرسال بريد إلكتروني</a>
          </div>

          <div class="sup-card">
            <div class="sup-card__icon">📍</div>
            <h3>زيارة المصنع</h3>
            <p>حدد موعداً للقاء شخصي</p>
            <a href={getLocalizedRoute('/iletisim', lang)} class="sup-card__btn">العنوان والخريطة</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         QUICK LINKS
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--cream" aria-labelledby="quick-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">وصول سريع</span>
          <h2 id="quick-h2">الموارد الشائعة</h2>
        </div>
        <div class="sup-quick">
          <a href={getLocalizedRoute('/sss', lang)}          class="sup-qlink">❓ الأسئلة الشائعة</a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)}  class="sup-qlink">📦 كتالوج المنتجات</a>
          <a href={getLocalizedRoute('/iletisim', lang)}     class="sup-qlink">📝 طلب عرض سعر</a>
          <a href={getLocalizedRoute('/hakkimizda', lang)}   class="sup-qlink">ℹ️ من نحن</a>
          <a href={getLocalizedRoute('/export', lang)}       class="sup-qlink">🌍 خدمات التصدير</a>
          <a href={getLocalizedRoute('/sertifikalar', lang)} class="sup-qlink">🏅 الشهادات</a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SUPPORT SERVICES
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--white" aria-labelledby="services-h2">
      <div class="sup-wrap">
        <div class="sup-head">
          <span class="sup-tag">خدماتنا</span>
          <h2 id="services-h2">خدمات الدعم التي نقدمها</h2>
        </div>
        <div class="sup-info-grid">
          <div class="sup-info-item">
            <div class="sup-info-icon">🔧</div>
            <h3>الدعم الفني</h3>
            <p>إرشادات احترافية من فريق مهندسينا حول تركيب المنتجات واستخدامها وصيانتها.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">🛡️</div>
            <h3>خدمة ما بعد البيع</h3>
            <p>خدمات صيانة وإصلاح مشمولة بالضمان لضمان أداء المنتج على المدى الطويل.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">📦</div>
            <h3>تتبع الطلبات</h3>
            <p>ابق على اطلاع بمراحل إنتاج طلبك حتى الموعد المقدر للتسليم.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">💼</div>
            <h3>استشارات المشاريع</h3>
            <p>حلول مخصصة وتسعير مُصمَّم خصيصاً للمشاريع الكبيرة والخاصة.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">📄</div>
            <h3>الوثائق</h3>
            <p>أدلة التركيب وصفحات بيانات المنتج وشهادات CE ووثائق المطابقة بناءً على الطلب.</p>
          </div>
          <div class="sup-info-item">
            <div class="sup-info-icon">🌐</div>
            <h3>دعم التصدير</h3>
            <p>وثائق الجمارك والتنسيق اللوجستي والدعم متعدد اللغات للمشترين الدوليين.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="sup-sec sup-sec--cream" aria-labelledby="faq-h2">
      <div class="sup-wrap sup-faq-wrap">
        <div class="sup-head">
          <span class="sup-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">الأسئلة المتكررة</h2>
        </div>

        <div class="sup-faqs" role="list">

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              ما هي ساعات الدعم لديكم؟
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">يتوفر دعم الهاتف والواتساب من الاثنين إلى الجمعة، من 09:00 إلى 18:00 (GMT+3). يُجاب على استفسارات البريد الإلكتروني خلال 24 ساعة.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              كيف يمكنني تتبع طلبي؟
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">تواصل معنا عبر الهاتف أو الواتساب أو البريد الإلكتروني برقم طلبك وسنزودك بتحديث كامل عن حالة الإنتاج والتسليم.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              هل تقدمون خدمة ما بعد البيع؟
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">نعم، نقدم خدمات صيانة وإصلاح مشمولة بالضمان لجميع منتجاتنا.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              هل يمكنني زيارة المصنع؟
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">زيارات المصنع مرحب بها. يُرجى التواصل معنا مسبقاً لتحديد موعد في منشأتنا بقيصري، تركيا.</p>
          </details>

          <details class="sup-faq" role="listitem">
            <summary class="sup-faq__q">
              هل تقدمون وثائق تقنية؟
              <svg class="sup-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <p class="sup-faq__a">نعم، تتوفر أدلة التركيب وصفحات البيانات الفنية وشهادات CE بناءً على الطلب. تواصل معنا وسنرسل الوثائق ذات الصلة.</p>
          </details>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="sup-cta" aria-label="تواصل معنا">
      <div class="sup-cta__glow" aria-hidden="true"></div>
      <div class="sup-wrap sup-cta__inner">
        <div class="sup-cta__text">
          <span class="sup-tag sup-tag--light">تواصل معنا</span>
          <h2>هل لديك المزيد من الأسئلة؟</h2>
          <p>فريقنا مستعد للمساعدة. تواصل معنا عبر الهاتف أو الواتساب أو البريد الإلكتروني وسنرد عليك في أقرب وقت.</p>
        </div>
        <div class="sup-cta__btns">
          <a href="tel:+905441690038" class="sup-btn sup-btn--gold">
            اتصل الآن
          </a>
          <a href="https://wa.me/905441690038" class="sup-btn sup-btn--wa" target="_blank" rel="noopener noreferrer">
            واتساب
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS ── */
  :root {
    --navy:   #0f2347;
    --gold:   #c9a84c;
    --gold-l: #dfc078;
    --white:  #ffffff;
    --cream:  #f9f6f0;
    --text:   #1a202c;
    --body:   #4a5568;
    --slate:  #6b7280;
    --bdr:    #e5e7eb;
    --green:  #16a34a;
    --radius: 14px;
  }

  /* ── RTL FONT ── */
  :lang(ar), [dir="rtl"] {
    font-family: 'Tajawal', 'Noto Sans Arabic', 'Cairo', Arial, sans-serif;
  }

  /* ── LAYOUT ── */
  .sup-wrap { max-width: 1200px; margin: 0 auto; padding-inline: clamp(1rem, 4vw, 2.5rem); }
  .sup-sec  { padding: clamp(3.5rem, 7vw, 6rem) 0; }
  .sup-sec--white { background: var(--white); }
  .sup-sec--cream { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .sup-head { text-align: center; margin-bottom: 3rem; }
  .sup-tag  {
    display: inline-block; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em;
    color: var(--gold); background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.3); border-radius: 4px; padding: 0.3rem 0.85rem;
    margin-bottom: 0.9rem;
  }
  .sup-tag--light { color: var(--gold-l); background: rgba(201,168,76,0.08); border-color: rgba(201,168,76,0.2); }
  .sup-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; color: var(--text); margin: 0;
  }

  /* ── BUTTONS ── */
  .sup-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.75rem; border-radius: 8px; font-weight: 700;
    font-size: 0.92rem; text-decoration: none; transition: all 0.25s; white-space: nowrap;
  }
  .sup-btn--gold  { background: var(--gold); color: var(--navy); }
  .sup-btn--gold:hover { background: var(--gold-l); transform: translateY(-2px); }
  .sup-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .sup-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }
  .sup-btn--wa    { background: var(--green); color: var(--white); }
  .sup-btn--wa:hover { background: #15803d; transform: translateY(-2px); }

  /* ── HERO ── */
  .sup-hero {
    position: relative; min-height: 70vh; display: flex;
    flex-direction: column; justify-content: center;
    padding-top: 70px; overflow: hidden;
  }
  .sup-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .sup-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.96) 0%, rgba(15,35,71,0.88) 60%, rgba(26,58,110,0.82) 100%);
  }
  .sup-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 20% 30%, rgba(201,168,76,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 90% 70%, rgba(30,74,138,0.3) 0%, transparent 60%);
  }
  .sup-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .sup-breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; flex-wrap: wrap;
    flex-direction: row-reverse; justify-content: flex-end;
  }
  .sup-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .sup-breadcrumb a:hover { color: var(--gold-l); }
  .sup-breadcrumb span[aria-current] { color: var(--gold); }
  .sup-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem; flex-direction: row-reverse;
    font-size: 0.82rem; font-weight: 600; letter-spacing: 0.02em;
    color: var(--gold); margin-bottom: 1.2rem;
  }
  .sup-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: 0.5; flex-shrink: 0; }
  .sup-hero__h1 {
    font-size: clamp(2rem, 4.5vw, 3.4rem); font-weight: 900;
    color: var(--white); line-height: 1.3; margin: 0 0 1.2rem;
  }
  .sup-hero__h1 em { font-style: normal; color: var(--gold); }
  .sup-hero__lead { font-size: 1.05rem; color: rgba(255,255,255,0.65); line-height: 2; max-width: 580px; margin: 0 0 1.5rem; }
  .sup-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .sup-htag {
    display: inline-block; padding: 0.3rem 0.85rem;
    border: 1px solid rgba(201,168,76,0.35); background: rgba(201,168,76,0.08);
    color: var(--gold-l); font-size: 0.82rem; font-weight: 600; border-radius: 4px;
  }
  .sup-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; flex-direction: row-reverse; }

