---
// src/pages/ar/contact.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';
const t    = useTranslations(lang);

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/contact`;

// ── CONTACT DATA ──────────────────────────────────────────────────────
const contact = {
  phone:    { display: '+90 544 169 00 38', schema: '+90-544-169-0038', href: 'tel:+905441690038', wa: '905441690038' },
  email:    { primary: 'export@cihanpandoor.com' },
  website:  'https://www.cihanpandoor.com',
  address:  { street: 'Organize Sanayi Bölgesi 29. Sokak No:28', city: 'Kayseri', postalCode: '38070' },
  coords:   { lat: 38.713006945276334, lng: 35.32028880684966 },
  maps:     {
    url:      'https://maps.app.goo.gl/XFKFB7tBeBGJ435N9',
    embedUrl: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d49811.34634400007!2d35.32028880684966!3d38.713006945276334!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x152b05342e965841%3A0xfa7a02f50cdebeee!2zQ2loYW5wYW5kb29yIMSww6cgT2RhIEthcMSxc8SxIMSwbWFsYXTEsSB2ZSDEsGhyYWNhdMSx!5e0!3m2!1sen!2str!4v1760624358805!5m2!1sen!2str'
  }
};

const waMessage = 'مرحباً، أود الحصول على معلومات حول منتجات CihanPan Door.';

// ── FAQ ───────────────────────────────────────────────────────────────
const faqs = [
  { q: 'إلى أي دول تقومون بالتصدير؟',            a: 'نقوم بالتصدير إلى الولايات المتحدة والاتحاد الأوروبي والمملكة المتحدة والشرق الأوسط وشمال أفريقيا. تأتي جميع الشحنات مع وثائق CE وISO 9001 وتصنيف الحريق الكاملة. كما نوفر أسعاراً وفق شروط Incoterms DDP/DAP لطلبات الحاويات.' },
  { q: 'ما هو الحد الأدنى لكمية الطلب؟',          a: 'الحد الأدنى للطلب هو 50 وحدة للنماذج القياسية. الأحجام أو التشطيبات المخصصة تتطلب 100 وحدة على الأقل. تُطبق خصومات الحجم من 200 وحدة. الطلبات المختلطة (مثل Laminox + Elitpan) تُحتسب كحد أدنى واحد.' },
  { q: 'ما هي مدة الإنتاج؟',                      a: 'النماذج القياسية: 15–25 يوم عمل بعد تأكيد الطلب. الأحجام أو التشطيبات المخصصة: 25–35 يوم عمل. قد يتوفر الإنتاج السريع — تواصل معنا لمناقشة جدولك الزمني.' },
  { q: 'هل تقدمون خدمات التركيب؟',                a: 'التركيب متاح في جميع أنحاء تركيا. بالنسبة لطلبات التصدير، نوفر أدلة التركيب الفنية ويمكننا ترتيب الدعم الفني الميداني للمشاريع الكبيرة.' },
  { q: 'ما هو الضمان الذي تقدمونه؟',              a: 'تأتي جميع نماذج الأبواب بضمان 5 سنوات من الشركة المصنعة يغطي عيوب المواد وتدهور الأسطح وبهتان الألوان. ينطبق الضمان على المنتجات المستخدمة في ظروف التشغيل العادية.' },
  { q: 'هل يمكنكم تصنيع أحجام مخصصة؟',           a: 'نعم. الحد الأقصى للعرض 120 سم، الحد الأقصى للارتفاع 250 سم. يتطلب الإنتاج المخصص 100 وحدة على الأقل ويستغرق 25–35 يوم عمل. يمكن أيضاً تحديد فتحات الزجاج وتحضير القفل الإلكتروني.' },
];

// ── SCHEMA ────────────────────────────────────────────────────────────
const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "اتصل بنا — CihanPan Door",
  "description": "تواصل مع CihanPan Door للحصول على أسعار الجملة واستفسارات التصدير واستشارات المشاريع.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "url": baseUrl,
    "contactPoint": [{
      "@type": "ContactPoint",
      "telephone": contact.phone.schema,
      "contactType": "Sales",
      "email": contact.email.primary,
      "areaServed": ["TR", "EU", "ME", "US"],
      "availableLanguage": ["Turkish", "English", "German", "Arabic"]
    }],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": contact.address.street,
      "addressLocality": contact.address.city,
      "postalCode": contact.address.postalCode,
      "addressCountry": "TR"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": contact.coords.lat, "longitude": contact.coords.lng },
    "hasMap": contact.maps.url
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "CihanPan Door",
  "url": baseUrl,
  "telephone": contact.phone.schema,
  "email": contact.email.primary,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": contact.address.street,
    "addressLocality": contact.address.city,
    "postalCode": contact.address.postalCode,
    "addressCountry": "TR"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": contact.coords.lat, "longitude": contact.coords.lng },
  "hasMap": contact.maps.url,
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  }],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "152" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "اتصل بنا",  "item": currentUrl },
  ]
};

const env = import.meta.env;
const publicWeb3formsKey = env.PUBLIC_WEB3FORMS_KEY || 'd890c520-d1c8-428f-9abb-f510ef10e1ff';
---

<I18nLayout
  title="اتصل بنا — CihanPan Door | عرض أسعار الجملة ☎ +90 544 169 00 38"
  description="تواصل مع CihanPan Door في قيصري للحصول على أسعار الجملة لأبواب PVC ولامينوكس وإليتبان وأبواب المستشفيات والفنادق. استفسارات التصدير مرحب بها. الحد الأدنى للطلب 50 وحدة."
  keywords="CihanPan Door اتصل, أبواب داخلية بالجملة تركيا, مصنع أبواب قيصري تصدير, سعر باب لامينوكس"
  canonical={currentUrl}
  schema={[contactSchema, localBusinessSchema, faqSchema, breadcrumbSchema]}
  ogTitle="اتصل بـ CihanPan Door — عرض سعر الجملة"
  ogDescription="احصل على عرض سعر مجاني بالجملة لأبواب Laminox وElitpan وPVC والمستشفيات والفنادق من قيصري، تركيا."
  ogImage="/assets/img/og/contact-og.webp"
  dir="rtl"
  lang="ar"
>
  <I18nHeader />

  <main class="lam" id="main-content" dir="rtl" lang="ar">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">اتصل بنا</span>
          </nav>
          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            تواصل معنا
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>اتصل بـ CihanPan Door</em><br/>عروض أسعار الجملة واستفسارات التصدير
          </h1>
          <p class="lam-hero__lead">
            أسعار الجملة المباشرة من المصنع لأبواب PVC ولامينوكس وإليتبان وأبواب المستشفيات والفنادق من قيصري، تركيا. رد خلال 24 ساعة.
          </p>
          <div class="lam-hero__actions">
            <a href={`#form`} class="lam-btn lam-btn--gold">
              طلب عرض سعر مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={`https://wa.me/${contact.phone.wa}?text=${encodeURIComponent(waMessage)}`} target="_blank" rel="noopener" class="lam-btn lam-btn--ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
              واتساب
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>24h</strong><span>رد</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>MOQ 50</strong><span>وحدة</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>5<sup>سنوات</sup></strong><span>ضمان</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>معتمد</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CONTACT CARDS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-label="معلومات الاتصال">
      <div class="lam-wrap">
        <div class="lam-head">
          <span class="lam-tag">اتصل بنا</span>
          <h2>تواصل معنا مباشرة</h2>
          <p>طرق متعددة للوصول إلى فريق المبيعات والتصدير لدينا — نرد باللغات التركية والإنجليزية والألمانية والعربية.</p>
        </div>

        <div class="lam-cinfo-grid">

          <!-- Phone -->
          <div class="lam-cinfo-card">
            <div class="lam-cinfo-icon">📞</div>
            <h3>الهاتف</h3>
            <a href={contact.phone.href} class="lam-cinfo-link">{contact.phone.display}</a>
            <p>الاثنين–السبت · 08:00–18:00 (توقيت تركيا)</p>
          </div>

          <!-- WhatsApp -->
          <div class="lam-cinfo-card">
            <div class="lam-cinfo-icon">💬</div>
            <h3>واتساب</h3>
            <a href={`https://wa.me/${contact.phone.wa}?text=${encodeURIComponent(waMessage)}`} target="_blank" rel="noopener" class="lam-cinfo-link">
              إرسال رسالة
            </a>
            <p>7/24 — أسرع قناة للرد</p>
          </div>

          <!-- Email -->
          <div class="lam-cinfo-card">
            <div class="lam-cinfo-icon">✉️</div>
            <h3>البريد الإلكتروني</h3>
            <a href={`mailto:${contact.email.primary}`} class="lam-cinfo-link">{contact.email.primary}</a>
            <p>رد خلال 24 ساعة</p>
          </div>

          <!-- Address -->
          <div class="lam-cinfo-card">
            <div class="lam-cinfo-icon">📍</div>
            <h3>عنوان المصنع</h3>
            <address style="font-style:normal;">
              {contact.address.street}<br/>
              {contact.address.city} {contact.address.postalCode}<br/>
              تركيا
            </address>
            <a href={contact.maps.url} target="_blank" rel="noopener" class="lam-cinfo-link" style="margin-top:0.5rem;">
              عرض على الخريطة ←
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CONTACT FORM
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="form" aria-labelledby="form-h2">
      <div class="lam-wrap">
        <div class="lam-form-wrap">
          <div class="lam-head" style="margin-bottom:2rem;">
            <span class="lam-tag">عرض سعر مجاني</span>
            <h2 id="form-h2">طلب عرض سعر بالجملة</h2>
            <p>املأ النموذج — سنرد خلال 24 ساعة بأسعار مباشرة من المصنع.</p>
          </div>

          <form id="contactForm" class="lam-form" novalidate>
            <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="lam-form-row">
              <div class="lam-form-group">
                <label for="name">الاسم الكامل *</label>
                <input type="text" id="name" name="name" required placeholder="اسمك الكامل" minlength="2" />
                <span id="name-error" class="lam-form-err"></span>
              </div>
              <div class="lam-form-group">
                <label for="email">البريد الإلكتروني *</label>
                <input type="email" id="email" name="email" required placeholder="you@company.com" />
                <span id="email-error" class="lam-form-err"></span>
              </div>
            </div>

            <div class="lam-form-row">
              <div class="lam-form-group">
                <label for="phone">الهاتف *</label>
                <input type="tel" id="phone" name="phone" required placeholder="+966 / +971 / +90 ..." />
                <span id="phone-error" class="lam-form-err"></span>
              </div>
              <div class="lam-form-group">
                <label for="company">اسم الشركة</label>
                <input type="text" id="company" name="company" placeholder="اسم شركتك (اختياري)" />
              </div>
            </div>

            <div class="lam-form-group">
              <label for="product">المنتج المطلوب</label>
              <select id="product" name="product">
                <option value="">اختر...</option>
                <option value="pvc">أبواب PVC</option>
                <option value="laminoks">أبواب لامينوكس</option>
                <option value="elitpan">أبواب إليتبان</option>
                <option value="hastane">أبواب المستشفيات</option>
                <option value="otel">أبواب الفنادق</option>
                <option value="yangin">أبواب مقاومة للحريق</option>
                <option value="diger">أخرى</option>
              </select>
            </div>

            <div class="lam-form-group">
              <label for="message">رسالتك *</label>
              <textarea id="message" name="message" required rows="5"
                placeholder="يرجى التحديد: نوع الباب، الكمية، بلد/ميناء التسليم، أي متطلبات خاصة..."
                minlength="10"></textarea>
              <span id="message-error" class="lam-form-err"></span>
            </div>

            <button type="submit" class="lam-btn lam-btn--gold lam-btn--submit" id="submitBtn">
              <span class="btn-text">إرسال طلب عرض السعر</span>
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         GOOGLE MAPS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="map-h2">
      <div class="lam-wrap">
        <div class="lam-head">
          <span class="lam-tag">موقع المصنع</span>
          <h2 id="map-h2">زورونا في قيصري</h2>
        </div>
        <div class="lam-map-wrap">
          <iframe
            src={contact.maps.embedUrl}
            width="100%"
            height="420"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="CihanPan Door Kayseri Organized Industrial Zone"
          ></iframe>
        </div>
        <div class="lam-map-actions">
          <a href={contact.maps.url} target="_blank" rel="noopener noreferrer" class="lam-btn lam-btn--navy">
            📍 فتح في خرائط جوجل
          </a>
          <a href={`https://www.google.com/maps/dir//${contact.coords.lat},${contact.coords.lng}`}
             target="_blank" rel="noopener noreferrer" class="lam-btn lam-btn--outline">
            🧭 الحصول على الاتجاهات
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="faq-h2">
      <div class="lam-wrap lam-faq-wrap">
        <div class="lam-head">
          <span class="lam-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">الأسئلة المتكررة</h2>
        </div>
        <div class="lam-faqs">
          {faqs.map(item => (
            <details class="lam-faq">
              <summary class="lam-faq__q">
                {item.q}
                <span class="lam-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="lam-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SOCIAL / CTA BAND
    ══════════════════════════════════════════ -->
    <section class="lam-cta" aria-labelledby="cta-h2">
      <div class="lam-cta__glow" aria-hidden="true"></div>
      <div class="lam-wrap lam-cta__inner">
        <div class="lam-cta__text">
          <span class="lam-tag lam-tag--gold">تابعونا</span>
          <h2 id="cta-h2">ابقَ على تواصل<br/>مع CihanPan Door</h2>
          <p>تابع أحدث نماذج الأبواب وعروض المشاريع وتحديثات الصناعة على وسائل التواصل الاجتماعي.</p>
        </div>
        <div class="lam-social-grid">
          <a href={`https://wa.me/${contact.phone.wa}?text=${encodeURIComponent(waMessage)}`} target="_blank" rel="noopener" class="lam-social-btn lam-social-btn--wa">
