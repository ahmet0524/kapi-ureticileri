  .lam-head p { color: var(--slate); font-size: 1rem; max-width: 560px; margin-inline: auto; line-height: 1.9; }
  .lam-tag { display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .lam-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .lam-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 600; padding: 0.9rem 1.75rem;
    border-radius: 8px; text-decoration: none; white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform .2s, box-shadow .2s, background .2s, border-color .2s;
    cursor: pointer; border: none;
  }
  .lam-btn--gold    { background: var(--gold);  color: var(--navy);  font-weight: 700; }
  .lam-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,.4); }
  .lam-btn--navy    { background: var(--navy);  color: var(--white); }
  .lam-btn--navy:hover  { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,.3); }
  .lam-btn--ghost   { background: transparent; color: rgba(255,255,255,.85); border: 1.5px solid rgba(255,255,255,.25); }
  .lam-btn--ghost:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.07); transform: translateY(-2px); }
  .lam-btn--outline { background: transparent; color: var(--navy); border: 1.5px solid var(--bdr); }
  .lam-btn--outline:hover { border-color: var(--navy); transform: translateY(-2px); }
  .lam-btn--submit  { width: 100%; justify-content: center; padding: 1rem 2rem; font-size: 1rem; }

  /* ── HERO ── */
  .lam-hero {
    position: relative; min-height: 65vh; display: flex;
    flex-direction: column; justify-content: center;
    padding-top: 70px; overflow: hidden;
  }
  .lam-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .lam-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,.96) 0%, rgba(15,35,71,.88) 60%, rgba(26,58,110,.82) 100%);
  }
  .lam-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 20% 30%, rgba(201,168,76,.09) 0%, transparent 65%),
