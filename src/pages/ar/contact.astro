  }
  .lam-sitem { display: flex; flex-direction: column; flex: 1; min-width: 80px; padding-inline: 1rem; text-align: center; }
  .lam-sitem:first-child { padding-right: 0; }
  .lam-sitem:last-child  { padding-left: 0; }
  .lam-sitem strong {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem; font-weight: 900; color: var(--gold); line-height: 1; display: block;
  }
  .lam-sitem strong sup { font-size: .7em; }
  .lam-sitem span { font-size: .72rem; letter-spacing: .02em; color: rgba(255,255,255,.5); margin-top: .3rem; display: block; }
  .lam-sdiv { width: 1px; height: 32px; background: rgba(255,255,255,.12); flex-shrink: 0; }

  /* ── CONTACT INFO GRID ── */
  .lam-cinfo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }
  .lam-cinfo-card {
    background: var(--white); border: 1px solid var(--bdr);
    border-radius: var(--radius); padding: 2rem 1.5rem;
