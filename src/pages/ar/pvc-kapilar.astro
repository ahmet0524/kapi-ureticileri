---
// src/pages/ar/pvc-kapilar.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang    = 'ar';
const baseUrl = 'https://cihanpandoor.netlify.app';
const pageUrl = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/pvc-kapilar`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const pvcSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "أبواب PVC الداخلية — 247 موديل | CihanPan Door",
  "description": "أبواب PVC داخلية مقاومة للماء ومضادة للبكتيريا بالجملة من كايسيري، تركيا. 247 موديل، معتمد CE وISO 9001. تصدير إلى الولايات المتحدة وأوروبا والشرق الأوسط.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "ItemList",
    "name": "موديلات أبواب PVC",
    "numberOfItems": 247,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "باب PVC داخلي",
        "description": "باب PVC داخلي مقاوم للماء ومضاد للبكتيريا. لا يتشوه في البيئات الرطبة. ضمان 5 سنوات. مصنّع تركي معتمد CE.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "PVC",
        "category": "باب داخلي",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": "247",
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.8",
          "reviewCount": "152",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "ما هو باب PVC ولماذا يُفضَّل؟", "acceptedAnswer": { "@type": "Answer", "text": "أبواب PVC مصنوعة من البولي فينيل كلوريد، مقاومة تمامًا للماء ومضادة للبكتيريا. لا تتشوه في البيئات الرطبة، سهلة الصيانة، وفعّالة من حيث التكلفة لمشاريع البيع بالجملة." }},
    { "@type": "Question", "name": "ما الفرق بين أبواب PVC والأبواب الخشبية؟", "acceptedAnswer": { "@type": "Answer", "text": "أبواب PVC مقاومة تمامًا للرطوبة، بينما الأبواب الخشبية حساسة للرطوبة وتحتاج إلى صيانة دورية. PVC أكثر اقتصادًا وأسهل في الصيانة مع مظهر جذاب." }},
    { "@type": "Question", "name": "أين تُستخدم أبواب PVC عادةً؟", "acceptedAnswer": { "@type": "Answer", "text": "الحمامات، المطابخ، الشرفات، غرف النوم، المستشفيات، غرف الفنادق وأي بيئة عالية الرطوبة. السطح المضاد للبكتيريا يجعلها مناسبة بشكل خاص للمشاريع الصحية والضيافة." }},
    { "@type": "Question", "name": "ما هو الحد الأدنى للطلب بالجملة؟", "acceptedAnswer": { "@type": "Answer", "text": "الحد الأدنى للطلب 50 وحدة. خصومات الكميات تسري من 200+ وحدة. تتوفر مقاسات مخصصة وتشطيبات وعلامة تجارية خاصة للطلبات الكبيرة." }},
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات",  "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "أبواب PVC", "item": currentUrl },
  ]
};

const allSchemas = [pvcSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'جميع المنتجات',   active: false },
  { slug: '/pvc-kapilar',               label: 'أبواب PVC',       active: true  },
  { slug: '/laminoks-kapilar',          label: 'أبواب لامينوكس',  active: false },
  { slug: '/elitpan-kapilar',           label: 'أبواب إليتبان',   active: false },
  { slug: '/hastane-kapilari',          label: 'أبواب المستشفيات',active: false },
  { slug: '/otel-kapilari',             label: 'أبواب الفنادق',   active: false },
  { slug: '/yangina-dayanikli-kapilar', label: 'أبواب مقاومة للحريق', active: false },
];
---

<I18nLayout
  title="أبواب PVC الداخلية — 247 موديل | بالجملة من تركيا | CihanPan Door"
  description="أبواب PVC داخلية مقاومة للماء ومضادة للبكتيريا بالجملة من كايسيري، تركيا. 247 موديل، معتمد CE وISO 9001. أسعار مباشرة من المصنع للمستوردين. الحد الأدنى 50 وحدة."
  keywords="أبواب PVC بالجملة تركيا, باب مقاوم للماء, باب مضاد للبكتيريا, مصدر أبواب تركي, باب PVC معتمد CE, أبواب داخلية بالجملة"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="أبواب PVC الداخلية — 247 موديل | CihanPan Door تركيا"
  ogDescription="أبواب PVC مقاومة للماء ومضادة للبكتيريا. مباشرة من المصنع في كايسيري. الحد الأدنى 50 وحدة. معتمد CE وISO 9001."
  ogImage="/assets/img/og/pvc-kapilar-og.webp"
  dir="rtl"
  lang="ar"
>
  <I18nHeader />

  <main class="pvc" id="main-content" dir="rtl" lang="ar">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="pvc-hero" aria-labelledby="pvc-h1">
      <div class="pvc-hero__bg" aria-hidden="true">
        <div class="pvc-hero__overlay"></div>
        <div class="pvc-hero__glow"></div>
      </div>
      <div class="pvc-wrap pvc-hero__inner">
        <div>
          <nav class="pvc-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">‹</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>المنتجات</a>
            <span aria-hidden="true">‹</span>
            <span aria-current="page">أبواب PVC</span>
          </nav>

          <span class="pvc-eyebrow">
            <span class="pvc-eyebrow__line"></span>
            الأكثر مبيعًا · 247 موديل
          </span>
          <h1 class="pvc-hero__h1" id="pvc-h1">
            <em>أبواب PVC الداخلية</em><br/>مقاومة للماء · مضادة للبكتيريا
          </h1>
          <p class="pvc-hero__lead">
            أبواب PVC بالجملة مباشرة من مصنعنا في كايسيري، تركيا.
            معتمدة CE وISO 9001. مثالية للحمامات والمستشفيات والبيئات الرطبة.
            الحد الأدنى للطلب 50 وحدة.
          </p>
          <div class="pvc-hero__tags">
            <span class="pvc-htag">✓ مقاوم للماء</span>
            <span class="pvc-htag">✓ مضاد للبكتيريا</span>
            <span class="pvc-htag">✓ 247 موديل</span>
            <span class="pvc-htag">✓ CE & ISO 9001</span>
          </div>
          <div class="pvc-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold">
              احصل على عرض سعر مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="pvc-btn pvc-btn--ghost">
              استعرض الموديلات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="pvc-wrap">
        <div class="pvc-statsbar">
          <div class="pvc-sitem"><strong>247</strong><span>موديل</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>CE</strong><span>معتمد</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>50<sup>+</sup></strong><span>خيار لوني</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>MOQ 50</strong><span>وحدة</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="pvc-wrap">

        <!-- Category filter tabs -->
        <nav class="pvc-catnav" aria-label="فئات الأبواب">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`pvc-catbtn${cat.active ? ' pvc-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="pvc-head" style="margin-top:0">
          <span class="pvc-tag">مجموعة أبواب PVC</span>
          <h2 id="catalogue-h2">موديلات أبواب PVC الداخلية</h2>
          <p>تصفّح مجموعتنا الكاملة من أبواب PVC. كل موديل متوفر بألوان متعددة. اطلب عرض سعر بالجملة لأي موديل.</p>
        </div>

        <!-- Quote CTA -->
        <div class="pvc-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--navy">
            اطلب عرض سعر بالجملة
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="pvc-quote-note">رد خلال 24 ساعة · الحد الأدنى 50 وحدة</span>
        </div>

        <!-- Products Grid (JS-rendered) -->
        <div class="pvc-grid" id="productsGrid" aria-live="polite" aria-label="موديلات أبواب PVC"></div>

        <!-- Loading state -->
        <div class="pvc-loading" id="loading" aria-label="جارٍ تحميل الموديلات">
          <div class="pvc-spinner" aria-hidden="true"></div>
          <p>جارٍ تحميل موديلات أبواب PVC…</p>
        </div>

        <!-- Pagination -->
        <nav class="pvc-pagination" aria-label="التنقل بين الصفحات">
          <div class="pvc-page-info">
            <span class="pvc-page-current">الصفحة 1 من 3</span>
            <span class="pvc-page-count">يُعرض 95 موديل</span>
          </div>
          <div class="pvc-page-btns">
            <span class="pvc-page-btn pvc-page-btn--disabled" aria-disabled="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18L15 12L9 6"/></svg>
              السابق
            </span>
            <a href={getLocalizedRoute('/pvc-kapilar-2', lang)} class="pvc-page-btn">
              الصفحة 2
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18L9 12L15 6"/></svg>
            </a>
          </div>
          <div class="pvc-page-dots" aria-hidden="true">
            <span class="pvc-dot pvc-dot--active"></span>
            <a href={getLocalizedRoute('/pvc-kapilar-2', lang)} class="pvc-dot"></a>
            <a href={getLocalizedRoute('/pvc-kapilar-3', lang)} class="pvc-dot"></a>
          </div>
        </nav>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--cream" aria-labelledby="content-h2">
      <div class="pvc-wrap pvc-content-wrap">

        <!-- Main editorial text -->
        <article class="pvc-article">
          <h2 id="content-h2">ما هو باب PVC؟ لماذا تختار أبواب PVC؟</h2>

          <p>
            <strong>أبواب PVC الداخلية</strong> مصنوعة من البولي فينيل كلوريد وتلبّي متطلبات المباني السكنية والتجارية الحديثة.
            في <strong>CihanPan Door</strong>، ينتج مصنعنا في كايسيري أبوابًا عالية الجودة منذ عام 1995،
            ونصدّر بالجملة إلى المستوردين في الولايات المتحدة وأوروبا والشرق الأوسط.
          </p>

          <h3>مزايا أبواب PVC</h3>
          <ul class="pvc-checklist">
            <li><strong>مقاومة للماء:</strong> مقاومة كاملة للرطوبة والماء — لا تتشوه ولا تنتفخ ولا تتعفن.</li>
            <li><strong>سطح مضاد للبكتيريا:</strong> يمنع نمو البكتيريا — مثالي للبيئات التي تستلزم النظافة.</li>
            <li><strong>سهولة الصيانة:</strong> يُنظَّف بقطعة قماش مبللة فقط — لا يحتاج إلى طلاء أو ورنيش.</li>
            <li><strong>عزل صوتي:</strong> تقليل فعّال للضوضاء بين الغرف.</li>
            <li><strong>اقتصادي:</strong> تسعير تنافسي بالجملة مع متانة عالية.</li>
          </ul>

          <h3>مجالات الاستخدام</h3>
          <p>تُقدّم أبواب PVC أداءً متفوقًا في البيئات الرطبة:</p>
          <ul class="pvc-checklist">
            <li><strong>أبواب الحمامات:</strong> مقاومة كاملة للبخار ورذاذ الماء.</li>
            <li><strong>أبواب المطابخ:</strong> لا تمتص روائح الطعام أو الزيوت.</li>
            <li><strong>المستشفيات والرعاية الصحية:</strong> السطح المضاد للبكتيريا يلبّي معايير النظافة.</li>
            <li><strong>غرف الفنادق:</strong> سهولة الصيانة بين الإقامات.</li>
            <li><strong>المجمعات السكنية:</strong> حل فعّال من حيث التكلفة للمشاريع الكبيرة.</li>
          </ul>

          <h3>المواصفات الفنية</h3>
          <ul class="pvc-checklist">
            <li>المقاس القياسي: 70×200 سم — مقاسات مخصصة متاحة</li>
            <li>القلب الداخلي: قرص الشهد أو خشب شبه صلب</li>
            <li>السطح: فيلم لمينات PVC</li>
            <li>أكثر من 50 خيار لون وتشطيب</li>
            <li>معتمد CE وISO 9001</li>
            <li>ضمان 5 سنوات من الشركة المصنّعة</li>
          </ul>
        </article>

        <!-- Sticky sidebar -->
        <aside class="pvc-sidebar">
          <div class="pvc-kpis">
            <div class="pvc-kpi"><strong>247</strong><span>موديل</span></div>
            <div class="pvc-kpi"><strong>50<sup>+</sup></strong><span>لون</span></div>
            <div class="pvc-kpi"><strong>CE</strong><span>معتمد</span></div>
            <div class="pvc-kpi"><strong>5yr</strong><span>ضمان</span></div>
          </div>

          <div class="pvc-contact-card">
            <span class="pvc-tag">تواصل معنا</span>
            <h3>اطلب عرض سعر</h3>
            <p>أرسل لنا الكميات ومتطلباتك — سنردّ خلال 24 ساعة.</p>
            <div class="pvc-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold pvc-btn--sm">
                نموذج التواصل
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="pvc-btn pvc-btn--wa pvc-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                واتساب
              </a>
              <a href="tel:+905441690038" class="pvc-btn pvc-btn--outline pvc-btn--sm">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <div class="pvc-features-card">
            <h3>المميزات الرئيسية</h3>
            <ul class="pvc-feat-list">
              <li>🚿 تقنية مقاومة الماء</li>
              <li>🦠 سطح مضاد للبكتيريا</li>
              <li>🔇 عزل صوتي</li>
              <li>💰 سعر تنافسي بالجملة</li>
              <li>📐 مقاسات مخصصة متاحة</li>
              <li>♻️ مواد صديقة للبيئة</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--white" aria-labelledby="faq-h2">
      <div class="pvc-wrap pvc-faq-wrap">
        <div class="pvc-head">
          <span class="pvc-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">أسئلة المشترين بالجملة الشائعة</h2>
        </div>
        <div class="pvc-faqs">
          {[
            { q: 'ما هو باب PVC ولماذا يُفضَّل؟',              a: 'أبواب PVC مصنوعة من البولي فينيل كلوريد، مقاومة تمامًا للماء ومضادة للبكتيريا. لا تتشوه في البيئات الرطبة، سهلة الصيانة، وفعّالة من حيث التكلفة لمشاريع البيع بالجملة.' },
            { q: 'ما الفرق بين أبواب PVC والأبواب الخشبية؟',  a: 'أبواب PVC مقاومة تمامًا للرطوبة، بينما الأبواب الخشبية حساسة للرطوبة وتحتاج إلى صيانة دورية. PVC أكثر اقتصادًا وأسهل في الصيانة مع مظهر جذاب.' },
            { q: 'أين تُستخدم أبواب PVC عادةً؟',              a: 'الحمامات، المطابخ، الشرفات، غرف النوم، المستشفيات، غرف الفنادق وأي بيئة عالية الرطوبة. السطح المضاد للبكتيريا يجعلها مناسبة بشكل خاص للمشاريع الصحية والضيافة.' },
            { q: 'ما هو الحد الأدنى للطلب بالجملة؟',          a: 'الحد الأدنى للطلب 50 وحدة. خصومات الكميات تسري من 200+ وحدة. تتوفر مقاسات مخصصة وتشطيبات وعلامة تجارية خاصة للطلبات الكبيرة.' },
          ].map(item => (
            <details class="pvc-faq">
              <summary class="pvc-faq__q">
                {item.q}
