---
// src/pages/ar/urunlerimiz.astro  (AR version)
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/urunlerimiz`;

// ── SCHEMA ───────────────────────────────────────────────────────────
const productsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "منتجاتنا — مواد الأبواب الداخلية والإكسسوارات",
  "description": "أكثر من 350 موديل وخيارات مواد. PVC، لامينوكس، إليتبان، قلب قرص العسل، الإكسسوارات.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "ItemList",
    "name": "فئات المنتجات",
    "numberOfItems": 6,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "item": { "@type": "Product", "name": "أبواب PVC الداخلية",     "url": `${pageUrl}/pvc-kapilar` }},
      { "@type": "ListItem", "position": 2, "item": { "@type": "Product", "name": "أبواب لامينوكس الداخلية","url": `${pageUrl}/laminoks-kapilar` }},
      { "@type": "ListItem", "position": 3, "item": { "@type": "Product", "name": "أبواب إليتبان MDF",       "url": `${pageUrl}/elitpan-kapilar` }},
      { "@type": "ListItem", "position": 4, "item": { "@type": "Product", "name": "أبواب المستشفيات",        "url": `${pageUrl}/hastane-kapilari` }},
      { "@type": "ListItem", "position": 5, "item": { "@type": "Product", "name": "أبواب غرف الفنادق",       "url": `${pageUrl}/otel-kapilari` }},
      { "@type": "ListItem", "position": 6, "item": { "@type": "Product", "name": "أبواب مقاومة للحريق",     "url": `${pageUrl}/yangina-dayanikli-kapilar` }},
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "ما هي موديلات الأبواب التي تصنعونها?",    "acceptedAnswer": { "@type": "Answer", "text": "أبواب PVC (247 موديل)، أبواب لامينوكس/ميلامين (أكثر من 80 موديل)، أبواب إليتبان (أكثر من 26 موديل)، أبواب المستشفيات، أبواب الفنادق، أبواب مقاومة للحريق وتصاميم مخصصة. أكثر من 350 موديل إجمالاً." }},
    { "@type": "Question", "name": "ما هي المواد الداخلية المستخدمة في الأبواب?", "acceptedAnswer": { "@type": "Answer", "text": "نستخدم قلب قرص العسل (Honeycomb)، خشب شبه صلب وخيارات ملء كامل. يوفر قلب قرص العسل بنية خفيفة الوزن وعالية المقاومة وعزلاً صوتياً ممتازاً." }},
    { "@type": "Question", "name": "ما الفرق بين سطح PVC ولامينوكس?",          "acceptedAnswer": { "@type": "Answer", "text": "أبواب PVC تستخدم طبقة بلاستيكية مقاومة للماء وأكثر اقتصادية. أبواب لامينوكس تتميز بسطح ميلامين عالي الضغط (HPL) على MDF — أكثر مقاومة للخدش بتشطيب راقٍ ومجموعة ألوان أوسع." }},
    { "@type": "Question", "name": "هل تصنعون أبواباً بمقاسات مخصصة?",        "acceptedAnswer": { "@type": "Answer", "text": "نعم. بالإضافة إلى المقاسات القياسية، نصنع أبعاداً غير اعتيادية لطلبات المشاريع بالجملة. تتوفر أيضاً تشطيبات مخصصة وخيارات الملصق الخاص." }},
    { "@type": "Question", "name": "هل منتجاتكم مشمولة بالضمان?",              "acceptedAnswer": { "@type": "Answer", "text": "جميع موديلات الأبواب مشمولة بضمان المصنع لمدة 5 سنوات يغطي عيوب الإنتاج وتقشر السطح وبهتان الألوان." }},
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات", "item": currentUrl }
  ]
};

const allSchemas = [productsSchema, faqSchema, breadcrumbSchema];

// ── CATEGORIES DATA ───────────────────────────────────────────────────
const doorCategories = [
  { slug: '/pvc-kapilar',               badge: 'الأكثر مبيعاً', badgeGold: true,  title: 'أبواب PVC الداخلية',     desc: 'سطح PVC مقاوم للماء ومضاد للبكتيريا. مثالي للحمامات والمستشفيات والأماكن عالية الرطوبة. 247 موديل.', tags: ['مقاوم للماء','مضاد للبكتيريا','سهل الصيانة'], img: '/assets/img/categories/pvc-kapilar.webp' },
  { slug: '/laminoks-kapilar',          badge: 'مميز',           badgeGold: false, title: 'أبواب لامينوكس الداخلية', desc: 'قلب MDF مع سطح لامينوكس متين ومقاوم للخدش. أكثر من 50 لون. 80+ موديل.', tags: ['مقاوم للخدش','50+ لون','قلب MDF'], img: '/assets/img/categories/laminoks-kapilar.webp', featured: true },
  { slug: '/elitpan-kapilar',           badge: 'بريميوم',        badgeGold: false, title: 'أبواب إليتبان MDF',        desc: 'سطح MDF مطلي بالأشعة فوق البنفسجية بلمعان عالٍ. جودة تصدير. أكثر من 26 موديل.', tags: ['طلاء UV','لمعان عالٍ','جودة تصدير'], img: '/assets/img/categories/elitpan-kapilar.webp' },
  { slug: '/hastane-kapilari',          badge: 'متخصص',          badgeGold: false, title: 'أبواب المستشفيات',          desc: 'أبواب صحية معتمدة CE. خيارات مبطنة بالرصاص، مقاومة للإشعاع ومضادة للميكروبات.', tags: ['معتمدة CE','خيار رصاصي','مضاد للميكروبات'], img: '/assets/img/categories/hastane-kapilari.webp' },
  { slug: '/otel-kapilari',             badge: 'ضيافة',           badgeGold: false, title: 'أبواب غرف الفنادق',         desc: 'أبواب معزولة صوتياً ومقاومة للحريق للفنادق 3★–5★. أسعار خاصة للطلبات فوق 500 وحدة.', tags: ['عزل صوتي','مقاوم للحريق','سعر الجملة'], img: '/assets/img/categories/otel-kapilari.webp' },
  { slug: '/yangina-dayanikli-kapilar', badge: 'معتمدة',          badgeGold: false, title: 'أبواب مقاومة للحريق',       desc: 'أبواب حريق EI30–EI90 معتمدة CE. متوافقة مع معايير البناء الأوروبية والدولية.', tags: ['EI30–EI90','معتمدة CE','متوافق مع المعايير'], img: '/assets/img/categories/yangina-dayanikli-kapilar.webp' },
];

const faqItems = [
  { q: 'ما هي موديلات الأبواب التي تصنعونها?',       a: 'أبواب PVC (247 موديل)، أبواب لامينوكس/ميلامين (أكثر من 80 موديل)، أبواب إليتبان (أكثر من 26 موديل)، أبواب المستشفيات، أبواب الفنادق، أبواب مقاومة للحريق وتصاميم مخصصة. أكثر من 350 موديل إجمالاً.' },
  { q: 'ما هي المواد الداخلية المستخدمة في الأبواب?', a: 'نستخدم قلب قرص العسل (Honeycomb)، خشب شبه صلب وخيارات ملء كامل. يوفر قلب قرص العسل بنية خفيفة الوزن وعالية المقاومة وعزلاً صوتياً ممتازاً.' },
  { q: 'ما الفرق بين سطح PVC ولامينوكس?',             a: 'أبواب PVC تستخدم طبقة بلاستيكية مقاومة للماء وأكثر اقتصادية. أبواب لامينوكس تتميز بسطح ميلامين عالي الضغط (HPL) على MDF — أكثر مقاومة للخدش بتشطيب راقٍ ومجموعة ألوان أوسع.' },
  { q: 'هل تصنعون أبواباً بمقاسات مخصصة?',           a: 'نعم. بالإضافة إلى المقاسات القياسية، نصنع أبعاداً غير اعتيادية لطلبات المشاريع بالجملة. تتوفر أيضاً تشطيبات مخصصة وخيارات الملصق الخاص.' },
  { q: 'هل منتجاتكم مشمولة بالضمان?',                 a: 'جميع موديلات الأبواب مشمولة بضمان المصنع لمدة 5 سنوات يغطي عيوب الإنتاج وتقشر السطح وبهتان الألوان.' },
];
---

<I18nLayout
  title="منتجاتنا | مواد الأبواب الداخلية والإكسسوارات | CihanPan Door"
  description="مجموعة أبواب داخلية بالجملة من تركيا. PVC، لامينوكس، إليتبان، قلب قرص العسل، الإكسسوارات. أكثر من 350 موديل، شهادة CE."
  keywords="مواد الأبواب الداخلية تركيا، سطح PVC، لامينوكس، قلب قرص العسل، مقابض الأبواب بالجملة، مصنع أبواب معتمد CE"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="مجموعة المنتجات | CihanPan Door"
  ogDescription="أكثر من 350 موديل باب بالجملة من قيصري، تركيا. أسعار مصنع مباشرة، معتمد CE وISO."
  ogImage="/assets/img/og/urunlerimiz-og.webp"
  lang="ar"
  dir="rtl"
>
  <I18nHeader />

  <main class="pp" id="main-content">

    <!-- ══════════════════════════════════════════
         PAGE HERO
    ══════════════════════════════════════════ -->
    <section class="pp-hero" aria-labelledby="pp-h1">
      <div class="pp-hero__bg" aria-hidden="true">
        <div class="pp-hero__overlay"></div>
      </div>
      <div class="pp-wrap pp-hero__inner">
        <div>
          <span class="pp-eyebrow">
            <span class="pp-eyebrow__line"></span>
            مباشرة من المصنع · قيصري، تركيا
          </span>
          <h1 class="pp-hero__h1" id="pp-h1">
            <em>مجموعة منتجاتنا</em><br/>— الأبواب الداخلية والمواد
          </h1>
          <p class="pp-hero__lead">
            أكثر من 350 موديل وخيارات مواد. شهادة CE وISO 9001. أسعار مصنع مباشرة للمستوردين بالجملة حول العالم.
          </p>
          <div class="pp-hero__tags">
            <span class="pp-htag">✓ 350+ موديل</span>
            <span class="pp-htag">✓ CE &amp; ISO 9001</span>
            <span class="pp-htag">✓ حد أدنى 50 وحدة</span>
            <span class="pp-htag">✓ مباشرة من المصنع</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         DOOR CATEGORIES
    ══════════════════════════════════════════ -->
    <section class="pp-sec pp-sec--white" id="door-categories" aria-labelledby="cats-h2">
      <div class="pp-wrap">
        <div class="pp-head">
          <span class="pp-tag">سلاسل الأبواب</span>
          <h2 id="cats-h2">مجموعة الأبواب الداخلية بالجملة</h2>
          <p>ستة خطوط إنتاج تغطي كل شريحة سوقية — السكنية والضيافة والرعاية الصحية والتجارية.</p>
        </div>

        <div class="pp-grid pp-grid--3">
          {doorCategories.map((cat, i) => (
            <article class={`pp-card ${cat.featured ? 'pp-card--featured' : ''}`}>
              <a href={getLocalizedRoute(cat.slug, lang)} class="pp-card__img-wrap" tabindex="-1" aria-hidden="true">
                <img
                  src={cat.img}
                  alt={cat.title}
                  width="480"
                  height="360"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class={`pp-card__badge ${cat.badgeGold ? 'pp-card__badge--gold' : ''}`}>{cat.badge}</span>
              </a>
              <div class="pp-card__body">
                <h3><a href={getLocalizedRoute(cat.slug, lang)}>{cat.title}</a></h3>
                <p>{cat.desc}</p>
                <ul class="pp-card__tags">
                  {cat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <a href={getLocalizedRoute(cat.slug, lang)} class="pp-card__cta">
                  عرض وطلب السعر
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="pp-sec pp-sec--white" aria-labelledby="faq-h2">
      <div class="pp-wrap pp-faq-wrap">
        <div class="pp-head">
          <span class="pp-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">الأسئلة الشائعة</h2>
        </div>
        <div class="pp-faqs">
          {faqItems.map(item => (
            <details class="pp-faq">
              <summary class="pp-faq__q">
                {item.q}
                <span class="pp-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="pp-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="pp-cta" aria-labelledby="cta-h2">
      <div class="pp-cta__glow" aria-hidden="true"></div>
      <div class="pp-wrap pp-cta__inner">
        <div class="pp-cta__text">
          <span class="pp-tag pp-tag--gold">ابدأ اليوم</span>
        <h2 id="cta-h2">اطلب عرض سعر بالجملة لخط الإنتاج</h2>
          <p>
            شارك نوع الباب والكميات ووجهة الشحن. نرد خلال 24 ساعة بأسعار مصنع مباشرة ووثائق CE/ISO كاملة.
          </p>
        </div>
        <div class="pp-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pp-btn pp-btn--gold">
            احصل على عرض سعر مجاني
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/hakkimizda', lang)} class="pp-btn pp-btn--ghost">
            من نحن
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS ── */
  .pp {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;

    font-family: 'Noto Sans Arabic', 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
  .pp-wrap {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }
  .pp-sec          { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .pp-sec--white   { background: var(--white); }
  .pp-sec--cream   { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .pp-head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .pp-head h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.7rem;
    line-height: 1.4;
  }
  .pp-head p {
    color: var(--slate);
    font-size: 1rem;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.9;
  }

  .pp-tag {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .pp-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .pp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .pp-btn--gold { background: var(--gold); color: var(--navy); font-weight: 700; }
  .pp-btn--gold:hover { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .pp-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .pp-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }

  /* ── HERO ── */
  .pp-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    padding-top: 70px;
    overflow: hidden;
  }
  .pp-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .pp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.97) 0%, rgba(15,35,71,0.92) 60%, rgba(26,58,110,0.88) 100%);
  }
  .pp-hero__inner {
    position: relative;
    z-index: 1;
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }
  .pp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }
  .pp-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: 0.5; flex-shrink: 0; }
  .pp-hero__h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.25;
    margin: 0 0 1.2rem;
  }
  .pp-hero__h1 em { font-style: normal; color: var(--gold); }
  .pp-hero__lead { font-size: 1.05rem; color: rgba(255,255,255,0.65); line-height: 2; max-width: 580px; margin: 0 0 1.5rem; }
  .pp-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .pp-htag {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border: 1px solid rgba(201,168,76,0.35);
    background: rgba(201,168,76,0.08);
    color: var(--gold-l);
    font-size: 0.82rem;
    font-weight: 600;
    border-radius: 4px;
  }

  /* ── GRIDS ── */
  .pp-grid--3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  /* ── DOOR CARDS ── */
  .pp-card {
    background: var(--white);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }
  .pp-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px rgba(15,35,71,0.1); border-color: rgba(201,168,76,0.3); }
  .pp-card--featured { border-color: var(--gold); box-shadow: 0 4px 24px rgba(201,168,76,0.15); }
  .pp-card__img-wrap { display: block; position: relative; overflow: hidden; aspect-ratio: 3/4; text-decoration: none; }
  .pp-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.45s cubic-bezier(0.22,1,0.36,1); }
  .pp-card:hover .pp-card__img-wrap img { transform: scale(1.06); }
  .pp-card__badge {
    position: absolute;
    top: 14px; left: 14px;          /* RTL: badge moves to left */
    background: var(--navy);
    color: var(--white);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    border-radius: 20px;
  }
  .pp-card__badge--gold { background: var(--gold); color: var(--navy); }
  .pp-card__body { padding: 1.5rem; }
