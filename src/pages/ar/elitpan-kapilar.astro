---
// src/pages/ar/elitpan-kapilar.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/elitpan-kapilar`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Elitpan-Serisi-301.webp",
  "CihanpanDoor-Elitpan-Serisi-302.webp",
  "CihanpanDoor-Elitpan-Serisi-303.webp",
  "CihanpanDoor-Elitpan-Serisi-304.webp",
  "CihanpanDoor-Elitpan-Serisi-305.webp",
  "CihanpanDoor-Elitpan-Serisi-306.webp",
  "CihanpanDoor-Elitpan-Serisi-307.webp",
  "CihanpanDoor-Elitpan-Serisi-308.webp",
  "CihanpanDoor-Elitpan-Serisi-309.webp",
  "CihanpanDoor-Elitpan-Serisi-310.webp",
  "CihanpanDoor-Elitpan-Serisi-311.webp",
  "CihanpanDoor-Elitpan-Serisi-312.webp",
  "CihanpanDoor-Elitpan-Serisi-313.webp",
  "CihanpanDoor-Elitpan-Serisi-314.webp",
  "CihanpanDoor-Elitpan-Serisi-315.webp",
  "CihanpanDoor-Elitpan-Serisi-316.webp",
  "CihanpanDoor-Elitpan-Serisi-317.webp",
  "CihanpanDoor-Elitpan-Serisi-318.webp",
  "CihanpanDoor-Elitpan-Serisi-319.webp",
  "CihanpanDoor-Elitpan-Serisi-320.webp",
  "CihanpanDoor-Elitpan-Serisi-321.webp",
  "CihanpanDoor-Elitpan-Serisi-322.webp",
  "CihanpanDoor-Elitpan-Serisi-323.webp",
  "CihanpanDoor-Elitpan-Serisi-324.webp",
  "CihanpanDoor-Elitpan-Serisi-325.webp",
  "CihanpanDoor-Elitpan-Serisi-326.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const elitpanSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `أبواب إليتبان الداخلية المغطاة بالأشعة فوق البنفسجية — ${modelCount}+ طراز | CihanPan Door`,
  "description": `أبواب إليتبان الداخلية بالجملة من قيصري، تركيا. مضادة للبكتيريا، مقاومة للخدش، ${modelCount}+ طراز، معتمدة CE، أسعار مباشرة من المصنع للفنادق والمستشفيات والمشاريع التجارية.`,
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "ItemList",
    "name": "طرازات أبواب إليتبان",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "باب إليتبان داخلي مغطى بالأشعة فوق البنفسجية",
        "description": "باب داخلي من MDF مغطى بالأشعة فوق البنفسجية. مضاد للبكتيريا، مقاوم للخدش، مقاوم للرطوبة. معتمد CE، ضمان 5 سنوات. تصنيع بالجملة من قيصري، تركيا.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "طلاء UV فوق MDF",
        "category": "باب داخلي",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "ما هو باب إليتبان؟", "acceptedAnswer": { "@type": "Answer", "text": "أبواب إليتبان هي أبواب داخلية فاخرة بقلب من MDF مغطى بطبقة UV مضادة للبكتيريا وعالية المقاومة للخدش والرطوبة، مثالية للمستشفيات والفنادق والمباني التجارية والمشاريع السكنية الراقية." }},
    { "@type": "Question", "name": "ما الفرق بين أبواب إليتبان ولامينوكس؟", "acceptedAnswer": { "@type": "Answer", "text": "كلا السلسلتين تستخدمان قلباً من MDF. أبواب إليتبان تتميز بطلاء UV يوفر لمعاناً استثنائياً وثبات ألوان وخصائص مضادة للبكتيريا. أبواب لامينوكس (HPL) تستخدم لمينيت ضغط عالٍ بمقاومة فائقة للخدش والصدمات. يُفضَّل إليتبان عندما تكون اللمعة الفاخرة والنظافة أولوية." }},
    { "@type": "Question", "name": "هل أبواب إليتبان مناسبة للبيئات الرطبة؟", "acceptedAnswer": { "@type": "Answer", "text": "نعم. طلاء UV وقلب MDF المقاوم للرطوبة يجعلان أبواب إليتبان مناسبة للحمامات والمطابخ والأماكن الداخلية ذات الرطوبة المعتدلة. للبيئات الرطبة جداً، يُنصح بإضافة عزل إضافي لإطار الباب." }},
    { "@type": "Question", "name": "ما هو الحد الأدنى للطلب بالجملة لأبواب إليتبان؟", "acceptedAnswer": { "@type": "Answer", "text": "الحد الأدنى للطلب 50 وحدة. تسري خصومات الكميات من 200 وحدة. تتوفر مقاسات مخصصة وفتحات زجاجية وخيارات العلامة التجارية الخاصة للطلبات الكبيرة." }},
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",  "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات", "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "أبواب إليتبان الداخلية", "item": currentUrl },
  ]
};

const allSchemas = [elitpanSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'جميع المنتجات',    active: false },
  { slug: '/pvc-kapilar',               label: 'أبواب PVC',         active: false },
  { slug: '/laminoks-kapilar',          label: 'أبواب لامينوكس',    active: false },
  { slug: '/elitpan-kapilar',           label: 'أبواب إليتبان',     active: true  },
  { slug: '/hastane-kapilari',          label: 'أبواب المستشفيات',  active: false },
  { slug: '/otel-kapilari',             label: 'أبواب الفنادق',     active: false },
  { slug: '/yangina-dayanikli-kapilar', label: 'أبواب مقاومة للحريق', active: false },
];

// ── SSR PRODUCT LIST (for SEO) ────────────────────────────────────────
interface ElitpanProduct {
  id: string;
  model: string;
  label: string;
  image: string;
  alt: string;
}

const elitpanProducts: ElitpanProduct[] = fileNames.map((fn) => {
  const model = fn.replace('.webp', '').split('-').pop()!;
  return {
    id:    `elitpan-${model}`,
    model,
    label: `إليتبان ${model}`,
    image: `/assets/img/elitpan-doors/${fn}`,
    alt:   `CihanPan Door طراز إليتبان ${model} — باب داخلي UV`,
  };
});

const faqItems = [
  { q: 'ما هو باب إليتبان؟',                               a: 'أبواب إليتبان هي أبواب داخلية فاخرة بقلب من MDF مغطى بطبقة UV مضادة للبكتيريا وعالية المقاومة للخدش والرطوبة، مثالية للمستشفيات والفنادق والمباني التجارية والمشاريع السكنية الراقية.' },
  { q: 'ما الفرق بين أبواب إليتبان ولامينوكس؟',           a: 'كلا السلسلتين تستخدمان قلباً من MDF. أبواب إليتبان تتميز بطلاء UV يوفر لمعاناً استثنائياً وثبات ألوان وخصائص مضادة للبكتيريا. أبواب لامينوكس تستخدم HPL بمقاومة فائقة للخدش. يُفضَّل إليتبان عندما تكون اللمعة والنظافة أولوية.' },
  { q: 'هل أبواب إليتبان مناسبة للبيئات الرطبة؟',          a: 'نعم. طلاء UV وقلب MDF المقاوم للرطوبة يجعلانها مناسبة للحمامات والمطابخ والأماكن ذات الرطوبة المعتدلة. للبيئات الرطبة جداً يُنصح بإضافة عزل لإطار الباب.' },
  { q: 'ما هو الحد الأدنى للطلب بالجملة؟',                 a: 'الحد الأدنى للطلب 50 وحدة. تسري خصومات الكميات من 200 وحدة فأكثر. تتوفر مقاسات مخصصة وفتحات زجاجية وخيارات العلامة التجارية الخاصة للطلبات الكبيرة.' },
];
---

<I18nLayout
  title={`أبواب إليتبان الداخلية UV — ${modelCount}+ طراز | بالجملة من تركيا | CihanPan Door`}
  description={`أبواب إليتبان الداخلية بالجملة من قيصري، تركيا. قلب MDF مضاد للبكتيريا، ${modelCount}+ طراز، معتمدة CE وISO 9001. أسعار مباشرة من المصنع للفنادق والمستشفيات والمشاريع التجارية. الحد الأدنى 50 وحدة.`}
  keywords="أبواب إليتبان بالجملة تركيا، مصنع أبواب UV، أبواب مضادة للبكتيريا قيصري، باب داخلي مقاوم للخدش معتمد CE"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={`أبواب إليتبان الداخلية — ${modelCount}+ طراز | CihanPan Door`}
  ogDescription="أبواب إليتبان الداخلية المضادة للبكتيريا. مباشرة من المصنع بقيصري. الحد الأدنى 50 وحدة."
  ogImage="/assets/img/og/elitpan-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content" dir="rtl" lang="ar">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">‹</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>المنتجات</a>
            <span aria-hidden="true">‹</span>
            <span aria-current="page">أبواب إليتبان</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            مجموعة UV الفاخرة · {modelCount}+ طراز
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>أبواب إليتبان الداخلية</em><br/>UV مغطاة · مضادة للبكتيريا · تشطيب فاخر
          </h1>
          <p class="lam-hero__lead">
            أبواب إليتبان الداخلية بالجملة مباشرة من مصنع قيصري، تركيا. طلاء UV على قلب MDF متين — مقاومة فائقة للبكتيريا والرطوبة والخدش. معتمدة CE وISO 9001. {modelCount}+ طراز. الحد الأدنى للطلب 50 وحدة.
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ قلب MDF مغطى بـ UV</span>
            <span class="lam-htag">✓ {modelCount}+ طراز</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ مضاد للبكتيريا</span>
            <span class="lam-htag">✓ الحد الأدنى 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              احصل على عرض سعر مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              استعرض الطرازات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}<sup>+</sup></strong><span>طراز</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>UV</strong><span>طلاء</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>معتمد</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>50+</strong><span>حد أدنى</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label="فئات الأبواب">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">مجموعة أبواب إليتبان</span>
          <h2 id="catalogue-h2">طرازات أبواب إليتبان الداخلية</h2>
          <p>
            استعرض المجموعة الكاملة لأبواب إليتبان UV — {modelCount} طراز، السلسلة 301–326. كل طراز متوفر بعدة خيارات تشطيب. اضغط على أي طراز لطلب عرض سعر بالجملة.
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            طلب عرض سعر بالجملة
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">رد خلال 24 ساعة · الحد الأدنى 50 وحدة</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid" id="productsGrid" aria-label="طرازات أبواب إليتبان">
          {elitpanProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 8 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <p class="lam-card__name">{product.label}</p>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">ما هو باب إليتبان؟ لماذا تختار MDF المغطى بالأشعة فوق البنفسجية؟</h2>

          <p>
            <strong>أبواب إليتبان الداخلية</strong> مصنوعة بقلب متين من MDF مشطَّب بـ <em>طلاء UV</em> يُثبَّت مباشرة على السطح تحت الأشعة فوق البنفسجية. في <strong>CihanPan Door</strong>، ينتج مصنعنا في قيصري المجموعة الكاملة المكونة من {modelCount} طراز من إليتبان لمشتري الجملة في الشرق الأوسط وأوروبا والولايات المتحدة.
          </p>

          <h3>مزايا أبواب إليتبان</h3>
          <ul class="lam-checklist">
            <li><strong>سطح مضاد للبكتيريا:</strong> يُنشئ طلاء UV سطحاً غير مسامي ومضاداً للبكتيريا — ضروري للمستشفيات والعيادات ومرافق تجهيز الغذاء.</li>
            <li><strong>ثبات لوني استثنائي:</strong> الأصباغ المثبتة بـ UV تقاوم البهتان من أشعة الشمس ومواد التنظيف بكفاءة أعلى من اللمينيت التقليدي.</li>
            <li><strong>مقاومة الخدش والصدمات:</strong> السطح المُصلَّد بـ UV يتحمل الاستخدام اليومي والعربات والأجسام الحادة الشائعة في البيئات التجارية.</li>
            <li><strong>مقاوم للرطوبة:</strong> قلب MDF المقاوم للرطوبة وطلاء UV المغلق يمنعان الانحناء في الحمامات والمطابخ.</li>
            <li><strong>سهولة الصيانة:</strong> السطح غير المسامي يُمسح بسهولة — لا حاجة للطلاء أو السدادة طوال عمر المنتج.</li>
            <li><strong>جماليات عالية اللمعان:</strong> طلاء UV يوفر لمعاناً عميقاً ومتسقاً يرفع مستوى التصميم الداخلي في الفنادق الفاخرة والمساكن الراقية.</li>
          </ul>

          <h3>تطبيقات مثالية</h3>
          <p>تتفوق أبواب إليتبان في كل مكان تتلاقى فيه النظافة والجماليات والمتانة:</p>
          <ul class="lam-checklist">
            <li><strong>المستشفيات والرعاية الصحية:</strong> السطح المضاد للبكتيريا يستوفي أصرم معايير النظافة في البيئات السريرية.</li>
            <li><strong>الفنادق والضيافة:</strong> التشطيب اللامع الفاخر والسطح المتين يتحملان حركة النزلاء الكثيفة بأدنى صيانة.</li>
            <li><strong>المباني التجارية:</strong> جماليات لامعة عصرية للمكاتب وأماكن البيع بالتجزئة والمباني العامة.</li>
            <li><strong>المناطق الرطبة السكنية:</strong> الخصائص المقاومة للرطوبة والمضادة للبكتيريا تجعل إليتبان الباب المثالي للحمام والمطبخ.</li>
          </ul>

          <h3>المواصفات الفنية</h3>
          <ul class="lam-checklist">
            <li>السطح: طلاء UV — لمعان عالٍ، مضاد للبكتيريا</li>
            <li>القلب: MDF متين مقاوم للرطوبة</li>
            <li>المقاس القياسي: 70×200 سم · 80×200 سم — مقاسات مخصصة متوفرة</li>
            <li>خيارات التشطيب: لمعان عالٍ، ساتان، منقوش</li>
            <li>خيارات فتحة الزجاج متوفرة</li>
            <li>معتمد CE وISO 9001</li>
            <li>ضمان المصنع 5 سنوات</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}<sup>+</sup></strong><span>طراز</span></div>
            <div class="lam-kpi"><strong>UV</strong><span>طلاء</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>معتمد</span></div>
            <div class="lam-kpi"><strong>5 سنوات</strong><span>ضمان</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">تواصل معنا</span>
            <h3>طلب عرض سعر</h3>
            <p>شاركنا الكمية والمتطلبات — نرد خلال 24 ساعة.</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                نموذج التواصل
              </a>
