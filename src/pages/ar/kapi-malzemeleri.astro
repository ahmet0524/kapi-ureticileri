---
// src/pages/ar/kapi-malzemeleri.astro
// AR → /ar/kapi-malzemeleri
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';

const lang  = 'ar';
const isRTL = true;

const colourCount = '50+';
const modelCount  = '350+';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const currentUrl = `${baseUrl}/ar/kapi-malzemeleri`;

// ── PAGE META ─────────────────────────────────────────────────────────
const meta = {
  title:         'مواد تصنيع الأبواب — الهيكل الداخلي والأسطح والإكسسوارات | CihanPan Door',
  description:   'اكتشف المواد الكاملة المستخدمة في إنتاج CihanPan Door: أنوية قرص النحل وشبه الصلبة، ألواح PVC وLaminox، مقابض، مفصلات وأختام صوتية. مصنع في قيصري، تركيا.',
  keywords:      'مواد تصنيع الأبواب، باب نواة قرص النحل، باب خشب شبه صلب، سطح PVC، لمينوكس HPL، مفصلات أبواب بالجملة',
  ogTitle:       'دليل مواد الأبواب | CihanPan Door',
  ogDescription: 'كل ما بداخل أبوابنا — أنوية قرص النحل، ألواح HPL، مقابض، مفصلات وأختام. بيع بالجملة مباشرة من المصنع في قيصري.',
};

// ── SCHEMA ────────────────────────────────────────────────────────────
const materialsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": meta.title,
  "description": meta.description,
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "publisher": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl }
};

const faqData = [
  { q: 'ما هي نواة قرص النحل في الأبواب الداخلية؟',
    a: 'نواة قرص النحل هي هيكل داخلي خفيف الوزن مصنوع من خلايا سداسية. توفر نسبة عالية من القوة إلى الوزن، وعزلاً صوتياً ممتازاً، ومقاومة للرطوبة مع الحفاظ على الباب خفيفاً وسهل التركيب.' },
  { q: 'ما الفرق بين نواة قرص النحل 1 ونواة قرص النحل 2؟',
    a: 'نواة قرص النحل 1 هي نواتنا القياسية خفيفة الوزن، مثالية للأبواب السكنية. نواة قرص النحل 2 تتميز ببنية خلوية أكثر كثافة توفر أداءً صوتياً متفوقاً وصلابة أكبر.' },
  { q: 'ما هو الخشب شبه الصلب ومتى يُستخدم؟',
    a: 'يجمع الخشب شبه الصلب بين إطارات خشبية طبيعية وحشو داخلي. يُستخدم في مجموعاتنا الراقية وفي كل مكان يتطلب قوة تثبيت مفصلات متفوقة أو إحساساً صلباً فاخراً.' },
  { q: 'ما الفرق بين أسطح PVC وLaminox؟',
    a: 'PVC هو فيلم ثرموبلاستيكي مقاوم للماء مضغوط بالتفريغ على MDF — مثالي للحمامات. Laminox (ميلامين HPL) هو لامينات عالي الضغط يوفر مقاومة أكبر للخدش والصدمات وتشطيباً فاخراً.' },
  { q: 'هل يمكنني طلب الإكسسوارات بشكل منفصل عن الأبواب؟',
    a: 'نعم. نوفر المقابض وأطقم الأقفال والمفصلات والأختام كمكونات متكاملة مع أبوابنا وكإكسسوارات منفصلة لطلبات المشاريع بالجملة. تواصل معنا للحصول على الأسعار والحد الأدنى للطلب.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",   "item": `${baseUrl}/ar` },
    { "@type": "ListItem", "position": 2, "name": "المنتجات",   "item": `${baseUrl}/ar/products` },
    { "@type": "ListItem", "position": 3, "name": "مواد الأبواب", "item": currentUrl },
  ]
};

const allSchemas = [materialsSchema, faqSchema, breadcrumbSchema];

// ── MATERIALS DATA ────────────────────────────────────────────────────
const materials = [
  {
    category: 'core', img: '/assets/img/materials/honeycomb-1-core.webp',
    title: 'نواة قرص النحل 1', subtitle: 'نواة خفيفة الوزن قياسية',
    desc: 'هيكل داخلي خفيف الوزن وعالي القوة بتصميم قرص النحل. تصميم الخلايا السداسية يزيد الصلابة إلى أقصى حد مع تقليل الوزن — يعزز متانة الباب ويوفر أداءً دائماً في جميع خطوط الأبواب القياسية.',
    tags: ['بناء خفيف الوزن', 'قوة عالية', 'عزل صوتي', 'مقاوم للرطوبة'],
    specs: [['حجم الخلية', '15-20 مم'], ['كثافة النواة', 'قياسية'], ['الأنسب لـ', 'أبواب سكنية']],
  },
  {
    category: 'core', img: '/assets/img/materials/honeycomb-2-core.webp',
    title: 'نواة قرص النحل 2', subtitle: 'نواة بريميوم كثيفة الخلايا',
    desc: 'قرص نحل كثيف الخلايا بتكنولوجيا تصنيع متقدمة. أداء صوتي متفوق وصلابة أكبر ومتانة محسّنة — يُستخدم في خطوط الأبواب الفاخرة والمشاريع حيث الأداء لا يقبل التنازل.',
    tags: ['بنية خلوية كثيفة', 'متانة فائقة', 'صوتيات محسّنة', 'صديق للبيئة'],
    specs: [['حجم الخلية', '10-13 مم'], ['كثافة النواة', 'عالية'], ['الأنسب لـ', 'أبواب فاخرة ومشاريع']],
  },
  {
    category: 'core', img: '/assets/img/materials/semi-solid-core.webp',
    title: 'خشب شبه صلب', subtitle: 'صلابة الخشب الطبيعي',
    desc: 'إطارات خشبية طبيعية مع حشو داخلي — صلابة الخشب الحقيقي بوزن عملي. قوة استثنائية لتثبيت المفصلات وإحساس فاخر، يُستخدم في مجموعات الأبواب الراقية لدينا.',
    tags: ['خشب طبيعي', 'صلابة عالية', 'جودة بريميوم', 'طويل الأمد'],
    specs: [['المادة', 'صنوبر طبيعي / حور'], ['الوزن', 'متوسط-ثقيل'], ['الأنسب لـ', 'مجموعات راقية']],
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'مواد سطح PVC', subtitle: 'لامينات ثرموبلاستيك مقاوم للماء',
    desc: 'فيلم PVC مقاوم للماء مضغوط بالتفريغ على ركيزة MDF. مقاوم للغاية للرطوبة، سهل التنظيف ومتوفر بطيف واسع من الألوان والتشطيبات الخشبية — الخيار الاقتصادي للمناطق الرطبة.',
    tags: ['مقاوم للماء', 'سهل التنظيف', 'نطاق واسع من الألوان', 'فعّال من حيث التكلفة'],
    specs: [['السماكة', '0.18-0.25 مم'], ['التشطيب', 'مات / لامع / نقش خشبي'], ['التطبيق', 'ضغط تفريغ']],
    link: '/ar/pvc-doors', linkLabel: 'عرض أبواب PVC',
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'مواد سطح Laminox', subtitle: 'لامينات ميلامين عالي الضغط (HPL)',
    desc: 'لامينات ميلامين عالي الضغط (HPL) ملصق على MDF. مقاومة فائقة للخدش والصدمات مقارنةً بـ PVC القياسي — أنماط أكثر ثراءً، خيارات مات أو لامع وتشطيب جمالي فاخر.',
    tags: ['مقاوم للخدش', 'مقاوم للصدمات', 'أنماط غنية', 'خيارات مات ولامع'],
    specs: [['السماكة', '0.6-1.0 مم'], ['التشطيب', 'مات / لامع عالي / منقوش'], ['التطبيق', 'ضغط بارد / ساخن']],
    link: '/ar/laminox-doors', linkLabel: 'عرض أبواب Laminox',
  },
  {
    category: 'accessories', img: '/assets/img/materials/door-handles.webp',
    title: 'مقابض الأبواب وأنظمة الأقفال', subtitle: 'أجهزة من الفولاذ المقاوم للصدأ والنحاس',
    desc: 'مقابض أبواب فاخرة من الفولاذ المقاوم للصدأ والنحاس. تصاميم بيئية، خيارات تشطيب متعددة — كروم، أسود مات، ذهبي، ساتان — مع أسطوانات قفل أمان مدمجة لكل تطبيق.',
    tags: ['فولاذ 304 مقاوم للصدأ', 'تصميم بيئي', 'تشطيب متعدد', 'أسطوانات قفل أمان'],
    specs: [['المادة', 'SS304 / نحاس'], ['التشطيبات', 'كروم، أسود مات، ذهبي، ساتان'], ['المعيار', 'EN 1906']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/hinges.webp',
    title: 'المفصلات والتركيبات', subtitle: 'أنظمة مفصلات هادئة وثقيلة الاستخدام',
    desc: 'أنظمة مفصلات مهندسة بدقة من فولاذ عالي الجودة. تشغيل هادئ، ضبط ثلاثي الأبعاد سهل وعمر خدمة طويل — متوافقة مع جميع أوزان وملفات أبواب CihanPan.',
    tags: ['تشغيل هادئ', 'متانة عالية', 'ضبط ثلاثي الأبعاد سهل', 'مقاوم للتآكل'],
    specs: [['المادة', 'فولاذ / سبيكة زنك'], ['قدرة التحميل', 'حتى 120 كجم'], ['التشطيب', 'نيكل / كروم / أبيض']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/seals.webp',
    title: 'أختام وأنظمة العزل', subtitle: 'إحكام صوتي كامل الهواء',
    desc: 'أختام عالية الجودة من TPE وEPDM تمنع تسرب الهواء وتقلل انتقال الصوت وتحسن كفاءة الطاقة. ضرورية للراحة السكنية وتجميعات الأبواب المصنفة صوتياً.',
    tags: ['إحكام هوائي', 'تقليل صوتي', 'توفير طاقة', 'مقاوم للأشعة فوق البنفسجية'],
    specs: [['المادة', 'TPE / EPDM'], ['نطاق الحرارة', '-30 إلى +80 درجة'], ['ضغط الضغط', '< 20 %']],
  },
];

// ── COMPARISON TABLE ──────────────────────────────────────────────────
const cmpHeaders = ['الخاصية', 'نواة قرص النحل 1', 'نواة قرص النحل 2', 'خشب شبه صلب'];

const comparisonRows = [
  ['الوزن',           'خفيف',           'متوسط-خفيف',    'متوسط-ثقيل'],
  ['القوة',           '3/5',            '4/5',           '5/5'],
  ['العزل الصوتي',    '3/5',            '4/5',           '4/5'],
  ['مقاومة الرطوبة',  '4/5',            '4/5',           '3/5'],
  ['صديق للبيئة',    'نعم',            'نعم',           'جزئياً'],
  ['الأنسب لـ',      'سكني / اقتصادي', 'فاخر / صوتي',  'راقي / صلب'],
];

// ── UI STRINGS ────────────────────────────────────────────────────────
const ui = {
  filterAll:         'الكل',
  filterCore:        'مواد النواة',
  filterSurface:     'مواد السطح',
  filterAccessories: 'الإكسسوارات',
  catCore:           'نواة',
  catSurface:        'سطح',
  catAccessory:      'إكسسوار',
  heroEyebrow:       'جودة التصنيع · قيصري، تركيا',
  heroH1a:           'ما بداخل كل باب',
  heroH1b:           'CihanPan',
  heroLead:          'من نواة قرص النحل إلى لامينات السطح وكل مفصلة بينهما — دليل شامل للمواد التي تحدد جودة أبوابنا.',
  heroCert1:         'ISO 9001 معتمد',
  heroCert2:         'CE متوافق',
  heroCert3:         'مباشر من المصنع',
  heroCert4:         'أسعار الجملة',
  heroBtn1:          'استكشف المواد',
  heroBtn2:          'طلب عرض سعر',
  coreTypes:         'أنواع النواة',
  surfaceLines:      'خطوط السطح',
  colourOptions:     'خيارات اللون',
  doorModels:        'موديلات الأبواب',
  introTag:          'فلسفتنا',
  introH2:           'الجودة تبدأ من الداخل',
  introP1:           'الباب لا يكون جيداً إلا بمجموع أجزائه. في CihanPan Door نتحكم في كل طبقة — النواة الداخلية ولامينات السطح والأجهزة — في مصنعنا بقيصري. يتم اختيار كل مادة واختبارها لتلبية معايير CE وISO 9001 قبل دخول الإنتاج.',
  introP2:           'فهم ما يوجد داخل أبوابنا يساعدك على تحديد المنتج الصحيح لكل مشروع — سواء كان سكنياً أو ضيافةً أو رعاية صحية أو تجارياً.',
  pillar1Title:      'هيكل النواة',
  pillar1Desc:       'يحدد الوزن والقوة والعزل الصوتي.',
  pillar2Title:      'تشطيب السطح',
  pillar2Desc:       'يحدد الجماليات والمتانة ومقاومة الرطوبة.',
  pillar3Title:      'الأجهزة',
  pillar3Desc:       'المقابض والمفصلات والأختام تكمل الأداء.',
  matTag:            'النطاق الكامل للمواد',
  matH2:             'المواد المستخدمة في أبوابنا',
  matSubtitle:       'قم بالتصفية حسب الفئة لاستكشاف كل مكون — من الهيكل الداخلي إلى السطح والأجهزة.',
  cmpTag:            'مقارنة جانبية',
  cmpH2:             'مقارنة مواد النواة',
  cmpSubtitle:       'اختر الهيكل الداخلي المناسب لاحتياجات مشروعك.',
  faqTag:            'الأسئلة الشائعة',
  faqH2:             'الأسئلة المتكررة',
  ctaTag:            'مستعد للطلب؟',
  ctaH2:             'احصل على أسعار مباشرة من المصنع\nلأي مادة أو باب',
  ctaP:              'شارك مواصفات مشروعك — نوع الباب وتفضيل النواة والتشطيب السطحي والكميات والوجهة. نرد خلال 24 ساعة بالتسعير الكامل ووثائق CE/ISO.',
  ctaBtn1:           'احصل على عرض مجاني',
  ctaBtn2:           'عرض جميع المنتجات',
  contactHref:       '/ar/contact',
  productsHref:      '/ar/products',
};
---

<I18nLayout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage="/assets/img/og/door-materials-og.webp"
  lang={lang}
  dir="rtl"
>
  <I18nHeader />

  <main class="dm" id="main-content" dir="rtl">

    <!-- HERO -->
    <section class="dm-hero" aria-labelledby="dm-h1">
      <div class="dm-hero__bg" aria-hidden="true">
        <div class="dm-hero__overlay"></div>
      </div>
      <div class="dm-wrap dm-hero__inner">
        <div class="dm-hero__content">
          <span class="dm-eyebrow">
            <span class="dm-eyebrow__line"></span>
            {ui.heroEyebrow}
          </span>
          <h1 class="dm-hero__h1" id="dm-h1">
            <em>{ui.heroH1a}</em><br/>{ui.heroH1b}
          </h1>
          <p class="dm-hero__lead">{ui.heroLead}</p>
          <div class="dm-hero__tags">
            <span class="dm-htag">✓ {ui.heroCert1}</span>
            <span class="dm-htag">✓ {ui.heroCert2}</span>
            <span class="dm-htag">✓ {ui.heroCert3}</span>
            <span class="dm-htag">✓ {ui.heroCert4}</span>
          </div>
          <div class="dm-hero__cta">
            <a href="#materials" class="dm-btn dm-btn--gold">{ui.heroBtn1}</a>
            <a href={ui.contactHref} class="dm-btn dm-btn--ghost">{ui.heroBtn2}</a>
          </div>
        </div>
        <div class="dm-hero__stats">
          <div class="dm-stat"><span class="dm-stat__num">3</span><span class="dm-stat__label">{ui.coreTypes}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">2</span><span class="dm-stat__label">{ui.surfaceLines}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{colourCount}</span><span class="dm-stat__label">{ui.colourOptions}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{modelCount}</span><span class="dm-stat__label">{ui.doorModels}</span></div>
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="dm-section dm-section--light">
      <div class="dm-wrap dm-intro">
        <div class="dm-intro__text">
          <span class="dm-tag">{ui.introTag}</span>
          <h2>{ui.introH2}</h2>
          <p>{ui.introP1}</p>
          <p>{ui.introP2}</p>
        </div>
        <div class="dm-intro__pillars">
          <div class="dm-pillar"><span class="dm-pillar__icon">🏗️</span><div><strong>{ui.pillar1Title}</strong><p>{ui.pillar1Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🎨</span><div><strong>{ui.pillar2Title}</strong><p>{ui.pillar2Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🔩</span><div><strong>{ui.pillar3Title}</strong><p>{ui.pillar3Desc}</p></div></div>
        </div>
      </div>
    </section>

    <!-- MATERIALS GRID -->
    <section class="dm-section" id="materials" aria-labelledby="dm-mat-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.matTag}</span>
          <h2 id="dm-mat-h2">{ui.matH2}</h2>
          <p class="dm-section__sub">{ui.matSubtitle}</p>
        </div>
        <div class="dm-filters" role="tablist">
          <button class="dm-filter dm-filter--active" data-filter="all" role="tab" aria-selected="true">{ui.filterAll}</button>
          <button class="dm-filter" data-filter="core" role="tab" aria-selected="false">{ui.filterCore}</button>
          <button class="dm-filter" data-filter="surface" role="tab" aria-selected="false">{ui.filterSurface}</button>
          <button class="dm-filter" data-filter="accessories" role="tab" aria-selected="false">{ui.filterAccessories}</button>
        </div>
        <div class="dm-grid">
          {materials.map(m => (
            <article class="dm-card" data-category={m.category}>
              <div class="dm-card__img">
                <img src={m.img} alt={m.title} loading="lazy" width="400" height="200"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="dm-card__placeholder">🚪</div>
                <span class="dm-card__cat-badge">
                  {m.category === 'core' ? ui.catCore : m.category === 'surface' ? ui.catSurface : ui.catAccessory}
                </span>
              </div>
              <div class="dm-card__body">
                <p class="dm-card__subtitle">{m.subtitle}</p>
                <h3>{m.title}</h3>
                <p class="dm-card__desc">{m.desc}</p>
                <ul class="dm-card__tags">
                  {m.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <table class="dm-card__specs">
                  <tbody>
                    {m.specs.map(([k,v]) => (
                      <tr><th scope="row">{k}</th><td>{v}</td></tr>
                    ))}
                  </tbody>
                </table>
                {m.link && (
                  <a href={m.link} class="dm-card__link">← {m.linkLabel}</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON TABLE -->
    <section class="dm-section dm-section--light" aria-labelledby="dm-cmp-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.cmpTag}</span>
          <h2 id="dm-cmp-h2">{ui.cmpH2}</h2>
          <p class="dm-section__sub">{ui.cmpSubtitle}</p>
        </div>
        <div class="dm-table-wrap">
          <table class="dm-cmp-table">
            <thead>
              <tr>{cmpHeaders.map(h => <th scope="col">{h}</th>)}</tr>
            </thead>
            <tbody>
              {comparisonRows.map(row => (
                <tr>
                  {row.map((cell, i) => i === 0
                    ? <td class="dm-cmp-prop">{cell}</td>
                    : <td>{cell}</td>
                  )}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="dm-section" aria-labelledby="dm-faq-h2">
      <div class="dm-wrap dm-faq-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.faqTag}</span>
          <h2 id="dm-faq-h2">{ui.faqH2}</h2>
        </div>
        <div class="dm-faqs">
          {faqData.map(f => (
            <details class="dm-faq">
              <summary class="dm-faq__q">
                {f.q}
                <svg class="dm-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="dm-faq__a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="dm-cta" aria-labelledby="dm-cta-h2">
      <div class="dm-cta__glow" aria-hidden="true"></div>
      <div class="dm-wrap dm-cta__inner">
        <div class="dm-cta__text">
          <span class="dm-tag dm-tag--light">{ui.ctaTag}</span>
          <h2 id="dm-cta-h2">{ui.ctaH2}</h2>
          <p>{ui.ctaP}</p>
        </div>
        <div class="dm-cta__btns">
          <a href={ui.contactHref}  class="dm-btn dm-btn--gold">{ui.ctaBtn1}</a>
          <a href={ui.productsHref} class="dm-btn dm-btn--ghost">{ui.ctaBtn2}</a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  :root {
    --navy:   #0f2347;
    --gold:   #c9a84c;
    --white:  #ffffff;
    --cream:  #f8f6f1;
    --text:   #1a1a2e;
    --body:   #4a4a6a;
    --slate:  #6b7280;
    --bdr:    #e5e0d8;
    --radius: 12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .dm-wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .dm-section { padding: clamp(4rem, 8vw, 6rem) 0; }
  .dm-section--light { background: var(--cream); }
  .dm-section__hd { text-align: center; margin-bottom: 3rem; }
  .dm-section__hd h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; color: var(--text); margin: 0.4rem 0 0.75rem; }
  .dm-section__sub { color: var(--body); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .dm-tag { display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.3rem 0.9rem; }
  .dm-tag--light { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }

  .dm-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.85rem 1.75rem; border-radius: 8px; font-family: 'Inter', system-ui, sans-serif; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
  .dm-btn--gold  { background: var(--gold); color: var(--navy); }
  .dm-btn--gold:hover { background: #b8943e; }
  .dm-btn--ghost { background: transparent; color: var(--white); border: 1.5px solid rgba(255,255,255,0.35); }
  .dm-btn--ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.6); }

  .dm-eyebrow { display: flex; align-items: center; gap: 0.75rem; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }
  .dm-eyebrow__line { display: inline-block; width: 32px; height: 2px; background: var(--gold); flex-shrink: 0; }

  .dm-hero { position: relative; min-height: 92vh; display: flex; align-items: center; background: var(--navy); overflow: hidden; }
  .dm-hero__bg { position: absolute; inset: 0; background: url('/assets/img/hero/door-materials-hero.webp') center/cover no-repeat; }
  .dm-hero__overlay { position: absolute; inset: 0; background: linear-gradient(120deg, rgba(15,35,71,0.92) 45%, rgba(15,35,71,0.55) 100%); }
  .dm-hero__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; padding-top: 6rem; padding-bottom: 4rem; }
  .dm-hero__content { max-width: 600px; }
  .dm-hero__h1 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2.2rem, 5vw, 3.75rem); font-weight: 700; color: var(--white); line-height: 1.1; margin-bottom: 1.25rem; }
  .dm-hero__h1 em { font-style: normal; color: var(--gold); display: block; }
  .dm-hero__lead { color: rgba(255,255,255,0.65); font-size: clamp(0.95rem, 1.8vw, 1.1rem); line-height: 1.75; margin-bottom: 1.5rem; max-width: 520px; }
  .dm-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .dm-htag { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 0.3rem 0.8rem; }
  .dm-hero__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .dm-hero__stats { display: flex; flex-direction: column; gap: 1rem; }
  .dm-stat { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 1.25rem 1.75rem; text-align: center; min-width: 120px; backdrop-filter: blur(6px); }
  .dm-stat__num { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 700; color: var(--gold); line-height: 1; }
  .dm-stat__label { display: block; font-size: 0.75rem; color: rgba(255,255,255,0.5); margin-top: 0.3rem; font-weight: 500; }

  .dm-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .dm-intro__text h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--text); margin: 0.4rem 0 1rem; line-height: 1.25; }
  .dm-intro__text p { color: var(--body); font-size: 0.975rem; line-height: 1.8; margin-bottom: 1rem; }
  .dm-intro__pillars { display: flex; flex-direction: column; gap: 1.25rem; }
  .dm-pillar { display: flex; gap: 1rem; align-items: flex-start; background: var(--cream); border: 1px solid var(--bdr); border-radius: var(--radius); padding: 1.25rem; }
  .dm-pillar__icon { font-size: 1.75rem; flex-shrink: 0; line-height: 1; }
  .dm-pillar strong { display: block; font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem; }
  .dm-pillar p { font-size: 0.875rem; color: var(--body); margin: 0; line-height: 1.6; }

  .dm-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .dm-filter { padding: 0.55rem 1.25rem; border-radius: 8px; border: 1.5px solid var(--bdr); background: var(--white); color: var(--body); font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; }
  .dm-filter:hover { border-color: var(--navy); color: var(--navy); }
  .dm-filter--active { background: var(--navy); border-color: var(--navy); color: var(--white); }

  .dm-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .dm-hidden { display: none !important; }
  .dm-card { background: var(--white); border: 1px solid var(--bdr); border-radius: var(--radius); overflow: hidden; transition: box-shadow 0.25s, transform 0.25s, border-color 0.25s; display: flex; flex-direction: column; }
  .dm-card:hover { box-shadow: 0 8px 32px rgba(15,35,71,0.1); transform: translateY(-4px); border-color: rgba(201,168,76,0.3); }
  .dm-card__img { position: relative; height: 200px; background: var(--cream); overflow: hidden; }
  .dm-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s; }
  .dm-card:hover .dm-card__img img { transform: scale(1.04); }
  .dm-card__placeholder { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; font-size: 2.5rem; background: var(--cream); }
  .dm-card__cat-badge { position: absolute; top: 0.75rem; right: 0.75rem; background: var(--navy); color: var(--white); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.25rem 0.65rem; border-radius: 6px; }
  .dm-card__body { padding: 1.4rem; display: flex; flex-direction: column; flex: 1; }
  .dm-card__subtitle { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin: 0 0 0.35rem; }
  .dm-card__body h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.15rem; font-weight: 700; color: var(--text); margin: 0 0 0.6rem; line-height: 1.3; }
  .dm-card__desc { font-size: 0.875rem; color: var(--body); line-height: 1.7; margin: 0 0 1rem; flex: 1; }
  .dm-card__tags { display: flex; flex-wrap: wrap; gap: 0.35rem; list-style: none; padding: 0; margin: 0 0 1rem; }
  .dm-card__tags li { background: var(--cream); border: 1px solid var(--bdr); color: var(--body); font-size: 0.72rem; font-weight: 500; padding: 0.2rem 0.6rem; border-radius: 20px; }
  .dm-card__specs { width: 100%; border-collapse: collapse; font-size: 0.8rem; margin-bottom: 1rem; }
  .dm-card__specs th { text-align: start; color: var(--slate); font-weight: 600; padding: 0.3rem 0.5rem 0.3rem 0; border-bottom: 1px solid var(--bdr); width: 45%; }
  .dm-card__specs td { color: var(--text); font-weight: 500; padding: 0.3rem 0; border-bottom: 1px solid var(--bdr); }
  .dm-card__link { display: inline-flex; align-items: center; font-size: 0.85rem; font-weight: 600; color: var(--navy); text-decoration: none; margin-top: auto; transition: color 0.2s; }
  .dm-card__link:hover { color: var(--gold); }

  .dm-table-wrap { overflow-x: auto; border-radius: var(--radius); border: 1px solid var(--bdr); }
  .dm-cmp-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; background: var(--white); }
  .dm-cmp-table thead th { background: var(--navy); color: var(--white); font-weight: 600; font-size: 0.85rem; padding: 1rem 1.25rem; text-align: start; white-space: nowrap; }
  .dm-cmp-table thead th:first-child { border-radius: 0 var(--radius) 0 0; }
  .dm-cmp-table thead th:last-child  { border-radius: var(--radius) 0 0 0; }
  .dm-cmp-table tbody tr { border-bottom: 1px solid var(--bdr); }
  .dm-cmp-table tbody tr:last-child { border-bottom: none; }
  .dm-cmp-table tbody tr:nth-child(even) { background: var(--cream); }
  .dm-cmp-table tbody td { padding: 0.85rem 1.25rem; color: var(--body); }
  .dm-cmp-prop { font-weight: 700; color: var(--text); white-space: nowrap; }

  .dm-faq-wrap { max-width: 780px; }
  .dm-faqs { display: flex; flex-direction: column; gap: 0.75rem; }
  .dm-faq { background: var(--white); border: 1px solid var(--bdr); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
  .dm-faq[open] { border-color: rgba(201,168,76,0.35); }
  .dm-faq__q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 1.5rem; cursor: pointer; font-weight: 600; font-size: 0.95rem; color: var(--text); list-style: none; user-select: none; transition: background 0.15s; }
  .dm-faq__q:hover { background: var(--cream); }
  .dm-faq__q::-webkit-details-marker { display: none; }
  .dm-faq__arrow { flex-shrink: 0; color: var(--slate); transition: transform 0.25s; }
  .dm-faq[open] .dm-faq__arrow { transform: rotate(180deg); color: var(--gold); }
  .dm-faq__a { padding: 1rem 1.5rem 1.25rem; font-size: 0.925rem; color: var(--body); line-height: 1.75; margin: 0; border-top: 1px solid var(--bdr); }

  .dm-cta { position: relative; background: var(--navy); overflow: hidden; padding: clamp(4rem, 8vw, 6rem) 0; }
  .dm-cta__glow { position: absolute; inset: 0; background: radial-gradient(ellipse 55% 80% at 105% 50%, rgba(201,168,76,0.14) 0%, transparent 65%), linear-gradient(140deg, #08192e 0%, var(--navy) 100%); pointer-events: none; }
  .dm-cta__inner { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; }
  .dm-cta__text h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 3vw, 2.4rem); font-weight: 700; color: var(--white); margin: 0.35rem 0 0.7rem; line-height: 1.2; white-space: pre-line; }
  .dm-cta__text p { color: rgba(255,255,255,0.55); font-size: 0.95rem; line-height: 1.7; max-width: 420px; margin: 0; }
  .dm-cta__btns { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

  @media (max-width: 1100px) { .dm-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 860px) {
    .dm-hero__inner { grid-template-columns: 1fr; }
    .dm-hero__stats { flex-direction: row; flex-wrap: wrap; justify-content: center; }
    .dm-stat { min-width: 100px; }
    .dm-intro { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 640px) {
    .dm-grid { grid-template-columns: 1fr; }
    .dm-cta__inner { flex-direction: column; text-align: center; }
    .dm-cta__btns { justify-content: center; }
    .dm-hero { min-height: auto; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const filterBtns = document.querySelectorAll('.dm-filter');
    const matCards   = document.querySelectorAll('.dm-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function () {
        filterBtns.forEach(b => { b.classList.remove('dm-filter--active'); b.setAttribute('aria-selected', 'false'); });
        this.classList.add('dm-filter--active');
        this.setAttribute('aria-selected', 'true');
        const filter = this.getAttribute('data-filter');
        matCards.forEach(card => {
          card.classList.toggle('dm-hidden', filter !== 'all' && card.getAttribute('data-category') !== filter);
        });
      });
    });
  });
</script>
