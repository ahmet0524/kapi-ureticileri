  ];

  function parseFileName(fn) {
    const parts = fn.replace('.webp','').split('-');
    const model   = parts[3];
    const variant = parts[4];
    const color   = parts.slice(5).join(' ');
    return { model, variant, color, label: `${model}-${variant} · ${color}` };
  }

  function buildCard(fn) {
    const { model, variant, color, label } = parseFileName(fn);
    const img = `/assets/img/pvc-kapilar/${fn}`;
    const alt = `CihanPan Door PVC Series ${model}-${variant} ${color} — باب داخلي مقاوم للماء`;
    const article = document.createElement('article');
    article.className = 'pvc-card';
    article.setAttribute('aria-label', label);
    article.innerHTML = `
      <div class="pvc-card__img">
        <img src="${img}" alt="${alt}" width="240" height="320" loading="lazy" decoding="async" />
      </div>
      <p class="pvc-card__name">${label}</p>
    `;
    return article;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const grid    = document.getElementById('productsGrid');
    const loading = document.getElementById('loading');
    if (!grid) return;
    loading.style.display = 'block';
    setTimeout(() => {
      const frag = document.createDocumentFragment();
      fileNames.forEach(fn => frag.appendChild(buildCard(fn)));
      grid.appendChild(frag);
      loading.style.display = 'none';
    }, 60);
  });
</script>
