---
// src/pages/ar/pvc-kapilar-3.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang       = 'ar';
const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/pvc-kapilar-3`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const pvcSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "أبواب PVC — الصفحة 3 (موديلات 129–140) | CihanPan Door",
  "description": "موديلات أبواب PVC الداخلية 129–140. أبواب مقاومة للماء ومضادة للبكتيريا بالجملة من كايسيري، تركيا. معتمد CE، أسعار مباشرة من المصنع.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "isPartOf": { "@type": "CollectionPage", "name": "أبواب PVC", "url": `${pageUrl}/pvc-kapilar` }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",  "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات",  "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "أبواب PVC", "item": `${pageUrl}/pvc-kapilar` },
    { "@type": "ListItem", "position": 4, "name": "الصفحة 3",  "item": currentUrl },
  ]
};

const allSchemas = [pvcSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'جميع المنتجات',       active: false },
  { slug: '/pvc-kapilar',               label: 'أبواب PVC',           active: true  },
  { slug: '/laminoks-kapilar',          label: 'أبواب لامينوكس',      active: false },
  { slug: '/elitpan-kapilar',           label: 'أبواب إليتبان',       active: false },
  { slug: '/hastane-kapilari',          label: 'أبواب المستشفيات',    active: false },
  { slug: '/otel-kapilari',             label: 'أبواب الفنادق',       active: false },
  { slug: '/yangina-dayanikli-kapilar', label: 'أبواب مقاومة للحريق', active: false },
];
---

<I18nLayout
  title="أبواب PVC الداخلية — الصفحة 3، موديلات 129–140 | CihanPan Door تركيا"
  description="موديلات أبواب PVC بالجملة 129–140 من كايسيري، تركيا. مقاومة للماء، مضادة للبكتيريا، معتمدة CE وISO 9001. الصفحة الأخيرة من المجموعة. الحد الأدنى 50 وحدة."
  keywords="أبواب PVC الصفحة 3, موديلات 129 130 131 140 PVC, أبواب داخلية بالجملة تركيا, آخر صفحة مجموعة PVC"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="أبواب PVC الصفحة 3 | CihanPan Door"
  ogDescription="موديلات 129–140. الصفحة الأخيرة من مجموعة أبواب PVC بالجملة من تركيا."
  ogImage="/assets/img/og/pvc-kapilar-og.webp"
  dir="rtl"
  lang="ar"
>
  <I18nHeader />

  <main class="pvc" id="main-content" dir="rtl" lang="ar">

    <!-- ══════════════════════════════════════════
         HERO — compact (الصفحة الأخيرة)
    ══════════════════════════════════════════ -->
    <section class="pvc-hero pvc-hero--compact" aria-labelledby="pvc-h1">
      <div class="pvc-hero__bg" aria-hidden="true">
        <div class="pvc-hero__overlay"></div>
        <div class="pvc-hero__glow"></div>
      </div>
      <div class="pvc-wrap pvc-hero__inner">
        <div>
          <nav class="pvc-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">‹</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>المنتجات</a>
            <span aria-hidden="true">‹</span>
            <a href={getLocalizedRoute('/pvc-kapilar', lang)}>أبواب PVC</a>
            <span aria-hidden="true">‹</span>
            <span aria-current="page">الصفحة 3</span>
          </nav>

          <span class="pvc-eyebrow">
            <span class="pvc-eyebrow__line"></span>
            موديلات 129–140 · الصفحة الأخيرة (3 من 3)
          </span>
          <h1 class="pvc-hero__h1" id="pvc-h1">
            <em>أبواب PVC الداخلية</em> — الصفحة 3
          </h1>
          <p class="pvc-hero__lead">
            الصفحة الأخيرة من مجموعة أبواب PVC المقاومة للماء والمضادة للبكتيريا.
            جميع الموديلات معتمدة CE وISO 9001. تصدير بالجملة مباشرة من مصنعنا في كايسيري، تركيا.
          </p>
          <div class="pvc-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold">
              احصل على عرض سعر مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href={getLocalizedRoute('/pvc-kapilar', lang)} class="pvc-btn pvc-btn--ghost">
              العودة إلى الصفحة 1 ›
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="pvc-wrap">

        <nav class="pvc-catnav" aria-label="فئات الأبواب">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`pvc-catbtn${cat.active ? ' pvc-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="pvc-head">
          <span class="pvc-tag">مجموعة أبواب PVC · الصفحة 3 من 3</span>
          <h2 id="catalogue-h2">موديلات أبواب PVC الداخلية 129–140</h2>
          <p>آخر 72 موديل من مجموعة PVC. متوفر بألوان متعددة. اطلب عرض سعر بالجملة لأي موديل.</p>
        </div>

        <div class="pvc-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--navy">
            اطلب عرض سعر بالجملة
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="pvc-quote-note">رد خلال 24 ساعة · الحد الأدنى 50 وحدة</span>
        </div>

        <div class="pvc-grid" id="productsGrid" aria-live="polite" aria-label="موديلات أبواب PVC الصفحة 3"></div>

        <div class="pvc-loading" id="loading" aria-label="جارٍ تحميل الموديلات">
          <div class="pvc-spinner" aria-hidden="true"></div>
          <p>جارٍ تحميل موديلات أبواب PVC…</p>
        </div>

        <!-- الصفحة الأخيرة: زر رجوع فقط، لا يوجد زر تالي -->
        <nav class="pvc-pagination" aria-label="التنقل بين الصفحات">
          <div class="pvc-page-info">
            <span class="pvc-page-current">الصفحة 3 من 3 — الصفحة الأخيرة</span>
            <span class="pvc-page-count">يُعرض 72 موديل · 247 موديل في المجموعة</span>
          </div>
          <div class="pvc-page-btns">
            <a href={getLocalizedRoute('/pvc-kapilar-2', lang)} class="pvc-page-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18L15 12L9 6"/></svg>
              الصفحة 2
            </a>
            <span class="pvc-page-btn pvc-page-btn--disabled" aria-disabled="true">
              الصفحة 3 (الأخيرة)
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18L9 12L15 6"/></svg>
            </span>
          </div>
          <div class="pvc-page-dots" aria-hidden="true">
            <a href={getLocalizedRoute('/pvc-kapilar', lang)} class="pvc-dot"></a>
            <a href={getLocalizedRoute('/pvc-kapilar-2', lang)} class="pvc-dot"></a>
            <span class="pvc-dot pvc-dot--active"></span>
          </div>
        </nav>

        <!-- نهاية المجموعة -->
        <div class="pvc-collection-end">
          <p>✓ لقد استعرضت مجموعة أبواب PVC الكاملة — 247 موديل في 3 صفحات.</p>
          <div class="pvc-collection-end__links">
            <a href={getLocalizedRoute('/laminoks-kapilar', lang)}>استعرض أبواب لامينوكس ←</a>
            <a href={getLocalizedRoute('/elitpan-kapilar', lang)}>استعرض أبواب إليتبان ←</a>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="pvc-cta" aria-labelledby="cta-h2">
      <div class="pvc-cta__glow" aria-hidden="true"></div>
      <div class="pvc-wrap pvc-cta__inner">
        <div class="pvc-cta__text">
          <span class="pvc-tag pvc-tag--gold">ابدأ التوريد اليوم</span>
          <h2 id="cta-h2">اطلب عرض سعر بالجملة<br/>لأبواب PVC</h2>
          <p>أرسل لنا الموديلات والكميات وميناء الوصول. سعر مباشر من المصنع مع وثائق CE وISO خلال 24 ساعة.</p>
        </div>
        <div class="pvc-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold">
            احصل على عرض سعر مجاني
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform:scaleX(-1)"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)} class="pvc-btn pvc-btn--ghost">
            جميع المنتجات
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap');

  .pvc {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;

    font-family: 'Noto Sans Arabic', system-ui, sans-serif;
    color: var(--text);
    direction: rtl;
  }

  .pvc-wrap { max-width: 1160px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2.5rem); width: 100%; }
  .pvc-sec        { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .pvc-sec--white { background: var(--white); }

  .pvc-head { text-align: center; margin-bottom: clamp(2rem, 4vw, 3.5rem); }
  .pvc-head h2 { font-family: 'Noto Sans Arabic', system-ui, sans-serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; color: var(--text); margin: 0.3rem 0 0.7rem; line-height: 1.4; }
  .pvc-head p  { color: var(--slate); font-size: 1rem; max-width: 560px; margin-inline: auto; line-height: 1.9; }

  .pvc-tag { display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.05em; color: var(--gold); margin-bottom: 0.4rem; }
  .pvc-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .pvc-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 600; padding: 0.9rem 1.75rem;
    border-radius: 8px; text-decoration: none; white-space: nowrap;
    font-family: 'Noto Sans Arabic', system-ui, sans-serif;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
  }
  .pvc-btn--gold  { background: var(--gold);  color: var(--navy);  font-weight: 700; }
  .pvc-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .pvc-btn--navy  { background: var(--navy);  color: var(--white); font-weight: 700; }
  .pvc-btn--navy:hover  { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,0.3); }
  .pvc-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .pvc-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }

  /* ── HERO ── */
  .pvc-hero { position: relative; display: flex; flex-direction: column; justify-content: center; padding-top: 70px; overflow: hidden; }
  .pvc-hero--compact { min-height: 55vh; }
  .pvc-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .pvc-hero__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,26,58,0.96) 0%, rgba(15,35,71,0.88) 60%, rgba(26,58,110,0.82) 100%); }
  .pvc-hero__glow    { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 70% at 80% 30%, rgba(201,168,76,0.09) 0%, transparent 65%), radial-gradient(ellipse 50% 80% at 10% 70%, rgba(30,74,138,0.3) 0%, transparent 60%); }
  .pvc-hero__inner   { position: relative; z-index: 1; padding-top: clamp(2rem, 5vw, 3.5rem); padding-bottom: clamp(2.5rem, 5vw, 4rem); }

  .pvc-breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; flex-direction: row-reverse; justify-content: flex-end; }
  .pvc-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .pvc-breadcrumb a:hover { color: var(--gold-l); }
  .pvc-breadcrumb span[aria-current] { color: var(--gold); }

  .pvc-eyebrow { display: inline-flex; align-items: center; gap: 0.75rem; font-size: 0.85rem; font-weight: 600; color: var(--gold); margin-bottom: 1rem; }
  .pvc-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: 0.5; flex-shrink: 0; }

  .pvc-hero__h1 { font-family: 'Noto Sans Arabic', system-ui, sans-serif; font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 900; color: var(--white); line-height: 1.3; margin: 0 0 1rem; }
  .pvc-hero__h1 em { font-style: normal; color: var(--gold); }
  .pvc-hero__lead { font-size: 1rem; color: rgba(255,255,255,0.62); line-height: 1.9; max-width: 560px; margin: 0 0 1.5rem; }
  .pvc-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ── CATEGORY NAV ── */
  .pvc-catnav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--bdr); }
  .pvc-catbtn { background: var(--white); color: var(--body); border: 1.5px solid var(--bdr); padding: 0.5rem 1.1rem; border-radius: 30px; font-size: 0.9rem; font-weight: 600; font-family: 'Noto Sans Arabic', system-ui, sans-serif; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
  .pvc-catbtn:hover { border-color: var(--navy); color: var(--navy); }
  .pvc-catbtn--active { background: var(--navy); color: var(--white); border-color: var(--navy); }

  .pvc-quote-row { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .pvc-quote-note { font-size: 0.9rem; color: var(--slate); }

  /* ── PRODUCTS GRID ── */
  .pvc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.25rem; min-height: 200px; }
  .pvc-grid :global(.pvc-card) { background: var(--white); border: 1px solid var(--bdr); border-radius: var(--radius); overflow: hidden; transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s; }
  .pvc-grid :global(.pvc-card:hover) { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(15,35,71,0.1); border-color: rgba(201,168,76,0.35); }
  .pvc-grid :global(.pvc-card__img) { aspect-ratio: 3/4; background: var(--cream); display: flex; align-items: center; justify-content: center; overflow: hidden; padding: 0.5rem; }
  .pvc-grid :global(.pvc-card__img img) { width: 100%; height: 100%; object-fit: contain; transition: transform 0.35s; }
  .pvc-grid :global(.pvc-card:hover .pvc-card__img img) { transform: scale(1.04); }
  .pvc-grid :global(.pvc-card__name) { padding: 0.75rem 1rem; font-size: 0.82rem; font-weight: 600; color: var(--text); text-align: center; line-height: 1.4; direction: ltr; }

  .pvc-loading { text-align: center; padding: 4rem 2rem; color: var(--slate); display: none; }
  .pvc-spinner { width: 36px; height: 36px; border: 3px solid var(--bdr); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.9s linear infinite; margin: 0 auto 1rem; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── PAGINATION ── */
  .pvc-pagination { display: flex; flex-direction: column; align-items: center; gap: 1.25rem; background: var(--white); border: 1px solid var(--bdr); border-radius: var(--radius); padding: 2rem; margin-top: 3rem; box-shadow: 0 4px 16px rgba(15,35,71,0.06); }
  .pvc-page-info { text-align: center; }
  .pvc-page-current { display: block; font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .pvc-page-count   { font-size: 0.875rem; color: var(--slate); }
  .pvc-page-btns    { display: flex; gap: 1rem; align-items: center; flex-direction: row-reverse; }
  .pvc-page-btn { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.75rem 1.75rem; border-radius: 10px; background: var(--navy); color: var(--white); font-size: 0.9rem; font-weight: 600; font-family: 'Noto Sans Arabic', system-ui, sans-serif; text-decoration: none; transition: all 0.2s; min-width: 130px; justify-content: center; }
  .pvc-page-btn:hover { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 6px 18px rgba(15,35,71,0.25); }
  .pvc-page-btn--disabled { background: var(--cream); color: var(--slate); border: 1px solid var(--bdr); cursor: not-allowed; }
  .pvc-page-btn--disabled:hover { transform: none; box-shadow: none; background: var(--cream); }
  .pvc-page-dots { display: flex; gap: 0.75rem; align-items: center; }
  .pvc-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--bdr); display: block; text-decoration: none; transition: all 0.2s; }
  .pvc-dot:hover { background: var(--slate); transform: scale(1.2); }
  .pvc-dot--active { background: var(--gold); transform: scale(1.3); box-shadow: 0 2px 8px rgba(201,168,76,0.4); }

  /* نهاية المجموعة */
  .pvc-collection-end { margin-top: 2rem; background: var(--cream); border: 1px solid var(--bdr); border-radius: var(--radius); padding: 1.5rem 2rem; text-align: center; }
  .pvc-collection-end p { font-size: 0.925rem; color: var(--body); margin: 0 0 1rem; font-weight: 500; }
  .pvc-collection-end__links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
  .pvc-collection-end__links a { font-size: 0.875rem; font-weight: 700; color: var(--navy-l); text-decoration: none; border-bottom: 1.5px solid var(--bdr); padding-bottom: 1px; transition: color 0.2s, border-color 0.2s; }
  .pvc-collection-end__links a:hover { color: var(--gold); border-color: var(--gold); }

  /* ── CTA BAND ── */
  .pvc-cta { position: relative; background: var(--navy); overflow: hidden; padding: clamp(4rem, 8vw, 6rem) 0; }
  .pvc-cta__glow { position: absolute; inset: 0; background: radial-gradient(ellipse 55% 80% at 105% 50%, rgba(201,168,76,0.14) 0%, transparent 65%), linear-gradient(140deg, #08192e 0%, var(--navy) 100%); pointer-events: none; }
  .pvc-cta__inner { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; }
  .pvc-cta__text h2 { font-size: clamp(1.75rem, 3vw, 2.4rem); font-weight: 700; color: var(--white); margin: 0.35rem 0 0.7rem; line-height: 1.4; }
  .pvc-cta__text p  { color: rgba(255,255,255,0.55); font-size: 0.95rem; line-height: 1.8; max-width: 420px; margin: 0; }
  .pvc-cta__btns { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .pvc-hero--compact { min-height: auto; }
