---
// src/pages/ar/hastane-kapilari.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/hastane-kapilari`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Hastane-Serisi-501-Tik-Antrasit.webp",
  "CihanpanDoor-Hastane-Serisi-502-Avola-Krem.webp",
  "CihanpanDoor-Hastane-Serisi-503-ABD-Ceviz-Krom.webp",
  "CihanpanDoor-Hastane-Serisi-504-Soft-Kapucino-Antrasit.webp",
  "CihanpanDoor-Hastane-Serisi-505-Saruhan-Krem.webp",
  "CihanpanDoor-Hastane-Serisi-506-Antrasit-Krom.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hospitalSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "أبواب المستشفيات والمرافق الصحية — السلسلة الصحية | CihanPan Door",
  "description": "أبواب مستشفيات صحية بالجملة من قيصري، تركيا. سطح PVC/HPL مضاد للبكتيريا، مقاومة للحريق 30–60 دقيقة، شهادة CE.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "ItemList",
    "name": "موديلات أبواب المستشفيات",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "باب مستشفى — السلسلة الصحية",
        "description": "باب مستشفى مغلف بـ PVC/HPL مضاد للبكتيريا. مقاوم للرطوبة، سهل التنظيف، مقاومة للحريق 30–60 دقيقة، شهادة CE.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "طلاء PVC/HPL مضاد للبكتيريا / MDF",
        "category": "باب مستشفى",
        "additionalProperty": [
          { "@type": "PropertyValue", "name": "مضاد للبكتيريا",      "value": "نعم" },
          { "@type": "PropertyValue", "name": "مقاومة الحريق",        "value": "30–60 دقيقة" },
          { "@type": "PropertyValue", "name": "شهادة النظافة",         "value": "CE" },
          { "@type": "PropertyValue", "name": "عزل صوتي",             "value": "32–42 dB" },
        ],
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "63",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "لماذا تحتاج المستشفيات إلى أبواب متخصصة؟",        "acceptedAnswer": { "@type": "Answer", "text": "يجب أن تلبي أبواب المستشفيات معايير صارمة للنظافة: أسطح مضادة للبكتيريا، ومقاومة للتنظيف المتكرر بالمطهرات، وبناء مقاوم للرطوبة، وعزل صوتي لراحة المرضى، ومقاومة للحريق من أجل السلامة." }},
    { "@type": "Question", "name": "أين تُستخدم أبواب المستشفيات؟",                   "acceptedAnswer": { "@type": "Answer", "text": "تُستخدم أبواب المستشفيات في غرف المرضى والعيادات الخارجية وغرف العمليات والمختبرات وغرف الأشعة السينية ووحدات العناية المركزة وأقسام الطوارئ ووحدات التعقيم." }},
    { "@type": "Question", "name": "ما الشهادات التي يجب أن تحملها أبواب المستشفيات؟", "acceptedAnswer": { "@type": "Answer", "text": "يجب أن تحمل أبواب المستشفيات شهادة CE وشهادة مقاومة الحريق (EN 1634) وتقرير اختبار مضاد للبكتيريا وشهادة عزل صوتي. جميع موديلات CihanPan Door حاصلة على شهادة CE." }},
    { "@type": "Question", "name": "ما هو الحد الأدنى لكميات الطلب بالجملة؟",         "acceptedAnswer": { "@type": "Answer", "text": "الحد الأدنى لكمية الطلب 50 وحدة. تُطبق خصومات الحجم من 100 وحدة فأكثر. تتوفر مقاسات مخصصة وخيارات تزجيج وأنظمة إغلاق تلقائي وحلول ذات علامة تجارية خاصة للمشاريع الكبيرة." }},
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",          "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات",           "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "أبواب المستشفيات",  "item": currentUrl },
  ]
};

const allSchemas = [hospitalSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'الكل',                  active: false },
  { slug: '/pvc-kapilar',               label: 'أبواب PVC',             active: false },
  { slug: '/laminoks-kapilar',          label: 'أبواب لامينوكس',        active: false },
  { slug: '/elitpan-doors',             label: 'أبواب إليتبان',          active: false },
  { slug: '/hastane-kapilari',          label: 'أبواب المستشفيات',      active: true  },
  { slug: '/otel-kapilari',             label: 'أبواب الفنادق',          active: false },
  { slug: '/yangina-dayanikli-kapilar', label: 'أبواب مقاومة للحريق',   active: false },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface HospitalProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  features: string;
  image: string;
  alt: string;
}

const hospitalProducts: HospitalProduct[] = fileNames.map((fn, i) => {
  const parts = fn.replace('.webp', '').split('-');
  const model = parts[3];
  const color = parts.slice(4).join(' ');
  return {
    id:       `hospital-${model}`,
    model,
    color,
    label:    `باب مستشفى ${model} · ${color}`,
    features: i < 3 ? 'صحي · شهادة CE' : 'مضاد للبكتيريا · مقاوم للحريق',
    image:    `/assets/img/hospital-doors/${fn}`,
    alt:      `CihanPan Door سلسلة المستشفيات ${model} ${color} — باب رعاية صحية`,
  };
});
---

<I18nLayout
  title="أبواب المستشفيات والمرافق الصحية — السلسلة الصحية | بالجملة | CihanPan Door"
  description="أبواب مستشفيات صحية بالجملة من قيصري، تركيا. سطح مضاد للبكتيريا، مقاوم للحريق، شهادة CE."
  keywords="أبواب مستشفيات بالجملة تركيا، باب رعاية صحية مضاد للبكتيريا، باب مقاوم للحريق قيصري، باب مستشفى شهادة CE"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="أبواب المستشفيات — السلسلة الصحية | CihanPan Door"
  ogDescription="أبواب مستشفيات صحية مضادة للبكتيريا ومقاومة للحريق. مباشرة من المصنع."
  ogImage="/assets/img/og/hospital-doors-og.webp"
  lang="ar"
  dir="rtl"
>
  <I18nHeader />

  <main class="lam" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">‹</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>المنتجات</a>
            <span aria-hidden="true">‹</span>
            <span aria-current="page">أبواب المستشفيات</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            مجموعة الرعاية الصحية · السلسلة الصحية
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>أبواب المستشفيات والمرافق الصحية</em><br/>مضاد للبكتيريا · مقاوم للحريق · شهادة CE
          </h1>
          <p class="lam-hero__lead">
            أبواب مستشفيات بالجملة مباشرة من مصنع قيصري، تركيا. طلاء PVC/HPL مضاد للبكتيريا فوق قلب MDF مقاوم للرطوبة. مقاومة للحريق 30–60 دقيقة، عزل صوتي 32–42 ديسيبل. شهادة CE وISO 9001. الحد الأدنى للطلب 50 وحدة.
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ سطح مضاد للبكتيريا</span>
            <span class="lam-htag">✓ مقاومة للحريق 30–60 دق</span>
            <span class="lam-htag">✓ عزل صوتي 32–42 dB</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ الحد الأدنى 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              احصل على عرض مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              تصفح الموديلات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>موديل</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>نظافة</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>60<sup>دق</sup></strong><span>مقاومة حريق</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>معتمد</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label="فئات الأبواب">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">مجموعة أبواب المستشفيات</span>
          <h2 id="catalogue-h2">موديلات أبواب المستشفيات والمرافق الصحية</h2>
          <p>
            {modelCount} موديلات أبواب مستشفيات صحية — السلسلة 501–506. مضادة للبكتيريا، مقاومة للحريق، ومعزولة صوتيًا.
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            احصل على عرض مشروع مستشفى
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <span class="lam-quote-note">رد خلال 24 ساعة · الحد الأدنى 50 وحدة</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label="موديلات أبواب المستشفيات">
          {hospitalProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.features}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">لماذا تتطلب أبواب المستشفيات حلولًا متخصصة</h2>

          <p>
            <strong>سلسلة المستشفيات من CihanPan Door</strong> مصممة خصيصًا للبيئات الصحية، حيث لا تكفي الأبواب الداخلية العادية. يجمع كل موديل بين <em>طلاء PVC/HPL المضاد للبكتيريا</em> وقلب MDF مقاوم للرطوبة، ليقدم حل باب صحيًا ومتينًا وآمنًا لمشتري الجملة حول العالم.
          </p>

          <h3>الميزات الرئيسية للبيئات الصحية</h3>
          <ul class="lam-checklist">
            <li><strong>سطح مضاد للبكتيريا:</strong> الطلاء المتخصص يثبط نمو البكتيريا — أمر بالغ الأهمية لمكافحة العدوى في البيئات السريرية.</li>
            <li><strong>مقاومة المطهرات:</strong> يتحمل السطح التنظيف المتكرر بمطهرات المستشفيات دون أن يتدهور.</li>
            <li><strong>بناء مقاوم للرطوبة:</strong> قلب MDF المقاوم للرطوبة يمنع التقوس في البيئات السريرية عالية الرطوبة.</li>
            <li><strong>عزل صوتي 32–42 ديسيبل:</strong> يحمي خصوصية المريض ويقلل من انتقال الضوضاء بين الأجنحة وغرف الاستشارات.</li>
            <li><strong>مقاومة الحريق 30–60 دقيقة:</strong> يلتزم بمعايير مقاومة الحريق EN 1634 لمسارات إخلاء آمنة في المرافق الصحية.</li>
            <li><strong>شهادة CE:</strong> جميع الموديلات حاصلة على شهادة CE وتمتثل لمتطلبات مرافق الرعاية الصحية الأوروبية.</li>
          </ul>

          <h3>تطبيقات الرعاية الصحية</h3>
          <p>تُستخدم سلسلة مستشفيات CihanPan Door في:</p>
          <ul class="lam-checklist">
            <li><strong>غرف المرضى:</strong> سطح صحي وعزل صوتي 32+ ديسيبل لراحة المريض وخصوصيته.</li>
            <li><strong>غرف العمليات:</strong> سطح متوافق مع البيئة المعقمة، مع توفر خيارات الإغلاق المحكم.</li>
            <li><strong>العيادات والخارجيين:</strong> متانة عالية لحركة المرور مع الحماية المضادة للبكتيريا لمناطق العيادات المزدحمة.</li>
            <li><strong>المختبرات:</strong> سطح مقاوم للمواد الكيميائية مناسب للمختبرات التي تستخدم المذيبات أو الكواشف بشكل متكرر.</li>
            <li><strong>وحدات العناية المركزة:</strong> أقصى قدر من النظافة بسطح منخفض الصيانة للاستخدام السريري على مدار الساعة.</li>
            <li><strong>أقسام الطوارئ:</strong> بناء مقاوم للصدمات لبيئات الطوارئ ذات الحركة الكثيفة.</li>
          </ul>

          <h3>المواصفات التقنية</h3>
          <ul class="lam-checklist">
            <li>السطح: طلاء PVC/HPL مضاد للبكتيريا</li>
            <li>القلب: MDF مقاوم للرطوبة</li>
            <li>الأحجام القياسية: 70×200 سم · 80×200 سم · 140×200 سم (مصراعين) — أحجام مخصصة متاحة</li>
            <li>مقاومة الحريق: 30–60 دقيقة (EN 1634)</li>
            <li>العزل الصوتي: 32–42 ديسيبل</li>
            <li>الأجهزة: مفصلات من الفولاذ المقاوم للصدأ، مقابض مضادة للبكتيريا، إغلاق تلقائي</li>
            <li>شهادة CE & ISO 9001</li>
            <li>ضمان المصنّع 5 سنوات</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>موديل</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>نظافة</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>معتمد</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>ضمان</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">متخصص رعاية صحية</span>
            <h3>احصل على عرض للمشروع</h3>
            <p>شارك نوع المنشأة والكمية والمتطلبات — يرد متخصص الرعاية الصحية لدينا خلال 24 ساعة.</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                نموذج الاتصال
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                واتساب
              </a>
              <a href="tel:+905441690038" class="lam-btn lam-btn--outline lam-btn--sm">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <div class="lam-features-card">
            <h3>الشهادات والخدمات</h3>
            <ul class="lam-feat-list">
              <li>🏅 شهادة CE & ISO 9001</li>
              <li>🔥 شهادة مقاومة الحريق</li>
              <li>🧪 تقرير اختبار مضاد للبكتيريا</li>
              <li>🔇 شهادة العزل الصوتي</li>
              <li>📐 مقاسات وتكوينات مخصصة</li>
