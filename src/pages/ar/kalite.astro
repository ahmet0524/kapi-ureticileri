---
// src/pages/ar/kalite.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang       = 'ar';
const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/kalite`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "سياسة الجودة — CihanPan Door",
  "description": "معايير الجودة والشهادات والالتزامات لـ CihanPan Door. اختبارات CE وISO 9001 ومقاومة الحريق والمضادة للبكتيريا. ضمان 5 سنوات.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",    "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "سياسة الجودة", "item": currentUrl },
  ]
};

// ── CONTENT ───────────────────────────────────────────────────────────
const controlSteps = [
  'فحص المواد الخام قبل بدء الإنتاج',
  'عمليات تدقيق الجودة في كل مرحلة من مراحل الإنتاج',
  'اختبارات الأبعاد والسطح للمنتج النهائي',
  'اختبارات شهادات مقاومة الحريق والعزل الصوتي',
  'الفحص قبل الشحن والتحقق من التعبئة',
  'متابعة رضا العملاء بعد التسليم',
];

const certs = [
  { label: 'شهادة CE',                         desc: 'جميع المنتجات تتوافق مع لوائح منتجات البناء الأوروبية (CPR 305/2011).' },
  { label: 'إدارة الجودة ISO 9001',             desc: 'تخضع عمليات المصنع لعمليات تدقيق سنوية وفق معيار إدارة الجودة ISO 9001:2015.' },
  { label: 'مقاومة الحريق — EN 1634',           desc: 'تم اختبار سلاسل أبواب المستشفيات والفنادق وفق EN 1634 لتقييمات مقاومة الحريق لمدة 30 و60 دقيقة.' },
  { label: 'تقرير الاختبار المضاد للبكتيريا',   desc: 'تم اختبار أسطح سلسلة Elitpan (UV) والمستشفيات لتثبيط البكتيريا وفق ISO 22196.' },
  { label: 'شهادة العزل الصوتي',               desc: 'تم اعتماد أبواب الفنادق والمستشفيات للأداء الصوتي 32–42 ديسيبل وفق EN ISO 10140.' },
  { label: 'شهادة الإنتاج الصديق للبيئة',       desc: 'يتم الحصول على أنوية MDF من موردين حاصلين على شهادة FSC؛ ونفايات الإنتاج تُعاد تدويرها بالكامل.' },
];

const commitments = [
  { icon: '🏭', title: 'جودة الإنتاج',         body: 'آلات CNC دقيقة وفريق خبير يضمنان إنتاجاً خالياً من العيوب في جميع سلاسل الأبواب.' },
  { icon: '🪵', title: 'جودة المواد',           body: 'أنوية MDF من الدرجة الأولى، لمينات HPL وUV معتمدة — لا تنازل في اختيار المواد الخام.' },
  { icon: '🤝', title: 'جودة الخدمة',          body: 'استشارة تقنية ما قبل البيع، ودعم وثائق التصدير، وخدمة ضمان ما بعد البيع.' },
  { icon: '🛡️', title: 'ضمان 5 سنوات',        body: 'تأتي جميع نماذج الأبواب بضمان المصنّع لمدة 5 سنوات يغطي العيوب وتدهور السطح وبهت الألوان.' },
  { icon: '📦', title: 'التسليم في الموعد',    body: 'مهلة إنتاج قياسية 15–25 يوم عمل؛ يتم تتبع جميع الشحنات وتوثيقها بوثائق CE/ISO.' },
  { icon: '♻️', title: 'الاستدامة',            body: 'مواد خام معتمدة من FSC، ومواد لاصقة على أساس مائي، وممارسات إنتاج بدون نفايات في جميع أنحاء المصنع.' },
];

const goals = [
  'رضا العملاء بنسبة 100% في كل طلب',
  'هدف إنتاج بدون عيوب في جميع خطوط الإنتاج',
  'التحسين المستمر من خلال عمليات تدقيق ISO السنوية',
  'التسليم في الموعد لكل مشروع حول العالم',
  'البحث والتطوير المستمر لحلول أبواب مبتكرة',
  'توسيع نطاق شهادة CE والشهادات الدولية',
];
---

<I18nLayout
  title="سياسة الجودة — معتمد CE وISO 9001 | CihanPan Door"
  description="معايير الجودة والشهادات والالتزامات لـ CihanPan Door. اختبارات CE وISO 9001 ومقاومة الحريق. ضمان المصنع لمدة 5 سنوات على جميع نماذج الأبواب."
  keywords="سياسة جودة CihanPan Door, مصنع أبواب معتمد CE, مصنع أبواب ISO 9001 قيصري"
  canonical={currentUrl}
  schema={[pageSchema, breadcrumbSchema]}
  ogTitle="سياسة الجودة — CihanPan Door"
  ogDescription="مصنع أبواب معتمد CE وISO 9001 من قيصري، تركيا. ضمان 5 سنوات."
  ogImage="/assets/img/og/quality-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">‹</span>
            <span aria-current="page">سياسة الجودة</span>
          </nav>
          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            CE · ISO 9001 · EN 1634
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>سياسة الجودة لدينا</em><br/>معاييرنا والتزاماتنا
          </h1>
          <p class="lam-hero__lead">
            في CihanPan Door، الجودة ليست نقطة تفتيش — بل فلسفة متجذرة في كل مرحلة من مراحل الإنتاج. معتمدون CE وISO 9001، مع تدقيق مصنعي سنوي وضمان 5 سنوات على جميع نماذج الأبواب.
          </p>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              طلب الشهادات
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            </a>
            <a href={getLocalizedRoute('/urunlerimiz', lang)} class="lam-btn lam-btn--ghost">
              عرض المنتجات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>CE</strong><span>معتمد</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>ISO</strong><span>9001</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>5<sup>سنوات</sup></strong><span>ضمان</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>0</strong><span>هدف العيوب</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         QUALITY CONTROL PROCESS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="ctrl-h2">
      <div class="lam-wrap lam-two-col">

        <div>
          <span class="lam-tag">عمليتنا</span>
          <h2 id="ctrl-h2">مراقبة الجودة في كل مرحلة</h2>
          <p>
            من اختيار المواد الخام حتى الشحن النهائي، تمر كل باب بعملية فحص متعددة المراحل صارمة. يضمن فريق الجودة لدينا والمدققون الخارجيون أن لا منتج يغادر المصنع دون استيفاء المواصفات الكاملة.
          </p>
          <ul class="lam-checklist lam-checklist--lg">
            {controlSteps.map(step => <li>{step}</li>)}
          </ul>
        </div>

        <div class="lam-qual-aside">
          <div class="lam-qual-card lam-qual-card--navy">
            <div class="lam-qual-icon">🏆</div>
            <h3>فلسفتنا في الجودة</h3>
            <p>
              الجودة لا تُضاف في النهاية — بل تُبنى منذ أول قطعة من المادة الخام حتى فحص التعبئة الأخير. كل فرد في الفريق مسؤول عن المعيار الذي يصل إلى عملائنا.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CERTIFICATIONS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="cert-h2">
      <div class="lam-wrap">
        <div class="lam-head">
          <span class="lam-tag">شهاداتنا</span>
          <h2 id="cert-h2">شهاداتنا ومعاييرنا</h2>
          <p>
            يتم تصنيع واختبار جميع منتجات CihanPan Door وفق المعايير الدولية التالية. تتوفر الوثائق الكاملة عند الطلب لطلبات التصدير.
          </p>
        </div>

        <div class="lam-cert-grid">
          {certs.map(cert => (
            <div class="lam-cert-card">
              <span class="lam-cert-badge">✓</span>
              <div>
                <strong>{cert.label}</strong>
                <p>{cert.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="lam-cert-cta">
          <p>هل تحتاج إلى نسخة من شهاداتنا لعملية الشراء الخاصة بك؟</p>
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            طلب الوثائق
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         COMMITMENTS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="commit-h2">
      <div class="lam-wrap">
        <div class="lam-head">
          <span class="lam-tag">التزاماتنا</span>
          <h2 id="commit-h2">ما نعد به كل عميل</h2>
        </div>

        <div class="lam-commit-grid">
          {commitments.map(c => (
            <div class="lam-commit-card">
              <div class="lam-commit-icon">{c.icon}</div>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         QUALITY GOALS
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="goals-h2">
      <div class="lam-wrap lam-two-col">

        <div class="lam-qual-aside lam-qual-aside--left">
          <div class="lam-qual-card lam-qual-card--gold">
            <div class="lam-qual-icon">🎯</div>
            <h3>أهداف الجودة لدينا</h3>
            <p>
              نقيس ونراجع ونحسّن — كل عام، كل طلب. هدفنا ليس تلبية الحد الأدنى من المعايير، بل تجاوز توقعات العملاء باستمرار.
            </p>
          </div>
        </div>

        <div>
          <span class="lam-tag">الأهداف</span>
          <h2 id="goals-h2">التحسين المستمر</h2>
          <p>
            الجودة في CihanPan Door ليست ثابتة. تدقيقات ISO 9001 السنوية وحلقات تغذية العملاء الراجعة واستثمار البحث والتطوير لدينا تقود دورة تحسين مستمرة عبر الإنتاج والمواد والخدمة.
          </p>
          <ul class="lam-checklist lam-checklist--lg">
            {goals.map(g => <li>{g}</li>)}
          </ul>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="lam-cta" aria-labelledby="cta-h2">
      <div class="lam-cta__glow" aria-hidden="true"></div>
      <div class="lam-wrap lam-cta__inner">
        <div class="lam-cta__text">
          <span class="lam-tag lam-tag--gold">اعمل معنا</span>
          <h2 id="cta-h2">
            هل أنت مستعد لتوريد<br/>أبواب معتمدة CE؟
          </h2>
          <p>
            اطلب عرض سعر جملة مجاني مع وثائق CE وISO 9001 ومقاومة الحريق الكاملة. تسعير مباشر من المصنع خلال 24 ساعة.
          </p>
        </div>
        <div class="lam-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
            احصل على عرض مجاني
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)} class="lam-btn lam-btn--ghost">
            جميع المنتجات
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS ── */
  .lam {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    --green:    #16a34a;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
  .lam-wrap { max-width: 1160px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2.5rem); width: 100%; }
  .lam-sec        { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .lam-sec--white { background: var(--white); }
  .lam-sec--cream { background: var(--cream); }

  .lam-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* ── SECTION HEAD ── */
  .lam-head { text-align: center; margin-bottom: clamp(2rem, 4vw, 3.5rem); }
  .lam-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700;
    color: var(--text); margin: 0.3rem 0 0.7rem; line-height: 1.2;
  }
  .lam-head p { color: var(--slate); font-size: 1rem; max-width: 600px; margin-inline: auto; line-height: 1.7; }

  .lam-two-col h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem); font-weight: 700;
    color: var(--text); margin: 0.3rem 0 1rem; line-height: 1.2;
  }
  .lam-two-col > div > p { font-size: 0.95rem; color: var(--body); line-height: 1.8; margin-bottom: 1.25rem; }

  .lam-tag { display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .lam-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .lam-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 600; padding: 0.9rem 1.75rem;
    border-radius: 8px; text-decoration: none; white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform .2s, box-shadow .2s, background .2s, border-color .2s;
    cursor: pointer; border: none;
  }
  .lam-btn--gold  { background: var(--gold);  color: var(--navy);  font-weight: 700; }
  .lam-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,.4); }
  .lam-btn--navy  { background: var(--navy);  color: var(--white); }
  .lam-btn--navy:hover  { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,.3); }
  .lam-btn--ghost { background: transparent; color: rgba(255,255,255,.85); border: 1.5px solid rgba(255,255,255,.25); }
  .lam-btn--ghost:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.07); transform: translateY(-2px); }

  /* ── HERO ── */
  .lam-hero {
    position: relative; min-height: 65vh; display: flex;
    flex-direction: column; justify-content: center;
    padding-top: 70px; overflow: hidden;
  }
  .lam-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .lam-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,.96) 0%, rgba(15,35,71,.88) 60%, rgba(26,58,110,.82) 100%);
  }
  .lam-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 80% 30%, rgba(201,168,76,.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 10% 70%, rgba(30,74,138,.3) 0%, transparent 60%);
  }
  .lam-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem,6vw,4rem);
    padding-bottom: clamp(3rem,6vw,5rem);
  }
  .lam-breadcrumb {
    display: flex; align-items: center; gap: .5rem;
    font-size: .78rem; color: rgba(255,255,255,.4); margin-bottom: 1.5rem; flex-wrap: wrap;
  }
  .lam-breadcrumb a { color: rgba(255,255,255,.4); text-decoration: none; transition: color .2s; }
  .lam-breadcrumb a:hover { color: var(--gold-l); }
  .lam-breadcrumb span[aria-current] { color: var(--gold); }
  .lam-eyebrow {
    display: inline-flex; align-items: center; gap: .75rem;
    font-size: .78rem; font-weight: 600; letter-spacing: .18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem;
  }
  .lam-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: .5; flex-shrink: 0; order: -1; }
  .lam-hero__h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem,4.5vw,3.6rem); font-weight: 900;
    color: var(--white); line-height: 1.1; margin: 0 0 1.2rem;
  }
  .lam-hero__h1 em { font-style: normal; color: var(--gold); }
  .lam-hero__lead { font-size: 1.05rem; color: rgba(255,255,255,.65); line-height: 1.8; max-width: 560px; margin: 0 0 2rem; }
  .lam-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .lam-statsbar {
    position: relative; z-index: 1;
    display: flex; align-items: center; flex-wrap: wrap;
    background: rgba(255,255,255,.06); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.1); border-radius: 12px;
    padding: 1.5rem 2rem; margin-top: 2rem;
  }
  .lam-sitem { display: flex; flex-direction: column; flex: 1; min-width: 80px; padding-inline: 1rem; text-align: center; }
  .lam-sitem:first-child { padding-right: 0; }
  .lam-sitem:last-child  { padding-left: 0; }
  .lam-sitem strong { font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; font-weight: 900; color: var(--gold); line-height: 1; display: block; }
  .lam-sitem strong sup { font-size: .7em; }
  .lam-sitem span { font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.5); margin-top: .3rem; display: block; }
  .lam-sdiv { width: 1px; height: 32px; background: rgba(255,255,255,.12); flex-shrink: 0; }

  /* ── CHECKLIST — RTL ── */
  .lam-checklist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .6rem; }
  .lam-checklist--lg li { font-size: 0.95rem; }
  .lam-checklist li { font-size: .9rem; color: var(--body); line-height: 1.6; padding-right: 1.75rem; padding-left: 0; position: relative; }
  .lam-checklist li::before { content: '✓'; position: absolute; right: 0; left: auto; color: var(--green); font-weight: 700; font-size: 1rem; }

  /* ── QUALITY ASIDE ── */
  .lam-qual-aside { display: flex; flex-direction: column; gap: 1.5rem; }
  .lam-qual-aside--left { order: -1; }
