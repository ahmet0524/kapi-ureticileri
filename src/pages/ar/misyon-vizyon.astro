---
// src/pages/ar/misyon-vizyon.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';

const lang = 'ar';

// ── SEO DATA ──────────────────────────────────────────────────────────
const baseUrl  = 'https://cihanpandoor.netlify.app';
const pageUrl  = `${baseUrl}/ar/misyon-vizyon`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "الرسالة والرؤية | CihanPan Door — مصنع أبواب تركيا",
  "description": "رسالة CihanPan Door ورؤيتها وقيمها الأساسية. مصنع أبواب داخلية معتمد CE وTSE وISO 9001 في قيصرية، تركيا منذ 1995. تصدير إلى الشرق الأوسط وأوروبا وأفريقيا.",
  "url": pageUrl,
  "inLanguage": "ar",
  "isPartOf": {
    "@type": "WebSite",
    "name": "CihanPan Door",
    "url": baseUrl
  },
  "about": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "alternateName": "Cihanpan Kapı",
    "url": baseUrl,
    "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
    "foundingDate": "1995",
    "description": "شركة CihanPan Door هي الشركة الرائدة في تصنيع وتصدير الأبواب الداخلية بالجملة في تركيا. معتمدة CE وTSE وISO 9001. أبواب PVC وMDF وLaminox للفنادق والمستشفيات والمشاريع السكنية والتجارية.",
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 150 },
    "areaServed": ["ME", "EU", "AF", "TR"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "name": "شهادة CE" },
      { "@type": "EducationalOccupationalCredential", "name": "شهادة TSE" },
      { "@type": "EducationalOccupationalCredential", "name": "ISO 9001" }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
      "addressLocality": "Kayseri",
      "addressRegion": "Kayseri",
      "postalCode": "38070",
      "addressCountry": "TR"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+90-544-169-0038",
      "contactType": "المبيعات",
      "availableLanguage": ["Arabic", "Turkish", "English", "German"],
      "areaServed": ["ME", "EU", "AF"]
    },
    "sameAs": [
      "https://www.cihanpandoor.com",
      "https://www.linkedin.com/company/cihanpan-door"
    ]
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": `${baseUrl}/ar` },
    { "@type": "ListItem", "position": 2, "name": "الرسالة والرؤية", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "ما هي رسالة CihanPan Door؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "رسالة CihanPan Door هي تقديم حلول أبواب عالية الجودة ومبتكرة من قيصرية إلى العالم، بتجاوز توقعات العملاء وإضافة قيمة حقيقية للقطاع من خلال ممارسات الإنتاج المستدامة."
      }
    },
    {
      "@type": "Question",
      "name": "هل تمتلك CihanPan Door شهادات دولية معتمدة؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "نعم. تمتلك CihanPan Door شهادات CE وTSE وISO 9001، مما يضمن الامتثال الكامل للمعايير الأوروبية والدولية لجميع منتجات الأبواب الداخلية."
      }
    },
    {
      "@type": "Question",
      "name": "ما هو الحد الأدنى للطلب بالجملة؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "الحد الأدنى للطلب بالجملة هو 50 وحدة. للمشاريع الكبيرة كالفنادق والمستشفيات والمجمعات السكنية، نقدم أسعاراً خاصة مخصصة مع دعم متكامل للمشروع."
      }
    },
    {
      "@type": "Question",
      "name": "ما أنواع الأبواب التي تصنعها CihanPan Door؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "نصنع أبواباً مطلية بـ PVC وLaminox وElitpan (MDF مطلي بالأشعة فوق البنفسجية) وأبواباً للمستشفيات والفنادق وأبواباً مقاومة للحريق. جميع المنتجات متاحة بمقاسات وألوان مخصصة."
      }
    }
  ]
};

const schemas = [aboutPageSchema, breadcrumbSchema, faqSchema];

// ── PAGE DATA ─────────────────────────────────────────────────────────
const values = [
  { num: '01', title: 'جودة من الدرجة الأولى',   text: 'تدخل خط الإنتاج لدينا المواد الخام الممتازة فقط. تخضع كل باب لفحص جودة متعدد المراحل قبل الشحن.' },
  { num: '02', title: 'موثوقية مُثبتة',            text: 'أكثر من 30 عاماً من التصنيع المتسق والتسليم في المواعيد — سجلنا يتحدث عن نفسه.' },
  { num: '03', title: 'العميل أولاً',              text: 'مديرو حسابات مخصصون وعينات قبل الشحن ودعم ما بعد البيع لكل شريك تجاري بالجملة.' },
  { num: '04', title: 'الابتكار والبحث والتطوير', text: 'الاستثمار المستمر في تقنية CNC والتشطيبات الجديدة يبقي كتالوجنا في طليعة اتجاهات السوق.' },
];

const timeline = [
  { year: '1995', title: 'التأسيس في قيصرية',        text: 'بدأنا كورشة متخصصة في الأبواب الداخلية في قيصرية، قلب الصناعة التركية.' },
  { year: '2003', title: 'افتتاح المصنع الحديث',      text: 'انتقلنا إلى المنطقة الصناعية المنظمة في قيصرية بخطوط إنتاج آلية متكاملة.' },
  { year: '2010', title: 'انطلاق التصدير الدولي',     text: 'بدأنا التصدير إلى أسواق الشرق الأوسط وأفريقيا — نخدم الآن أكثر من 25 دولة.' },
  { year: '2018', title: 'الحصول على شهادة ISO 9001', text: 'حصلنا على شهادة ISO 9001 إلى جانب اعتمادات CE وTSE الموجودة مسبقاً.' },
  { year: '2024', title: '600,000 وحدة / سنة',        text: 'وصلنا إلى طاقة إنتاجية سنوية تبلغ 600,000 طقم أبواب — جاهزون لأي كميات بالجملة.' },
];

const certs = [
  { badge: 'CE',  title: 'شهادة CE',  text: 'تؤكد الامتثال لمعايير السلامة والجودة في السوق الأوروبية' },
  { badge: 'TSE', title: 'شهادة TSE', text: 'معهد المعايير التركية — علامة الجودة الإلزامية للمصنّعين الأتراك' },
  { badge: 'ISO', title: 'ISO 9001:2015', text: 'نظام إدارة الجودة الدولي — إنتاج متسق في كل دفعة' },
];

const whyUs = [
  { icon: '🏭', title: 'سعر المصنع المباشر',       text: 'لا وكلاء ولا وسطاء. تشتري مباشرة من المصنع — أقصى هامش ربح لأعمالك.' },
  { icon: '🌍', title: 'جاهز للتصدير العالمي',      text: 'وثائق كاملة: الفاتورة التجارية وقائمة التعبئة وشهادة المنشأ وشهادات CE/ISO.' },
  { icon: '📦', title: 'الحد الأدنى 50 وحدة',       text: 'الحد الأدنى المنخفض يتيح لك اختبار جودة المنتج قبل الالتزام بكميات كبيرة.' },
  { icon: '⚙️', title: 'مقاسات وتشطيبات مخصصة',    text: 'أبعاد غير قياسية وألوان مخصصة وعلامة تجارية خاصة — كل ذلك متاح لطلبات الجملة.' },
  { icon: '🚢', title: 'شروط تسليم مرنة',            text: 'EXW وFOB وCIF — نعمل مع وكيل الشحن الخاص بك أو نتولى اللوجستيات بالكامل عند الطلب.' },
  { icon: '🏅', title: 'معتمد CE + ISO',             text: 'كل شحنة مدعومة بوثائق CE وTSE وISO 9001 لتخليص جمركي سلس.' },
];
---

<I18nLayout
  title="الرسالة والرؤية | CihanPan Door — مصنع أبواب تركيا"
  description="رسالة CihanPan Door ورؤيتها وقيمها الأساسية. مصنع أبواب داخلية معتمد CE وTSE وISO 9001 في قيصرية، تركيا منذ 1995. تصدير إلى الشرق الأوسط وأوروبا وأفريقيا."
  keywords="CihanPan Door الرسالة الرؤية, مصنع أبواب تركيا, تصدير أبواب تركيا, شهادة CE للأبواب, إنتاج أبواب ISO 9001, أبواب بالجملة تركيا"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="الرسالة والرؤية | CihanPan Door"
  ogDescription="رسالة CihanPan Door: تقديم حلول أبواب عالية الجودة ومبتكرة من تركيا إلى العالم. رؤيتنا: أن نصبح المصدّر الأول للأبواب بالجملة."
  ogImage="/assets/img/og/misyon-vizyon-ar-og.webp"
>
  <I18nHeader />

  <main class="mv" dir="rtl" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="mv-hero" aria-labelledby="hero-heading">
      <div class="mv-hero__grid" aria-hidden="true"></div>
      <div class="mv-wrap mv-hero__inner">

        <div class="mv-hero__copy">
          <span class="mv-eyebrow">
            <span class="mv-eyebrow__line"></span>
            قيصرية، تركيا · منذ 1995
          </span>

          <h1 class="mv-hero__h1" id="hero-heading">
            الجودة دليلنا،<br>
            <em>الابتكار</em><br>
            مبدؤنا الراسخ
          </h1>

          <p class="mv-hero__sub">
            تصنيع معتمد CE وTSE وISO 9001 في قيصرية منذ 1995.
            تصدير إلى <strong>الشرق الأوسط وأوروبا وأفريقيا</strong> — أكثر من 25 دولة —
            بطاقة إنتاجية تبلغ <strong>600,000 وحدة سنوياً</strong>.
          </p>

          <div class="mv-hero__tags">
            <span class="mv-htag">✓ معتمد CE</span>
            <span class="mv-htag">✓ ISO 9001</span>
            <span class="mv-htag">✓ الحد الأدنى 50 وحدة</span>
            <span class="mv-htag">✓ جاهز للتصدير</span>
          </div>

          <div class="mv-stats">
            <div class="mv-stat">
              <strong>30<sup>+</sup></strong>
              <span>سنوات تصنيع</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>600K</strong>
              <span>وحدة / سنة</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>25<sup>+</sup></strong>
              <span>دولة تصدير</span>
            </div>
            <div class="mv-stat-div"></div>
            <div class="mv-stat">
              <strong>150<sup>+</sup></strong>
              <span>موظف</span>
            </div>
          </div>
        </div>

        <div class="mv-hero__badges" aria-label="شهادات الجودة">
          <div class="mv-hb mv-hb--gold" title="معتمد CE">CE</div>
          <div class="mv-hb" title="معتمد TSE">TSE</div>
          <div class="mv-hb" title="معتمد ISO 9001">ISO<br>9001</div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الرسالة / الرؤية
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="mv-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">توجهنا</span>
          <h2 id="mv-heading">الرسالة والرؤية</h2>
          <p>القيم والأهداف طويلة المدى التي تشكّل أسلوب تصنيعنا وتصديرنا</p>
        </div>
        <div class="mv-cards">
          <div class="mv-card mv-card--blue">
            <div class="mv-card__bar"></div>
            <div class="mv-card__icon mv-card__icon--blue" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>رسالتنا</h3>
            <p>أن نكون أكثر <strong>مصدّري الأبواب الداخلية بالجملة موثوقيةً من تركيا</strong> — نقدم جودة مباشرة من المصنع، وتوثيقاً كاملاً CE/ISO، ولوجستيات موثوقة لكل طلب دولي.</p>
            <ul class="mv-checks">
              <li>أسعار المصنع المباشرة — بدون وكلاء أو وسطاء</li>
              <li>بالجملة من 50 وحدة مع أسعار خاصة للكميات الكبيرة</li>
              <li>مقاسات وتشطيبات مخصصة وعلامة تجارية خاصة</li>
            </ul>
          </div>
          <div class="mv-card mv-card--gold">
            <div class="mv-card__bar"></div>
            <div class="mv-card__icon mv-card__icon--gold" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3>رؤيتنا</h3>
            <p>أن نصبح <strong>المصنّع التركي للأبواب الداخلية الأول في ذهن المشترين بالجملة</strong> في الشرق الأوسط وأوروبا — معروفاً بالجودة المعتمدة والتسليم في الوقت المحدد والشفافية التجارية.</p>
            <ul class="mv-checks">
              <li>CE وTSE وISO 9001 — في كل شحنة</li>
              <li>إنتاج مستدام وصديق للبيئة</li>
              <li>التوسع إلى أكثر من 40 دولة بحلول 2027</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         قيم التصنيع
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--navy" aria-labelledby="values-heading">
      <div class="mv-wrap">
        <div class="mv-head mv-head--light">
          <span class="mv-tag">المبادئ الأساسية</span>
          <h2 id="values-heading">قيم التصنيع لدينا</h2>
          <p>ما نؤمن به — من اختيار المواد الخام إلى تسليم الشحنات</p>
        </div>
        <div class="mv-vals">
          {values.map(v => (
            <div class="mv-val">
              <span class="mv-val__n" aria-hidden="true">{v.num}</span>
              <div class="mv-val__bar" aria-hidden="true"></div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
              <div class="mv-val__sweep" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الاستدامة
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--cream" aria-labelledby="sustain-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">البيئة والمستقبل</span>
          <h2 id="sustain-heading">التزامنا بالاستدامة</h2>
          <p>إنتاج مسؤول يضيف قيمة للإنسان والكوكب معاً</p>
        </div>
        <div class="mv-sustain">
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">♻️</div>
            <h3>مواد قابلة لإعادة التدوير</h3>
            <p>معظم المواد الخام المستخدمة في إنتاجنا قابلة لإعادة التدوير، وخطوط إنتاجنا مصممة لتقليل الهدر في كل مرحلة.</p>
          </div>
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">⚡</div>
            <h3>كفاءة الطاقة</h3>
            <p>أنظمة إدارة الطاقة الذكية وبنية الإضاءة LED في مصنعنا تقلل باستمرار من بصمتنا الكربونية.</p>
          </div>
          <div class="mv-sustain__card">
            <div class="mv-sustain__icon">🌱</div>
            <h3>إنتاج صديق للبيئة</h3>
            <p>أنظمة دهانات وطلاء آمنة بيئياً تحافظ على جودة الهواء الداخلي وتصون الموارد الطبيعية.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الخط الزمني
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="history-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">30 عاماً من التصنيع</span>
          <h2 id="history-heading">تاريخنا كمصنّع تركي<br>للأبواب الداخلية</h2>
          <p>المحطات الرئيسية التي جعلت من CihanPan Door مورداً بالجملة موثوقاً عالمياً</p>
        </div>
        <div class="mv-tl-wrap">
          {timeline.map((item) => (
            <div class="mv-tl">
              <div class="mv-tl__yr">{item.year}</div>
              <div class="mv-tl__spine" aria-hidden="true">
                <div class="mv-tl__line"></div>
                <div class="mv-tl__dot"></div>
                <div class="mv-tl__line"></div>
              </div>
              <div class="mv-tl__body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الشهادات
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--cream" aria-labelledby="certs-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">المعايير الدولية</span>
          <h2 id="certs-heading">إنتاج أبواب داخلية معتمد<br>CE وTSE وISO 9001</h2>
          <p>كل شحنة بالجملة مدعومة بوثائق جودة معترف بها دولياً</p>
        </div>
        <div class="mv-certs">
          {certs.map(c => (
            <div class="mv-cert">
              <div class="mv-cert__badge" aria-label={c.title}>{c.badge}</div>
              <div class="mv-cert__body">
                <h3>{c.title}</h3>
                <p>{c.text}</p>
              </div>
              <div class="mv-cert__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              </div>
            </div>
          ))}
        </div>
        <p class="mv-certs__note">
          جميع الشهادات متاحة عند الطلب وتُدرج في كل حزمة وثائق تصدير.
          <a href="/ar/contact" class="mv-link">اطلب نسخة ‹</a>
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         لماذا نحن
    ══════════════════════════════════════════ -->
    <section class="mv-sec mv-sec--white" aria-labelledby="whyus-heading">
      <div class="mv-wrap">
        <div class="mv-head">
          <span class="mv-tag">لماذا CihanPan Door</span>
          <h2 id="whyus-heading">لماذا يختار المستوردون<br>مصنعنا التركي للأبواب</h2>
          <p>مزايا المصنّع المباشر التي تحمي هوامش ربحك وتبسّط سلسلة التوريد</p>
        </div>
        <div class="mv-why">
          {whyUs.map(w => (
            <div class="mv-why__card">
              <div class="mv-why__icon" aria-hidden="true">{w.icon}</div>
              <h3>{w.title}</h3>
              <p>{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الأسئلة الشائعة
