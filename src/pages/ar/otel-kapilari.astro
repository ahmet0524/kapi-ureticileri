---
// src/pages/ar/otel-kapilari.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../../i18n/utils';

const lang  = 'ar';
const t     = useTranslations(lang);

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/otel-kapilari`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Otel-Serisi-401-Italyan-Ceviz.webp",
  "CihanpanDoor-Otel-Serisi-402-Kestane.webp",
  "CihanpanDoor-Otel-Serisi-403-Tik.webp",
  "CihanpanDoor-Otel-Serisi-404-Yildiz-Metal-Antrasit.webp",
  "CihanpanDoor-Otel-Serisi-405-Vision-Gri.webp",
  "CihanpanDoor-Otel-Serisi-406-Dark-Santana.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "أبواب الفنادق والضيافة — السلسلة المميزة | CihanPan Door",
  "description": "أبواب فنادق فاخرة بالجملة من قيصري، تركيا. تشطيبات لامينيت فاخرة، عازلة للصوت، مقاومة للحريق، شهادة CE.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "mainEntity": {
    "@type": "ItemList",
    "name": "موديلات أبواب الفنادق",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": "باب فندقي — السلسلة المميزة",
        "description": "باب فندقي لامينيت فاخر. عازل للصوت لراحة الضيوف، مقاوم للحريق، شهادة CE. متين للاستخدام اليومي المكثف.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "لامينيت فاخر / MDF",
        "category": "باب فندقي",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية",       "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": "المنتجات",       "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": "أبواب الفنادق",  "item": currentUrl },
  ]
};

const allSchemas = [hotelSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: 'الكل',                active: false },
  { slug: '/pvc-kapilar',               label: 'أبواب PVC',           active: false },
  { slug: '/laminoks-kapilar',          label: 'أبواب لامينوكس',      active: false },
  { slug: '/elitpan-doors',             label: 'أبواب إليتبان',       active: false },
  { slug: '/hospital-doors',            label: 'أبواب المستشفيات',    active: false },
  { slug: '/otel-kapilari',             label: 'أبواب الفنادق',        active: true  },
  { slug: '/yangina-dayanikli-kapilar', label: 'الأبواب المقاومة للحريق', active: false },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface HotelProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  badge: string;
  image: string;
  alt: string;
}

const hotelProducts: HotelProduct[] = fileNames.map((fn, i) => {
  const parts = fn.replace('.webp', '').split('-');
  const model = parts[3];
  const color = parts.slice(4).join(' ');
  return {
    id:    `hotel-${model}`,
    model,
    color,
    label: `Hotel ${model} · ${color}`,
    badge: i < 3 ? 'مميز · تصميم أنيق' : 'فاخر · تصميم حصري',
    image: `/assets/img/hotel-doors/${fn}`,
    alt:   `CihanPan Door سلسلة الفنادق ${model} ${color} — باب ضيافة فاخر`,
  };
});
---

<I18nLayout
  title="أبواب الفنادق والضيافة — السلسلة المميزة | بالجملة | CihanPan Door"
  description="أبواب فنادق فاخرة بالجملة من قيصري، تركيا. لامينيت فاخر، عازلة للصوت، مقاومة للحريق، شهادة CE وISO 9001."
  keywords="أبواب فنادق بالجملة تركيا، مصنع أبواب ضيافة قيصري، باب فندقي مميز شهادة CE، باب فندقي عازل للصوت"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="أبواب الفنادق — السلسلة المميزة | CihanPan Door"
  ogDescription="أبواب فنادق فاخرة عازلة للصوت ومقاومة للحريق. مباشرة من المصنع."
  ogImage="/assets/img/og/hotel-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="مسار التنقل">
            <a href={pageUrl}>الرئيسية</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>المنتجات</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">أبواب الفنادق</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            مجموعة الضيافة · السلسلة المميزة
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            <em>أبواب الفنادق والضيافة</em><br/>تشطيب فاخر · عازل للصوت · شهادة CE
          </h1>
          <p class="lam-hero__lead">
            أبواب فنادق بالجملة مباشرة من مصنع قيصري، تركيا. تشطيبات لامينيت فاخرة على قلب MDF متين — مصممة لبيئات الضيافة ذات الحركة العالية. شهادة CE وISO 9001. الحد الأدنى للطلب 50 وحدة.
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ تشطيب لامينيت فاخر</span>
            <span class="lam-htag">✓ عزل صوتي 32–42 dB</span>
            <span class="lam-htag">✓ مقاوم للحريق</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ MOQ 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              احصل على عرض سعر مجاني
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              تصفح الموديلات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>موديل</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>جودة</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>42<sup>dB</sup></strong><span>صوت</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>معتمد</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label="فئات الأبواب">
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">مجموعة أبواب الفنادق</span>
          <h2 id="catalogue-h2">
            موديلات أبواب الفنادق والضيافة
          </h2>
          <p>
            {`${modelCount} موديلات أبواب فنادق مميزة — السلسلة 401–406. تشطيبات بنقوش خشبية فاخرة وعصرية مصممة لمشاريع الضيافة الراقية.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            طلب عرض سعر لمشروع فندقي
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <span class="lam-quote-note">رد خلال 24 ساعة · الحد الأدنى 50 وحدة</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label="موديلات أبواب الفنادق">
          {hotelProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.badge}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            ما الذي يجعل الباب الفندقي متميزاً؟ نهج CihanPan
          </h2>

          <p>
            تجمع <strong>سلسلة الفنادق من CihanPan Door</strong> بين فهم متطلبات تصميم الضيافة ودقة التصنيع في مصنعنا بقيصري. كل موديل مبني على قلب MDF متين مغطى بـ<em>تشطيب لامينيت فاخر</em> — مصمم لتحمل ملايين دورات الفتح والإغلاق مع الحفاظ على المظهر الراقي طوال عمر المنشأة.
          </p>

          <h3>الميزات الرئيسية لبيئات الضيافة</h3>
          <ul class="lam-checklist">
            <li><strong>تشطيب لامينيت فاخر:</strong> تشطيبات بنقوش خشبية غنية وعصرية — جوز إيطالي، كستناء، تيك، رمادي فيجن والمزيد — ترفع جماليات الممرات والغرف.</li>
            <li><strong>عزل صوتي 32–42 dB:</strong> يحمي خصوصية الضيوف ويقلل ضجيج الممرات — عامل حاسم للتقييمات الإيجابية وتكرار الحجوزات.</li>
            <li><strong>متانة للاستخدام المكثف:</strong> قلب MDF والتشطيب اللامينيت يتحملان الاستخدام المستمر النموذجي في الفنادق ذات معدلات الإشغال العالية.</li>
            <li><strong>الامتثال لسلامة الحريق:</strong> خيارات مقاومة للحريق متاحة لتلبية لوائح البناء في تركيا والاتحاد الأوروبي والشرق الأوسط.</li>
            <li><strong>سهولة الصيانة:</strong> التشطيب اللامينيت سهل التنظيف — لا يحتاج إلى إعادة طلاء دورية، مما يقلل وقت توقف التدبير المنزلي.</li>
            <li><strong>جاهز للقفل الإلكتروني:</strong> تحضير مسبق لأنظمة القفل الإلكتروني بطاقة المفتاح وRFID متاح في جميع موديلات سلسلة الفنادق.</li>
          </ul>

          <h3>تطبيقات الضيافة</h3>
          <p>تُستخدم سلسلة فنادق CihanPan Door في:</p>
          <ul class="lam-checklist">
            <li><strong>غرف الضيوف في الفنادق:</strong> تشطيب فاخر وعزل صوتي لتجربة ضيوف متميزة في المنشآت من 3 إلى 5 نجوم.</li>
            <li><strong>الفنادق البوتيكية:</strong> تشطيبات بنقوش خشبية مميزة تكمل مفاهيم التصميم الداخلي الفريدة.</li>
            <li><strong>الشقق الفندقية:</strong> حل متين للإقامة طويلة المدى مع إشغال يومي مرتفع.</li>
            <li><strong>المنتجعات السياحية:</strong> حلول توريد بالجملة للمنشآت الكبيرة التي تحتاج إلى مئات الأبواب المتطابقة.</li>
            <li><strong>النزل والبيوت الضيافة:</strong> خيار مميز فعّال من حيث التكلفة يوفر متانة على مستوى الفنادق بأسعار جملة تنافسية.</li>
            <li><strong>مرافق المؤتمرات والفعاليات:</strong> أبواب عازلة للصوت مثالية لغرف الاجتماعات والمساحات الوظيفية.</li>
          </ul>

          <h3>المواصفات الفنية</h3>
          <ul class="lam-checklist">
            <li>السطح: لامينيت فاخر — بنقوش خشبية وتشطيبات عصرية</li>
            <li>القلب: MDF صلب متين</li>
            <li>الأحجام القياسية: 80×200 سم · 90×200 سم — أحجام مخصصة متاحة</li>
            <li>العزل الصوتي: 32–42 dB</li>
            <li>مقاومة الحريق: اختياري 30–60 دقيقة (EN 1634)</li>
            <li>الأجهزة: مفصلات للاستخدام الثقيل، نظام مانع للارتطام، تحضير قفل إلكتروني</li>
            <li>شهادة CE وISO 9001</li>
            <li>ضمان المصنع 5 سنوات</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>موديل</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>جودة</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>معتمد</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>ضمان</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">متخصص الضيافة</span>
            <h3>طلب عرض سعر للمشروع</h3>
            <p>شاركنا نوع منشأتك وعدد الغرف ومتطلباتك — يرد عليك متخصصنا خلال 24 ساعة.</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                نموذج الاتصال
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                واتساب
              </a>
              <a href="tel:+905441690038" class="lam-btn lam-btn--outline lam-btn--sm" style="color: white;">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <div class="lam-features-card">
            <h3>الميزات الرئيسية</h3>
            <ul class="lam-feat-list">
              <li>✨ تشطيب لامينيت فاخر</li>
              <li>🔇 عزل صوتي 32–42 dB</li>
              <li>🔥 خيارات مقاومة للحريق</li>
              <li>🔑 جاهز للقفل الإلكتروني</li>
              <li>🏨 توريد بالجملة للمشاريع</li>
              <li>📐 أحجام وتكوينات مخصصة</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" aria-labelledby="faq-h2">
      <div class="lam-wrap lam-faq-wrap">
        <div class="lam-head">
          <span class="lam-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">الأسئلة المتداولة</h2>
        </div>
        <div class="lam-faqs">
          {([
            { q: 'ما الذي يجعل الباب مناسباً للاستخدام الفندقي؟',          a: 'يجب أن تتحمل أبواب الفنادق الاستخدام اليومي المستمر في مئات الغرف، وتوفر عزلاً صوتياً متميزاً لخصوصية الضيوف، وتلبي اشتراطات السلامة من الحريق، وتحافظ على مظهر فاخر يعكس هوية المنشأة.' },
            { q: 'ما خيارات التشطيب المتاحة لأبواب الفنادق؟',               a: 'تتضمن السلسلة (401–406) تشطيبات بنقوش خشبية غنية كالجوز الإيطالي والكستناء والتيك والأنثراسيت المعدني النجمي والرمادي فيجن والسنتانا الداكن. تشطيبات مخصصة وخيارات ألوان RAL متاحة للطلبات الكبيرة.' },
            { q: 'ما مستوى العزل الصوتي لأبواب الفنادق؟',                   a: 'توفر أبواب فنادق CihanPan Door عزلاً صوتياً من 32 إلى 42 dB حسب الموديل والتكوين. أختام صوتية وإطارات متاحة لتحقيق أقصى أداء في ممرات الغرف.' },
