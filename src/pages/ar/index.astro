---
// src/pages/ar/index.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang = 'ar';
const baseUrl = 'https://cihanpandoor.netlify.app';
const pageUrl = `${baseUrl}/ar`;

// ── SCHEMA ───────────────────────────────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CihanPan Door",
  "url": baseUrl,
  "inLanguage": "ar-SA",
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${baseUrl}/search?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CihanPan Door",
  "url": baseUrl,
  "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
  "foundingDate": "1995",
  "description": "شركة تصنيع أبواب داخلية معتمدة بـ CE وISO 9001 في قيصري، تركيا منذ عام 1995.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
    "addressLocality": "Kayseri",
    "addressRegion": "Kayseri",
    "postalCode": "38070",
    "addressCountry": "TR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+90-544-169-0038",
    "contactType": "Sales",
    "availableLanguage": ["Turkish", "English", "Arabic", "German"],
    "areaServed": ["TR", "US", "EU", "ME"]
  },
  "sameAs": ["https://www.cihanpandoor.com"]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "مجموعة الأبواب الداخلية",
  "url": pageUrl,
  "numberOfItems": 6,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "أبواب PVC",               "url": `${pageUrl}/pvc-kapilar` },
    { "@type": "ListItem", "position": 2, "name": "أبواب لامينوكس",          "url": `${pageUrl}/laminoks-kapilar` },
    { "@type": "ListItem", "position": 3, "name": "أبواب الفنادق",           "url": `${pageUrl}/otel-kapilari` },
    { "@type": "ListItem", "position": 4, "name": "أبواب المستشفيات",        "url": `${pageUrl}/hastane-kapilari` },
    { "@type": "ListItem", "position": 5, "name": "أبواب إليتبان MDF",       "url": `${pageUrl}/elitpan-kapilar` },
    { "@type": "ListItem", "position": 6, "name": "أبواب مقاومة للحريق",    "url": `${pageUrl}/yangina-dayanikli-kapilar` }
  ]
};

const schemas = [websiteSchema, organizationSchema, productSchema];

// ── CATEGORIES DATA ──────────────────────────────────────────────────
const categories = [
  {
    slug: '/pvc-kapilar',
    img: '/assets/img/categories/pvc-kapilar.webp',
    badge: 'الأكثر مبيعاً',
    badgeGold: true,
    title: 'أبواب PVC الداخلية',
    desc: 'أبواب PVC مقاومة للرطوبة ومضادة للبكتيريا. مثالية للحمامات والمستشفيات والبيئات عالية الرطوبة.',
    tags: ['مقاوم للماء', 'مضاد للبكتيريا', 'سهل التنظيف'],
  },
  {
    slug: '/laminoks-kapilar',
    img: '/assets/img/categories/laminoks-kapilar.webp',
    badge: 'مميز',
    badgeGold: false,
    title: 'أبواب لامينوكس الداخلية',
    desc: 'لب MDF ممتاز مع سطح لامينوكس متين. مقاوم للخدوش بأكثر من 50 خياراً للألوان لمشاريع الجملة.',
    tags: ['مقاوم للخدش', '+50 لوناً', 'لب MDF'],
    featured: true,
  },
  {
    slug: '/elitpan-kapilar',
    img: '/assets/img/categories/CihanpanDoor-Elitpan-Serisi-317.jpg',
    badge: 'بريميوم',
    badgeGold: false,
    title: 'أبواب إليتبان MDF',
    desc: 'سطح MDF مطلي بالأشعة فوق البنفسجية بلمسة نهائية لامعة. جودة تصدير للجملة السكنية والتجارية.',
    tags: ['طلاء UV', 'لمعان عالٍ', 'جودة تصدير'],
  },
  {
    slug: '/hastane-kapilari',
    img: '/assets/img/categories/hastane-kapilari.webp',
    badge: 'متخصص',
    badgeGold: false,
    title: 'أبواب درجة المستشفيات',
    desc: 'أبواب نظافة معتمدة CE لمرافق الرعاية الصحية. خيارات مبطنة بالرصاص ومضادة للإشعاع ومضادة للميكروبات.',
    tags: ['معتمدة CE', 'خيار رصاص', 'مضاد للميكروبات'],
  },
  {
    slug: '/otel-kapilari',
    img: '/assets/img/categories/otel-kapilari.webp',
    badge: 'ضيافة',
    badgeGold: false,
    title: 'أبواب غرف الفنادق',
    desc: 'أبواب فندقية معزولة صوتياً ومقاومة للحريق للفنادق من 3 إلى 5 نجوم. أسعار خاصة للطلبيات فوق 500 وحدة.',
    tags: ['عزل صوتي', 'مقاوم للحريق', 'سعر جملة'],
  },
  {
    slug: '/yangina-dayanikli-kapilar',
    img: '/assets/img/categories/yangina-dayanikli-kapilar.webp',
    badge: 'معتمدة',
    badgeGold: false,
    title: 'أبواب مقاومة للحريق',
    desc: 'أبواب حريق EI30–EI90 معتمدة CE. متوافقة مع معايير البناء الأوروبية والدولية.',
    tags: ['EI30–EI90', 'معتمدة CE', 'مطابق للمواصفات'],
  },
];

const trustItems = [
  { icon: '🏭', label: 'مباشر من المصنع',    desc: 'بدون وسطاء — شراء مباشر من الشركة المصنّعة' },
  { icon: '📋', label: 'CE + ISO 9001',       desc: 'جودة معتمدة في كل شحنة جملة' },
  { icon: '📦', label: 'الحد الأدنى 50 وحدة', desc: 'حد أدنى منخفض للاختبار قبل التوسع' },
  { icon: '🌍', label: '+25 دولة',            desc: 'سجل تصدير مثبت منذ عام 2010' },
  { icon: '🚢', label: 'شروط FOB / CIF',      desc: 'شروط Incoterms مرنة للمستوردين' },
  { icon: '⚡', label: 'رد خلال 24 ساعة',    desc: 'عرض سعر خلال يوم عمل واحد' },
];
---

<I18nLayout
  title="مصنع أبواب داخلية بالجملة من تركيا | معتمد CE وISO | CihanPan Door"
  description="شركة تصنيع أبواب داخلية بالجملة معتمدة بـ CE وISO 9001 في تركيا. أبواب PVC ولامينوكس وMDF ومقاومة للحريق. تصدير إلى الولايات المتحدة وأوروبا والشرق الأوسط. الحد الأدنى 50 وحدة."
  keywords="مصنع أبواب داخلية تركيا, أبواب داخلية بالجملة تركيا, تصدير أبواب تركي, أبواب PVC بالجملة, مصدر أبواب MDF, مصنع أبواب معتمد CE ISO"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="مصنع الأبواب الداخلية الأول بالجملة في تركيا | CihanPan Door"
  ogDescription="أبواب داخلية بالجملة مباشرة من المصنع في قيصري، تركيا. معتمدة CE وTSE وISO 9001. تصدير إلى أكثر من 25 دولة منذ عام 1995."
  ogImage="/assets/img/og/home-og.webp"
>
  <I18nHeader />

  <main class="hp" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="hp-hero" aria-labelledby="hero-h1">
      <div class="hp-hero__bg" aria-hidden="true">
        <div class="hp-hero__img"></div>
        <div class="hp-hero__overlay"></div>
        <div class="hp-hero__glow"></div>
      </div>

      <div class="hp-wrap hp-hero__inner">
        <div class="hp-hero__copy">
          <span class="hp-eyebrow">
            <span class="hp-eyebrow__line"></span>
            قيصري، تركيا · منذ عام 1995
          </span>

          <h1 class="hp-hero__h1" id="hero-h1">
            الشركة الرائدة في تصنيع<br /><em>الأبواب الداخلية بالجملة</em><br />وتصديرها من تركيا
          </h1>

          <p class="hp-hero__lead">
            معتمدة بـ CE وTSE وISO 9001. أبواب داخلية PVC وMDF ولامينوكس للمستوردين بالجملة في الولايات المتحدة وأوروبا والشرق الأوسط. طاقة إنتاجية 600,000 وحدة سنوياً.
          </p>

          <div class="hp-hero__tags">
            <span class="hp-htag">✓ معتمدة CE</span>
            <span class="hp-htag">✓ ISO 9001</span>
            <span class="hp-htag">✓ الحد الأدنى 50 وحدة</span>
            <span class="hp-htag">✓ جاهز للتصدير</span>
          </div>

          <div class="hp-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--gold">
              احصل على عرض سعر
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#products" class="hp-btn hp-btn--ghost">
              عرض جميع المنتجات
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="hp-wrap">
        <div class="hp-statsbar">
          <div class="hp-sitem">
            <strong>30<sup>+</sup></strong>
            <span>سنة خبرة</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>600K</strong>
            <span>وحدة / سنة</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>25<sup>+</sup></strong>
            <span>دولة تصدير</span>
          </div>
          <div class="hp-sdiv"></div>
          <div class="hp-sitem">
            <strong>15K m²</strong>
            <span>مساحة المصنع</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         TRUST BAR
    ══════════════════════════════════════════ -->
    <section class="hp-trust" aria-label="لماذا تختارنا">
      <div class="hp-wrap">
        <div class="hp-trust__grid">
          {trustItems.map(item => (
            <div class="hp-trust__item">
              <span class="hp-trust__icon" aria-hidden="true">{item.icon}</span>
              <div>
                <strong>{item.label}</strong>
                <p>{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         PRODUCTS
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" id="products" aria-labelledby="products-h2">
      <div class="hp-wrap">
        <div class="hp-head">
          <span class="hp-tag">نطاق منتجاتنا</span>
          <h2 id="products-h2">مجموعة الأبواب الداخلية بالجملة — مباشر من المصنع في تركيا</h2>
          <p>جميع خطوط الإنتاج معتمدة بـ CE وISO 9001 ومتاحة للتصدير بالجملة إلى الولايات المتحدة وأوروبا والشرق الأوسط.</p>
        </div>

        <div class="hp-products">
          {categories.map((cat, i) => (
            <article class={`hp-product ${cat.featured ? 'hp-product--featured' : ''}`}>
              <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__img-wrap" tabindex="-1" aria-hidden="true">
                <img
                  src={cat.img}
                  alt={cat.title}
                  width="480"
                  height="360"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class={`hp-product__badge ${cat.badgeGold ? 'hp-product__badge--gold' : ''}`}>{cat.badge}</span>
              </a>
              <div class="hp-product__body">
                <h3><a href={getLocalizedRoute(cat.slug, lang)}>{cat.title}</a></h3>
                <p>{cat.desc}</p>
                <ul class="hp-product__tags">
                  {cat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <a href={getLocalizedRoute(cat.slug, lang)} class="hp-product__cta">
                  عرض وطلب السعر
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SOLUTIONS
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--navy" aria-labelledby="solutions-h2">
      <div class="hp-wrap">
        <div class="hp-head hp-head--light">
          <span class="hp-tag">كيف نعمل</span>
          <h2 id="solutions-h2">خدمات البيع بالجملة والتصدير</h2>
          <p>ثلاثة نماذج توريد مرنة للمستوردين والموزعين ومطوري المشاريع</p>
        </div>

        <div class="hp-solutions">
          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">01</div>
            <div class="hp-sol__icon" aria-hidden="true">🏭</div>
            <h3>طلبات الجملة</h3>
            <p>الحد الأدنى 50 وحدة. أسعار ثابتة للمقاسات القياسية. خصومات على الكميات من 200 وحدة فأكثر.</p>
            <ul>
              <li>الحد الأدنى 50 وحدة</li>
              <li>خصومات الكميات متاحة</li>
              <li>وثائق CE/ISO مشمولة</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">02</div>
            <div class="hp-sol__icon" aria-hidden="true">🌍</div>
            <h3>خدمات التصدير والاستيراد</h3>
            <p>توثيق تصدير كامل: فاتورة تجارية، قائمة تعبئة، شهادة منشأ، شهادات CE وISO. شروط FOB / CIF / EXW.</p>
            <ul>
              <li>شروط FOB / CIF / EXW</li>
              <li>توثيق تصدير كامل</li>
              <li>تنسيق الشحن</li>
            </ul>
          </div>

          <div class="hp-sol">
            <div class="hp-sol__num" aria-hidden="true">03</div>
            <div class="hp-sol__icon" aria-hidden="true">🏗️</div>
            <h3>حلول المشاريع المخصصة</h3>
            <p>مقاسات غير قياسية، علامة تجارية خاصة، تشطيبات مخصصة — متاحة للفنادق والمستشفيات والمجمعات السكنية.</p>
            <ul>
              <li>مقاسات وتشطيبات مخصصة</li>
              <li>علامة تجارية خاصة متاحة</li>
              <li>دعم قياس الموقع</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ABOUT
    ══════════════════════════════════════════ -->
    <section class="hp-sec hp-sec--white" aria-labelledby="about-h2">
      <div class="hp-wrap hp-about">

        <div class="hp-about__text">
          <span class="hp-tag">عن CihanPan Door</span>
          <h2 id="about-h2">مصنع أبواب داخلية معتمد CE وISO 9001 في قيصري، تركيا</h2>

          <p>تأسست <strong>CihanPan Door</strong> عام 1995، وتُعدّ من أكثر شركات تصنيع الأبواب الداخلية بالجملة خبرةً في تركيا. تعمل من منشأة إنتاج تبلغ مساحتها 15,000 م² في المنطقة الصناعية المنظمة بقيصري، وتنتج أكثر من <strong>600,000 طقم باب داخلي سنوياً</strong> للمشترين بالجملة في الولايات المتحدة وأوروبا والشرق الأوسط.</p>
          <h3>لماذا استيراد الأبواب الداخلية من تركيا؟</h3>
          <p>تُعدّ تركيا البديل الرائد لتصنيع الأبواب الصينية للمستوردين الأمريكيين — إذ تقدم <strong>جودة معتمدة CE وISO</strong> بأسعار تنافسية مع أوقات شحن بحري أقصر بكثير. تشحن CihanPan Door إلى جميع الموانئ الرئيسية.</p>
          <h3>قدراتنا في تصنيع الأبواب الداخلية</h3>
          <p>نصنّع <strong>أبواب PVC، ولامينوكس، وإليتبان MDF، وأبواب صحية للمستشفيات، وأبواب غرف الفنادق، وأبواب مقاومة للحريق EI30–EI90</strong>. جميع خطوط الإنتاج تدعم المقاسات المخصصة والأبعاد غير القياسية والعلامة التجارية الخاصة.</p>

          <div class="hp-about__cta">
            <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--navy">
              طلب أسعار الجملة
            </a>
            <a href="https://www.cihanpandoor.com/E-Katalog.pdf" target="_blank" rel="noopener noreferrer" class="hp-btn hp-btn--outline-dark">
              تحميل الكتالوج (PDF)
            </a>
          </div>
        </div>

        <aside class="hp-about__stats" aria-label="إحصائيات الشركة">
          <div class="hp-kpi">
            <strong>1995</strong>
            <span>سنة التأسيس</span>
          </div>
          <div class="hp-kpi">
            <strong>600K</strong>
            <span>وحدة / سنة</span>
          </div>
          <div class="hp-kpi">
            <strong>25<sup>+</sup></strong>
            <span>دولة تصدير</span>
          </div>
          <div class="hp-kpi">
            <strong>150<sup>+</sup></strong>
            <span>موظف</span>
          </div>
          <div class="hp-kpi">
            <strong>15K m²</strong>
            <span>مساحة المصنع</span>
          </div>
        </aside>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="hp-cta" aria-labelledby="cta-h2">
      <div class="hp-cta__glow" aria-hidden="true"></div>
      <div class="hp-wrap hp-cta__inner">
        <div class="hp-cta__text">
          <span class="hp-tag hp-tag--gold">ابدأ التوريد اليوم</span>
          <h2 id="cta-h2">اطلب عرض سعر للأبواب الداخلية بالجملة من تركيا</h2>
          <p>أخبرنا بأنواع الأبواب والكميات والوجهة. نرد خلال 24 ساعة بأسعار مباشرة من المصنع ووثائق CE/ISO كاملة.</p>
        </div>
        <div class="hp-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="hp-btn hp-btn--gold">
            احصل على عرض مجاني
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/hakkimizda', lang)} class="hp-btn hp-btn--ghost">
            تعرف علينا
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  .hp {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    font-family: 'Cairo', 'Tajawal', system-ui, sans-serif;
    color: var(--text);
    direction: rtl;
  }

  .hp-wrap {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }

  .hp-sec          { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .hp-sec--white   { background: var(--white); }
  .hp-sec--navy    { background: var(--navy); }
  .hp-sec--cream   { background: var(--cream); }

  .hp-head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .hp-head h2 {
    font-family: 'Cairo', 'Tajawal', system-ui, sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
