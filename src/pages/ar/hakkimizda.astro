---
// src/pages/ar/hakkimizda.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// ── SEO DATA ──────────────────────────────────────────────────────────
const baseUrl = 'https://cihanpandoor.netlify.app';
const pageUrl = `${baseUrl}/ar/hakkimizda`;

// ── SCHEMA: AboutPage + Organization ─────────────────────────────────
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "من نحن — CihanPan Door | مصنع ومصدّر أبواب داخلية من تركيا",
  "description": "CihanPan Door مصنع أبواب داخلية معتمد بشهادات CE وTSE وISO 9001 في قيصري، تركيا. نصدّر بالجملة إلى الولايات المتحدة وأوروبا والشرق الأوسط منذ عام 1995 بطاقة إنتاجية 600,000 وحدة سنوياً.",
  "url": pageUrl,
  "inLanguage": "ar",
  "isPartOf": {
    "@type": "WebSite",
    "name": "CihanPan Door",
    "url": baseUrl
  },
  "about": {
    "@type": "Organization",
    "name": "CihanPan Door",
    "alternateName": "Cihanpan Kapı",
    "url": baseUrl,
    "logo": `${baseUrl}/assets/img/logo/header-logo1.webp`,
    "foundingDate": "1995",
    "description": "الشركة الرائدة في تركيا لتصنيع وتصدير الأبواب الداخلية بالجملة. معتمدة CE وTSE وISO 9001. أبواب PVC وMDF ولامينوكس للفنادق والمستشفيات والمشاريع السكنية والتجارية.",
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 150 },
    "areaServed": ["US", "EU", "ME", "AF"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "name": "شهادة CE" },
      { "@type": "EducationalOccupationalCredential", "name": "شهادة TSE" },
      { "@type": "EducationalOccupationalCredential", "name": "ISO 9001" }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Organize Sanayi Bölgesi 29. Sokak No:28",
      "addressLocality": "Kayseri",
      "addressRegion": "Kayseri",
      "postalCode": "38070",
      "addressCountry": "TR"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+90-544-169-0038",
      "contactType": "المبيعات",
      "availableLanguage": ["العربية", "الإنجليزية", "التركية", "الألمانية"],
      "areaServed": ["ME", "AF", "EU"]
    },
    "sameAs": [
      "https://www.cihanpandoor.com",
      "https://www.linkedin.com/company/cihanpan-door"
    ]
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": `${baseUrl}/ar` },
    { "@type": "ListItem", "position": 2, "name": "من نحن", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "هل CihanPan Door مصنع أبواب داخلية معتمد؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "نعم. تحمل CihanPan Door شهادات CE وTSE وISO 9001، مما يضمن الامتثال الكامل للمعايير الأوروبية والدولية لجميع منتجات الأبواب الداخلية."
      }
    },
    {
      "@type": "Question",
      "name": "ما هو الحد الأدنى لكمية الطلب للأبواب بالجملة؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "الحد الأدنى لطلب الجملة هو 50 وحدة. وللمشاريع الكبرى كالفنادق والمستشفيات والمجمعات السكنية، نقدم تسعيراً خاصاً للكميات الكبيرة."
      }
    },
    {
      "@type": "Question",
      "name": "هل تصدّر CihanPan Door الأبواب إلى دول الشرق الأوسط؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "نعم. نصدّر الأبواب الداخلية بالجملة إلى أكثر من 25 دولة تشمل دول الخليج وشمال أفريقيا والشرق الأوسط. نوفر وثائق تصدير كاملة وأسعاراً تنافسية FOB/CIF."
      }
    },
    {
      "@type": "Question",
      "name": "ما أنواع الأبواب الداخلية التي تصنعونها؟",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "نصنع أبواباً مغلفة بـ PVC، ولامينوكس، وإيليتبان (MDF مطلي بالأشعة فوق البنفسجية)، وأبواباً للمستشفيات والفنادق ومقاومة للحريق. تتوفر مقاسات وألوان مخصصة لجميع طلبات الجملة."
      }
    }
  ]
};

const schemas = [aboutPageSchema, breadcrumbSchema, faqSchema];

// ── PAGE DATA ─────────────────────────────────────────────────────────
const values = [
  { num: '01', title: 'جودة من الدرجة الأولى',    text: 'نستخدم فقط المواد الخام المتميزة في خط الإنتاج. تخضع كل باب لفحص جودة متعدد المراحل قبل الشحن.' },
  { num: '02', title: 'موثوقية مُثبتة',           text: 'أكثر من 30 عاماً من التصنيع المتواصل والتسليم في الوقت المحدد — سجلنا يتحدث عن نفسه.' },
  { num: '03', title: 'العميل أولاً',              text: 'مدير حساب مخصص وعينات قبل الشحن ودعم ما بعد البيع لكل شريك جملة.' },
  { num: '04', title: 'الابتكار والبحث والتطوير', text: 'استثمار مستمر في تقنية CNC وأسطح تشطيب جديدة يبقي كتالوجنا في طليعة اتجاهات السوق.' },
];

const timeline = [
  { year: '1995', title: 'التأسيس في قيصري',              text: 'انطلقنا كورشة متخصصة في الأبواب الداخلية في قيصري، عاصمة الصناعة التركية.' },
  { year: '2003', title: 'افتتاح المصنع الحديث',          text: 'انتقلنا إلى المنطقة الصناعية المنظمة بقيصري بخطوط إنتاج آلية متكاملة.' },
  { year: '2010', title: 'انطلاق التصدير الدولي',         text: 'بدأنا التصدير إلى أسواق الشرق الأوسط وأفريقيا — نخدم الآن أكثر من 25 دولة.' },
  { year: '2018', title: 'الحصول على شهادة ISO 9001',     text: 'حصلنا على شهادة ISO 9001 إضافةً إلى اعتمادات CE وTSE القائمة.' },
  { year: '2024', title: '600,000 وحدة سنوياً',           text: 'بلغنا طاقة إنتاجية سنوية تبلغ 600,000 مجموعة باب — جاهزون لأي حجم من طلبات الجملة.' },
];

const certs = [
  { badge: 'CE',  title: 'شهادة CE',   text: 'تؤكد الامتثال لمعايير السلامة والجودة في السوق الأوروبية' },
  { badge: 'TSE', title: 'شهادة TSE',  text: 'معهد المعايير التركي — علامة الجودة الإلزامية للمصنّعين الأتراك' },
  { badge: 'ISO', title: 'ISO 9001:2015', text: 'نظام إدارة الجودة الدولي — إنتاج متسق في كل دفعة' },
];

const whyUs = [
  { icon: '🏭', title: 'سعر مباشر من المصنع',    text: 'لا وكلاء، لا وسطاء. تشتري مباشرة من المصنّع — هامش ربح أقصى لعملك.' },
  { icon: '🌍', title: 'جاهز للتصدير',            text: 'توثيق كامل: فاتورة تجارية، قائمة تعبئة، شهادة منشأ، وشهادات CE/ISO مضمنة.' },
  { icon: '📦', title: 'الحد الأدنى 50 وحدة',    text: 'حد أدنى منخفض يتيح لك اختبار جودة المنتج قبل الالتزام بكميات كبيرة.' },
  { icon: '⚙️', title: 'مقاسات وتشطيبات مخصصة', text: 'مقاسات غير معيارية، ألوان مخصصة، علامة تجارية خاصة — متاحة لجميع طلبات الجملة.' },
  { icon: '🚢', title: 'شروط تسليم مرنة',        text: 'EXW أو FOB أو CIF — نتعاون مع شركة الشحن الخاصة بك أو ندير اللوجستيات من الألف إلى الياء.' },
  { icon: '🏅', title: 'معتمد CE + ISO',          text: 'كل شحنة مدعومة بوثائق CE وTSE وISO 9001 لتسهيل إجراءات الجمارك.' },
];
---

<I18nLayout
  title="مصنع ومصدّر أبواب داخلية من تركيا | CihanPan Door – منذ 1995"
  description="مصنع أبواب داخلية معتمد CE وISO 9001 في تركيا. أبواب PVC وMDF ولامينوكس بالجملة للولايات المتحدة وأوروبا والشرق الأوسط. 600 ألف وحدة سنوياً. الحد الأدنى 50 وحدة. اطلب عرض سعر."
  keywords="مصنع أبواب داخلية تركيا، أبواب داخلية بالجملة، مصدّر أبواب تركيا، أبواب PVC بالجملة، أبواب MDF تركيا، مصنع أبواب معتمد ISO، استيراد أبواب من تركيا"
  canonical={pageUrl}
  schema={schemas}
  ogTitle="الشركة الرائدة لتصدير الأبواب الداخلية بالجملة من تركيا | CihanPan Door"
  ogDescription="أبواب داخلية مباشرة من المصنع في قيصري، تركيا. معتمدة CE وTSE وISO 9001. نصدّر إلى الولايات المتحدة وأوروبا والشرق الأوسط منذ 1995. الحد الأدنى 50 وحدة."
  ogImage="/assets/img/og/about-og.webp"
>
  <I18nHeader />

  <main class="ab" id="main-content" dir="rtl" lang="ar">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="ab-hero" aria-labelledby="hero-heading">
      <div class="ab-hero__grid" aria-hidden="true"></div>
      <div class="ab-wrap ab-hero__inner">

        <div class="ab-hero__copy">
          <span class="ab-eyebrow">
            <span class="ab-eyebrow__line"></span>
            قيصري، تركيا · تأسست عام 1995
          </span>

          <h1 class="ab-hero__h1" id="hero-heading">
            الشركة الرائدة في تركيا<br>
            <em>لتصنيع الأبواب الداخلية</em><br>
            وتصديرها بالجملة
          </h1>

          <p class="ab-hero__sub">
            مصنع أبواب داخلية بالجملة معتمد بشهادات CE وTSE وISO 9001 في قيصري، تركيا.
            نصدّر أبواب PVC وMDF ولامينوكس إلى <strong>الولايات المتحدة وأوروبا والشرق الأوسط</strong>
            منذ عام 1995 — بطاقة إنتاجية <strong>600,000 وحدة سنوياً</strong>.
          </p>

          <div class="ab-hero__tags">
            <span class="ab-htag">✓ معتمد CE</span>
            <span class="ab-htag">✓ ISO 9001</span>
            <span class="ab-htag">✓ الحد الأدنى: 50 وحدة</span>
            <span class="ab-htag">✓ جاهز للتصدير</span>
          </div>

          <div class="ab-stats">
            <div class="ab-stat">
              <strong>30<sup>+</sup></strong>
              <span>سنة خبرة</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>600K</strong>
              <span>وحدة / سنة</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>25<sup>+</sup></strong>
              <span>دولة تصدير</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
              <strong>150<sup>+</sup></strong>
              <span>موظف</span>
            </div>
          </div>
        </div>

        <div class="ab-hero__badges" aria-label="شهادات الجودة">
          <div class="ab-hb ab-hb--gold" title="معتمد CE">CE</div>
          <div class="ab-hb" title="معتمد TSE">TSE</div>
          <div class="ab-hb" title="معتمد ISO 9001">ISO<br>9001</div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         لماذا نحن
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--cream" aria-labelledby="whyus-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">لماذا CihanPan Door</span>
          <h2 id="whyus-heading">لماذا يختار المستوردون<br>مصنعنا للأبواب الداخلية في تركيا</h2>
          <p>مزايا المصنّع المباشر التي تحمي هوامش أرباحك وتبسّط سلسلة توريدك</p>
        </div>
        <div class="ab-why">
          {whyUs.map(w => (
            <div class="ab-why__card">
              <div class="ab-why__icon" aria-hidden="true">{w.icon}</div>
              <h3>{w.title}</h3>
              <p>{w.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الرسالة / الرؤية
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="mv-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">توجهنا</span>
          <h2 id="mv-heading">رسالتنا ورؤيتنا</h2>
          <p>القيم والأهداف بعيدة المدى التي تشكّل طريقة تصنيعنا وتصديرنا</p>
        </div>
        <div class="ab-mv">
          <div class="ab-mv__card ab-mv__card--blue">
            <div class="ab-mv__bar"></div>
            <div class="ab-mv__icon ab-mv__icon--blue" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>رسالتنا</h3>
            <p>أن نكون <strong>أكثر مصدّري الأبواب الداخلية بالجملة موثوقيةً من تركيا</strong> — بتقديم جودة مباشرة من المصنع، وتوثيق CE/ISO كامل، ولوجستيات موثوقة لكل طلب دولي.</p>
            <ul class="ab-checks">
              <li>تسعير مباشر من المصنع — لا وسطاء</li>
              <li>جملة من 50 وحدة مع أسعار خاصة للكميات الكبيرة</li>
              <li>مقاسات وتشطيبات وعلامة تجارية خاصة</li>
            </ul>
          </div>
          <div class="ab-mv__card ab-mv__card--gold">
            <div class="ab-mv__bar"></div>
            <div class="ab-mv__icon ab-mv__icon--gold" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
            <h3>رؤيتنا</h3>
            <p>أن نكون <strong>الاسم الأول في أذهان مشتري الجملة في الولايات المتحدة وأوروبا والشرق الأوسط</strong> عند البحث عن مصنّع أبواب داخلية تركي — بالجودة المعتمدة، والتسليم في الوقت المحدد، وممارسات الأعمال الشفافة.</p>
            <ul class="ab-checks">
              <li>شهادات CE وTSE وISO 9001 مع كل شحنة</li>
              <li>إنتاج مستدام صديق للبيئة</li>
              <li>التوسع إلى 40+ دولة تصدير بحلول 2027</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         قيمنا
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--navy" aria-labelledby="values-heading">
      <div class="ab-wrap">
        <div class="ab-head ab-head--light">
          <span class="ab-tag">مبادئنا الأساسية</span>
          <h2 id="values-heading">قيمنا في التصنيع</h2>
          <p>ما نؤمن به من اختيار المواد الخام حتى تسليم الشحنة</p>
        </div>
        <div class="ab-vals">
          {values.map(v => (
            <div class="ab-val">
              <span class="ab-val__n" aria-hidden="true">{v.num}</span>
              <div class="ab-val__bar" aria-hidden="true"></div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
              <div class="ab-val__sweep" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         تاريخنا
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="history-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">30 عاماً من التصنيع</span>
          <h2 id="history-heading">تاريخنا بوصفنا<br>مصنع أبواب داخلية تركياً</h2>
          <p>المحطات الرئيسية التي حوّلت CihanPan Door إلى مورد جملة موثوق به عالمياً</p>
        </div>
        <div class="ab-tl-wrap">
          {timeline.map((item) => (
            <div class="ab-tl">
              <div class="ab-tl__yr">{item.year}</div>
              <div class="ab-tl__spine" aria-hidden="true">
                <div class="ab-tl__line"></div>
                <div class="ab-tl__dot"></div>
                <div class="ab-tl__line"></div>
              </div>
              <div class="ab-tl__body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الشهادات
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--cream" aria-labelledby="certs-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">المعايير الدولية</span>
          <h2 id="certs-heading">إنتاج الأبواب الداخلية<br>المعتمد CE وTSE وISO 9001</h2>
          <p>كل شحنة جملة مدعومة بوثائق الجودة المعترف بها دولياً</p>
        </div>
        <div class="ab-certs">
          {certs.map(c => (
            <div class="ab-cert">
              <div class="ab-cert__badge" aria-label={c.title}>{c.badge}</div>
              <div class="ab-cert__body">
                <h3>{c.title}</h3>
                <p>{c.text}</p>
              </div>
              <div class="ab-cert__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          ))}
        </div>

        <p class="ab-certs__note">
          جميع الشهادات متاحة عند الطلب وتُدرج في حزمة وثائق التصدير مع كل شحنة.
          <a href="/ar/iletisim" class="ab-link">اطلب نسخة →</a>
        </p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         الأسئلة الشائعة
    ══════════════════════════════════════════ -->
    <section class="ab-sec ab-sec--white" aria-labelledby="faq-heading">
      <div class="ab-wrap">
        <div class="ab-head">
          <span class="ab-tag">الأسئلة الشائعة</span>
          <h2 id="faq-heading">أسئلة شائعة لمشتري الجملة</h2>
          <p>كل ما تحتاج معرفته قبل تقديم أول طلب استيراد أبواب داخلية من تركيا</p>
        </div>
        <div class="ab-faq">
          <details class="ab-faq__item">
            <summary><h3>هل CihanPan Door مصنع أبواب داخلية معتمد؟</h3></summary>
            <p>نعم. تحمل CihanPan Door <strong>شهادات CE وTSE وISO 9001</strong>، مما يضمن الامتثال الكامل للمعايير الأوروبية والدولية لجميع منتجات الأبواب الداخلية. تُرفق الشهادات مع كل شحنة جملة.</p>
          </details>
          <details class="ab-faq__item">
