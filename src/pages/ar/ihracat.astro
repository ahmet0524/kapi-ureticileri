---
// src/pages/ar/ihracat.astro
import I18nLayout from '../../layouts/I18nLayout.astro';
import I18nHeader from '../../components/I18nHeader.astro';
import I18nFooter from '../../components/I18nFooter.astro';
import { getLocalizedRoute } from '../../i18n/utils';

const lang     = 'ar';
const baseUrl  = 'https://cihanpandoor.netlify.app';
const pageUrl  = `${baseUrl}/ar`;
const currentUrl = `${pageUrl}/ihracat`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const exportSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "التصدير الدولي | CihanPan Door",
  "description": "خدمات التصدير الدولي من CihanPan Door. تصدير أبواب عالية الجودة إلى أوروبا والشرق الأوسط وأفريقيا. معتمد CE وISO 9001. بيع بالجملة مباشرة من المصنع.",
  "url": currentUrl,
  "inLanguage": "ar-SA",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": pageUrl },
      { "@type": "ListItem", "position": 2, "name": "التصدير",  "item": currentUrl },
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "ما هو الحد الأدنى لكمية التصدير؟",      "acceptedAnswer": { "@type": "Answer", "text": "بالنسبة للطلبات القائمة على الحاويات، الحد الأدنى هو حاوية كاملة واحدة (ما يقارب 300–400 باب). يتوفر تسعير خاص لشحنات LCL." }},
    { "@type": "Question", "name": "ما هي مدة التسليم؟",                    "acceptedAnswer": { "@type": "Answer", "text": "يستغرق الإنتاج 3–4 أسابيع بعد تأكيد الطلب. تتراوح أوقات الشحن بين 1–3 أسابيع حسب الدولة المقصودة." }},
    { "@type": "Question", "name": "ما طرق الدفع التي تقبلونها؟",           "acceptedAnswer": { "@type": "Answer", "text": "نقبل خطاب الاعتماد (L/C)، والتحويل المصرفي (T/T)، و30% مقدماً + 70% قبل الشحن." }},
    { "@type": "Question", "name": "هل ترسلون عينات؟",                      "acceptedAnswer": { "@type": "Answer", "text": "نعم، نرسل عينات إلى عملاء التصدير المحتملين على أساس freight-collect (يدفع المستلم)." }},
    { "@type": "Question", "name": "هل تصنعون تصاميم مخصصة؟",              "acceptedAnswer": { "@type": "Answer", "text": "نعم، نقدم تصميماً مخصصاً قائماً على المشروع وإنتاجاً وفق المقاس. يرجى التواصل معنا للاستفسار عن الحد الأدنى للكميات." }},
  ]
};

const allSchemas = [exportSchema, faqSchema];
---

<I18nLayout
  title="التصدير الدولي | CihanPan Door"
  description="خدمات التصدير الدولي من CihanPan Door. تصدير أبواب عالية الجودة إلى أوروبا والشرق الأوسط وأفريقيا. معتمد CE وISO 9001. بيع بالجملة مباشرة من المصنع."
  keywords="تصدير أبواب تركيا, أبواب جملة مصنع قيصري, تصدير أبواب معتمدة CE, مصنع أبواب تركيا أوروبا الشرق الأوسط أفريقيا"
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle="التصدير الدولي | CihanPan Door"
  ogDescription="تصدير أبواب عالية الجودة إلى أوروبا والشرق الأوسط وأفريقيا. معتمد CE وISO 9001. تسعير مباشر من المصنع."
  ogImage="/assets/img/og/export-og.webp"
  lang="ar"
>
  <I18nHeader />

  <main class="exp" id="main-content" dir="rtl">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="exp-hero" aria-labelledby="exp-h1">
      <div class="exp-hero__bg" aria-hidden="true">
        <div class="exp-hero__overlay"></div>
        <div class="exp-hero__glow"></div>
      </div>
      <div class="exp-wrap exp-hero__inner">
        <nav class="exp-breadcrumb" aria-label="مسار التنقل">
          <a href={pageUrl}>الرئيسية</a>
          <span aria-hidden="true">‹</span>
          <span aria-current="page">التصدير</span>
        </nav>

        <span class="exp-eyebrow">
          <span class="exp-eyebrow__line"></span>
          توزيع عالمي · مباشرة من المصنع
        </span>

        <h1 class="exp-hero__h1" id="exp-h1">
          🌍 <em>التصدير الدولي</em><br/>حلول أبواب عالية الجودة من قيصري إلى العالم
        </h1>
        <p class="exp-hero__lead">
          تُصدّر CihanPan Door إلى أوروبا والشرق الأوسط وأفريقيا. معتمدون ISO 9001 وCE.
          تسعير مباشر من المصنع مع دعم كامل لوثائق الجمارك.
        </p>
        <div class="exp-hero__tags">
          <span class="exp-htag">✓ أكثر من 15 دولة</span>
          <span class="exp-htag">✓ أكثر من 50 ألف باب / سنة</span>
          <span class="exp-htag">✓ CE & ISO 9001</span>
          <span class="exp-htag">✓ حاوية واحدة كحد أدنى</span>
          <span class="exp-htag">✓ رد خلال 24 ساعة</span>
        </div>
        <div class="exp-hero__actions">
          <a href={getLocalizedRoute('/iletisim', lang)} class="exp-btn exp-btn--gold">
            طلب عرض سعر تصدير
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <a href="mailto:export@cihanpandoor.com" class="exp-btn exp-btn--ghost">
            export@cihanpandoor.com
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="exp-wrap">
        <div class="exp-statsbar">
          <div class="exp-sitem"><strong>15+</strong><span>دولة</span></div>
          <div class="exp-sdiv"></div>
          <div class="exp-sitem"><strong>50K+</strong><span>باب / سنة</span></div>
          <div class="exp-sdiv"></div>
          <div class="exp-sitem"><strong>30%</strong><span>حصة التصدير</span></div>
          <div class="exp-sdiv"></div>
          <div class="exp-sitem"><strong>100%</strong><span>رضا العملاء</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         INTRO
    ══════════════════════════════════════════ -->
    <section class="exp-sec exp-sec--white" aria-labelledby="intro-h2">
      <div class="exp-wrap exp-intro-wrap">
        <div class="exp-head">
          <span class="exp-tag">انتشار عالمي</span>
          <h2 id="intro-h2">شريك تصدير موثوق منذ اليوم الأول</h2>
          <p>
            تُصدّر CihanPan Door إلى <strong>أوروبا والشرق الأوسط وأفريقيا</strong> إضافةً إلى السوق التركية المحلية.
            بإنتاج يرقى إلى مستوى معايير الجودة الدولية، نشارك في مشاريع عالمية حول العالم.
            تجعلنا شهادتا ISO 9001 وCE شريكاً تجارياً موثوقاً في جميع أنحاء العالم.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FEATURE CARDS
    ══════════════════════════════════════════ -->
    <section class="exp-sec exp-sec--cream" aria-labelledby="features-h2">
      <div class="exp-wrap">
        <div class="exp-head">
          <span class="exp-tag">ما نقدمه</span>
          <h2 id="features-h2">خدمات التصدير &amp; التغطية</h2>
        </div>

        <div class="exp-cards">

          <div class="exp-card">
            <div class="exp-card__icon">📦</div>
            <h3>خدمات التصدير</h3>
            <ul>
              <li>شحنات حاويات كاملة وLCL</li>
              <li>تعبئة وحماية مخصصة</li>
              <li>دعم وثائق الجمارك</li>
              <li>حلول لوجستية دولية</li>
              <li>إعداد الوثائق التقنية</li>
              <li>دعم عملاء متعدد اللغات</li>
            </ul>
          </div>

          <div class="exp-card">
            <div class="exp-card__icon">🌐</div>
            <h3>المناطق التي نُصدّر إليها</h3>
            <ul>
              <li>دول الاتحاد الأوروبي</li>
              <li>أسواق الشرق الأوسط</li>
              <li>شمال أفريقيا</li>
              <li>دول البلقان</li>
              <li>مجلس التعاون الخليجي</li>
              <li>جمهوريات آسيا الوسطى</li>
            </ul>
          </div>

          <div class="exp-card">
            <div class="exp-card__icon">✅</div>
            <h3>مزايا التصدير لدينا</h3>
            <ul>
              <li>أسعار تنافسية مباشرة من المصنع</li>
              <li>ضمان التسليم في الموعد المحدد</li>
              <li>منتجات معتمدة CE</li>
              <li>دعم باللغات العربية والتركية والإنجليزية</li>
              <li>طاقة استيعابية للطلبات الكبيرة</li>
              <li>حلول مشاريع مخصصة</li>
            </ul>
          </div>

          <div class="exp-card">
            <div class="exp-card__icon">🤝</div>
            <h3>عملية التصدير</h3>
            <ul>
              <li>1. عرض السعر &amp; إرسال العينة</li>
              <li>2. العقد &amp; جدول الدفع</li>
              <li>3. الإنتاج &amp; مراقبة الجودة</li>
              <li>4. التعبئة &amp; التوثيق</li>
              <li>5. الشحن &amp; تتبع التسليم</li>
              <li>6. الدعم ما بعد البيع</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CERTIFICATES
    ══════════════════════════════════════════ -->
    <section class="exp-sec exp-sec--white" aria-labelledby="cert-h2">
      <div class="exp-wrap">
        <div class="exp-head">
          <span class="exp-tag">الشهادات</span>
          <h2 id="cert-h2">شهاداتنا الدولية</h2>
        </div>

        <div class="exp-certs">
          <div class="exp-cert">
            <div class="exp-cert__icon">🏆</div>
            <h3>ISO 9001</h3>
            <p>نظام إدارة الجودة</p>
          </div>
          <div class="exp-cert">
            <div class="exp-cert__icon">✓</div>
            <h3>شهادة CE</h3>
            <p>علامة المطابقة الأوروبية</p>
          </div>
          <div class="exp-cert">
            <div class="exp-cert__icon">🔥</div>
            <h3>اختبارات الحريق</h3>
            <p>المعايير الدولية (EN 1634)</p>
          </div>
          <div class="exp-cert">
            <div class="exp-cert__icon">🌱</div>
            <h3>الشهادة البيئية</h3>
            <p>التصنيع المستدام</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="exp-sec exp-sec--cream" aria-labelledby="faq-h2">
      <div class="exp-wrap exp-faq-wrap">
        <div class="exp-head">
          <span class="exp-tag">الأسئلة الشائعة</span>
          <h2 id="faq-h2">الأسئلة الأكثر شيوعاً</h2>
        </div>
        <div class="exp-faqs">
          {[
            { q: 'ما هو الحد الأدنى لكمية التصدير؟',      a: 'بالنسبة للطلبات القائمة على الحاويات، الحد الأدنى هو حاوية كاملة واحدة (ما يقارب 300–400 باب). يتوفر تسعير خاص لشحنات LCL (الشحن الجزئي للحاوية).' },
            { q: 'ما هي مدة التسليم؟',                    a: 'يستغرق الإنتاج 3–4 أسابيع بعد تأكيد الطلب. تتراوح أوقات الشحن بين 1–3 أسابيع حسب الدولة المقصودة.' },
            { q: 'ما طرق الدفع التي تقبلونها؟',           a: 'نقبل خطاب الاعتماد (L/C)، والتحويل المصرفي (T/T)، و30% مقدماً + 70% قبل الشحن.' },
            { q: 'هل ترسلون عينات؟',                      a: 'نعم، نرسل عينات إلى عملاء التصدير المحتملين على أساس freight-collect (يدفع المستلم رسوم الشحن).' },
            { q: 'هل تصنعون تصاميم مخصصة؟',              a: 'نعم، نقدم تصميماً مخصصاً قائماً على المشروع وإنتاجاً وفق المقاس. يرجى التواصل معنا للاستفسار عن الحد الأدنى للكميات.' },
          ].map(item => (
            <details class="exp-faq">
              <summary class="exp-faq__q">
                {item.q}
                <span class="exp-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="exp-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="exp-cta" aria-labelledby="cta-h2">
      <div class="exp-cta__glow" aria-hidden="true"></div>
      <div class="exp-wrap exp-cta__inner">
        <div class="exp-cta__text">
          <span class="exp-tag exp-tag--gold">استفسارات التصدير</span>
          <h2 id="cta-h2">
            تواصل معنا للتصدير
          </h2>
          <p>
            احصل على عروض أسعار مخصصة لمشاريعك وطلباتك الدولية.
            يرد فريق التصدير لدينا خلال 24 ساعة.
          </p>
        </div>
        <div class="exp-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="exp-btn exp-btn--gold">
            نموذج عرض السعر
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </a>
          <a href="mailto:export@cihanpandoor.com" class="exp-btn exp-btn--ghost">
            export@cihanpandoor.com
          </a>
          <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="exp-btn exp-btn--wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
            واتساب
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS ── */
  .exp {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    --green:    #16a34a;

    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
  .exp-wrap { max-width: 1160px; margin-inline: auto; padding-inline: clamp(1.25rem, 5vw, 2.5rem); width: 100%; }
  .exp-sec        { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .exp-sec--white { background: var(--white); }
  .exp-sec--cream { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .exp-head { text-align: center; margin-bottom: clamp(2rem, 4vw, 3.5rem); }
  .exp-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700;
    color: var(--text); margin: 0.3rem 0 0.7rem; line-height: 1.2;
  }
  .exp-head p { color: var(--slate); font-size: 1rem; max-width: 700px; margin-inline: auto; line-height: 1.7; }
  .exp-head strong { color: var(--navy); }

  .exp-tag { display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .exp-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .exp-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.9rem; font-weight: 600; padding: 0.9rem 1.75rem;
    border-radius: 8px; text-decoration: none; white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
    cursor: pointer; border: none;
  }
  .exp-btn--gold  { background: var(--gold);  color: var(--navy); font-weight: 700; }
  .exp-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .exp-btn--navy  { background: var(--navy);  color: var(--white); }
  .exp-btn--navy:hover  { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,0.3); }
  .exp-btn--ghost { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .exp-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }
  .exp-btn--wa    { background: var(--green); color: var(--white); }
  .exp-btn--wa:hover { background: #15803d; transform: translateY(-2px); }

  /* ── HERO ── */
  .exp-hero {
    position: relative; min-height: 70vh; display: flex;
    flex-direction: column; justify-content: center;
    padding-top: 70px; overflow: hidden;
  }
  .exp-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .exp-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.96) 0%, rgba(15,35,71,0.88) 60%, rgba(26,58,110,0.82) 100%);
  }
  .exp-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 80% 30%, rgba(201,168,76,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 10% 70%, rgba(30,74,138,0.3) 0%, transparent 60%);
  }
  .exp-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .exp-breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; flex-wrap: wrap;
  }
  .exp-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .exp-breadcrumb a:hover { color: var(--gold-l); }
  .exp-breadcrumb span[aria-current] { color: var(--gold); }
  .exp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
