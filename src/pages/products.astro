  @media (max-width: 900px) {
    .pp-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .pp-grid--4 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .pp-grid--3, .pp-grid--4 { grid-template-columns: 1fr; }
    .pp-cta__inner { flex-direction: column; text-align: center; }
    .pp-cta__btns  { justify-content: center; }
    .pp-hero { min-height: auto; }
