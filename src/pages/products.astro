  .pp-card__body > p, .pp-mat-card__body > p {
    font-size: 0.9rem;
    color: var(--body);
    line-height: 1.7;
    margin: 0 0 1rem;
  }
  .pp-card__tags, .pp-mat-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.1rem;
