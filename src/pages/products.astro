  /* ── RTL ── */
  html[dir="rtl"] .pp-eyebrow__line { order: -1; }
  html[dir="rtl"] .pp-btn svg       { transform: scaleX(-1); }
  html[dir="rtl"] .pp-card__cta svg { transform: scaleX(-1); }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const filterBtns = document.querySelectorAll('.pp-filter');
    const matCards   = document.querySelectorAll('.pp-mat-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function () {
        filterBtns.forEach(b => {
          b.classList.remove('pp-filter--active');
          b.setAttribute('aria-selected', 'false');
        });
        this.classList.add('pp-filter--active');
        this.setAttribute('aria-selected', 'true');

        const filter = this.getAttribute('data-filter');
        matCards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-category') === filter) {
            card.classList.remove('pp-hidden');
          } else {
            card.classList.add('pp-hidden');
          }
        });
      });
    });
  });
</script>
