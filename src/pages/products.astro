---
// src/pages/urunlerimiz.astro  (EN version)
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEN = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/urunlerimiz`;

// ── SCHEMA ───────────────────────────────────────────────────────────
const productsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN ? "Product Range — Interior Door Materials & Accessories" : "Ürünlerimiz",
  "description": isEN
    ? "Full range of interior door products from CihanPan Door: PVC, Laminox, Elitpan surface materials, honeycomb core, door accessories. 350+ models, CE certified."
    : "350+ kapı modeli ve malzeme. PVC, Laminoks, Elitpan yüzeyler, honeycomb core, aksesuarlar.",
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "Product Categories" : "Ürün Kategorileri",
    "numberOfItems": 7,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "item": { "@type": "Product", "name": isEN ? "PVC Interior Doors" : "PVC Kapılar", "url": `${pageUrl}/pvc-kapilar` }},
      { "@type": "ListItem", "position": 2, "item": { "@type": "Product", "name": isEN ? "Laminox Interior Doors" : "Laminoks Kapılar", "url": `${pageUrl}/laminoks-kapilar` }},
      { "@type": "ListItem", "position": 3, "item": { "@type": "Product", "name": isEN ? "Elitpan MDF Doors" : "Elitpan Kapılar", "url": `${pageUrl}/elitpan-kapilar` }},
      { "@type": "ListItem", "position": 4, "item": { "@type": "Product", "name": isEN ? "Hospital Doors" : "Hastane Kapıları", "url": `${pageUrl}/hastane-kapilari` }},
      { "@type": "ListItem", "position": 5, "item": { "@type": "Product", "name": isEN ? "Hotel Room Doors" : "Otel Kapıları", "url": `${pageUrl}/otel-kapilari` }},
      { "@type": "ListItem", "position": 6, "item": { "@type": "Product", "name": isEN ? "Fire-Resistant Doors" : "Yangın Kapıları", "url": `${pageUrl}/yangina-dayanikli-kapilar` }},
      { "@type": "ListItem", "position": 7, "item": { "@type": "Product", "name": isEN ? "Door Materials & Accessories" : "Kapı Malzemeleri", "url": currentUrl }},
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "What door models do you manufacture?", "acceptedAnswer": { "@type": "Answer", "text": "We produce PVC doors (247 models), Laminox/Melamine doors (80+ models), Elitpan doors (26+ models), hospital doors, hotel doors, fire-resistant doors and custom designs. Over 350 models in total." }},
    { "@type": "Question", "name": "What core materials are used inside the doors?", "acceptedAnswer": { "@type": "Answer", "text": "We use honeycomb core, semi solid wood and full-fill core options. Honeycomb core offers lightweight construction, high strength and sound insulation." }},
    { "@type": "Question", "name": "What is the difference between PVC and Laminox?", "acceptedAnswer": { "@type": "Answer", "text": "PVC doors use a waterproof plastic laminate and are more economical. Laminox doors have a high-pressure melamine (HPL) surface over MDF — more scratch-resistant with a premium finish." }},
    { "@type": "Question", "name": "Do you offer custom-size door production?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we manufacture non-standard sizes alongside our catalog range. Custom dimensions, finishes and private-label options are available for bulk project orders." }},
    { "@type": "Question", "name": "Are your products covered by warranty?", "acceptedAnswer": { "@type": "Answer", "text": "All door models come with a 5-year manufacturer warranty covering production defects, surface delamination and color fading." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home" : "Ana Sayfa", "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler", "item": currentUrl }
  ]
};

const allSchemas = [productsSchema, faqSchema, breadcrumbSchema];

// ── CATEGORIES DATA ───────────────────────────────────────────────────
const doorCategories = [
  { slug: '/pvc-kapilar',               badge: isEN ? 'Best Seller' : 'Çok Satan',   badgeGold: true,  title: isEN ? 'PVC Interior Doors'    : 'PVC Kapılar',          desc: isEN ? 'Waterproof antibacterial PVC surface. Ideal for bathrooms, hospitals and high-humidity spaces. 247 models.' : 'Su geçirmez antibakteriyel PVC yüzey. 247 model.', tags: isEN ? ['Waterproof','Antibacterial','Easy Clean'] : ['Su Geçirmez','Antibakteriyel','Kolay Bakım'], img: '/assets/img/categories/pvc-kapilar.webp' },
  { slug: '/laminoks-kapilar',          badge: isEN ? 'Featured'    : 'Öne Çıkan',   badgeGold: false, title: isEN ? 'Laminox Interior Doors' : 'Laminoks Kapılar',      desc: isEN ? 'Premium MDF core with durable Laminox surface. Scratch-resistant in 50+ color options. 80+ models.' : 'MDF özlü, çizilmez laminoks yüzey. 80+ model.', tags: isEN ? ['Scratch-Resistant','50+ Colors','MDF Core'] : ['Çizilmez','50+ Renk','MDF Özlü'], img: '/assets/img/categories/laminoks-kapilar.webp', featured: true },
  { slug: '/elitpan-kapilar',           badge: 'Premium',           badgeGold: false, title: isEN ? 'Elitpan MDF Doors'    : 'Elitpan Kapılar',          desc: isEN ? 'UV-coated MDF surface with high-gloss finish. Export-grade quality. 26+ models.' : 'UV boyalı parlak MDF yüzey. 26+ model.', tags: isEN ? ['UV Coated','High Gloss','Export Grade'] : ['UV Boyalı','Parlak Yüzey','İhracat'], img: '/assets/img/categories/elitpan-kapilar.webp' },
  { slug: '/hastane-kapilari',          badge: isEN ? 'Specialist'  : 'Uzman',        badgeGold: false, title: isEN ? 'Hospital Grade Doors'  : 'Hastane Kapıları',       desc: isEN ? 'CE certified hygiene doors. Lead-lined, radio-opaque and antimicrobial options.' : 'CE sertifikalı hijyen kapılar. Kurşun seçenek mevcut.', tags: isEN ? ['CE Certified','Lead-Lined Option','Antimicrobial'] : ['CE Sertifikalı','Kurşun Seçenek','Antimikrobiyal'], img: '/assets/img/categories/hastane-kapilari.webp' },
  { slug: '/otel-kapilari',             badge: isEN ? 'Hospitality' : 'Otel',         badgeGold: false, title: isEN ? 'Hotel Room Doors'      : 'Otel Kapıları',           desc: isEN ? 'Sound-insulated, fire-rated doors for 3★–5★ properties. Bulk pricing on 500+ units.' : 'Ses yalıtımlı, yangın dayanımlı otel kapıları.', tags: isEN ? ['Sound-Insulated','Fire-Rated','Bulk Pricing'] : ['Ses Yalıtımı','Yangın Dayanımı','Toplu Fiyat'], img: '/assets/img/categories/otel-kapilari.webp' },
  { slug: '/yangina-dayanikli-kapilar', badge: isEN ? 'Certified'   : 'Sertifikalı',  badgeGold: false, title: isEN ? 'Fire-Resistant Doors'  : 'Yangına Dayanıklı Kapılar', desc: isEN ? 'EI30–EI90 rated fire doors with CE certification. European & international building code compliant.' : 'CE sertifikalı EI30–EI90 yangın kapıları.', tags: isEN ? ['EI30–EI90','CE Certified','Building Code'] : ['EI30–EI90','CE Sertifikalı','Yönetmelik Uyumlu'], img: '/assets/img/categories/yangina-dayanikli-kapilar.webp' },
];

// ── MATERIALS DATA ─────────────────────────────────────────────────
const materials = [
  {
    category: 'core',
    img: '/assets/img/materials/honeycomb-1-core.webp',
    title: isEN ? 'Honeycomb Core 1' : 'Honeycomb Core 1',
    desc: isEN ? 'High-strength, lightweight honeycomb inner structure. Enhances door durability and provides lasting performance.' : 'Yüksek mukavemet ve hafif honeycomb iç yapı malzemesi.',
    tags: isEN ? ['Lightweight','High Strength','Sound Insulation','Moisture Resistant'] : ['Hafif Yapı','Yüksek Mukavemet','Ses Yalıtımı','Nem Direnci'],
  },
  {
    category: 'core',
    img: '/assets/img/materials/honeycomb-2-core.webp',
    title: isEN ? 'Honeycomb Core 2' : 'Honeycomb Core 2',
    desc: isEN ? 'Dense-cell honeycomb with advanced technology. Superior performance and durability for premium door lines.' : 'Yoğun hücre yapılı gelişmiş honeycomb. Üstün dayanıklılık.',
    tags: isEN ? ['Dense Cell','Superior Durability','Good Acoustics','Eco-Friendly'] : ['Yoğun Hücre','Üstün Dayanıklılık','Akustik','Çevre Dostu'],
  },
  {
    category: 'core',
    img: '/assets/img/materials/semi-solid-core.webp',
    title: isEN ? 'Semi Solid Wood' : 'Semi Solid Wood',
    desc: isEN ? 'Natural wood solidity combined with modern manufacturing. Used in our premium door collections.' : 'Doğal ahşap sağlamlığı, modern üretim tekniğiyle birleşir.',
    tags: isEN ? ['Natural Wood','High Solidity','Premium Quality','Long-Lasting'] : ['Doğal Ahşap','Yüksek Sağlamlık','Premium','Uzun Ömürlü'],
  },
  {
    category: 'surface',
    img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: isEN ? 'PVC Surface Materials' : 'PVC Yüzey Malzemeleri',
    desc: isEN ? 'Waterproof PVC laminate coatings. Ideal for humid environments — easy to clean, available in many colors.' : 'Su geçirmez PVC kaplama. Nemli ortamlar için ideal.',
    tags: isEN ? ['Waterproof','Easy Clean','Multi-Color','Cost-Effective'] : ['Su Geçirmez','Kolay Temizlik','Çok Renk','Ekonomik'],
    link: getLocalizedRoute('/pvc-kapilar', lang),
    linkLabel: isEN ? 'View PVC Doors' : 'PVC Kapıları Gör',
  },
  {
    category: 'surface',
    img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: isEN ? 'Laminox Surface Materials' : 'Laminoks Yüzey Malzemeleri',
    desc: isEN ? 'High-pressure melamine (HPL) laminate over MDF. Scratch and impact resistant with a premium aesthetic.' : 'MDF üzerine yüksek basınçlı laminat. Çizilme direnci yüksek.',
    tags: isEN ? ['Scratch-Resistant','Impact-Resistant','Rich Patterns','Matt/Gloss'] : ['Çizilmez','Darbe Dayanımı','Zengin Desen','Mat/Parlak'],
    link: getLocalizedRoute('/laminoks-kapilar', lang),
    linkLabel: isEN ? 'View Laminox Doors' : 'Laminoks Kapıları Gör',
  },
  {
    category: 'accessories',
    img: '/assets/img/materials/door-handles.webp',
    title: isEN ? 'Door Handles & Lock Systems' : 'Kapı Kolları ve Kilit Sistemleri',
    desc: isEN ? 'Stainless steel and brass door handles. Ergonomic designs and security lock options in various finishes.' : 'Paslanmaz çelik ve pirinç kapı kolları. Güvenlik kilitleri.',
    tags: isEN ? ['Stainless Steel','Ergonomic','Multi-Finish','Security Locks'] : ['Paslanmaz','Ergonomik','Çeşitli Renkler','Güvenlik'],
  },
  {
    category: 'accessories',
    img: '/assets/img/materials/hinges.webp',
    title: isEN ? 'Hinges & Fixings' : 'Menteşeler ve Bağlantı Elemanları',
    desc: isEN ? 'Silent, durable hinge systems made from high-quality materials. Easy installation and adjustable setting.' : 'Sessiz ve dayanıklı menteşe sistemleri. Kolay montaj.',
    tags: isEN ? ['Silent Operation','High Durability','Easy Install','Adjustable'] : ['Sessiz Çalışma','Dayanıklı','Kolay Montaj','Ayarlanabilir'],
  },
  {
    category: 'accessories',
    img: '/assets/img/materials/seals.webp',
    title: isEN ? 'Seals & Weatherstrip Systems' : 'Conta ve Fitil Sistemleri',
    desc: isEN ? 'High-quality seals that prevent air and sound infiltration. Key for energy efficiency and acoustic comfort.' : 'Hava ve ses geçişini engelleyen conta sistemleri.',
    tags: isEN ? ['Airtight','Acoustic Seal','Energy Saving','UV Resistant'] : ['Hava Sızdırmaz','Ses Yalıtımı','Enerji Tasarrufu','UV Dayanımı'],
  },
];
---

<I18nLayout
  title={isEN
    ? "Product Range | Interior Doors, Materials & Accessories | CihanPan Door"
    : "Ürünlerimiz | İç Kapı Malzemeleri ve Aksesuarlar | CihanPan Door"}
  description={isEN
    ? "Wholesale interior door collection from Turkey. PVC, Laminox, Elitpan surface materials, honeycomb core, door handles and accessories. 350+ models, CE certified."
    : "Türkiye'den toptan iç kapı koleksiyonu. PVC, Laminoks, Elitpan, honeycomb core, aksesuarlar. 350+ model, CE sertifikalı."}
  keywords={isEN
    ? "interior door materials Turkey, PVC door surface, Laminox laminate, honeycomb core door, door handles wholesale, CE certified door manufacturer"
    : "kapı malzemeleri, pvc yüzey, laminoks kaplama, honeycomb core, kapı aksesuarları"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? "Interior Door Product Range | CihanPan Door" : "Ürün Gamı | CihanPan Door"}
  ogDescription={isEN
    ? "350+ wholesale interior door models from Kayseri, Turkey. Factory-direct pricing, CE & ISO certified."
    : "Kayseri'den 350+ toptan kapı modeli."}
  ogImage="/assets/img/og/urunlerimiz-og.webp"
>
  <I18nHeader />

  <main class="pp" id="main-content">

    <!-- ══════════════════════════════════════════
         PAGE HERO
    ══════════════════════════════════════════ -->
    <section class="pp-hero" aria-labelledby="pp-h1">
      <div class="pp-hero__bg" aria-hidden="true">
        <div class="pp-hero__overlay"></div>
      </div>
      <div class="pp-wrap pp-hero__inner">
        <div>
          <span class="pp-eyebrow">
            <span class="pp-eyebrow__line"></span>
            {isEN ? 'Factory Direct · Kayseri, Turkey' : 'Fabrikadan · Kayseri, Türkiye'}
          </span>
          <h1 class="pp-hero__h1" id="pp-h1">
            {isEN
              ? <><em>Full Product Range</em><br/>— Interior Doors &amp; Materials</>
              : <><em>Ürün Gamımız</em><br/>— Kapılar ve Malzemeler</>}
          </h1>
          <p class="pp-hero__lead">
            {isEN
              ? '350+ door models and material options. CE & ISO 9001 certified. Factory-direct pricing for wholesale importers worldwide.'
              : '350+ kapı modeli ve malzeme seçeneği. CE ve ISO 9001 sertifikalı. Toptan satış ve ihracat.'}
          </p>
          <div class="pp-hero__tags">
            <span class="pp-htag">✓ 350+ Models</span>
            <span class="pp-htag">✓ CE & ISO 9001</span>
            <span class="pp-htag">✓ MOQ 50 Units</span>
            <span class="pp-htag">✓ Factory Direct</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         DOOR CATEGORIES
    ══════════════════════════════════════════ -->
    <section class="pp-sec pp-sec--white" id="door-categories" aria-labelledby="cats-h2">
      <div class="pp-wrap">
        <div class="pp-head">
          <span class="pp-tag">{isEN ? 'Door Lines' : 'Kapı Serileri'}</span>
          <h2 id="cats-h2">
            {isEN ? 'Wholesale Interior Door Collection' : 'Toptan Kapı Koleksiyonu'}
          </h2>
          <p>
            {isEN
              ? 'Six production lines covering every market segment — residential, hospitality, healthcare and commercial.'
              : 'Konut, otel, hastane ve ticari projelere yönelik altı üretim serisi.'}
          </p>
        </div>

        <div class="pp-grid pp-grid--3">
          {doorCategories.map((cat, i) => (
            <article class={`pp-card ${cat.featured ? 'pp-card--featured' : ''}`}>
              <a href={getLocalizedRoute(cat.slug, lang)} class="pp-card__img-wrap" tabindex="-1" aria-hidden="true">
                <img
                  src={cat.img}
                  alt={cat.title}
                  width="480"
                  height="360"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <span class={`pp-card__badge ${cat.badgeGold ? 'pp-card__badge--gold' : ''}`}>{cat.badge}</span>
              </a>
              <div class="pp-card__body">
                <h3><a href={getLocalizedRoute(cat.slug, lang)}>{cat.title}</a></h3>
                <p>{cat.desc}</p>
                <ul class="pp-card__tags">
                  {cat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <a href={getLocalizedRoute(cat.slug, lang)} class="pp-card__cta">
                  {isEN ? 'View & Request Quote' : 'İncele & Teklif Al'}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         MATERIALS & ACCESSORIES
    ══════════════════════════════════════════ -->
    <section class="pp-sec pp-sec--cream" id="materials" aria-labelledby="mat-h2">
      <div class="pp-wrap">
        <div class="pp-head">
          <span class="pp-tag">{isEN ? 'What Goes Inside' : 'İç Bileşenler'}</span>
          <h2 id="mat-h2">
            {isEN ? 'Door Materials & Accessories' : 'Kapı Malzemeleri ve Aksesuarlar'}
          </h2>
          <p>
            {isEN
              ? 'Every component — from inner core to surface laminate and hardware — sourced and quality-controlled at our facility.'
              : 'İç çekirdekten yüzey kaplamasına, her bileşen fabrikamızda kalite kontrolünden geçer.'}
          </p>
        </div>

        <!-- Filter Tabs -->
        <div class="pp-filters" role="tablist" aria-label={isEN ? 'Filter by material type' : 'Malzeme türüne göre filtrele'}>
          <button class="pp-filter pp-filter--active" data-filter="all" role="tab" aria-selected="true">
            {isEN ? 'All' : 'Hepsi'}
          </button>
          <button class="pp-filter" data-filter="core" role="tab" aria-selected="false">
            {isEN ? 'Core Materials' : 'İç Materyal'}
          </button>
          <button class="pp-filter" data-filter="surface" role="tab" aria-selected="false">
            {isEN ? 'Surface Materials' : 'Yüzey Malzemeleri'}
          </button>
          <button class="pp-filter" data-filter="accessories" role="tab" aria-selected="false">
            {isEN ? 'Accessories' : 'Aksesuarlar'}
          </button>
        </div>

        <div class="pp-grid pp-grid--4" id="materials-grid">
          {materials.map(mat => (
            <article class="pp-mat-card" data-category={mat.category}>
              <div class="pp-mat-card__img">
                <img
                  src={mat.img}
                  alt={mat.title}
                  width="300"
                  height="220"
                  loading="lazy"
                  decoding="async"
                  onerror="this.style.display='none';this.parentElement.querySelector('.pp-mat-card__placeholder').style.display='flex'"
                />
                <div class="pp-mat-card__placeholder" aria-hidden="true">
                  <span>📦</span>
                </div>
              </div>
              <div class="pp-mat-card__body">
                <span class="pp-mat-card__cat">{mat.category === 'core' ? (isEN ? 'Core' : 'İç Yapı') : mat.category === 'surface' ? (isEN ? 'Surface' : 'Yüzey') : (isEN ? 'Accessory' : 'Aksesuar')}</span>
                <h3>{mat.title}</h3>
                <p>{mat.desc}</p>
                <ul class="pp-mat-card__tags">
                  {mat.tags.map(tag => <li>{tag}</li>)}
                </ul>
                {mat.link && (
                  <a href={mat.link} class="pp-card__cta">
                    {mat.linkLabel}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="pp-sec pp-sec--white" aria-labelledby="faq-h2">
      <div class="pp-wrap pp-faq-wrap">
        <div class="pp-head">
          <span class="pp-tag">{isEN ? 'FAQ' : 'Sık Sorulan Sorular'}</span>
          <h2 id="faq-h2">
            {isEN ? 'Frequently Asked Questions' : 'Sık Sorulan Sorular'}
          </h2>
        </div>
        <div class="pp-faqs">
          {(isEN ? [
            { q: 'What door models do you manufacture?', a: 'PVC doors (247 models), Laminox/Melamine doors (80+ models), Elitpan doors (26+ models), hospital doors, hotel doors, fire-resistant doors and custom designs — over 350 models in total.' },
            { q: 'What core materials are used inside the doors?', a: 'We use honeycomb core, semi solid wood and full-fill core options. Honeycomb provides lightweight construction, high strength and excellent sound insulation properties.' },
            { q: 'What is the difference between PVC and Laminox surfaces?', a: 'PVC doors use a waterproof plastic laminate and are more economical. Laminox doors feature a high-pressure melamine (HPL) surface over MDF — more scratch-resistant with a premium finish and wider colour range.' },
            { q: 'Do you offer custom-size production?', a: 'Yes. Alongside our catalog sizes we manufacture non-standard dimensions for bulk project orders. Custom finishes and private-label options are also available.' },
            { q: 'Are your products covered by warranty?', a: 'All door models come with a 5-year manufacturer warranty covering production defects, surface delamination and colour fading.' },
          ] : [
            { q: 'Hangi kapı modellerini üretiyorsunuz?', a: 'PVC kapılar (247 model), Laminoks/Melamin kapılar (80+ model), Elitpan kapılar (26+ model), hastane kapıları, otel kapıları, yangın kapıları ve özel tasarım kapılar. Toplam 350+ model.' },
            { q: 'Kapılarda hangi iç materyal kullanılıyor?', a: 'Honeycomb core, semi solid wood ve tam dolgu iç materyal seçenekleri kullanılmaktadır.' },
            { q: 'PVC ve Laminoks arasındaki fark nedir?', a: 'PVC kapılar su geçirmez plastik kaplama ile ekonomiktir. Laminoks kapılar MDF üzerine yüksek basınçlı melamin (HPL) ile daha çizilmez ve premium görünümlüdür.' },
            { q: 'Özel ölçü kapı üretimi yapıyor musunuz?', a: 'Evet. Standart ölçülerin yanında toplu projelerde özel boyut, yüzey ve özel etiket seçenekleri sunuyoruz.' },
            { q: 'Ürünleriniz garanti kapsamında mı?', a: 'Tüm kapı modellerimiz 5 yıl üretici garantisi ile sunulmaktadır.' },
          ]).map(item => (
            <details class="pp-faq">
              <summary class="pp-faq__q">
                {item.q}
                <span class="pp-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="pp-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="pp-cta" aria-labelledby="cta-h2">
      <div class="pp-cta__glow" aria-hidden="true"></div>
      <div class="pp-wrap pp-cta__inner">
        <div class="pp-cta__text">
          <span class="pp-tag pp-tag--gold">
            {isEN ? 'Start Sourcing Today' : 'Hemen Başlayın'}
          </span>
          <h2 id="cta-h2">
