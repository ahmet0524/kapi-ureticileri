  .pp-card__tags li, .pp-mat-card__tags li {
    background: var(--cream);
    color: var(--body);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.28rem 0.7rem;
    border-radius: 20px;
    border: 1px solid var(--bdr);
