---
// src/pages/hospital-doors.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang  = getLangFromUrl(Astro.url);
const t     = useTranslations(lang);
const isEN  = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/hospital-doors`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Hastane-Serisi-501-Tik-Antrasit.webp",
  "CihanpanDoor-Hastane-Serisi-502-Avola-Krem.webp",
  "CihanpanDoor-Hastane-Serisi-503-ABD-Ceviz-Krom.webp",
  "CihanpanDoor-Hastane-Serisi-504-Soft-Kapucino-Antrasit.webp",
  "CihanpanDoor-Hastane-Serisi-505-Saruhan-Krem.webp",
  "CihanpanDoor-Hastane-Serisi-506-Antrasit-Krom.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hospitalSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN
    ? "Hospital & Healthcare Doors — Hygienic Series | CihanPan Door"
    : "Hastane ve Sağlık Tesisi Kapıları — Hijyenik Seri | CihanPan Door",
  "description": isEN
    ? "Wholesale hygienic hospital doors from Kayseri, Turkey. Antibacterial PVC/HPL surface, 30–60 min fire rating, 32–42 dB sound insulation, CE certified. Factory-direct pricing for hospitals, clinics and healthcare projects."
    : "Kayseri'den toptan hijyenik hastane kapıları. Antibakteriyel PVC/HPL yüzey, 30–60 dk yangın dayanımı, CE belgeli.",
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "Hospital Door Models" : "Hastane Kapı Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": isEN ? "Hospital Door — Hygienic Series" : "Hastane Kapısı — Hijyenik Seri",
        "description": isEN
          ? "Antibacterial PVC/HPL coated hospital door. Moisture-proof, easy-to-clean, 30–60 min fire rating, 32–42 dB sound insulation. CE certified, 5-year warranty. Wholesale from Kayseri, Turkey."
          : "Antibakteriyel PVC/HPL kaplı hastane kapısı. Çarpma yapmaz, kolay temizlenebilir, 30–60 dk yangın dayanımı, CE belgeli.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": isEN ? "Antibacterial PVC/HPL Coating over MDF" : "Antibakteriyel PVC/HPL Kaplama / MDF",
        "category": isEN ? "Hospital Door" : "Hastane Kapısı",
        "additionalProperty": [
          { "@type": "PropertyValue", "name": isEN ? "Antibacterial" : "Antibakteriyel", "value": isEN ? "Yes" : "Evet" },
          { "@type": "PropertyValue", "name": isEN ? "Fire Rating"   : "Yangın Dayanımı", "value": "30–60 min" },
          { "@type": "PropertyValue", "name": isEN ? "Hygiene Cert"  : "Hijyen Sertifikası", "value": "CE" },
          { "@type": "PropertyValue", "name": isEN ? "Sound Insulation" : "Ses Yalıtımı", "value": "32–42 dB" },
        ],
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "63",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "Why do hospitals need specialised doors?",         "acceptedAnswer": { "@type": "Answer", "text": "Hospital doors must meet strict hygiene standards: antibacterial surfaces, resistance to frequent disinfectant cleaning, moisture-proof construction, sound insulation for patient comfort and fire resistance for safety. Standard interior doors do not provide these properties." }},
    { "@type": "Question", "name": "Where are hospital doors used?",                   "acceptedAnswer": { "@type": "Answer", "text": "Hospital doors are used in patient rooms, polyclinics, operating theatres, laboratories, X-ray rooms, intensive care units, emergency departments and sterilisation units. Different areas require different technical specifications." }},
    { "@type": "Question", "name": "What certifications should hospital doors carry?", "acceptedAnswer": { "@type": "Answer", "text": "Hospital doors should carry CE certification, a fire resistance certificate (EN 1634), an antibacterial test report, a sound insulation certificate and comply with relevant health ministry standards. All CihanPan Door hospital models are CE certified." }},
    { "@type": "Question", "name": "What is the MOQ for wholesale hospital door orders?", "acceptedAnswer": { "@type": "Answer", "text": "Minimum order quantity is 50 units. Volume discounts apply from 100 units. Custom dimensions, glazing options, automatic closer systems and private-label solutions are available for larger healthcare projects." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home"     : "Ana Sayfa",            "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler",              "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "Hospital Doors" : "Hastane Kapıları", "item": currentUrl },
  ]
};

const allSchemas = [hospitalSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: isEN ? 'All Products'   : 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: isEN ? 'PVC Doors'      : 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: isEN ? 'Laminox Doors'  : 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',             label: isEN ? 'Elitpan Doors'  : 'Elitpan Kapılar',   active: false },
  { slug: '/hospital-doors',            label: isEN ? 'Hospital Doors' : 'Hastane Kapıları',  active: true  },
  { slug: '/otel-kapilari',             label: isEN ? 'Hotel Doors'    : 'Otel Kapıları',      active: false },
  { slug: '/yangina-dayanikli-kapilar', label: isEN ? 'Fire-Rated'     : 'Yangın Kapıları',   active: false },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface HospitalProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  features: string;
  image: string;
  alt: string;
}

const hospitalProducts: HospitalProduct[] = fileNames.map((fn, i) => {
  const parts = fn.replace('.webp', '').split('-');
  const model = parts[3];
  const color = parts.slice(4).join(' ');
  return {
    id:       `hospital-${model}`,
    model,
    color,
    label:    `Hospital ${model} · ${color}`,
    features: i < 3
      ? (isEN ? 'Hygienic · CE Certified'         : 'Hijyenik · CE Belgeli')
      : (isEN ? 'Antibacterial · Fire-Rated'       : 'Antibakteriyel · Yangın Güvenlikli'),
    image:    `/assets/img/hospital-doors/${fn}`,
    alt:      isEN
      ? `CihanPan Door Hospital Series ${model} ${color} — Hygienic Healthcare Door`
      : `CihanPan Door Hastane Serisi ${model} ${color} — Hijyenik Sağlık Tesisi Kapısı`,
  };
});
---

<I18nLayout
  title={isEN
    ? "Hospital & Healthcare Doors — Hygienic Series | Wholesale Turkey | CihanPan Door"
    : "Hastane ve Sağlık Tesisi Kapıları — Hijyenik Seri | Toptan | CihanPan Door"}
  description={isEN
    ? "Wholesale hygienic hospital doors from Kayseri, Turkey. Antibacterial PVC/HPL surface, 30–60 min fire rating, 32–42 dB sound insulation, CE & ISO 9001 certified. Factory-direct pricing. MOQ 50 units."
    : "Kayseri'den toptan hijyenik hastane kapıları. Antibakteriyel yüzey, yangın güvenlikli, CE sertifikalı."}
  keywords={isEN
    ? "hospital doors wholesale Turkey, hygienic healthcare door manufacturer, antibacterial door CE certified, fire-rated hospital door Kayseri, healthcare facility door bulk order"
    : "hastane kapısı, hijyenik kapı, antibakteriyel kapı, yangın dayanımlı kapı, sağlık tesisi kapısı toptan kayseri"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? "Hospital & Healthcare Doors — Hygienic Series | CihanPan Door" : "Hastane Kapıları — Hijyenik Seri | CihanPan Door"}
  ogDescription={isEN
    ? "Antibacterial, fire-rated hygienic hospital doors. Factory direct from Kayseri. MOQ 50 units."
    : "Antibakteriyel, yangın güvenlikli hijyenik hastane kapıları. Fabrikadan doğrudan."}
  ogImage="/assets/img/og/hospital-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>{isEN ? 'Home' : 'Ana Sayfa'}</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>{isEN ? 'Products' : 'Ürünler'}</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{isEN ? 'Hospital Doors' : 'Hastane Kapıları'}</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            {isEN ? 'Healthcare Collection · Hygienic Series' : 'Sağlık Koleksiyonu · Hijyenik Seri'}
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            {isEN
              ? <><em>Hospital &amp; Healthcare Doors</em><br/>Antibacterial · Fire-Rated · CE Certified</>
              : <><em>Hastane ve Sağlık Tesisi Kapıları</em><br/>Antibakteriyel · Yangın Güvenlikli · CE Belgeli</>}
          </h1>
          <p class="lam-hero__lead">
            {isEN
              ? 'Factory-direct wholesale hospital doors from Kayseri, Turkey. Antibacterial PVC/HPL coating over moisture-resistant MDF core. 30–60 min fire rating, 32–42 dB sound insulation. CE & ISO 9001 certified. MOQ 50 units.'
              : 'Kayseri fabrikasından toptan hastane kapıları. Nem dayanımlı MDF özlü antibakteriyel PVC/HPL kaplama. 30–60 dk yangın dayanımı, 32–42 dB ses yalıtımı. CE ve ISO 9001 sertifikalı.'}
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ {isEN ? 'Antibacterial Surface' : 'Antibakteriyel Yüzey'}</span>
            <span class="lam-htag">✓ {isEN ? '30–60 min Fire Rating' : '30–60 dk Yangın'}</span>
            <span class="lam-htag">✓ {isEN ? '32–42 dB Sound' : '32–42 dB Ses'}</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ MOQ 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              {isEN ? 'Get a Free Quote' : 'Ücretsiz Teklif Al'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              {isEN ? 'Browse Models' : 'Modelleri Gör'}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>{isEN ? 'Hygiene' : 'Hijyen'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>60<sup>min</sup></strong><span>{isEN ? 'Fire Rating' : 'Yangın'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label={isEN ? 'Door categories' : 'Kapı kategorileri'}>
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">{isEN ? 'Hospital Door Collection' : 'Hastane Kapı Koleksiyonu'}</span>
          <h2 id="catalogue-h2">
            {isEN ? 'Hospital & Healthcare Door Models' : 'Hastane ve Sağlık Tesisi Kapı Modelleri'}
          </h2>
          <p>
            {isEN
              ? `${modelCount} hygienic hospital door models — series 501–506. Antibacterial, fire-rated and sound-insulated. Click any model to request a wholesale quote.`
              : `${modelCount} hijyenik hastane kapısı modeli — 501–506 serisi. Antibakteriyel, yangın güvenlikli ve ses yalıtımlı.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            {isEN ? 'Request Healthcare Project Quote' : 'Hastane Proje Teklifi Al'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">{isEN ? 'Response within 24 hours · MOQ 50 units' : '24 saat içinde yanıt · Min. 50 adet'}</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label={isEN ? 'Hospital door models' : 'Hastane kapı modelleri'}>
          {hospitalProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.features}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            {isEN
              ? 'Why Hospital Doors Require Specialised Solutions'
              : 'Hastane Kapıları Neden Özel Çözüm Gerektirir'}
          </h2>

          <p>
            {isEN
              ? (<><strong>CihanPan Door's hospital series</strong> is engineered specifically for healthcare environments, where standard interior doors are simply not sufficient. Each model combines an <em>antibacterial PVC/HPL coating</em> with a moisture-resistant MDF core to deliver a hygienic, durable and safe door solution for wholesale buyers worldwide.</>)
              : (<><strong>CihanPan Door'un hastane serisi</strong>, standart iç kapıların yetersiz kaldığı sağlık ortamları için özel olarak tasarlanmıştır. Her model, dünya genelinde toptan alıcılar için hijyenik, dayanıklı ve güvenli bir kapı çözümü sunan <em>antibakteriyel PVC/HPL kaplama</em> ile nem dayanımlı MDF özü bir arada sunar.</>)}
          </p>

          <h3>{isEN ? 'Key Features for Healthcare Environments' : 'Sağlık Ortamları İçin Temel Özellikler'}</h3>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Antibacterial Surface:' : 'Antibakteriyel Yüzey:'}</strong> {isEN ? 'Specialist coating inhibits bacterial growth — critical for infection control in clinical settings.' : 'Özel kaplama bakteri üremesini engeller — klinik ortamlarda enfeksiyon kontrolü için kritiktir.'}</li>
            <li><strong>{isEN ? 'Disinfectant-Resistant:' : 'Dezenfektan Dayanımı:'}</strong> {isEN ? 'Surface withstands repeated cleaning with hospital-grade disinfectants without degrading.' : 'Yüzey, hastane sınıfı dezenfektanlarla tekrarlanan temizliğe bozulmadan dayanır.'}</li>
            <li><strong>{isEN ? 'Moisture-Proof Construction:' : 'Su Dayanımlı Yapı:'}</strong> {isEN ? 'Moisture-resistant MDF core prevents warping in high-humidity clinical environments.' : 'Nem dayanımlı MDF öz, yüksek nemli klinik ortamlarda çarpma yapmaz.'}</li>
            <li><strong>{isEN ? 'Sound Insulation 32–42 dB:' : 'Ses Yalıtımı 32–42 dB:'}</strong> {isEN ? 'Protects patient privacy and reduces noise transmission between wards and consultation rooms.' : 'Hasta mahremiyetini korur ve koğuşlar ile muayene odaları arasındaki gürültü iletimini azaltır.'}</li>
            <li><strong>{isEN ? 'Fire Rating 30–60 min:' : 'Yangın Dayanımı 30–60 dk:'}</strong> {isEN ? 'Complies with EN 1634 fire resistance standards for safe evacuation routes in healthcare facilities.' : 'Sağlık tesislerinde güvenli tahliye yolları için EN 1634 yangın dayanım standartlarına uygundur.'}</li>
            <li><strong>{isEN ? 'CE Certified:' : 'CE Belgeli:'}</strong> {isEN ? 'All models are CE certified and comply with EU healthcare facility requirements.' : 'Tüm modeller CE belgeli ve AB sağlık tesisi gereksinimlerine uygundur.'}</li>
          </ul>

          <h3>{isEN ? 'Healthcare Applications' : 'Sağlık Tesisi Kullanım Alanları'}</h3>
          <p>{isEN ? 'CihanPan Door hospital series is specified for:' : 'CihanPan Door hastane serisi şu alanlarda belirlenmektedir:'}</p>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Patient Rooms:' : 'Hasta Odaları:'}</strong> {isEN ? 'Hygienic surface and 32+ dB sound insulation for patient comfort and privacy.' : 'Hasta konforu ve mahremiyeti için hijyenik yüzey ve 32+ dB ses yalıtımı.'}</li>
            <li><strong>{isEN ? 'Operating Theatres:' : 'Ameliyathaneler:'}</strong> {isEN ? 'Sterile-environment compatible surface, hermetic sealing options available.' : 'Steril ortamla uyumlu yüzey, hermetik sızdırmazlık seçeneği mevcuttur.'}</li>
            <li><strong>{isEN ? 'Polyclinics & Outpatient:' : 'Poliklinikler:'}</strong> {isEN ? 'High-traffic durability with antibacterial protection for busy outpatient areas.' : 'Yoğun poliklinik alanları için antibakteriyel koruma ile yüksek trafik dayanıklılığı.'}</li>
            <li><strong>{isEN ? 'Laboratories:' : 'Laboratuvarlar:'}</strong> {isEN ? 'Chemical-resistant surface suitable for labs with frequent solvent or reagent use.' : 'Sık solvent veya reaktif kullanılan laboratuvarlara uygun kimyasal dirençli yüzey.'}</li>
            <li><strong>{isEN ? 'Intensive Care Units:' : 'Yoğun Bakım:'}</strong> {isEN ? 'Maximum hygiene with low-maintenance surface for around-the-clock clinical use.' : 'Kesintisiz klinik kullanım için düşük bakımlı yüzeyle maksimum hijyen.'}</li>
            <li><strong>{isEN ? 'Emergency Departments:' : 'Acil Servis:'}</strong> {isEN ? 'Impact-resistant construction for high-footfall, high-impact emergency environments.' : 'Yoğun geçişli, darbe yoğun acil ortamlar için darbeye dayanıklı yapı.'}</li>
          </ul>

          <h3>{isEN ? 'Technical Specifications' : 'Teknik Özellikler'}</h3>
          <ul class="lam-checklist">
            <li>{isEN ? 'Surface: Antibacterial PVC/HPL coating' : 'Yüzey: Antibakteriyel PVC/HPL kaplama'}</li>
            <li>{isEN ? 'Core: Moisture-resistant MDF' : 'Öz: Nem dayanımlı MDF'}</li>
            <li>{isEN ? 'Standard sizes: 70×200 cm · 80×200 cm · 140×200 cm (double leaf) — custom sizes available' : 'Standart boyutlar: 70×200 cm · 80×200 cm · 140×200 cm (çift kanat) — özel boyut mevcut'}</li>
            <li>{isEN ? 'Fire resistance: 30–60 minutes (EN 1634)' : 'Yangın dayanımı: 30–60 dakika (EN 1634)'}</li>
            <li>{isEN ? 'Sound insulation: 32–42 dB' : 'Ses yalıtımı: 32–42 dB'}</li>
            <li>{isEN ? 'Hardware: Stainless steel hinges, antibacterial handles, auto-closer' : 'Aksesuar: Paslanmaz menteşe, antibakteriyel kol, otomatik kapanma'}</li>
            <li>CE & ISO 9001 {isEN ? 'certified' : 'sertifikalı'}</li>
            <li>{isEN ? '5-year manufacturer warranty' : '5 yıl üretici garantisi'}</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>{isEN ? 'Hygiene' : 'Hijyen'}</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>{isEN ? 'Warranty' : 'Garanti'}</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">{isEN ? 'Healthcare Specialist' : 'Sağlık Uzmanı'}</span>
            <h3>{isEN ? 'Request a Project Quote' : 'Proje Teklifi Al'}</h3>
            <p>{isEN ? 'Share your facility type, quantity and requirements — our healthcare specialist responds within 24 hours.' : 'Tesis türünüzü, adeti ve gereksinimlerinizi paylaşın — 24 saat içinde yanıt veririz.'}</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                {isEN ? 'Contact Form' : 'İletişim Formu'}
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
