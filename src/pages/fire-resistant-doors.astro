---
// src/pages/fire-resistant-doors.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang  = getLangFromUrl(Astro.url);
const t     = useTranslations(lang);
const isEN  = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/fire-resistant-doors`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Yangin-Serisi-601-EI30-White.webp",
  "CihanpanDoor-Yangin-Serisi-602-EI60-Anthracite.webp",
  "CihanpanDoor-Yangin-Serisi-603-EI90-Grey.webp",
  "CihanpanDoor-Yangin-Serisi-604-EI30-Walnut.webp",
  "CihanpanDoor-Yangin-Serisi-605-EI60-Oak.webp",
  "CihanpanDoor-Yangin-Serisi-606-EI90-Wenge.webp",
  "CihanpanDoor-Yangin-Serisi-607-EI30-Cappuccino.webp",
  "CihanpanDoor-Yangin-Serisi-608-EI60-Black.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN
    ? "Fire-Resistant Doors — EI Certified Series | CihanPan Door"
    : "Yangina Dayanikli Kapilar — EI Sertifikali Seri | CihanPan Door",
  "description": isEN
    ? "Fire-resistant doors from Kayseri, Turkey. EI-30, EI-60, EI-90 certified, TSE approved, smoke-sealed. Factory-direct for commercial, hospitality and public building projects."
    : "Kayseri uretimi yangina dayanikli kapi modelleri. EI-30, EI-60, EI-90 sertifikali, TSE onayli.",
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "Fire-Resistant Door Models" : "Yangina Dayanikli Kapi Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": isEN ? "Fire-Resistant Door — EI Certified Series" : "Yangina Dayanikli Kapi — EI Sertifikali",
        "description": isEN
          ? "EI-30 to EI-90 certified fire-resistant door. TSE approved, smoke-sealed gasket system, automatic closing. For commercial buildings, hospitals, hotels and public projects."
          : "EI-30, EI-60, EI-90 sertifikali yangina dayanikli kapi. TSE onayli, duman sizdirmaz conta, otomatik kapanma.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": isEN ? "Fire-Resistant Steel" : "Yangin Dayanikli Celik",
        "category": isEN ? "Fire-Resistant Door" : "Yangina Dayanikli Kapi",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "TRY",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "businessFunction": "http://purl.org/goodrelations/v1#Sell"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "What is a fire-resistant door?",                        "acceptedAnswer": { "@type": "Answer", "text": "A fire-resistant door is a certified door assembly that prevents the spread of fire and smoke for a defined period. EI-30, EI-60 and EI-90 ratings indicate 30, 60 or 90 minutes of resistance." }},
    { "@type": "Question", "name": "What is the difference between EI-30, EI-60 and EI-90?","acceptedAnswer": { "@type": "Answer", "text": "These ratings indicate how long the door resists fire and smoke passage. EI-30 provides 30 minutes, EI-60 provides 60 minutes and EI-90 provides 90 minutes of protection according to TS EN 1634-1." }},
    { "@type": "Question", "name": "Where are fire-resistant doors required?",               "acceptedAnswer": { "@type": "Answer", "text": "Fire-resistant doors are mandatory in commercial buildings, hospitals, hotels, schools, shopping centres and apartment complexes. Fire escape routes and stairwells are required to have fire-rated doors by regulation." }},
    { "@type": "Question", "name": "What is the MOQ for fire door orders?",                 "acceptedAnswer": { "@type": "Answer", "text": "Minimum order quantity is 10 units. Volume discounts apply from 50 units. Custom dimensions, panic hardware, electric lock preparation and project documentation are available for full building fit-outs." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home"     : "Ana Sayfa",          "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler",            "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "Fire-Resistant Doors" : "Yangina Dayanikli Kapilar",   "item": currentUrl },
  ]
};

const allSchemas = [hotelSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: isEN ? 'All Products'   : 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: isEN ? 'PVC Doors'      : 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: isEN ? 'Laminox Doors'  : 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',             label: isEN ? 'Elitpan Doors'  : 'Elitpan Kapılar',   active: false },
  { slug: '/hospital-doors',            label: isEN ? 'Hospital Doors' : 'Hastane Kapıları',  active: false },
  { slug: '/hotel-doors',               label: isEN ? 'Hotel Doors'    : 'Otel Kapilari',      active: false },
  { slug: '/yangina-dayanikli-kapilar', label: isEN ? 'Fire-Resistant' : 'Yangin Kapilari',   active: true  },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface FireProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  badge: string;
  image: string;
  alt: string;
}

const fireProducts: FireProduct[] = fileNames.map((fn, i) => {
  const parts     = fn.replace('.webp', '').split('-');
  const model     = parts[3];
  const fireRaw   = parts[4];
  const color     = parts.slice(5).join(' ');
  const fireRating = fireRaw.replace('EI', 'EI-');
  return {
    id:    `fire-${model}`,
    model,
    color,
    label: isEN ? `Fire ${model} - ${color}` : `Yangin ${model} - ${color}`,
    badge: isEN ? `${fireRating} - TSE Certified` : `${fireRating} - TSE Onayli`,
    image: `/assets/img/yangina-dayanikli-kapilar/${fn}`,
    alt:   isEN
      ? `CihanPan Door Fire Series ${model} ${color} ${fireRating} Certified Fire Door`
      : `CihanPan Door Yangin Serisi ${model} ${color} ${fireRating} Sertifikali Yangin Kapisi`,
  };
});
---

<I18nLayout
  title={isEN
    ? "Fire-Resistant Doors — EI Certified Series | CihanPan Door Turkey"
    : "Yangina Dayanikli Kapilar — EI Sertifikali Seri | CihanPan Door"}
  description={isEN
    ? "Fire-resistant doors from Kayseri, Turkey. EI-30, EI-60, EI-90 certified, TSE approved, smoke-sealed gasket. Factory-direct for commercial, hospitality and public building projects."
    : "Kayseri uretimi yangina dayanikli kapi modelleri. EI-30, EI-60, EI-90 sertifikali, TSE onayli."}
  keywords={isEN
    ? "fire resistant doors Turkey, fire door EI-30 EI-60 EI-90, fire door manufacturer Kayseri, TSE certified fire door, smoke-sealed fire door wholesale"
    : "yangina dayanikli kapi, yangin kapisi, EI-30 kapi, EI-60 kapi, kayseri yangin kapisi, TSE onayli yangin kapisi"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? "Fire-Resistant Doors — EI Certified Series | CihanPan Door" : "Yangina Dayanikli Kapilar — EI Sertifikali | CihanPan Door"}
  ogDescription={isEN
    ? "EI-30 to EI-90 certified fire-resistant doors. TSE approved, smoke-sealed. Factory direct from Kayseri."
    : "EI-30, EI-60, EI-90 sertifikali yangina dayanikli kapilar. TSE onayli. Fabrikadan dogrudan."}
  ogImage="/assets/img/og/fire-resistant-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>{isEN ? 'Home' : 'Ana Sayfa'}</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>{isEN ? 'Products' : 'Ürünler'}</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{isEN ? 'Hotel Doors' : 'Otel Kapıları'}</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            {isEN ? 'Fire Safety Collection · EI Certified Series' : 'Yangin Guvenlik Koleksiyonu · EI Sertifikali'}
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            {isEN
              ? <><em>Fire-Resistant Doors</em><br/>EI-30 / EI-60 / EI-90 Certified · TSE Approved · Smoke-Sealed</>
              : <><em>Yangina Dayanikli Kapilar</em><br/>EI Sertifikali · TSE Onayli · Duman Sizdirmaz</>}
          </h1>
          <p class="lam-hero__lead">
            {isEN
              ? 'Fire-resistant doors factory-direct from Kayseri, Turkey. EI-30, EI-60 and EI-90 certified, TSE approved — engineered for commercial buildings, hospitals, hotels and public projects.'
              : 'Kayseri fabrikasindan toptan yangin kapilari. EI-30, EI-60, EI-90 yangin dayanim sertifikali, TSE onayli modeller.'}
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ EI-30 / EI-60 / EI-90</span>
            <span class="lam-htag">✓ {isEN ? 'TSE Approved' : 'TSE Onayli'}</span>
            <span class="lam-htag">✓ {isEN ? 'Smoke-Sealed Gasket' : 'Duman Sizdirmaz Conta'}</span>
            <span class="lam-htag">✓ {isEN ? 'Auto-Close System' : 'Otomatik Kapanma'}</span>
            <span class="lam-htag">✓ TS EN 1634-1</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--fire">
              {isEN ? 'Get a Fire Door Quote' : 'Yangin Kapisi Teklifi Al'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              {isEN ? 'Browse Models' : 'Modelleri Gor'}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>TSE</strong><span>{isEN ? 'Approved' : 'Onay'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>EI-90</strong><span>{isEN ? 'Certified' : 'Sertifika'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>{isEN ? 'Safety' : 'Guvenlik'}</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label={isEN ? 'Door categories' : 'Kapi kategorileri'}>
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">{isEN ? 'Fire Door Collection' : 'Yangin Kapi Koleksiyonu'}</span>
          <h2 id="catalogue-h2">
            {isEN ? 'Fire-Resistant Door Models' : 'Yangina Dayanikli Kapi Modelleri'}
          </h2>
          <p>
            {isEN
              ? `${modelCount} fire-resistant door models — series 601–608. EI-30, EI-60 and EI-90 certified, TSE approved. Contact us for a wholesale project quote.`
              : `${modelCount} yangin guvenlik kapisi modeli — 601–608 serisi. EI-30, EI-60 ve EI-90 sertifikali, TSE onayli.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            {isEN ? 'Request Fire Door Project Quote' : 'Yangin Kapisi Proje Teklifi Al'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">{isEN ? 'Response within 24 hours · Project-based pricing' : '24 saat icinde yanit · Proje bazli fiyatlandirma'}</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label={isEN ? 'Fire door models' : 'Yangin kapi modelleri'}>
          {fireProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.badge}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            {isEN
              ? 'What Makes a Certified Fire-Resistant Door? The CihanPan Approach'
              : 'Sertifikali Bir Yangina Dayanikli Kapi Nedir? CihanPan Yaklasimi'}
          </h2>

          <p>
            {isEN
              ? (<><strong>CihanPan Door fire series</strong> combines strict fire safety engineering with Kayseri factory precision. Each model is built with a <em>fire-resistant steel frame</em> and mineral wool core — certified to TS EN 1634-1 standards for EI-30, EI-60 and EI-90 ratings.</>)
              : (<><strong>CihanPan Door yangin serisi</strong>, siki yangin guvenligi muhendisligi ile Kayseri fabrikamizin uretim hassasiyetini birlestirmektedir. Her model TS EN 1634-1 standartlarina uygun EI-30, EI-60 ve EI-90 sertifikalari icin tasarlanmistir.</>)}
          </p>

          <h3>{isEN ? 'Key Fire Safety Features' : 'Temel Yangin Guvenligi Ozellikleri'}</h3>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'EI-30 / EI-60 / EI-90 Certification:' : 'EI-30 / EI-60 / EI-90 Sertifikasi:'}</strong> {isEN ? 'Three fire resistance levels — 30, 60 and 90 minutes — to meet different building class requirements under Turkish and EU fire regulations.' : 'Turk ve AB yangin yonetmeliklerinde farkli bina sinifi gereksinimlerini karsilamak icin uc yangin direnci seviyesi.'}</li>
            <li><strong>{isEN ? 'TSE Approved:' : 'TSE Onayli:'}</strong> {isEN ? 'Turkish Standards Institute certification confirms compliance with TS EN 1634-1 fire resistance and smoke control tests.' : 'Turk Standartlari Enstitusu sertifikasi, TS EN 1634-1 yangin direnci ve duman kontrol testlerine uygunlugu onaylar.'}</li>
            <li><strong>{isEN ? 'Smoke-Sealed Gasket System:' : 'Duman Sizdirmaz Conta Sistemi:'}</strong> {isEN ? 'Intumescent and smoke-seal gaskets prevent toxic gas and smoke passage at all temperatures, protecting escape routes.' : 'Intumesans ve duman conta sistemleri tum sicakliklarinda zehirli gaz ve duman gecisini engelleyerek kacis yollarini korur.'}</li>
            <li><strong>{isEN ? 'Automatic Closing Mechanism:' : 'Otomatik Kapanma Mekanizmasi:'}</strong> {isEN ? 'Spring-loaded or hydraulic door closer ensures the door is always closed — preventing fire spread through open doors.' : 'Yay yuklu veya hidrolik kapi kapatici, kapinin her zaman kapali olmasini saglar ve acik kapi uzerinden yangin yayilmasini onler.'}</li>
            <li><strong>{isEN ? 'Steel Frame Construction:' : 'Celik Cerceve Konstruksiyonu:'}</strong> {isEN ? 'Galvanised steel frame and door leaf resist structural deformation under extreme heat, maintaining door integrity.' : 'Galvanizli celik cerceve ve kapi kanadi, asiri isi altinda yapisal bozulmaya karsi direnir.'}</li>
            <li><strong>{isEN ? 'Panic Hardware Ready:' : 'Panik Donanimina Hazir:'}</strong> {isEN ? 'Compatible with panic bar and electromagnetic hold-open systems for emergency exit compliance.' : 'Acil cikis uyumu icin panik bar ve elektromanyetik acik tutma sistemleriyle uyumludur.'}</li>
          </ul>

          <h3>{isEN ? 'Applications' : 'Kullanim Alanlari'}</h3>
          <p>{isEN ? 'CihanPan Door fire series is specified for:' : 'CihanPan Door yangin serisi su alanlarda tercih edilir:'}</p>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Shopping Centres & Commercial Buildings:' : 'AVM ve Is Merkezleri:'}</strong> {isEN ? 'Fire compartment doors, escape routes and stairwell enclosures requiring EI-60 or EI-90 certification.' : 'EI-60 veya EI-90 sertifikasi gerektiren yangin bolmesi kapilari, kacis yollari ve merdiven alanlari.'}</li>
            <li><strong>{isEN ? 'Hospitals & Healthcare:' : 'Hastaneler:'}</strong> {isEN ? 'Patient corridors, operating theatre entrances and critical care zones where fire containment is essential.' : 'Yangin kontrolunun kritik oldugu hasta koridorlari, ameliyathane girisleri ve yogun bakim bolgeleri.'}</li>
            <li><strong>{isEN ? 'Hotels & Hospitality:' : 'Oteller:'}</strong> {isEN ? 'Floor corridor fire doors, stairwell access and service area compartmentalisation.' : 'Kat koridor yangin kapilari, merdiven girisleri ve servis alani bolmelendirmesi.'}</li>
            <li><strong>{isEN ? 'Industrial Facilities:' : 'Endustriyel Tesisler:'}</strong> {isEN ? 'Heavy-duty fire compartment doors for manufacturing plants, warehouses and process facilities.' : 'Uretim tesisleri, depolar ve proses tesisleri icin agir hizmet yangin bolmesi kapilari.'}</li>
            <li><strong>{isEN ? 'Apartment Buildings:' : 'Apartmanlar:'}</strong> {isEN ? 'Common area fire doors, basement access and service shaft enclosures required by residential building codes.' : 'Konut bina kodlari tarafindan zorunlu olan ortak alan yangin kapilari, bodrum girisleri ve tesisat sahtalari.'}</li>
            <li><strong>{isEN ? 'Public Buildings:' : 'Kamu Binalari:'}</strong> {isEN ? 'Schools, universities and government buildings requiring certified fire doors on escape routes and stairwells.' : 'Kacis yollarinda ve merdiven kovalarinda sertifikali yangin kapilari gerektiren okullar, universiteler ve resmi binalar.'}</li>
          </ul>

          <h3>{isEN ? 'Technical Specifications' : 'Teknik Ozellikler'}</h3>
          <ul class="lam-checklist">
            <li>{isEN ? 'Frame: Galvanised fire-resistant steel, 1.5 mm thickness' : 'Cerceve: Galvanizli yangin dayanikli celik, 1.5 mm et kalinligi'}</li>
            <li>{isEN ? 'Core: Fire-resistant mineral wool (density: 100 kg/m3)' : 'Dolgu: Yangin dayanikli mineral yun (yogunluk: 100 kg/m3)'}</li>
            <li>{isEN ? 'Standard sizes: 80x200 cm, 90x200 cm — custom sizes available' : 'Standart boyutlar: 80x200 cm, 90x200 cm — ozel olcu mevcut'}</li>
            <li>{isEN ? 'Fire rating: EI-30, EI-60, EI-90 (TS EN 1634-1)' : 'Yangin dayanimi: EI-30, EI-60, EI-90 (TS EN 1634-1)'}</li>
            <li>{isEN ? 'Hardware: Fire hinges, automatic door closer, smoke-sealed threshold, panic bar' : 'Aksesuarlar: Yangin mentesesi, otomatik kapama, duman sizdirmaz esik, panik bar'}</li>
            <li>TSE {isEN ? 'approved · TS EN 1634-1 certified · 2-year manufacturer warranty' : 'onayli · TS EN 1634-1 sertifikali · 2 yil uretici garantisi'}</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
            <div class="lam-kpi"><strong>TSE</strong><span>{isEN ? 'Approved' : 'Onay'}</span></div>
            <div class="lam-kpi"><strong>EI-90</strong><span>{isEN ? 'Certified' : 'Sertifika'}</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>{isEN ? 'Safety' : 'Guvenlik'}</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">{isEN ? 'Fire Safety Specialist' : 'Yangin Guvenligi Uzmani'}</span>
            <h3>{isEN ? 'Request a Fire Door Quote' : 'Yangin Kapisi Teklifi Al'}</h3>
            <p>{isEN ? 'Share your building type, fire rating requirement and door count — our fire safety specialist responds within 24 hours.' : 'Bina turunuzu, sertifika duzeyini ve kapi sayisini paylasin — 24 saat icinde yanit veririz.'}</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--fire lam-btn--sm">
                {isEN ? 'Contact Form' : 'Iletisim Formu'}
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
