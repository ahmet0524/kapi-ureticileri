---
// src/pages/hotel-doors.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang  = getLangFromUrl(Astro.url);
const t     = useTranslations(lang);
const isEN  = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/hotel-doors`;

// ── FILE LIST ─────────────────────────────────────────────────────────
const fileNames = [
  "CihanpanDoor-Otel-Serisi-401-Italyan-Ceviz.webp",
  "CihanpanDoor-Otel-Serisi-402-Kestane.webp",
  "CihanpanDoor-Otel-Serisi-403-Tik.webp",
  "CihanpanDoor-Otel-Serisi-404-Yildiz-Metal-Antrasit.webp",
  "CihanpanDoor-Otel-Serisi-405-Vision-Gri.webp",
  "CihanpanDoor-Otel-Serisi-406-Dark-Santana.webp",
];

const modelCount = fileNames.length;

// ── SCHEMA ────────────────────────────────────────────────────────────
const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN
    ? "Hotel & Hospitality Doors — Premium Series | CihanPan Door"
    : "Otel ve Konaklama Tesisi Kapıları — Premium Seri | CihanPan Door",
  "description": isEN
    ? "Wholesale premium hotel doors from Kayseri, Turkey. Luxury laminate finishes, sound-insulated, fire-rated, CE certified. Factory-direct pricing for hotels, resorts and hospitality projects. MOQ 50 units."
    : "Kayseri'den toptan premium otel kapıları. Lüks laminat yüzey, ses yalıtımlı, yangın güvenlikli, CE belgeli.",
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "Hotel Door Models" : "Otel Kapı Modelleri",
    "numberOfItems": modelCount,
    "itemListElement": [
      {
        "@type": "Product",
        "name": isEN ? "Hotel Door — Premium Series" : "Otel Kapısı — Premium Seri",
        "description": isEN
          ? "Premium laminate hotel door. Sound-insulated for guest comfort, fire-rated for safety, CE certified. Durable under heavy daily use. Wholesale from Kayseri, Turkey."
          : "Premium laminat otel kapısı. Misafir konforu için ses yalıtımlı, yangın güvenlikli, CE belgeli. Yoğun günlük kullanımda dayanıklı.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": isEN ? "Premium Laminate over MDF" : "Premium Laminat / MDF",
        "category": isEN ? "Hotel Door" : "Otel Kapısı",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": modelCount.toString(),
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "87",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "What makes a door suitable for hotel use?",              "acceptedAnswer": { "@type": "Answer", "text": "Hotel doors must withstand constant daily use across hundreds of rooms, deliver superior sound insulation for guest privacy, meet fire-safety regulations and maintain a premium aesthetic that reflects the property's brand. CihanPan Door's hotel series is engineered specifically for these requirements." }},
    { "@type": "Question", "name": "What finish options are available for hotel doors?",     "acceptedAnswer": { "@type": "Answer", "text": "The hotel series (401–406) includes rich wood-grain finishes such as Italian Walnut, Chestnut, Teak, Star Metal Anthracite, Vision Grey and Dark Santana. Custom finishes, veneers and RAL colour options are available for larger orders." }},
    { "@type": "Question", "name": "What sound insulation do hotel doors provide?",          "acceptedAnswer": { "@type": "Answer", "text": "CihanPan Door hotel doors provide 32–42 dB sound insulation depending on the model and configuration. Acoustic seals and door frames are available to maximise performance in guest room corridors." }},
    { "@type": "Question", "name": "What is the MOQ for wholesale hotel door orders?",       "acceptedAnswer": { "@type": "Answer", "text": "Minimum order quantity is 50 units. Volume discounts apply from 100 units. Custom dimensions, glazing panels, electronic lock preparation and private-label solutions are available for full hotel fit-out projects." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home"     : "Ana Sayfa",          "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler",            "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "Hotel Doors" : "Otel Kapıları",   "item": currentUrl },
  ]
};

const allSchemas = [hotelSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: isEN ? 'All Products'   : 'Tümü',             active: false },
  { slug: '/pvc-kapilar',               label: isEN ? 'PVC Doors'      : 'PVC Kapılar',       active: false },
  { slug: '/laminoks-kapilar',          label: isEN ? 'Laminox Doors'  : 'Laminoks Kapılar',  active: false },
  { slug: '/elitpan-doors',             label: isEN ? 'Elitpan Doors'  : 'Elitpan Kapılar',   active: false },
  { slug: '/hospital-doors',            label: isEN ? 'Hospital Doors' : 'Hastane Kapıları',  active: false },
  { slug: '/hotel-doors',               label: isEN ? 'Hotel Doors'    : 'Otel Kapıları',      active: true  },
  { slug: '/yangina-dayanikli-kapilar', label: isEN ? 'Fire-Rated'     : 'Yangın Kapıları',   active: false },
];

// ── SSR PRODUCT LIST ──────────────────────────────────────────────────
interface HotelProduct {
  id: string;
  model: string;
  color: string;
  label: string;
  badge: string;
  image: string;
  alt: string;
}

const hotelProducts: HotelProduct[] = fileNames.map((fn, i) => {
  const parts = fn.replace('.webp', '').split('-');
  const model = parts[3];
  const color = parts.slice(4).join(' ');
  return {
    id:    `hotel-${model}`,
    model,
    color,
    label: `Hotel ${model} · ${color}`,
    badge: i < 3
      ? (isEN ? 'Premium · Elegant Design'  : 'Premium · Şık Tasarım')
      : (isEN ? 'Luxury · Exclusive Design' : 'Lüks · Özel Tasarım'),
    image: `/assets/img/hotel-doors/${fn}`,
    alt:   isEN
      ? `CihanPan Door Hotel Series ${model} ${color} — Premium Hospitality Door`
      : `CihanPan Door Otel Serisi ${model} ${color} — Premium Konaklama Kapısı`,
  };
});
---

<I18nLayout
  title={isEN
    ? "Hotel & Hospitality Doors — Premium Series | Wholesale Turkey | CihanPan Door"
    : "Otel ve Konaklama Tesisi Kapıları — Premium Seri | Toptan | CihanPan Door"}
  description={isEN
    ? "Wholesale premium hotel doors from Kayseri, Turkey. Luxury laminate finishes, 32–42 dB sound insulation, fire-rated, CE & ISO 9001 certified. Factory-direct pricing for hotels, resorts and hospitality projects. MOQ 50 units."
    : "Kayseri'den toptan premium otel kapıları. Lüks laminat, ses yalıtımlı, yangın güvenlikli, CE sertifikalı."}
  keywords={isEN
    ? "hotel doors wholesale Turkey, hospitality door manufacturer Kayseri, premium hotel door CE certified, sound insulated hotel door, luxury door bulk order"
    : "otel kapısı toptan, konaklama tesisi kapısı, premium kapı kayseri, ses yalıtımlı otel kapısı, lüks kapı"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? "Hotel & Hospitality Doors — Premium Series | CihanPan Door" : "Otel Kapıları — Premium Seri | CihanPan Door"}
  ogDescription={isEN
    ? "Premium luxury hotel doors with sound insulation and fire rating. Factory direct from Kayseri. MOQ 50 units."
    : "Ses yalıtımlı ve yangın güvenlikli premium otel kapıları. Fabrikadan doğrudan."}
  ogImage="/assets/img/og/hotel-doors-og.webp"
>
  <I18nHeader />

  <main class="lam" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="lam-hero" aria-labelledby="lam-h1">
      <div class="lam-hero__bg" aria-hidden="true">
        <div class="lam-hero__overlay"></div>
        <div class="lam-hero__glow"></div>
      </div>
      <div class="lam-wrap lam-hero__inner">
        <div>
          <nav class="lam-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>{isEN ? 'Home' : 'Ana Sayfa'}</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>{isEN ? 'Products' : 'Ürünler'}</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{isEN ? 'Hotel Doors' : 'Otel Kapıları'}</span>
          </nav>

          <span class="lam-eyebrow">
            <span class="lam-eyebrow__line"></span>
            {isEN ? 'Hospitality Collection · Premium Series' : 'Konaklama Koleksiyonu · Premium Seri'}
          </span>
          <h1 class="lam-hero__h1" id="lam-h1">
            {isEN
              ? <><em>Hotel &amp; Hospitality Doors</em><br/>Luxury Finish · Sound-Insulated · CE Certified</>
              : <><em>Otel ve Konaklama Kapıları</em><br/>Lüks Yüzey · Ses Yalıtımlı · CE Belgeli</>}
          </h1>
          <p class="lam-hero__lead">
            {isEN
              ? 'Factory-direct wholesale hotel doors from Kayseri, Turkey. Premium laminate finishes over durable MDF core — engineered for high-traffic hospitality environments. CE & ISO 9001 certified. MOQ 50 units.'
              : 'Kayseri fabrikasından toptan otel kapıları. Dayanıklı MDF özlü premium laminat yüzeyler — yoğun konaklama ortamları için tasarlanmış. CE ve ISO 9001 sertifikalı.'}
          </p>
          <div class="lam-hero__tags">
            <span class="lam-htag">✓ {isEN ? 'Luxury Laminate Finish' : 'Lüks Laminat Yüzey'}</span>
            <span class="lam-htag">✓ {isEN ? '32–42 dB Sound' : '32–42 dB Ses'}</span>
            <span class="lam-htag">✓ {isEN ? 'Fire-Rated' : 'Yangın Güvenlikli'}</span>
            <span class="lam-htag">✓ CE & ISO 9001</span>
            <span class="lam-htag">✓ MOQ 50</span>
          </div>
          <div class="lam-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold">
              {isEN ? 'Get a Free Quote' : 'Ücretsiz Teklif Al'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="lam-btn lam-btn--ghost">
              {isEN ? 'Browse Models' : 'Modelleri Gör'}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="lam-wrap">
        <div class="lam-statsbar">
          <div class="lam-sitem"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>A+</strong><span>{isEN ? 'Quality' : 'Kalite'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>42<sup>dB</sup></strong><span>{isEN ? 'Sound' : 'Ses'}</span></div>
          <div class="lam-sdiv"></div>
          <div class="lam-sitem"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="lam-wrap">

        <nav class="lam-catnav" aria-label={isEN ? 'Door categories' : 'Kapı kategorileri'}>
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`lam-catbtn${cat.active ? ' lam-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="lam-head">
          <span class="lam-tag">{isEN ? 'Hotel Door Collection' : 'Otel Kapı Koleksiyonu'}</span>
          <h2 id="catalogue-h2">
            {isEN ? 'Hotel & Hospitality Door Models' : 'Otel ve Konaklama Kapı Modelleri'}
          </h2>
          <p>
            {isEN
              ? `${modelCount} premium hotel door models — series 401–406. Luxury wood-grain and contemporary finishes designed for high-end hospitality projects. Click any model to request a wholesale quote.`
              : `${modelCount} premium otel kapısı modeli — 401–406 serisi. Yüksek kaliteli konaklama projeleri için lüks ahşap dokulu ve çağdaş yüzeyler.`}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="lam-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--navy">
            {isEN ? 'Request Hotel Project Quote' : 'Otel Proje Teklifi Al'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="lam-quote-note">{isEN ? 'Response within 24 hours · MOQ 50 units' : '24 saat içinde yanıt · Min. 50 adet'}</span>
        </div>

        <!-- Products Grid — SSR rendered for SEO -->
        <div class="lam-grid lam-grid--wide" id="productsGrid" aria-label={isEN ? 'Hotel door models' : 'Otel kapı modelleri'}>
          {hotelProducts.map((product, i) => (
            <article class="lam-card" aria-label={product.label}>
              <div class="lam-card__img">
                <img
                  src={product.image}
                  alt={product.alt}
                  width="240"
                  height="320"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="lam-card__body">
                <p class="lam-card__name">{product.label}</p>
                <span class="lam-card__badge">{product.badge}</span>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="lam-sec lam-sec--cream" aria-labelledby="content-h2">
      <div class="lam-wrap lam-content-wrap">

        <article class="lam-article">
          <h2 id="content-h2">
            {isEN
              ? 'What Makes a Great Hotel Door? The CihanPan Approach'
              : 'İyi Bir Otel Kapısını Ne Yapar? CihanPan Yaklaşımı'}
          </h2>

          <p>
            {isEN
              ? (<><strong>CihanPan Door's hotel series</strong> combines an understanding of hospitality design requirements with the manufacturing precision of our Kayseri factory. Each model is built on a durable MDF core finished with a <em>premium laminate surface</em> — engineered to survive millions of door cycles while maintaining a luxury aesthetic across the lifetime of the property.</>)
              : (<><strong>CihanPan Door'un otel serisi</strong>, konaklama tasarım gereksinimlerini Kayseri fabrikamızın üretim hassasiyetiyle birleştirir. Her model, mülkün ömrü boyunca lüks estetiği korurken milyonlarca kapı döngüsüne dayanacak şekilde <em>premium laminat yüzeyle</em> kaplanmış dayanıklı MDF öz üzerine inşa edilmiştir.</>)}
          </p>

          <h3>{isEN ? 'Key Features for Hospitality Environments' : 'Konaklama Ortamları İçin Temel Özellikler'}</h3>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Premium Laminate Surface:' : 'Premium Laminat Yüzey:'}</strong> {isEN ? 'Rich wood-grain and contemporary finishes — Italian Walnut, Chestnut, Teak, Vision Grey and more — elevate corridor and room aesthetics.' : 'Zengin ahşap dokulu ve çağdaş yüzeyler — İtalyan Ceviz, Kestane, Tik, Vision Gri ve daha fazlası — koridor ve oda estetiğini yükseltir.'}</li>
            <li><strong>{isEN ? 'Sound Insulation 32–42 dB:' : 'Ses Yalıtımı 32–42 dB:'}</strong> {isEN ? 'Protects guest privacy and reduces corridor noise — a critical factor for positive reviews and repeat bookings.' : 'Misafir mahremiyetini korur ve koridor gürültüsünü azaltır — olumlu yorumlar ve tekrar rezervasyonlar için kritik bir faktör.'}</li>
            <li><strong>{isEN ? 'High-Traffic Durability:' : 'Yoğun Trafik Dayanıklılığı:'}</strong> {isEN ? 'MDF core and laminate surface withstand the constant use typical in hotels with high occupancy rates.' : 'MDF öz ve laminat yüzey, yüksek doluluk oranlarına sahip otellerde tipik olan sürekli kullanıma dayanır.'}</li>
            <li><strong>{isEN ? 'Fire Safety Compliance:' : 'Yangın Güvenliği Uyumu:'}</strong> {isEN ? 'Fire-rated options available to meet hospitality building regulations in Turkey, the EU and the Middle East.' : 'Türkiye, AB ve Orta Doğu\'daki konaklama binası yönetmeliklerini karşılamak için yangın dayanımlı seçenekler mevcuttur.'}</li>
            <li><strong>{isEN ? 'Easy Maintenance:' : 'Kolay Bakım:'}</strong> {isEN ? 'Laminate surface cleans easily — no periodic refinishing or painting required, minimising housekeeping downtime.' : 'Laminat yüzey kolayca temizlenir — periyodik yeniden kaplama veya boyama gerekmez, temizlik arıza süresini en aza indirir.'}</li>
            <li><strong>{isEN ? 'Electronic Lock Ready:' : 'Elektronik Kilit Hazır:'}</strong> {isEN ? 'Pre-cut preparation for card-key and RFID electronic locking systems available on all hotel series models.' : 'Tüm otel serisi modellerinde kart anahtarlı ve RFID elektronik kilit sistemleri için önceden hazırlanmış açıklık mevcuttur.'}</li>
          </ul>

          <h3>{isEN ? 'Hospitality Applications' : 'Konaklama Kullanım Alanları'}</h3>
          <p>{isEN ? 'CihanPan Door hotel series is specified for:' : 'CihanPan Door otel serisi şu alanlarda tercih edilir:'}</p>
          <ul class="lam-checklist">
            <li><strong>{isEN ? 'Hotel Guest Rooms:' : 'Otel Odaları:'}</strong> {isEN ? 'Premium finish and sound insulation for a superior guest experience across 3-star to 5-star properties.' : '3 yıldızdan 5 yıldıza kadar mülklerde üstün misafir deneyimi için premium yüzey ve ses yalıtımı.'}</li>
            <li><strong>{isEN ? 'Boutique Hotels:' : 'Butik Oteller:'}</strong> {isEN ? 'Distinctive wood-grain finishes that complement unique interior design concepts.' : 'Benzersiz iç tasarım konseptlerini tamamlayan ayırt edici ahşap dokulu yüzeyler.'}</li>
            <li><strong>{isEN ? 'Apart Hotels & Serviced Apartments:' : 'Apart Oteller:'}</strong> {isEN ? 'Durable solution for long-stay accommodation with high daily occupancy.' : 'Yüksek günlük doluluklu uzun süreli konaklama için dayanıklı çözüm.'}</li>
            <li><strong>{isEN ? 'Holiday Resorts:' : 'Tatil Köyleri:'}</strong> {isEN ? 'Bulk supply solutions for large resort properties requiring hundreds of matching doors.' : 'Yüzlerce eşleşen kapı gerektiren büyük tatil köyü tesisleri için toplu tedarik çözümleri.'}</li>
            <li><strong>{isEN ? 'Hostels & Guesthouses:' : 'Pansiyonlar:'}</strong> {isEN ? 'Cost-effective premium option offering hotel-grade durability at competitive wholesale prices.' : 'Rekabetçi toptan fiyatlarla otel kalitesinde dayanıklılık sunan maliyet etkin premium seçenek.'}</li>
            <li><strong>{isEN ? 'Conference & Event Facilities:' : 'Toplantı ve Etkinlik Tesisleri:'}</strong> {isEN ? 'Sound-insulated doors ideal for breakout rooms, meeting spaces and function rooms.' : 'Toplantı odaları, konferans alanları ve etkinlik salonları için ideal ses yalıtımlı kapılar.'}</li>
          </ul>

          <h3>{isEN ? 'Technical Specifications' : 'Teknik Özellikler'}</h3>
          <ul class="lam-checklist">
            <li>{isEN ? 'Surface: Premium laminate — wood-grain and contemporary finishes' : 'Yüzey: Premium laminat — ahşap dokulu ve çağdaş yüzeyler'}</li>
            <li>{isEN ? 'Core: Solid durable MDF' : 'Öz: Masif dayanıklı MDF'}</li>
            <li>{isEN ? 'Standard sizes: 80×200 cm · 90×200 cm — custom sizes available' : 'Standart boyutlar: 80×200 cm · 90×200 cm — özel boyut mevcut'}</li>
            <li>{isEN ? 'Sound insulation: 32–42 dB' : 'Ses yalıtımı: 32–42 dB'}</li>
            <li>{isEN ? 'Fire rating: optional 30–60 min (EN 1634)' : 'Yangın dayanımı: isteğe bağlı 30–60 dk (EN 1634)'}</li>
            <li>{isEN ? 'Hardware: heavy-duty hinges, anti-slam system, electronic lock prep' : 'Aksesuar: ağır hizmet menteşe, çarpma önleyici sistem, elektronik kilit hazırlığı'}</li>
            <li>CE & ISO 9001 {isEN ? 'certified' : 'sertifikalı'}</li>
            <li>{isEN ? '5-year manufacturer warranty' : '5 yıl üretici garantisi'}</li>
          </ul>
        </article>

        <!-- Sidebar -->
        <aside class="lam-sidebar">
          <div class="lam-kpis">
            <div class="lam-kpi"><strong>{modelCount}</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
            <div class="lam-kpi"><strong>A+</strong><span>{isEN ? 'Quality' : 'Kalite'}</span></div>
            <div class="lam-kpi"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
            <div class="lam-kpi"><strong>5yr</strong><span>{isEN ? 'Warranty' : 'Garanti'}</span></div>
          </div>

          <div class="lam-contact-card">
            <span class="lam-tag">{isEN ? 'Hospitality Specialist' : 'Konaklama Uzmanı'}</span>
            <h3>{isEN ? 'Request a Project Quote' : 'Proje Teklifi Al'}</h3>
            <p>{isEN ? 'Share your property type, room count and requirements — our hospitality specialist responds within 24 hours.' : 'Tesis türünüzü, oda sayısını ve gereksinimlerinizi paylaşın — 24 saat içinde yanıt veririz.'}</p>
            <div class="lam-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="lam-btn lam-btn--gold lam-btn--sm">
                {isEN ? 'Contact Form' : 'İletişim Formu'}
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="lam-btn lam-btn--wa lam-btn--sm">
