  .lam-btn--gold    { background: var(--gold);  color: var(--navy);  font-weight: 700; }
  .lam-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .lam-btn--navy    { background: var(--navy);  color: var(--white); font-weight: 700; }
