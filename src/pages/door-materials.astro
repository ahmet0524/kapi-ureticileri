  .dm-card__cat-badge { position: absolute; top: 0.75rem; left: 0.75rem; background: var(--navy); color: var(--white); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.25rem 0.65rem; border-radius: 6px; }
