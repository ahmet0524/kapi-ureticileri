---
// src/pages/door-materials.astro
// EN → /door-materials
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';

const lang  = 'en';
const isRTL = false;

const colourCount = '50+';
const modelCount  = '350+';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const currentUrl = baseUrl + '/door-materials';

// ── PAGE META ─────────────────────────────────────────────────────────
const meta = {
  title:       'Door Manufacturing Materials — Core, Surface & Accessories | CihanPan Door',
  description: 'Explore the full range of materials used in CihanPan Door production: honeycomb & semi-solid cores, PVC and Laminox surface laminates, handles, hinges and acoustic seals. Wholesale interior door manufacturer in Kayseri, Turkey.',
  keywords:    'door manufacturing materials, honeycomb core door, semi solid wood door, PVC door surface, Laminox HPL laminate, door hinges wholesale, door handles Turkey',
  ogTitle:     'Door Materials Guide | CihanPan Door',
  ogDescription: 'Everything inside our doors — honeycomb cores, HPL laminates, handles, hinges and seals. Factory-direct wholesale from Kayseri, Turkey.',
};

// ── SCHEMA ────────────────────────────────────────────────────────────
const materialsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": meta.title,
  "description": meta.description,
  "url": currentUrl,
  "inLanguage": "en-US",
  "publisher": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl }
};

const faqData = [
  { q: 'What is honeycomb core in interior doors?',
    a: 'Honeycomb core is a lightweight inner structure made of hexagonal cells. It provides a high strength-to-weight ratio, excellent sound insulation and moisture resistance while keeping the door lightweight and easy to install.' },
  { q: 'What is the difference between Honeycomb Core 1 and Honeycomb Core 2?',
    a: 'Honeycomb Core 1 is our standard lightweight core, ideal for residential doors. Honeycomb Core 2 features a denser cell structure that delivers superior acoustic performance and greater rigidity.' },
  { q: 'What is Semi Solid Wood and when is it used?',
    a: 'Semi solid wood combines natural wood frames with internal blocking. It is used in our high-end collections and wherever superior hinge-holding strength or a premium solid feel is required.' },
  { q: 'What is the difference between PVC and Laminox surfaces?',
    a: 'PVC is a waterproof thermoplastic film vacuum-pressed onto MDF — ideal for bathrooms. Laminox (HPL melamine) is a high-pressure laminate with greater scratch and impact resistance and a premium finish.' },
  { q: 'Can I order door accessories separately from the doors?',
    a: 'Yes. We supply handles, lock sets, hinges and seals both as integrated components and as standalone accessories for bulk project orders. Contact us for pricing and MOQs.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",     "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Products", "item": baseUrl + '/products' },
    { "@type": "ListItem", "position": 3, "name": "Door Materials", "item": currentUrl },
  ]
};

const allSchemas = [materialsSchema, faqSchema, breadcrumbSchema];

// ── MATERIALS DATA ────────────────────────────────────────────────────
const materials = [
  {
    category: 'core', img: '/assets/img/materials/honeycomb-1-core.webp',
    title: 'Honeycomb Core 1', subtitle: 'Standard Lightweight Core',
    desc: 'High-strength, lightweight honeycomb inner structure. The hexagonal cell design maximises rigidity while minimising weight — enhancing door durability and providing lasting performance across all standard door lines.',
    tags: ['Lightweight Construction', 'High Strength', 'Sound Insulation', 'Moisture Resistant'],
    specs: [['Cell Size', '15-20 mm'], ['Core Density', 'Standard'], ['Best For', 'Residential doors']],
  },
  {
    category: 'core', img: '/assets/img/materials/honeycomb-2-core.webp',
    title: 'Honeycomb Core 2', subtitle: 'Dense-Cell Premium Core',
    desc: 'Dense-cell honeycomb with advanced manufacturing technology. Superior acoustic performance, greater rigidity and enhanced durability — used in our premium and project-grade door lines where performance is non-negotiable.',
    tags: ['Dense Cell Structure', 'Superior Durability', 'Enhanced Acoustics', 'Eco-Friendly'],
    specs: [['Cell Size', '10-13 mm'], ['Core Density', 'High'], ['Best For', 'Premium & project doors']],
  },
  {
    category: 'core', img: '/assets/img/materials/semi-solid-core.webp',
    title: 'Semi Solid Wood', subtitle: 'Natural Wood Solidity',
    desc: 'Natural wood frames combined with internal blocking — the solidity of real wood at a practical weight. Exceptional hinge-holding strength and a premium feel, used in our high-end door collections.',
    tags: ['Natural Wood', 'High Solidity', 'Premium Quality', 'Long-Lasting'],
    specs: [['Material', 'Natural pine / poplar'], ['Weight', 'Medium-heavy'], ['Best For', 'High-end collections']],
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'PVC Surface Materials', subtitle: 'Waterproof Thermoplastic Laminate',
    desc: 'Waterproof PVC film vacuum-pressed onto MDF substrate. Highly resistant to humidity, easy to clean and available in a wide spectrum of colours and wood-grain finishes — the economical choice for wet areas.',
    tags: ['Waterproof', 'Easy to Clean', 'Wide Colour Range', 'Cost-Effective'],
    specs: [['Thickness', '0.18-0.25 mm'], ['Finish', 'Matt / Gloss / Wood-grain'], ['Application', 'Vacuum press']],
    link: '/pvc-doors', linkLabel: 'View PVC Doors',
  },
  {
    category: 'surface', img: '/assets/img/materials/PVCFOLYOLAR.webp',
    title: 'Laminox Surface Materials', subtitle: 'High-Pressure Melamine Laminate (HPL)',
    desc: 'High-pressure melamine (HPL) laminate bonded onto MDF. Superior scratch and impact resistance compared to standard PVC — richer patterns, matt or gloss options and a premium aesthetic finish.',
    tags: ['Scratch-Resistant', 'Impact-Resistant', 'Rich Patterns', 'Matt & Gloss Options'],
    specs: [['Thickness', '0.6-1.0 mm'], ['Finish', 'Matt / High-gloss / Textured'], ['Application', 'Cold / hot press']],
    link: '/laminox-doors', linkLabel: 'View Laminox Doors',
  },
  {
    category: 'accessories', img: '/assets/img/materials/door-handles.webp',
    title: 'Door Handles & Lock Systems', subtitle: 'Stainless Steel & Brass Hardware',
    desc: 'Premium door handles in stainless steel and brass. Ergonomic designs, multi-finish options — chrome, matte black, gold, satin — with integrated security lock cylinders for every application.',
    tags: ['304 Stainless Steel', 'Ergonomic Design', 'Multi-Finish', 'Security Lock Cylinders'],
    specs: [['Material', 'SS304 / Brass'], ['Finishes', 'Chrome, Matt Black, Gold, Satin'], ['Standard', 'EN 1906']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/hinges.webp',
    title: 'Hinges & Fixings', subtitle: 'Silent, Heavy-Duty Hinge Systems',
    desc: 'Precision-engineered hinge systems from high-grade steel. Silent operation, easy three-dimensional adjustment and long service life — compatible with all CihanPan door weights and profiles.',
    tags: ['Silent Operation', 'High Durability', 'Easy 3D Adjustment', 'Corrosion Resistant'],
    specs: [['Material', 'Steel / zinc alloy'], ['Load Capacity', 'Up to 120 kg'], ['Finish', 'Nickel / chrome / white']],
  },
  {
    category: 'accessories', img: '/assets/img/materials/seals.webp',
    title: 'Seals & Weatherstrip Systems', subtitle: 'Airtight Acoustic Sealing',
    desc: 'High-quality TPE and EPDM seals that prevent air infiltration, reduce sound transmission and improve energy efficiency. Essential for residential comfort and acoustic-rated door assemblies.',
    tags: ['Airtight Seal', 'Acoustic Reduction', 'Energy Saving', 'UV & Weather Resistant'],
    specs: [['Material', 'TPE / EPDM'], ['Temperature Range', '-30 to +80 C'], ['Compression Set', '< 20 %']],
  },
];

// ── COMPARISON TABLE ──────────────────────────────────────────────────
const cmpHeaders = ['Property', 'Honeycomb Core 1', 'Honeycomb Core 2', 'Semi Solid Wood'];

const comparisonRows = [
  ['Weight',           'Lightweight',          'Medium-light',        'Medium-heavy'],
  ['Strength',         '3/5',                  '4/5',                 '5/5'],
  ['Sound Insulation', '3/5',                  '4/5',                 '4/5'],
  ['Moisture Resist.', '4/5',                  '4/5',                 '3/5'],
  ['Eco-Friendly',     'Yes',                  'Yes',                 'Partial'],
  ['Best For',         'Residential / Budget', 'Premium / Acoustic',  'High-end / Solid feel'],
];

// ── UI STRINGS ────────────────────────────────────────────────────────
const ui = {
  filterAll:         'All',
  filterCore:        'Core Materials',
  filterSurface:     'Surface Materials',
  filterAccessories: 'Accessories',
  catCore:           'Core',
  catSurface:        'Surface',
  catAccessory:      'Accessory',
  heroEyebrow:       'Manufacturing Quality · Kayseri, Turkey',
  heroH1a:           'What Goes Inside',
  heroH1b:           'Every CihanPan Door',
  heroLead:          'From the honeycomb core to the surface laminate and every hinge in between — a complete guide to the materials that define our door quality.',
  heroCert1:         'ISO 9001 Certified',
  heroCert2:         'CE Compliant',
  heroCert3:         'Factory Direct',
  heroCert4:         'Wholesale Pricing',
  heroBtn1:          'Explore Materials',
  heroBtn2:          'Request a Quote',
  coreTypes:         'Core Types',
  surfaceLines:      'Surface Lines',
  colourOptions:     'Colour Options',
  doorModels:        'Door Models',
  introTag:          'Our Philosophy',
  introH2:           'Quality Starts from the Inside',
  introP1:           'A door is only as good as the sum of its parts. At CihanPan Door we control every layer — inner core, surface laminate and hardware — at our Kayseri factory. Each material is selected and tested to meet CE and ISO 9001 standards before entering production.',
  introP2:           'Understanding what goes inside our doors helps you specify the right product for every project — whether residential, hospitality, healthcare or commercial.',
  pillar1Title:      'Core Structure',
  pillar1Desc:       'Determines weight, strength and sound insulation.',
  pillar2Title:      'Surface Finish',
  pillar2Desc:       'Sets aesthetics, durability and moisture resistance.',
  pillar3Title:      'Hardware',
  pillar3Desc:       'Handles, hinges and seals complete the performance.',
  matTag:            'Full Material Range',
  matH2:             'Materials Used in Our Doors',
  matSubtitle:       'Filter by category to explore every component — from inner structure to surface and hardware.',
  cmpTag:            'Side-by-Side',
  cmpH2:             'Core Material Comparison',
  cmpSubtitle:       'Choose the right inner structure for your project needs.',
  faqTag:            'FAQ',
  faqH2:             'Frequently Asked Questions',
  ctaTag:            'Ready to Order?',
  ctaH2:             'Get Factory-Direct Pricing\nfor Any Material or Door',
  ctaP:              'Share your project specifications — door type, core preference, surface finish, quantities and destination. We respond within 24 hours with full pricing and CE/ISO documentation.',
  ctaBtn1:           'Get a Free Quote',
  ctaBtn2:           'View All Products',
  contactHref:       '/contact',
  productsHref:      '/products',
};
---

<I18nLayout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage="/assets/img/og/door-materials-og.webp"
  lang={lang}
  dir="ltr"
>
  <I18nHeader />

  <main class="dm" id="main-content" dir="ltr">

    <!-- HERO -->
    <section class="dm-hero" aria-labelledby="dm-h1">
      <div class="dm-hero__bg" aria-hidden="true">
        <div class="dm-hero__overlay"></div>
      </div>
      <div class="dm-wrap dm-hero__inner">
        <div class="dm-hero__content">
          <span class="dm-eyebrow">
            <span class="dm-eyebrow__line"></span>
            {ui.heroEyebrow}
          </span>
          <h1 class="dm-hero__h1" id="dm-h1">
            <em>{ui.heroH1a}</em><br/>{ui.heroH1b}
          </h1>
          <p class="dm-hero__lead">{ui.heroLead}</p>
          <div class="dm-hero__tags">
            <span class="dm-htag">✓ {ui.heroCert1}</span>
            <span class="dm-htag">✓ {ui.heroCert2}</span>
            <span class="dm-htag">✓ {ui.heroCert3}</span>
            <span class="dm-htag">✓ {ui.heroCert4}</span>
          </div>
          <div class="dm-hero__cta">
            <a href="#materials" class="dm-btn dm-btn--gold">{ui.heroBtn1}</a>
            <a href={ui.contactHref} class="dm-btn dm-btn--ghost">{ui.heroBtn2}</a>
          </div>
        </div>
        <div class="dm-hero__stats">
          <div class="dm-stat"><span class="dm-stat__num">3</span><span class="dm-stat__label">{ui.coreTypes}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">2</span><span class="dm-stat__label">{ui.surfaceLines}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{colourCount}</span><span class="dm-stat__label">{ui.colourOptions}</span></div>
          <div class="dm-stat"><span class="dm-stat__num">{modelCount}</span><span class="dm-stat__label">{ui.doorModels}</span></div>
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="dm-section dm-section--light">
      <div class="dm-wrap dm-intro">
        <div class="dm-intro__text">
          <span class="dm-tag">{ui.introTag}</span>
          <h2>{ui.introH2}</h2>
          <p>{ui.introP1}</p>
          <p>{ui.introP2}</p>
        </div>
        <div class="dm-intro__pillars">
          <div class="dm-pillar"><span class="dm-pillar__icon">🏗️</span><div><strong>{ui.pillar1Title}</strong><p>{ui.pillar1Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🎨</span><div><strong>{ui.pillar2Title}</strong><p>{ui.pillar2Desc}</p></div></div>
          <div class="dm-pillar"><span class="dm-pillar__icon">🔩</span><div><strong>{ui.pillar3Title}</strong><p>{ui.pillar3Desc}</p></div></div>
        </div>
      </div>
    </section>

    <!-- MATERIALS GRID -->
    <section class="dm-section" id="materials" aria-labelledby="dm-mat-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.matTag}</span>
          <h2 id="dm-mat-h2">{ui.matH2}</h2>
          <p class="dm-section__sub">{ui.matSubtitle}</p>
        </div>
        <div class="dm-filters" role="tablist" aria-label="Filter materials">
          <button class="dm-filter dm-filter--active" data-filter="all" role="tab" aria-selected="true">{ui.filterAll}</button>
          <button class="dm-filter" data-filter="core" role="tab" aria-selected="false">{ui.filterCore}</button>
          <button class="dm-filter" data-filter="surface" role="tab" aria-selected="false">{ui.filterSurface}</button>
          <button class="dm-filter" data-filter="accessories" role="tab" aria-selected="false">{ui.filterAccessories}</button>
        </div>
        <div class="dm-grid">
          {materials.map(m => (
            <article class="dm-card" data-category={m.category}>
              <div class="dm-card__img">
                <img src={m.img} alt={m.title} loading="lazy" width="400" height="200"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="dm-card__placeholder">🚪</div>
                <span class="dm-card__cat-badge">
                  {m.category === 'core' ? ui.catCore : m.category === 'surface' ? ui.catSurface : ui.catAccessory}
                </span>
              </div>
              <div class="dm-card__body">
                <p class="dm-card__subtitle">{m.subtitle}</p>
                <h3>{m.title}</h3>
                <p class="dm-card__desc">{m.desc}</p>
                <ul class="dm-card__tags">
                  {m.tags.map(tag => <li>{tag}</li>)}
                </ul>
                <table class="dm-card__specs">
                  <tbody>
                    {m.specs.map(([k,v]) => (
                      <tr><th scope="row">{k}</th><td>{v}</td></tr>
                    ))}
                  </tbody>
                </table>
                {m.link && (
                  <a href={m.link} class="dm-card__link">{m.linkLabel} →</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- COMPARISON TABLE -->
    <section class="dm-section dm-section--light" aria-labelledby="dm-cmp-h2">
      <div class="dm-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.cmpTag}</span>
          <h2 id="dm-cmp-h2">{ui.cmpH2}</h2>
          <p class="dm-section__sub">{ui.cmpSubtitle}</p>
        </div>
        <div class="dm-table-wrap">
          <table class="dm-cmp-table">
            <thead>
              <tr>{cmpHeaders.map(h => <th scope="col">{h}</th>)}</tr>
            </thead>
            <tbody>
              {comparisonRows.map(row => (
                <tr>
                  {row.map((cell, i) => i === 0
                    ? <td class="dm-cmp-prop">{cell}</td>
                    : <td>{cell}</td>
                  )}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="dm-section" aria-labelledby="dm-faq-h2">
      <div class="dm-wrap dm-faq-wrap">
        <div class="dm-section__hd">
          <span class="dm-tag">{ui.faqTag}</span>
          <h2 id="dm-faq-h2">{ui.faqH2}</h2>
        </div>
        <div class="dm-faqs">
          {faqData.map(f => (
            <details class="dm-faq">
              <summary class="dm-faq__q">
                {f.q}
                <svg class="dm-faq__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="dm-faq__a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="dm-cta" aria-labelledby="dm-cta-h2">
      <div class="dm-cta__glow" aria-hidden="true"></div>
      <div class="dm-wrap dm-cta__inner">
        <div class="dm-cta__text">
          <span class="dm-tag dm-tag--light">{ui.ctaTag}</span>
          <h2 id="dm-cta-h2">{ui.ctaH2}</h2>
          <p>{ui.ctaP}</p>
        </div>
        <div class="dm-cta__btns">
          <a href={ui.contactHref}  class="dm-btn dm-btn--gold">{ui.ctaBtn1}</a>
          <a href={ui.productsHref} class="dm-btn dm-btn--ghost">{ui.ctaBtn2}</a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  :root {
    --navy:   #0f2347;
    --gold:   #c9a84c;
    --white:  #ffffff;
    --cream:  #f8f6f1;
    --text:   #1a1a2e;
    --body:   #4a4a6a;
    --slate:  #6b7280;
    --bdr:    #e5e0d8;
    --radius: 12px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .dm-wrap { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .dm-section { padding: clamp(4rem, 8vw, 6rem) 0; }
  .dm-section--light { background: var(--cream); }
  .dm-section__hd { text-align: center; margin-bottom: 3rem; }
  .dm-section__hd h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; color: var(--text); margin: 0.4rem 0 0.75rem; }
  .dm-section__sub { color: var(--body); font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .dm-tag { display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25); border-radius: 20px; padding: 0.3rem 0.9rem; }
  .dm-tag--light { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }

  .dm-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.85rem 1.75rem; border-radius: 8px; font-family: 'Inter', system-ui, sans-serif; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
  .dm-btn--gold  { background: var(--gold); color: var(--navy); }
  .dm-btn--gold:hover { background: #b8943e; }
  .dm-btn--ghost { background: transparent; color: var(--white); border: 1.5px solid rgba(255,255,255,0.35); }
  .dm-btn--ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.6); }

  .dm-eyebrow { display: flex; align-items: center; gap: 0.75rem; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }
  .dm-eyebrow__line { display: inline-block; width: 32px; height: 2px; background: var(--gold); flex-shrink: 0; }

  .dm-hero { position: relative; min-height: 92vh; display: flex; align-items: center; background: var(--navy); overflow: hidden; }
  .dm-hero__bg { position: absolute; inset: 0; background: url('/assets/img/hero/door-materials-hero.webp') center/cover no-repeat; }
  .dm-hero__overlay { position: absolute; inset: 0; background: linear-gradient(120deg, rgba(15,35,71,0.92) 45%, rgba(15,35,71,0.55) 100%); }
  .dm-hero__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; padding-top: 6rem; padding-bottom: 4rem; }
  .dm-hero__content { max-width: 600px; }
  .dm-hero__h1 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2.2rem, 5vw, 3.75rem); font-weight: 700; color: var(--white); line-height: 1.1; margin-bottom: 1.25rem; }
  .dm-hero__h1 em { font-style: normal; color: var(--gold); display: block; }
  .dm-hero__lead { color: rgba(255,255,255,0.65); font-size: clamp(0.95rem, 1.8vw, 1.1rem); line-height: 1.75; margin-bottom: 1.5rem; max-width: 520px; }
  .dm-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .dm-htag { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 0.3rem 0.8rem; }
  .dm-hero__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .dm-hero__stats { display: flex; flex-direction: column; gap: 1rem; }
  .dm-stat { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 1.25rem 1.75rem; text-align: center; min-width: 120px; backdrop-filter: blur(6px); }
  .dm-stat__num { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 700; color: var(--gold); line-height: 1; }
  .dm-stat__label { display: block; font-size: 0.75rem; color: rgba(255,255,255,0.5); margin-top: 0.3rem; font-weight: 500; }

  .dm-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .dm-intro__text h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: var(--text); margin: 0.4rem 0 1rem; line-height: 1.25; }
  .dm-intro__text p { color: var(--body); font-size: 0.975rem; line-height: 1.8; margin-bottom: 1rem; }
  .dm-intro__pillars { display: flex; flex-direction: column; gap: 1.25rem; }
