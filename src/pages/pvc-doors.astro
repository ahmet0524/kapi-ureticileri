  function parseFileName(fileName) {
    const base  = fileName.replace('.webp', '');
    const parts = base.split('-');
    // Parts: CihanpanDoor - PVC - Serisi - 101 - A - Color...
    const model  = parts[3];         // e.g. "101"
    const variant = parts[4];        // e.g. "A"
    const color  = parts.slice(5).join(' '); // e.g. "ABD Ceviz"
    return { model, variant, color, label: `${model}-${variant} · ${color}` };
  }

  function buildCard(fileName) {
    const { model, variant, color, label } = parseFileName(fileName);
    const img = `/assets/img/pvc-kapilar/${fileName}`;
    const alt = `CihanPan Door PVC Series ${model}-${variant} ${color} — Waterproof Interior Door`;

    const article = document.createElement('article');
    article.className = 'pvc-card';
    article.setAttribute('aria-label', label);
    article.innerHTML = `
      <div class="pvc-card__img">
        <img src="${img}" alt="${alt}" width="240" height="320" loading="lazy" decoding="async" />
      </div>
      <p class="pvc-card__name">${label}</p>
    `;
    return article;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const grid    = document.getElementById('productsGrid');
    const loading = document.getElementById('loading');
    if (!grid) return;

    loading.style.display = 'block';

    // Use requestIdleCallback / setTimeout to avoid blocking paint
    setTimeout(() => {
      const frag = document.createDocumentFragment();
      fileNames.forEach(fn => frag.appendChild(buildCard(fn)));
      grid.appendChild(frag);
      loading.style.display = 'none';
    }, 60);
  });
</script>
