---
// src/pages/pvc-kapilar.astro
import I18nLayout from '../layouts/I18nLayout.astro';
import I18nHeader from '../components/I18nHeader.astro';
import I18nFooter from '../components/I18nFooter.astro';
import { getLangFromUrl, useTranslations, getLocalizedRoute } from '../i18n/utils';

const lang  = getLangFromUrl(Astro.url);
const t     = useTranslations(lang);
const isEN  = lang === 'en';

const baseUrl    = 'https://cihanpandoor.netlify.app';
const pageUrl    = lang === 'tr' ? baseUrl : `${baseUrl}/${lang}`;
const currentUrl = `${pageUrl}/pvc-kapilar`;

// ── SCHEMA ────────────────────────────────────────────────────────────
const pvcSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isEN ? "PVC Interior Doors — 247 Models | CihanPan Door" : "PVC İç Oda Kapıları — 247 Model | CihanPan Door",
  "description": isEN
    ? "Wholesale waterproof antibacterial PVC interior doors from Kayseri, Turkey. 247 models, CE certified, factory-direct pricing. Ideal for bathrooms, hospitals and high-humidity environments."
    : "Kayseri'den toptan su geçirmez, antibakteriyel PVC iç oda kapıları. 247 model, CE belgeli.",
  "url": currentUrl,
  "inLanguage": lang === 'tr' ? 'tr-TR' : lang === 'ar' ? 'ar-SA' : 'en-US',
  "mainEntity": {
    "@type": "ItemList",
    "name": isEN ? "PVC Door Models" : "PVC Kapı Modelleri",
    "numberOfItems": 247,
    "itemListElement": [
      {
        "@type": "Product",
        "name": isEN ? "PVC Interior Door" : "PVC İç Oda Kapısı",
        "description": isEN
          ? "Waterproof antibacterial PVC interior door. No warping in humid environments, 5-year warranty, easy maintenance. CE certified Turkish manufacturer."
          : "Su geçirmez antibakteriyel PVC iç oda kapısı. Nemli ortamlarda çarpma yapmaz, 5 yıl garanti.",
        "brand": { "@type": "Brand", "name": "CihanPan Door" },
        "manufacturer": { "@type": "Organization", "name": "CihanPan Door", "url": baseUrl },
        "material": "PVC",
        "category": isEN ? "Interior Door" : "İç Oda Kapısı",
        "offers": {
          "@type": "AggregateOffer",
          "url": currentUrl,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "offerCount": "247",
          "businessFunction": "http://purl.org/goodrelations/v1#Sell",
          "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.8",
          "reviewCount": "152",
          "bestRating": "5",
          "worstRating": "1"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": isEN ? [
    { "@type": "Question", "name": "What is a PVC door and why is it preferred?", "acceptedAnswer": { "@type": "Answer", "text": "PVC doors are interior doors made from Polyvinyl Chloride. They are waterproof, antibacterial and will not warp in humid environments. Easy to maintain and cost-effective for wholesale projects." }},
    { "@type": "Question", "name": "What is the difference between PVC and wood doors?", "acceptedAnswer": { "@type": "Answer", "text": "PVC doors are fully waterproof and moisture-resistant, whereas wooden doors are sensitive to humidity. PVC doors are more economical and require less maintenance while still delivering an attractive appearance." }},
    { "@type": "Question", "name": "Where are PVC doors typically used?", "acceptedAnswer": { "@type": "Answer", "text": "PVC doors are ideal for bathrooms, kitchens, balconies, bedrooms and offices. They are especially preferred in high-humidity environments such as hospitals, hotels and residential buildings in tropical climates." }},
    { "@type": "Question", "name": "What is the MOQ for wholesale PVC door orders?", "acceptedAnswer": { "@type": "Answer", "text": "Our minimum order quantity is 50 units. Volume discounts are available from 200 units. Custom sizes, finishes and private-label options are available for larger orders." }},
  ] : []
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Home"     : "Ana Sayfa", "item": pageUrl },
    { "@type": "ListItem", "position": 2, "name": isEN ? "Products" : "Ürünler",   "item": `${pageUrl}/urunlerimiz` },
    { "@type": "ListItem", "position": 3, "name": isEN ? "PVC Interior Doors" : "PVC Kapılar", "item": currentUrl },
  ]
};

const allSchemas = [pvcSchema, faqSchema, breadcrumbSchema];

// ── CATEGORY NAV ──────────────────────────────────────────────────────
const catNav = [
  { slug: '/urunlerimiz',               label: isEN ? 'All Products'      : 'Tümü',                  active: false },
  { slug: '/pvc-kapilar',               label: isEN ? 'PVC Doors'         : 'PVC Kapılar',            active: true  },
  { slug: '/laminoks-kapilar',          label: isEN ? 'Laminox Doors'     : 'Laminoks Kapılar',       active: false },
  { slug: '/elitpan-kapilar',           label: isEN ? 'Elitpan Doors'     : 'Elitpan Kapılar',        active: false },
  { slug: '/hastane-kapilari',          label: isEN ? 'Hospital Doors'    : 'Hastane Kapıları',       active: false },
  { slug: '/otel-kapilari',             label: isEN ? 'Hotel Doors'       : 'Otel Kapıları',          active: false },
  { slug: '/yangina-dayanikli-kapilar', label: isEN ? 'Fire-Rated Doors'  : 'Yangın Kapıları',        active: false },
];
---

<I18nLayout
  title={isEN
    ? "PVC Interior Doors — 247 Models | Wholesale from Turkey | CihanPan Door"
    : "PVC İç Oda Kapıları — 247 Model | Toptan | CihanPan Door"}
  description={isEN
    ? "Wholesale waterproof antibacterial PVC interior doors from Kayseri, Turkey. 247 models, CE & ISO 9001 certified. Factory-direct pricing for US, Europe and Middle East importers. MOQ 50 units."
    : "Kayseri'den toptan su geçirmez, antibakteriyel PVC kapılar. 247 model, CE sertifikalı."}
  keywords={isEN
    ? "PVC interior doors wholesale Turkey, waterproof door manufacturer, antibacterial PVC door, Turkish door exporter, CE certified PVC door"
    : "pvc kapı, pvc iç oda kapısı, su geçirmez kapı, antibakteriyel kapı, toptan pvc kapı"}
  canonical={currentUrl}
  schema={allSchemas}
  ogTitle={isEN ? "PVC Interior Doors — 247 Models | CihanPan Door Turkey" : "PVC Kapılar — 247 Model | CihanPan Door"}
  ogDescription={isEN
    ? "Waterproof, antibacterial PVC interior doors. Factory direct from Kayseri. MOQ 50 units."
    : "Su geçirmez, antibakteriyel PVC kapılar. Fabrikadan doğrudan."}
  ogImage="/assets/img/og/pvc-kapilar-og.webp"
>
  <I18nHeader />

  <main class="pvc" id="main-content">

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="pvc-hero" aria-labelledby="pvc-h1">
      <div class="pvc-hero__bg" aria-hidden="true">
        <div class="pvc-hero__overlay"></div>
        <div class="pvc-hero__glow"></div>
      </div>
      <div class="pvc-wrap pvc-hero__inner">
        <div>
          <nav class="pvc-breadcrumb" aria-label="Breadcrumb">
            <a href={pageUrl}>{isEN ? 'Home' : 'Ana Sayfa'}</a>
            <span aria-hidden="true">›</span>
            <a href={getLocalizedRoute('/urunlerimiz', lang)}>{isEN ? 'Products' : 'Ürünler'}</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{isEN ? 'PVC Doors' : 'PVC Kapılar'}</span>
          </nav>

          <span class="pvc-eyebrow">
            <span class="pvc-eyebrow__line"></span>
            {isEN ? 'Best Seller · 247 Models' : 'Çok Satan · 247 Model'}
          </span>
          <h1 class="pvc-hero__h1" id="pvc-h1">
            {isEN
              ? <><em>PVC Interior Doors</em><br/>Waterproof · Antibacterial</>
              : <><em>PVC İç Oda Kapıları</em><br/>Su Geçirmez · Antibakteriyel</>}
          </h1>
          <p class="pvc-hero__lead">
            {isEN
              ? 'Factory-direct wholesale PVC interior doors from Kayseri, Turkey. CE & ISO 9001 certified. Ideal for bathrooms, hospitals and high-humidity environments. MOQ 50 units.'
              : 'Kayseri fabrikasından toptan PVC kapılar. CE ve ISO 9001 sertifikalı. Banyo, hastane ve nemli ortamlar için ideal. Min. 50 adet.'}
          </p>
          <div class="pvc-hero__tags">
            <span class="pvc-htag">✓ {isEN ? 'Waterproof' : 'Su Geçirmez'}</span>
            <span class="pvc-htag">✓ {isEN ? 'Antibacterial' : 'Antibakteriyel'}</span>
            <span class="pvc-htag">✓ {isEN ? '247 Models' : '247 Model'}</span>
            <span class="pvc-htag">✓ CE & ISO 9001</span>
          </div>
          <div class="pvc-hero__actions">
            <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold">
              {isEN ? 'Get a Free Quote' : 'Ücretsiz Teklif Al'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#catalogue" class="pvc-btn pvc-btn--ghost">
              {isEN ? 'Browse Models' : 'Modelleri Gör'}
            </a>
          </div>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="pvc-wrap">
        <div class="pvc-statsbar">
          <div class="pvc-sitem"><strong>247</strong><span>{isEN ? 'Models' : 'Model'}</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>CE</strong><span>{isEN ? 'Certified' : 'Sertifikalı'}</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>50<sup>+</sup></strong><span>{isEN ? 'Color Options' : 'Renk Seçeneği'}</span></div>
          <div class="pvc-sdiv"></div>
          <div class="pvc-sitem"><strong>MOQ 50</strong><span>{isEN ? 'Units' : 'Adet'}</span></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CATEGORY NAV + PRODUCT GRID
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--white" id="catalogue" aria-labelledby="catalogue-h2">
      <div class="pvc-wrap">

        <!-- Category filter tabs -->
        <nav class="pvc-catnav" aria-label={isEN ? 'Door categories' : 'Kapı kategorileri'}>
          {catNav.map(cat => (
            <a
              href={getLocalizedRoute(cat.slug, lang)}
              class={`pvc-catbtn${cat.active ? ' pvc-catbtn--active' : ''}`}
              aria-current={cat.active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          ))}
        </nav>

        <div class="pvc-head" style="margin-top:0">
          <span class="pvc-tag">{isEN ? 'PVC Door Collection' : 'PVC Kapı Koleksiyonu'}</span>
          <h2 id="catalogue-h2">
            {isEN ? 'PVC Interior Door Models' : 'PVC Kapı Modelleri'}
          </h2>
          <p>
            {isEN
              ? 'Browse our full PVC door collection. Every model is available in multiple color variants. Click any model to request a wholesale quote.'
              : 'Tüm PVC kapı koleksiyonumuzu inceleyin. Her model birden fazla renk varyantında mevcuttur.'}
          </p>
        </div>

        <!-- Quote CTA -->
        <div class="pvc-quote-row">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--navy">
            {isEN ? 'Request Wholesale Quote' : 'Toptan Teklif Al'}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <span class="pvc-quote-note">{isEN ? 'Response within 24 hours · MOQ 50 units' : '24 saat içinde yanıt · Min. 50 adet'}</span>
        </div>

        <!-- Products Grid (JS-rendered) -->
        <div class="pvc-grid" id="productsGrid" aria-live="polite" aria-label={isEN ? 'PVC door models' : 'PVC kapı modelleri'}></div>

        <!-- Loading state -->
        <div class="pvc-loading" id="loading" aria-label={isEN ? 'Loading models' : 'Modeller yükleniyor'}>
          <div class="pvc-spinner" aria-hidden="true"></div>
          <p>{isEN ? 'Loading PVC door models…' : 'PVC kapı modelleri yükleniyor…'}</p>
        </div>

        <!-- Pagination -->
        <nav class="pvc-pagination" aria-label={isEN ? 'Page navigation' : 'Sayfa navigasyonu'}>
          <div class="pvc-page-info">
            <span class="pvc-page-current">{isEN ? 'Page 1 of 3' : 'Sayfa 1 / 3'}</span>
            <span class="pvc-page-count">{isEN ? '95 models shown' : '95 model gösteriliyor'}</span>
          </div>
          <div class="pvc-page-btns">
            <span class="pvc-page-btn pvc-page-btn--disabled" aria-disabled="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18L9 12L15 6"/></svg>
              {isEN ? 'Previous' : 'Önceki'}
            </span>
            <a href={getLocalizedRoute('/pvc-doors-2', lang)} class="pvc-page-btn">
              {isEN ? 'Page 2' : 'Sayfa 2'}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18L15 12L9 6"/></svg>
            </a>
          </div>
          <div class="pvc-page-dots" aria-hidden="true">
            <span class="pvc-dot pvc-dot--active"></span>
            <a href={getLocalizedRoute('/pvc-doors-2', lang)} class="pvc-dot"></a>
            <a href={getLocalizedRoute('/pvc-doors-3', lang)} class="pvc-dot"></a>
          </div>
        </nav>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEO CONTENT + SIDEBAR
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--cream" aria-labelledby="content-h2">
      <div class="pvc-wrap pvc-content-wrap">

        <!-- Main editorial text -->
        <article class="pvc-article">
          <h2 id="content-h2">
            {isEN
              ? 'What Is a PVC Interior Door? Why Choose PVC?'
              : 'PVC Kapı Nedir? Neden PVC Kapı Tercih Edilir?'}
          </h2>

          <p>
            {isEN
              ? (<><strong>PVC interior doors</strong> are manufactured from Polyvinyl Chloride and designed to meet modern residential and commercial requirements. At <strong>CihanPan Door</strong>, our Kayseri factory has produced high-quality PVC doors since 1995, supplying wholesale buyers across the USA, Europe and the Middle East.</>)
              : (<><strong>PVC kapılar</strong>, Polivinil Klorür malzemesinden üretilen iç oda kapılarıdır. <strong>CihanPan Door</strong> olarak, 1995'ten bu yana Kayseri fabrikamızda toptan satış ve ihracat için üretim yapıyoruz.</>)}
          </p>

          <h3>{isEN ? 'Advantages of PVC Doors' : 'PVC Kapının Avantajları'}</h3>
          <ul class="pvc-checklist">
            <li><strong>{isEN ? 'Waterproof:' : 'Su Geçirmez:'}</strong> {isEN ? 'Fully resistant to moisture and water — will not warp, swell or rot.' : 'Nem ve suya karşı tamamen dirençli — çarpma, şişme veya çürüme yapmaz.'}</li>
            <li><strong>{isEN ? 'Antibacterial Surface:' : 'Antibakteriyel Yüzey:'}</strong> {isEN ? 'Inhibits bacterial growth — ideal for hygiene-critical environments.' : 'Bakteri üremesini engeller — hijyen gerektiren ortamlar için ideal.'}</li>
            <li><strong>{isEN ? 'Easy Maintenance:' : 'Kolay Bakım:'}</strong> {isEN ? 'Clean with a damp cloth only — no painting or sealing required.' : 'Sadece nemli bezle temizlenir — boya veya vernikleme gerekmez.'}</li>
            <li><strong>{isEN ? 'Sound Insulation:' : 'Ses İzolasyonu:'}</strong> {isEN ? 'Effective noise reduction between rooms.' : 'Odalar arasında etkili ses azaltma.'}</li>
            <li><strong>{isEN ? 'Cost-Effective:' : 'Ekonomik:'}</strong> {isEN ? 'Competitive wholesale pricing with high durability.' : 'Yüksek dayanıklılıkta rekabetçi toptan fiyatlandırma.'}</li>
          </ul>

          <h3>{isEN ? 'Common Applications' : 'Kullanım Alanları'}</h3>
          <p>{isEN ? 'PVC doors deliver superior performance in humid environments:' : 'PVC kapılar nemli ortamlarda üstün performans gösterir:'}</p>
          <ul class="pvc-checklist">
            <li><strong>{isEN ? 'Bathroom Doors:' : 'Banyo Kapıları:'}</strong> {isEN ? 'Fully resistant to steam and water splashes.' : 'Buhar ve su sıçramalarına karşı tamamen dayanıklı.'}</li>
            <li><strong>{isEN ? 'Kitchen Doors:' : 'Mutfak Kapıları:'}</strong> {isEN ? 'Does not absorb cooking odours or grease.' : 'Yemek kokuları veya yağ absorbe etmez.'}</li>
            <li><strong>{isEN ? 'Hospital & Healthcare:' : 'Hastane ve Sağlık:'}</strong> {isEN ? 'Antibacterial surface meets hygiene standards.' : 'Antibakteriyel yüzey hijyen standartlarını karşılar.'}</li>
            <li><strong>{isEN ? 'Hotel Rooms:' : 'Otel Odaları:'}</strong> {isEN ? 'Easy maintenance between guest turnovers.' : 'Misafir değişimleri arasında kolay bakım.'}</li>
            <li><strong>{isEN ? 'Residential Complexes:' : 'Konut Projeleri:'}</strong> {isEN ? 'Cost-efficient solution for large-scale projects.' : 'Büyük ölçekli projeler için maliyet etkin çözüm.'}</li>
          </ul>

          <h3>{isEN ? 'Technical Specifications' : 'Teknik Özellikler'}</h3>
          <ul class="pvc-checklist">
            <li>{isEN ? 'Standard size: 70×200 cm — custom sizes available' : 'Standart boyut: 70×200 cm — özel boyut mevcut'}</li>
            <li>{isEN ? 'Core: Honeycomb or semi-solid wood' : 'İç yapı: Honeycomb veya yarı masif ahşap'}</li>
            <li>{isEN ? 'Surface: PVC laminate film' : 'Yüzey: PVC laminat film'}</li>
            <li>{isEN ? '50+ colour and pattern options' : '50+ renk ve desen seçeneği'}</li>
            <li>CE & ISO 9001 {isEN ? 'certified' : 'sertifikalı'}</li>
            <li>{isEN ? '5-year manufacturer warranty' : '5 yıl üretici garantisi'}</li>
          </ul>
        </article>

        <!-- Sticky sidebar -->
        <aside class="pvc-sidebar">
          <!-- KPI stats (same style as index about section) -->
          <div class="pvc-kpis">
            <div class="pvc-kpi">
              <strong>247</strong>
              <span>{isEN ? 'Models' : 'Model'}</span>
            </div>
            <div class="pvc-kpi">
              <strong>50<sup>+</sup></strong>
              <span>{isEN ? 'Colors' : 'Renk'}</span>
            </div>
            <div class="pvc-kpi">
              <strong>CE</strong>
              <span>{isEN ? 'Certified' : 'Sertifikalı'}</span>
            </div>
            <div class="pvc-kpi">
              <strong>5yr</strong>
              <span>{isEN ? 'Warranty' : 'Garanti'}</span>
            </div>
          </div>

          <!-- Quick contact -->
          <div class="pvc-contact-card">
            <span class="pvc-tag">{isEN ? 'Get in Touch' : 'İletişim'}</span>
            <h3>{isEN ? 'Request a Quote' : 'Teklif Al'}</h3>
            <p>{isEN ? 'Share your quantity and requirements — we respond within 24 hours.' : 'Miktar ve gereksinimlerinizi paylaşın — 24 saat içinde yanıt veririz.'}</p>
            <div class="pvc-contact-btns">
              <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold pvc-btn--sm">
                {isEN ? 'Contact Form' : 'İletişim Formu'}
              </a>
              <a href="https://wa.me/905441690038" target="_blank" rel="noopener" class="pvc-btn pvc-btn--wa pvc-btn--sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.89 3.488"/></svg>
                WhatsApp
              </a>
              <a href="tel:+905441690038" class="pvc-btn pvc-btn--outline pvc-btn--sm">
                📞 +90 544 169 00 38
              </a>
            </div>
          </div>

          <!-- Feature highlights -->
          <div class="pvc-features-card">
            <h3>{isEN ? 'Key Features' : 'Öne Çıkan Özellikler'}</h3>
            <ul class="pvc-feat-list">
              <li>🚿 {isEN ? 'Waterproof technology' : 'Su geçirmez teknoloji'}</li>
              <li>🦠 {isEN ? 'Antibacterial surface' : 'Antibakteriyel yüzey'}</li>
              <li>🔇 {isEN ? 'Sound insulation' : 'Ses yalıtımı'}</li>
              <li>💰 {isEN ? 'Competitive wholesale price' : 'Rekabetçi toptan fiyat'}</li>
              <li>📐 {isEN ? 'Custom sizes available' : 'Özel ölçü mevcut'}</li>
              <li>♻️ {isEN ? 'Eco-friendly materials' : 'Çevre dostu malzeme'}</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         FAQ
    ══════════════════════════════════════════ -->
    <section class="pvc-sec pvc-sec--white" aria-labelledby="faq-h2">
      <div class="pvc-wrap pvc-faq-wrap">
        <div class="pvc-head">
          <span class="pvc-tag">FAQ</span>
          <h2 id="faq-h2">{isEN ? 'Frequently Asked Questions' : 'Sık Sorulan Sorular'}</h2>
        </div>
        <div class="pvc-faqs">
          {(isEN ? [
            { q: 'What is a PVC door and why is it preferred?',         a: 'PVC doors are made from Polyvinyl Chloride — fully waterproof and antibacterial. They will not warp in humid environments, require minimal maintenance and offer excellent value for wholesale projects.' },
            { q: 'What is the difference between PVC and wood doors?',  a: 'PVC doors are fully waterproof and moisture-resistant, whereas wooden doors are sensitive to humidity and need regular sealing. PVC is more economical, easier to maintain and still provides an attractive finish.' },
            { q: 'Where are PVC doors typically used?',                 a: 'Bathrooms, kitchens, balconies, bedrooms, hospitals, hotel rooms and any high-humidity environment. Their waterproof antibacterial surface makes them especially suited for healthcare and hospitality projects.' },
            { q: 'What is the MOQ for wholesale orders?',               a: 'Minimum order quantity is 50 units. Volume discounts apply from 200+ units. Custom dimensions, finishes and private-label options are available for larger bulk orders.' },
          ] : [
            { q: 'PVC kapı nedir ve neden tercih edilir?',              a: 'PVC kapılar, Polivinil Klorür malzemesinden üretilen, su geçirmez ve antibakteriyel özellikli kapılardır. Nemli ortamlarda çarpma yapmaz, bakımı kolaydır ve toptan satış projeleri için maliyet etkindir.' },
            { q: 'PVC ile ahşap kapı arasındaki fark nedir?',           a: 'PVC kapılar tamamen su geçirmez ve neme dayanıklıyken, ahşap kapılar neme karşı hassastır ve düzenli bakım gerektirir. PVC daha ekonomik ve bakımı daha kolaydır.' },
            { q: 'PVC kapı hangi alanlarda kullanılır?',                a: 'Banyo, mutfak, balkon, yatak odası, hastane, otel odaları ve yüksek nem gerektiren her ortam. Su geçirmez antibakteriyel yüzeyi sağlık ve konaklama projelerine özellikle uygundur.' },
            { q: 'Toptan siparişlerde MOQ nedir?',                      a: 'Minimum sipariş miktarı 50 adettir. 200+ adet için hacim indirimleri geçerlidir. Büyük toplu siparişler için özel ölçü, yüzey ve özel etiket seçenekleri mevcuttur.' },
          ]).map(item => (
            <details class="pvc-faq">
              <summary class="pvc-faq__q">
                {item.q}
                <span class="pvc-faq__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </summary>
              <p class="pvc-faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         CTA BAND
    ══════════════════════════════════════════ -->
    <section class="pvc-cta" aria-labelledby="cta-h2">
      <div class="pvc-cta__glow" aria-hidden="true"></div>
      <div class="pvc-wrap pvc-cta__inner">
        <div class="pvc-cta__text">
          <span class="pvc-tag pvc-tag--gold">{isEN ? 'Start Sourcing Today' : 'Hemen Başlayın'}</span>
          <h2 id="cta-h2">
            {isEN
              ? 'Request a PVC Door\nWholesale Quote'
              : 'PVC Kapı Toptan\nFiyat Teklifi Alın'}
          </h2>
          <p>
            {isEN
              ? 'Share your door models, quantities and destination port. Factory-direct pricing with CE & ISO documentation within 24 hours.'
              : 'Kapı modellerini, adeti ve teslimat noktasını paylaşın. 24 saat içinde CE & ISO belgeli fiyat teklifi.'}
          </p>
        </div>
        <div class="pvc-cta__btns">
          <a href={getLocalizedRoute('/iletisim', lang)} class="pvc-btn pvc-btn--gold">
            {isEN ? 'Get a Free Quote' : 'Ücretsiz Teklif Al'}
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={getLocalizedRoute('/urunlerimiz', lang)} class="pvc-btn pvc-btn--ghost">
            {isEN ? 'All Products' : 'Tüm Ürünler'}
          </a>
        </div>
      </div>
    </section>

  </main>

  <I18nFooter />
</I18nLayout>

<style>
  /* ── TOKENS — index.astro ile özdeş ── */
  .pvc {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --navy-l:   #1e4a8a;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
    --radius:   14px;
    --green:    #16a34a;

    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text);
  }

  /* ── LAYOUT ── */
  .pvc-wrap {
    max-width: 1160px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 2.5rem);
    width: 100%;
  }
  .pvc-sec          { padding-block: clamp(4rem, 8vw, 6.5rem); }
  .pvc-sec--white   { background: var(--white); }
  .pvc-sec--cream   { background: var(--cream); }

  /* ── SECTION HEAD ── */
  .pvc-head {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .pvc-head h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: var(--text);
    margin: 0.3rem 0 0.7rem;
    line-height: 1.2;
  }
  .pvc-head p {
    color: var(--slate);
    font-size: 1rem;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.7;
  }

  .pvc-tag { display: inline-block; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .pvc-tag--gold { color: rgba(201,168,76,0.9); }

  /* ── BUTTONS ── */
  .pvc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    font-family: 'Inter', system-ui, sans-serif;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
    cursor: pointer;
    border: none;
  }
  .pvc-btn--gold     { background: var(--gold);  color: var(--navy);  font-weight: 700; }
  .pvc-btn--gold:hover  { background: var(--gold-l); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }
  .pvc-btn--navy     { background: var(--navy);  color: var(--white); font-weight: 700; }
  .pvc-btn--navy:hover  { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(15,35,71,0.3); }
  .pvc-btn--ghost    { background: transparent; color: rgba(255,255,255,0.85); border: 1.5px solid rgba(255,255,255,0.25); }
  .pvc-btn--ghost:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.07); transform: translateY(-2px); }
  .pvc-btn--wa       { background: #16a34a; color: var(--white); }
  .pvc-btn--wa:hover { background: #15803d; transform: translateY(-2px); }
  .pvc-btn--outline  { background: transparent; color: var(--navy); border: 1.5px solid var(--bdr); }
  .pvc-btn--outline:hover { border-color: var(--navy); transform: translateY(-2px); }
  .pvc-btn--sm       { font-size: 0.85rem; padding: 0.65rem 1.25rem; }

  /* ── HERO ── */
  .pvc-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 70px;
    overflow: hidden;
  }
  .pvc-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .pvc-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(10,26,58,0.96) 0%, rgba(15,35,71,0.88) 60%, rgba(26,58,110,0.82) 100%);
  }
  .pvc-hero__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 80% 30%, rgba(201,168,76,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 10% 70%, rgba(30,74,138,0.3) 0%, transparent 60%);
  }
  .pvc-hero__inner {
    position: relative; z-index: 1;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* Breadcrumb */
  .pvc-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1.5rem;
  }
  .pvc-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .pvc-breadcrumb a:hover { color: var(--gold-l); }
  .pvc-breadcrumb span[aria-current] { color: var(--gold); }

  .pvc-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.2rem;
  }
  .pvc-eyebrow__line { display: block; width: 28px; height: 1px; background: var(--gold); opacity: 0.5; flex-shrink: 0; }

  .pvc-hero__h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    margin: 0 0 1.2rem;
  }
  .pvc-hero__h1 em { font-style: normal; color: var(--gold); }

  .pvc-hero__lead {
    font-size: 1.05rem; color: rgba(255,255,255,0.65);
    line-height: 1.8; max-width: 560px; margin: 0 0 1.5rem;
  }
  .pvc-hero__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .pvc-htag {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border: 1px solid rgba(201,168,76,0.35);
    background: rgba(201,168,76,0.08);
    color: var(--gold-l);
    font-size: 0.82rem; font-weight: 600; border-radius: 4px;
  }
  .pvc-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Stats bar */
  .pvc-statsbar {
    position: relative; z-index: 1;
    display: flex; align-items: center; flex-wrap: wrap; gap: 0;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-top: 2rem;
  }
  .pvc-sitem { display: flex; flex-direction: column; flex: 1; min-width: 80px; padding-inline: 1rem; text-align: center; }
  .pvc-sitem:first-child { padding-left: 0; }
  .pvc-sitem:last-child  { padding-right: 0; }
  .pvc-sitem strong {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem; font-weight: 900; color: var(--gold); line-height: 1; display: block;
  }
  .pvc-sitem strong sup { font-size: 0.7em; }
  .pvc-sitem span { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-top: 0.3rem; display: block; }
  .pvc-sdiv { width: 1px; height: 32px; background: rgba(255,255,255,0.12); flex-shrink: 0; }

  /* ── CATEGORY NAV ── */
  .pvc-catnav {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 2.5rem; padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--bdr);
  }
  .pvc-catbtn {
    background: var(--white); color: var(--body);
    border: 1.5px solid var(--bdr);
    padding: 0.5rem 1.1rem; border-radius: 30px;
    font-size: 0.875rem; font-weight: 600; font-family: 'Inter', system-ui, sans-serif;
    text-decoration: none; transition: all 0.2s; white-space: nowrap;
  }
  .pvc-catbtn:hover { border-color: var(--navy); color: var(--navy); }
  .pvc-catbtn--active { background: var(--navy); color: var(--white); border-color: var(--navy); }

  /* Quote row */
  .pvc-quote-row {
    display: flex; align-items: center; gap: 1.5rem;
    margin-bottom: 2.5rem; flex-wrap: wrap;
  }
  .pvc-quote-note { font-size: 0.875rem; color: var(--slate); }

  /* ── PRODUCTS GRID ── */
  .pvc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    min-height: 300px;
  }

  /* Cards are injected by JS — styles here */
  .pvc-grid :global(.pvc-card) {
    background: var(--white);
    border: 1px solid var(--bdr);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    cursor: pointer;
  }
  .pvc-grid :global(.pvc-card:hover) {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(15,35,71,0.1);
    border-color: rgba(201,168,76,0.35);
  }
  .pvc-grid :global(.pvc-card__img) {
    aspect-ratio: 3/4;
    background: var(--cream);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding: 0.5rem;
  }
  .pvc-grid :global(.pvc-card__img img) {
    width: 100%; height: 100%; object-fit: contain;
    transition: transform 0.35s ease;
  }
  .pvc-grid :global(.pvc-card:hover .pvc-card__img img) { transform: scale(1.04); }
  .pvc-grid :global(.pvc-card__name) {
    padding: 0.75rem 1rem;
    font-size: 0.82rem; font-weight: 600;
    color: var(--text); text-align: center;
    line-height: 1.4;
  }

  /* Loading */
  .pvc-loading { text-align: center; padding: 4rem 2rem; color: var(--slate); display: none; }
  .pvc-spinner {
    width: 36px; height: 36px;
    border: 3px solid var(--bdr);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    margin: 0 auto 1rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── PAGINATION ── */
  .pvc-pagination {
    display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
    background: var(--white); border: 1px solid var(--bdr);
    border-radius: var(--radius); padding: 2rem;
    margin-top: 3rem;
    box-shadow: 0 4px 16px rgba(15,35,71,0.06);
  }
  .pvc-page-info { text-align: center; }
  .pvc-page-current { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .pvc-page-count  { font-size: 0.875rem; color: var(--slate); }
  .pvc-page-btns   { display: flex; gap: 1rem; align-items: center; }
  .pvc-page-btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.75rem 1.75rem; border-radius: 10px;
    background: var(--navy); color: var(--white);
    font-size: 0.9rem; font-weight: 600; font-family: 'Inter', system-ui, sans-serif;
    text-decoration: none; transition: all 0.2s;
    min-width: 140px; justify-content: center;
  }
  .pvc-page-btn:hover { background: var(--navy-mid); transform: translateY(-2px); box-shadow: 0 6px 18px rgba(15,35,71,0.25); }
  .pvc-page-btn--disabled { background: var(--cream); color: var(--slate); border: 1px solid var(--bdr); cursor: not-allowed; }
  .pvc-page-btn--disabled:hover { transform: none; box-shadow: none; }
  .pvc-page-dots { display: flex; gap: 0.75rem; align-items: center; }
  .pvc-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--bdr); display: block; text-decoration: none; transition: all 0.2s; }
  .pvc-dot:hover { background: var(--slate); transform: scale(1.2); }
  .pvc-dot--active { background: var(--gold); transform: scale(1.3); box-shadow: 0 2px 8px rgba(201,168,76,0.4); }

  /* ── SEO CONTENT SECTION ── */
  .pvc-content-wrap {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }
  .pvc-article {
    background: var(--white);
    padding: 2.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--bdr);
  }
  .pvc-article h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 2.5vw, 2.1rem);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1.25rem;
    line-height: 1.2;
  }
  .pvc-article h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem; font-weight: 700;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }
  .pvc-article p { font-size: 0.95rem; color: var(--body); line-height: 1.8; margin: 0 0 1rem; }
  .pvc-article strong { color: var(--navy); }

  .pvc-checklist { list-style: none; padding: 0; margin: 0 0 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .pvc-checklist li {
    font-size: 0.925rem; color: var(--body); line-height: 1.6;
    padding-left: 1.5rem; position: relative;
  }
  .pvc-checklist li::before {
    content: '✓';
    position: absolute; left: 0;
    color: var(--green); font-weight: 700;
  }

  /* Sidebar */
  .pvc-sidebar { display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 90px; }

  .pvc-kpis {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; background: var(--bdr);
    border: 1px solid var(--bdr); border-radius: var(--radius); overflow: hidden;
  }
  .pvc-kpi {
    background: var(--white); padding: 1.25rem; text-align: center; transition: background 0.2s;
  }
  .pvc-kpi:hover { background: var(--cream); }
  .pvc-kpi strong {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem; font-weight: 900; color: var(--navy); line-height: 1; margin-bottom: 0.3rem;
  }
  .pvc-kpi strong sup { font-size: 0.65em; }
  .pvc-kpi span { font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--slate); }

  .pvc-contact-card {
    background: var(--navy); border-radius: var(--radius); padding: 1.75rem;
  }
  .pvc-contact-card .pvc-tag { color: rgba(201,168,76,0.85); }
  .pvc-contact-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem; font-weight: 700; color: var(--white); margin: 0.3rem 0 0.6rem;
  }
  .pvc-contact-card p { font-size: 0.875rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin: 0 0 1.25rem; }
  .pvc-contact-btns { display: flex; flex-direction: column; gap: 0.6rem; }

  .pvc-features-card {
    background: var(--white); border: 1px solid var(--bdr); border-radius: var(--radius); padding: 1.5rem;
  }
  .pvc-features-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 1rem;
  }
  .pvc-feat-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .pvc-feat-list li { font-size: 0.9rem; color: var(--body); display: flex; align-items: center; gap: 0.5rem; }

  /* ── FAQ ── */
  .pvc-faq-wrap { max-width: 780px; }
  .pvc-faqs { display: flex; flex-direction: column; gap: 0.75rem; }
  .pvc-faq { background: var(--white); border: 1px solid var(--bdr); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
  .pvc-faq[open] { border-color: rgba(201,168,76,0.35); }
  .pvc-faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.1rem 1.5rem; cursor: pointer;
    font-weight: 600; font-size: 0.95rem; color: var(--text);
    list-style: none; user-select: none; transition: background 0.15s;
  }
  .pvc-faq__q:hover { background: var(--cream); }
  .pvc-faq__q::-webkit-details-marker { display: none; }
  .pvc-faq__arrow { flex-shrink: 0; color: var(--slate); transition: transform 0.25s; }
  .pvc-faq[open] .pvc-faq__arrow { transform: rotate(180deg); color: var(--gold); }
  .pvc-faq__a {
    padding: 1rem 1.5rem 1.25rem;
    font-size: 0.925rem; color: var(--body); line-height: 1.75; margin: 0;
    border-top: 1px solid var(--bdr);
  }

  /* ── CTA BAND ── */
  .pvc-cta {
    position: relative; background: var(--navy); overflow: hidden;
    padding: clamp(4rem, 8vw, 6rem) 0;
  }
  .pvc-cta__glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 55% 80% at 105% 50%, rgba(201,168,76,0.14) 0%, transparent 65%),
      linear-gradient(140deg, #08192e 0%, var(--navy) 100%);
    pointer-events: none;
  }
  .pvc-cta__inner {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    gap: 3rem; flex-wrap: wrap;
  }
  .pvc-cta__text h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.75rem, 3vw, 2.4rem); font-weight: 700;
    color: var(--white); margin: 0.35rem 0 0.7rem;
    line-height: 1.2; white-space: pre-line;
  }
  .pvc-cta__text p { color: rgba(255,255,255,0.55); font-size: 0.95rem; line-height: 1.7; max-width: 420px; margin: 0; }
  .pvc-cta__btns { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

  /* ── RESPONSIVE ── */
