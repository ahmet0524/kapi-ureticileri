  /* ── CONTACT INFO GRID ── */
  .lam-cinfo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }
  .lam-cinfo-card {
