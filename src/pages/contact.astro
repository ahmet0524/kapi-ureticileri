  .lam-social-btn:hover { transform: translateY(-2px); opacity: .9; }
  .lam-social-btn--wa    { background: #16a34a; color: #fff; }
  .lam-social-btn--ig    { background: linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); color: #fff; }
