    display: block; color: var(--navy); font-weight: 600; font-size: 1rem;
    text-decoration: none; transition: color .2s; margin-bottom: .4rem;
  }
  .lam-cinfo-link:hover { color: var(--gold); }
  .lam-cinfo-card address { font-size: .9rem; color: var(--body); line-height: 1.6; }
  .lam-cinfo-card p { font-size: .85rem; color: var(--slate); margin: 0; }

  /* ── CONTACT FORM ── */
  .lam-form-wrap { max-width: 760px; margin-inline: auto; }
  .lam-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .lam-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .lam-form-group { display: flex; flex-direction: column; gap: .4rem; }
  .lam-form-group label { font-size: .875rem; font-weight: 600; color: var(--text); }
  .lam-form-group input,
  .lam-form-group select,
  .lam-form-group textarea {
    padding: .85rem 1rem; border: 1.5px solid var(--bdr); border-radius: 8px;
