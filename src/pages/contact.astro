<script define:vars={{ publicWeb3formsKey, isEN }}>
  document.addEventListener('DOMContentLoaded', () => {
    const accessKey = publicWeb3formsKey;

    // ── FIELD VALIDATION ──────────────────────────────────────
    function validateField(field) {
      const errEl = document.getElementById(`${field.name}-error`);
      let msg = '';

      if (field.required && !field.value.trim()) {
        msg = isEN ? 'This field is required.' : 'Bu alan zorunludur.';
      } else if (field.type === 'email' && field.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
        msg = isEN ? 'Please enter a valid email address.' : 'Geçerli bir e-posta girin.';
      } else if (field.type === 'tel' && field.value && !/^[\+]?[\d\s\-\(\)]{7,}$/.test(field.value)) {
        msg = isEN ? 'Please enter a valid phone number.' : 'Geçerli bir telefon numarası girin.';
      } else if (field.minLength > 0 && field.value && field.value.length < field.minLength) {
        msg = isEN
          ? `Minimum ${field.minLength} characters required.`
          : `En az ${field.minLength} karakter gereklidir.`;
      }

      if (errEl) errEl.textContent = msg;
      field.classList.toggle('lam-input-err', !!msg);
      return !msg;
    }

    function setLoading(btn, on) {
      btn.disabled = on;
      btn.querySelector('.btn-text').textContent = on
        ? (isEN ? 'Sending…' : 'Gönderiliyor…')
        : (isEN ? 'Send Quote Request' : 'Teklif İsteyin');
    }

    // ── TOAST NOTIFICATION ────────────────────────────────────
    function toast(type, title, body) {
      document.getElementById('lamToast')?.remove();

      const colour = type === 'success' ? '#16a34a' : type === 'error' ? '#dc2626' : '#3b82f6';
      const icon   = type === 'success' ? '✓'       : type === 'error' ? '✕'       : 'ℹ';

      const el = document.createElement('div');
      el.id = 'lamToast';
      el.setAttribute('role', 'alert');
      el.setAttribute('aria-live', 'polite');
      el.style.cssText = `
        position:fixed; top:20px; right:20px; min-width:320px; max-width:420px;
        background:#fff; border-radius:12px; box-shadow:0 20px 60px rgba(0,0,0,0.2);
        z-index:999999; overflow:hidden; animation:lamSlideIn .35s cubic-bezier(.68,-.55,.265,1.55);
        font-family:'Inter',system-ui,sans-serif;
      `;
      el.innerHTML = `
        <style>
          @keyframes lamSlideIn { from{transform:translateX(120%);opacity:0} to{transform:translateX(0);opacity:1} }
          @keyframes lamSlideOut { from{transform:translateX(0);opacity:1} to{transform:translateX(120%);opacity:0} }
          @keyframes lamBar { from{width:100%} to{width:0%} }
          @media(max-width:640px){ #lamToast{top:10px!important;right:10px!important;left:10px!important;min-width:auto!important;max-width:none!important} }
        </style>
        <div style="display:flex;align-items:flex-start;padding:18px;gap:14px;">
          <div style="width:44px;height:44px;border-radius:50%;background:${colour};display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:bold;color:#fff;flex-shrink:0;">${icon}</div>
          <div style="flex:1;padding-top:2px;">
            <div style="font-size:16px;font-weight:700;color:#0f1929;margin-bottom:4px;">${title}</div>
            <div style="font-size:13px;color:#607080;line-height:1.5;">${body}</div>
          </div>
          <button onclick="this.closest('#lamToast').remove()" style="background:none;border:none;color:#9ca3af;font-size:26px;cursor:pointer;padding:0;width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:6px;line-height:1;margin-top:-2px;" aria-label="Close">&times;</button>
        </div>
        <div style="height:4px;background:#e4eaf4;position:relative;overflow:hidden;">
          <div style="height:100%;background:${colour};animation:lamBar 5s linear forwards;"></div>
        </div>
      `;
      document.body.appendChild(el);
      setTimeout(() => {
        if (el.parentNode) {
          el.style.animation = 'lamSlideOut .3s ease forwards';
          setTimeout(() => el.remove(), 300);
        }
      }, 5000);
    }

    // ── FORM SUBMISSION ───────────────────────────────────────
    const form = document.getElementById('contactForm');
    if (!form) return;

    let submitting = false;
    let lastTime = 0;

    form.addEventListener('blur', e => {
      if (e.target.matches('input,textarea,select')) validateField(e.target);
    }, true);

    form.addEventListener('submit', async e => {
      e.preventDefault();

      if (Date.now() - lastTime < 3000) {
        toast('error',
          isEN ? 'Too fast!' : 'Çok Hızlı!',
          isEN ? 'Please wait a moment and try again.' : 'Lütfen birkaç saniye bekleyin.');
        return;
      }
      if (submitting) return;

      let valid = true;
      form.querySelectorAll('input,textarea,select').forEach(f => {
        if (f.name !== 'honeypot' && !validateField(f)) valid = false;
      });
      if (!valid) {
        toast('error',
          isEN ? 'Form Error' : 'Form Hatası',
          isEN ? 'Please fill in all required fields correctly.' : 'Lütfen tüm zorunlu alanları doldurun.');
        return;
      }
      if (form.querySelector('[name="honeypot"]')?.value) return;

      const btn = form.querySelector('#submitBtn');
      submitting = true;
      lastTime = Date.now();
      setLoading(btn, true);

      try {
        const fd = new FormData(form);
        const payload = {
          access_key: accessKey,
          name:       fd.get('name'),
          email:      fd.get('email'),
          phone:      fd.get('phone')   || '—',
          company:    fd.get('company') || '—',
          product:    fd.get('product') || '—',
          message:    fd.get('message'),
          from_name:  'CihanPan Door Website',
          subject:    isEN ? 'New Contact Form — CihanPan Door' : 'Yeni İletişim Formu — CihanPan Door',
          replyto:    fd.get('email'),
        };

        const ctrl = new AbortController();
        const tid  = setTimeout(() => ctrl.abort(), 15000);
        const res  = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload),
          signal: ctrl.signal,
        });
        clearTimeout(tid);
        const result = await res.json();

        if (result.success) {
          toast('success',
            isEN ? 'Sent Successfully!' : 'Başarıyla Gönderildi!',
            isEN ? 'We will get back to you within 24 hours.' : 'En kısa sürede size dönüş yapacağız.');
          form.reset();
        } else {
          throw new Error(result.message || 'failed');
        }
      } catch (err) {
        let msg = isEN ? 'An error occurred. Please try again.' : 'Bir hata oluştu. Lütfen tekrar deneyin.';
        if (err.name === 'AbortError') msg = isEN ? 'Request timed out. Please check your connection.' : 'Zaman aşımı. İnternet bağlantınızı kontrol edin.';
        toast('error', isEN ? 'Send Failed' : 'Gönderim Başarısız', msg);
      } finally {
        submitting = false;
        setLoading(btn, false);
      }
    });
  });
</script>

<style>
  /* ── TOKENS — laminoks-doors.astro ile özdeş ── */
  .lam {
    --navy:     #0f2347;
    --navy-mid: #1a3a6e;
    --gold:     #c9a84c;
    --gold-l:   #e2bc6a;
    --cream:    #faf8f4;
    --slate:    #607080;
    --text:     #0f1929;
    --body:     #3d4f63;
    --bdr:      #e4eaf4;
    --white:    #ffffff;
